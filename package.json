{
  "name": "academorix-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,cjs,mjs,json,md,css,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,cjs,mjs,json,md,css,yaml,yml}\"",
    "knip": "knip",
    "size": "size-limit",
    "quality": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm knip",
    "quality:fix": "pnpm format && pnpm lint:fix",
    "ci": "pnpm quality && pnpm test && pnpm build",
    "e2e": "pnpm --filter @academorix/dashboard build && playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "heroui:login": "pnpm dlx heroui-pro@latest login",
    "heroui:setup": "pnpm dlx heroui-pro@latest install react --yes",
    "heroui:update": "pnpm dlx heroui-pro@latest update --yes",
    "heroui:status": "pnpm dlx heroui-pro@latest status",
    "secrets:pull:web": "doppler secrets download --project academorix-dashboard --config dev --no-file --format env > apps/dashboard/environments/.env",
    "secrets:pull:landing": "doppler secrets download --project academorix-marketing --config dev --no-file --format env > apps/landing-page/environments/.env",
    "secrets:pull": "pnpm secrets:pull:web && pnpm secrets:pull:landing",
    "secrets:open:web": "doppler open dashboard --project academorix-dashboard --config dev",
    "secrets:open:landing": "doppler open dashboard --project academorix-marketing --config dev",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@academorix/eslint-config": "workspace:*",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@playwright/test": "catalog:",
    "@size-limit/file": "catalog:",
    "eslint": "catalog:",
    "husky": "catalog:",
    "knip": "catalog:",
    "lint-staged": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "size-limit": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
