# ── Package manager settings for enterprise-grade workspace ────────────
#
# See https://pnpm.io/npmrc for full option reference.

# Enforce engine versions declared in root package.json. Fail install if
# Node/pnpm don't satisfy the workspace's `engines` constraints.
engine-strict=true

# Pin dependencies to exact versions when installing (no ^ or ~). Combined
# with the catalog: entries in pnpm-workspace.yaml this gives fully
# reproducible installs.
save-exact=true

# Auto-install missing peerDependencies. Combined with strict-peer-dependencies=false
# below, this lets us install a workspace with some optional peers unmet.
auto-install-peers=true
strict-peer-dependencies=false

# Resolve versions to their highest satisfying entry (rather than the
# time-based `time-based` mode). Deterministic + newest safely.
resolution-mode=highest

# Workspace resolution — walk workspace packages deeply when resolving
# dependencies. Combined with prefer-workspace-packages, this ensures a
# consumer of @stackra/support ALWAYS picks up the local workspace copy
# rather than accidentally hitting the registry.
link-workspace-packages=deep
prefer-workspace-packages=true

# Deduplicate peer dependents so multiple packages sharing a peer share a
# single resolved version. Reduces node_modules bloat and eliminates the
# "multiple react-stately instances" class of runtime bugs.
dedupe-peer-dependents=true

# Don't ask before purging modules when a lockfile change requires it.
confirm-modules-purge=false
