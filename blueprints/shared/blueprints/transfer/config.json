{
  "id": "stackra://modules/transfer/config",
  "$version": 1,
  "title": "transfer \u2014 developer configuration",
  "configFile": "config/transfer.php",
  "envPrefix": "TRANSFER_",
  "sections": {
    "queue": {
      "description": "Queue routing for the transfer chain.",
      "keys": [
        {
          "path": "transfer.queue.connection",
          "type": "string",
          "env": "TRANSFER_QUEUE_CONNECTION",
          "default": null,
          "description": "Null = default Laravel queue connection."
        },
        {
          "path": "transfer.queue.name",
          "type": "string",
          "env": "TRANSFER_QUEUE_NAME",
          "default": "transfer",
          "description": "Queue name that ImportEntityJob / ExportEntityJob + coordinator + housekeeping use. Notification fan-out uses `notifications` queue regardless."
        }
      ]
    },
    "storage": {
      "description": "Filesystem disks + paths per artifact kind.",
      "keys": [
        {
          "path": "transfer.storage.default_disk",
          "type": "string",
          "env": "TRANSFER_STORAGE_DISK",
          "default": "local",
          "description": "Fallback disk when a kind-specific disk isn't set."
        },
        {
          "path": "transfer.storage.paths.source",
          "type": "string",
          "default": "transfer/sources"
        },
        {
          "path": "transfer.storage.paths.result",
          "type": "string",
          "default": "transfer/results"
        },
        { "path": "transfer.storage.paths.errors", "type": "string", "default": "transfer/errors" },
        {
          "path": "transfer.storage.paths.template",
          "type": "string",
          "default": "transfer/templates"
        },
        {
          "path": "transfer.storage.paths.workbook",
          "type": "string",
          "default": "transfer/workbooks"
        },
        {
          "path": "transfer.storage.disks.source",
          "type": "string",
          "default": null,
          "description": "Null = fall back to default_disk."
        },
        { "path": "transfer.storage.disks.result", "type": "string", "default": null },
        { "path": "transfer.storage.disks.errors", "type": "string", "default": null },
        { "path": "transfer.storage.disks.template", "type": "string", "default": null },
        { "path": "transfer.storage.disks.workbook", "type": "string", "default": null }
      ]
    },
    "csv": {
      "description": "CSV formatting defaults. Per-request override via ImportRequestData / ExportRequestData.csv object. Attribute-level default via #[Importable(csv:)] / #[Exportable(csv:)].",
      "keys": [
        {
          "path": "transfer.csv.field_separator",
          "type": "string",
          "env": "TRANSFER_CSV_FIELD_SEP",
          "default": ",",
          "description": "Common: ',' | ';' | '|' | '\\t'."
        },
        {
          "path": "transfer.csv.multi_value_separator",
          "type": "string",
          "env": "TRANSFER_CSV_MULTI_SEP",
          "default": "|",
          "description": "Separator for multi-value fields."
        },
        {
          "path": "transfer.csv.enclosure",
          "type": "string",
          "env": "TRANSFER_CSV_ENCLOSURE",
          "default": "\""
        }
      ]
    },
    "import": {
      "keys": [
        {
          "path": "transfer.import.chunk_size",
          "type": "int",
          "env": "TRANSFER_IMPORT_CHUNK",
          "default": 500,
          "description": "WithChunkReading + WithBatchInserts default. Overridable per-attribute via #[Importable(chunkSize:)]."
        },
        {
          "path": "transfer.import.batch_size",
          "type": "int",
          "env": "TRANSFER_IMPORT_BATCH",
          "default": 500
        },
        {
          "path": "transfer.import.max_file_size",
          "type": "int",
          "env": "TRANSFER_IMPORT_MAX_FILE",
          "default": 10485760,
          "description": "Bytes. Also gated by entitlement transfer.max_file_size_bytes."
        },
        {
          "path": "transfer.import.stop_on_error",
          "type": "bool",
          "env": "TRANSFER_STOP_ON_ERROR",
          "default": false,
          "description": "Default halt-on-first-error behaviour. Overridable per-request."
        },
        {
          "path": "transfer.import.max_errors",
          "type": "int",
          "env": "TRANSFER_MAX_ERRORS",
          "default": 0,
          "description": "0 = unlimited. When >0, exceed to trigger stop_on_error behaviour mid-run."
        },
        {
          "path": "transfer.import.encoding.auto_detect",
          "type": "bool",
          "default": true,
          "description": "Detect UTF-8 BOM / Windows-1252 / MacRoman / UTF-16 and normalise to UTF-8."
        },
        {
          "path": "transfer.import.encoding.strict",
          "type": "bool",
          "default": false,
          "description": "When true, reject files with any decoding failure. When false, replace unmappable byte sequences with U+FFFD."
        }
      ]
    },
    "export": {
      "keys": [
        {
          "path": "transfer.export.chunk_size",
          "type": "int",
          "env": "TRANSFER_EXPORT_CHUNK",
          "default": 1000,
          "description": "WithCustomChunkSize default."
        },
        {
          "path": "transfer.export.query_size",
          "type": "int",
          "env": "TRANSFER_EXPORT_QUERY_SIZE",
          "default": null,
          "description": "WithCustomQuerySize override. Null = query builder count()."
        },
        {
          "path": "transfer.export.auto_size",
          "type": "bool",
          "env": "TRANSFER_EXPORT_AUTO_SIZE",
          "default": true,
          "description": "ShouldAutoSize default (XLSX only)."
        },
        {
          "path": "transfer.export.strict_null",
          "type": "bool",
          "default": false,
          "description": "WithStrictNullComparison."
        },
        {
          "path": "transfer.export.sync_threshold",
          "type": "int",
          "env": "TRANSFER_EXPORT_SYNC_THRESHOLD",
          "default": 5000,
          "description": "Max row count for POST /exports/stream inline path. Above this, refuse with TRANSFER_SYNC_THRESHOLD_EXCEEDED."
        }
      ]
    },
    "preview": {
      "keys": [
        {
          "path": "transfer.preview.rows",
          "type": "int",
          "default": 10,
          "description": "Rows returned by POST /imports/preview."
        },
        {
          "path": "transfer.preview.ttl_seconds",
          "type": "int",
          "default": 900,
          "description": "Preview parses store the source file for this long so a follow-up import doesn't re-upload."
        }
      ]
    },
    "pdf": {
      "keys": [
        {
          "path": "transfer.pdf.driver",
          "type": "enum<dompdf,mpdf>",
          "env": "TRANSFER_PDF_DRIVER",
          "default": "dompdf"
        },
        { "path": "transfer.pdf.paper_size", "type": "string", "default": "a4" },
        {
          "path": "transfer.pdf.orientation",
          "type": "enum<portrait,landscape>",
          "default": "landscape"
        }
      ]
    },
    "notifications": {
      "keys": [
        {
          "path": "transfer.notifications.default_channels",
          "type": "array<string>",
          "default": ["database", "broadcast"],
          "description": "Channels used when nothing else resolved. Overridden per-tenant, per-user, per-request in that precedence."
        },
        {
          "path": "transfer.notifications.completed_channels_max",
          "type": "int",
          "default": 5,
          "description": "Cap on channel array length."
        },
        {
          "path": "transfer.notifications.async",
          "type": "bool",
          "default": true,
          "description": "SendXferJobNotificationJob is queued. False = sync (only for tests)."
        }
      ]
    },
    "retention": {
      "keys": [
        {
          "path": "transfer.retention.tier_days.short",
          "type": "int",
          "env": "TRANSFER_RETENTION_SHORT_DAYS",
          "default": 90
        },
        {
          "path": "transfer.retention.tier_days.medium",
          "type": "int",
          "env": "TRANSFER_RETENTION_MEDIUM_DAYS",
          "default": 180
        },
        {
          "path": "transfer.retention.tier_days.long",
          "type": "int",
          "env": "TRANSFER_RETENTION_LONG_DAYS",
          "default": 365
        },
        { "path": "transfer.retention.artifact_ttl_days.source", "type": "int", "default": 7 },
        { "path": "transfer.retention.artifact_ttl_days.result", "type": "int", "default": 7 },
        { "path": "transfer.retention.artifact_ttl_days.errors", "type": "int", "default": 14 },
        { "path": "transfer.retention.artifact_ttl_days.template", "type": "int", "default": 30 },
        { "path": "transfer.retention.artifact_ttl_days.workbook", "type": "int", "default": 7 },
        { "path": "transfer.retention.mapping_profile_grace_days", "type": "int", "default": 365 },
        {
          "path": "transfer.retention.stale_hours",
          "type": "int",
          "default": 24,
          "description": "queued/running with no progress > stale_hours \u2192 auto-cancel."
        },
        { "path": "transfer.retention.prune_chunk_size", "type": "int", "default": 1000 }
      ]
    },
    "signed_url": {
      "keys": [
        {
          "path": "transfer.signed_url.ttl_minutes",
          "type": "int",
          "env": "TRANSFER_SIGNED_TTL",
          "default": 1440,
          "description": "24h default. Email links must survive at least a workday."
        }
      ]
    },
    "temporary_files": {
      "description": "Passthrough of maatwebsite/excel's own temporary_files config so the multi-server + resync guarantees compose cleanly.",
      "keys": [
        {
          "path": "transfer.temporary_files.remote_disk",
          "type": "string",
          "env": "TRANSFER_TEMP_REMOTE_DISK",
          "default": null,
          "description": "e.g. 's3'. Forwarded to excel.temporary_files.remote_disk on boot. Multi-server chunk continuity."
        },
        {
          "path": "transfer.temporary_files.force_resync_remote",
          "type": "bool",
          "default": true,
          "description": "Delete local temp after each chunk to avoid disk-exhaustion in a multi-worker fleet. Forwarded to excel.temporary_files.force_resync_remote."
        }
      ]
    },
    "progress": {
      "keys": [
        {
          "path": "transfer.progress.every_rows",
          "type": "int",
          "default": 1000,
          "description": "Emit XferJobProgress every N rows within a chunk."
        },
        {
          "path": "transfer.progress.every_percent",
          "type": "int",
          "default": 5,
          "description": "Alternative granularity: emit XferJobProgress every N % progress. Whichever triggers first."
        }
      ]
    },
    "shards": {
      "keys": [
        {
          "path": "transfer.shards.enabled",
          "type": "bool",
          "default": false,
          "description": "Fan-out large operations into shards. Requires feature toggle transfer.sharded + entitlement transfer.can_use_sharded."
        },
        {
          "path": "transfer.shards.min_rows_per_shard",
          "type": "int",
          "default": 25000,
          "description": "Files below this stay as a single chain."
        },
        {
          "path": "transfer.shards.max_shards",
          "type": "int",
          "default": 100,
          "description": "Hard cap regardless of row count."
        }
      ]
    },
    "concurrency": {
      "keys": [
        {
          "path": "transfer.concurrency.enforced_at_dispatch",
          "type": "bool",
          "default": true,
          "description": "Refuse dispatch when tenant already has max_concurrent_jobs in flight. False = queue-and-wait behind Laravel queue (worse UX; may cause head-of-line blocking)."
        }
      ]
    }
  }
}
