{
  "id": "academorix://modules/transfer/schemas/xfer-job",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "XferJob",
  "description": "The persisted domain record for a single import / export / sample operation. Not a queue job \u2014 lives independently of Laravel's queue chain (which Laravel Excel dispatches under `->queue()`). Owns lifecycle status, counters, artifact links, frozen notification channels, retention window, and audit trail identity.",
  "type": "object",
  "x-module": "transfer",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "xfer_jobs",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "xfer_",
    "incrementing": false,
    "model": "Academorix\\Transfer\\Models\\XferJob",
    "interface": "Academorix\\Transfer\\Contracts\\Data\\XferJobInterface",
    "implements": ["Academorix\\Transfer\\Contracts\\Data\\XferJobInterface"],
    "traits": ["HasUlids", "BelongsToTenant", "HasActivityLog", "HasAudit", "SoftDeletes"],
    "casts": {
      "kind": "Academorix\\Transfer\\Enums\\XferJobKind",
      "mode": "Academorix\\Transfer\\Enums\\ImportMode",
      "format": "string",
      "status": "Academorix\\Transfer\\Enums\\XferJobStatus",
      "counters": "Academorix\\Transfer\\Casts\\XferJobCountersCast",
      "params": "array",
      "filters": "array",
      "notify_channels": "Academorix\\Transfer\\Casts\\NotifyChannelListCast",
      "retention_tier": "string",
      "shards_total": "integer",
      "shards_completed": "integer",
      "progress_percent": "integer",
      "source_file_size_bytes": "integer",
      "started_at": "immutable_datetime",
      "finished_at": "immutable_datetime",
      "last_progress_at": "immutable_datetime",
      "artifact_purged_at": "immutable_datetime"
    },
    "hidden": ["source_file_hash"],
    "guarded": [
      "id",
      "tenant_id",
      "status",
      "counters",
      "shards_total",
      "shards_completed",
      "progress_percent",
      "started_at",
      "finished_at"
    ]
  },
  "x-database": {
    "engine": "postgres",
    "description": "Owning table for the transfer domain record. One row per initiated operation. Survives beyond the Laravel queue chain lifetime \u2014 the queue completes, the record persists (up to retention tier).",
    "columns": {
      "id": {
        "type": "string",
        "length": 64,
        "primary": true,
        "description": "Prefixed ULID: `xfer_<26 chars>`."
      },
      "tenant_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": {
          "table": "tenants",
          "column": "id",
          "onUpdate": "cascade",
          "onDelete": "cascade"
        },
        "description": "Tenant scope. Null for platform-admin-initiated system-level operations (rare)."
      },
      "causer_type": {
        "type": "string",
        "length": 128,
        "nullable": false,
        "description": "Polymorphic initiator type. Typically the User model; may be ServiceAccount for API-driven jobs."
      },
      "causer_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "description": "Polymorphic initiator id."
      },
      "kind": {
        "type": "string",
        "length": 16,
        "nullable": false,
        "description": "Operation kind. Enum: import / export / sample."
      },
      "entity": {
        "type": "string",
        "length": 128,
        "nullable": false,
        "description": "Entity key registered in EntityRegistry (e.g. `athletes`) or workbook key (`workbook:athlete_roster`)."
      },
      "mode": {
        "type": "string",
        "length": 16,
        "nullable": true,
        "description": "Import mode. Enum: append / upsert / replace / delete. Null for exports + samples."
      },
      "format": {
        "type": "string",
        "length": 16,
        "nullable": true,
        "description": "File format. Enum: csv / xlsx / json / pdf. Null for samples."
      },
      "status": {
        "type": "string",
        "length": 32,
        "nullable": false,
        "default": "'queued'",
        "description": "Lifecycle. Enum: queued / running / succeeded / partially_succeeded / failed / cancelling / cancelled."
      },
      "counters": {
        "type": "jsonb",
        "nullable": false,
        "default": "'{\"total\":0,\"created\":0,\"updated\":0,\"skipped\":0,\"failed\":0,\"deleted\":0}'",
        "description": "Live counters. Updated by shard completion + AfterImport / AfterSheet listeners. Cast to a value object."
      },
      "params": {
        "type": "jsonb",
        "nullable": true,
        "description": "Frozen snapshot of ImportRequestData / ExportRequestData with secrets redacted. For reproducibility + support."
      },
      "filters": {
        "type": "jsonb",
        "nullable": true,
        "description": "Frozen filter dictionary from the request (spatie/laravel-query-builder grammar). Same shape the list endpoint accepts."
      },
      "mapping_profile_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": {
          "table": "xfer_mapping_profiles",
          "column": "id",
          "onUpdate": "cascade",
          "onDelete": "set null"
        },
        "description": "Reference to the header-remap profile applied at request time. Null when the entity's default map was used."
      },
      "source_filename": {
        "type": "string",
        "length": 255,
        "nullable": true,
        "description": "Original file name uploaded by the user. Display-only \u2014 storage path is on source_artifact_id."
      },
      "source_file_size_bytes": {
        "type": "bigint",
        "nullable": true,
        "description": "Uploaded file size."
      },
      "source_file_hash": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "description": "SHA-256 of the uploaded file. Enables idempotent-retry detection + duplicate-import warnings."
      },
      "source_artifact_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": {
          "table": "xfer_artifacts",
          "column": "id",
          "onUpdate": "cascade",
          "onDelete": "set null"
        },
        "description": "Pointer to the uploaded file artifact. Purged per retention (usually shorter than the row)."
      },
      "result_artifact_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": {
          "table": "xfer_artifacts",
          "column": "id",
          "onUpdate": "cascade",
          "onDelete": "set null"
        },
        "description": "Pointer to the export result file or import success summary artifact."
      },
      "errors_artifact_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": {
          "table": "xfer_artifacts",
          "column": "id",
          "onUpdate": "cascade",
          "onDelete": "set null"
        },
        "description": "Pointer to the `errors.csv` artifact for `partially_succeeded` imports."
      },
      "notify_channels": {
        "type": "jsonb",
        "nullable": false,
        "default": "'[\"database\",\"broadcast\"]'",
        "description": "Resolved-at-dispatch notification channels. Frozen \u2014 preference changes mid-run do not affect delivery. Order matters (delivery attempted in listed order)."
      },
      "notify_locale": {
        "type": "string",
        "length": 8,
        "nullable": false,
        "default": "'en'",
        "description": "Locale for the notification copy. Passed to `HasLocalePreference::preferredLocale()` on our Laravel Excel wrappers."
      },
      "retention_tier": {
        "type": "string",
        "length": 16,
        "nullable": false,
        "default": "'short'",
        "description": "Row retention. Enum: short (90d) / medium (180d) / long (365d). Set at insert from tenant plan + entitlement. Distinct from artifact retention (see xfer-artifact)."
      },
      "queue_connection": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "description": "Queue connection override. Null = default from config."
      },
      "queue_name": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "default": "'transfer'",
        "description": "Queue name Laravel Excel's chain runs on."
      },
      "laravel_queue_batch_id": {
        "type": "uuid",
        "nullable": true,
        "description": "Pointer to Laravel's `job_batches` row when we use `Bus::batch()` for shard fan-out. Enables `job_batches.progress()` introspection alongside our counters."
      },
      "shards_total": {
        "type": "integer",
        "nullable": false,
        "default": "1",
        "description": "Number of shards in the chain. 1 = unsharded (Laravel Excel's own chunking still applies inside a shard)."
      },
      "shards_completed": {
        "type": "integer",
        "nullable": false,
        "default": "0",
        "description": "Shards that reached succeeded or failed. Drives progress_percent when shards_total > 1."
      },
      "progress_percent": {
        "type": "integer",
        "nullable": false,
        "default": "0",
        "description": "0\u2013100. Coarse-grained: (shards_completed / shards_total) * 100 by default; overridable by inner AfterChunk events."
      },
      "started_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "First status transition into `running`."
      },
      "finished_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "Terminal transition into succeeded / partially_succeeded / failed / cancelled."
      },
      "last_progress_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "Last progress update. Used by stalled-job health probe (job in `running` with no progress > threshold minutes)."
      },
      "artifact_purged_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "When PruneXferArtifactsJob nulled the artifact FKs but retained the row. UI shows 'Artifacts expired' after this."
      },
      "last_error_message": {
        "type": "text",
        "nullable": true,
        "description": "Human-readable error message from the last failure event."
      },
      "last_error_code": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "description": "Machine-readable error code from `errors.json` catalog."
      },
      "cancelled_by_type": {
        "type": "string",
        "length": 128,
        "nullable": true,
        "description": "Polymorphic canceller type."
      },
      "cancelled_by_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "description": "Polymorphic canceller id."
      },
      "cancel_reason": { "type": "string", "length": 255, "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false },
      "deleted_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "Soft delete. Used only for platform-admin operational cleanup; regular purge is hard delete via retention scan."
      }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "created_at"],
        "unique": false,
        "name": "xfer_jobs_tenant_time_idx",
        "description": "Primary read path: `GET /api/v1/transfer/jobs`."
      },
      {
        "columns": ["causer_type", "causer_id", "created_at"],
        "unique": false,
        "name": "xfer_jobs_causer_time_idx",
        "description": "Per-user history."
      },
      {
        "columns": ["status", "created_at"],
        "unique": false,
        "name": "xfer_jobs_status_time_idx",
        "description": "Filter + stalled-detection scans."
      },
      {
        "columns": ["kind", "entity", "created_at"],
        "unique": false,
        "name": "xfer_jobs_kind_entity_time_idx",
        "description": "Per-entity operational stats."
      },
      {
        "columns": ["retention_tier", "created_at"],
        "unique": false,
        "name": "xfer_jobs_retention_scan_idx",
        "description": "PruneXferArtifactsJob DB-row scan predicate."
      },
      {
        "columns": ["last_progress_at"],
        "unique": false,
        "name": "xfer_jobs_progress_scan_idx",
        "predicate": "status = 'running'",
        "description": "Stalled-job health probe scan (partial index)."
      },
      {
        "columns": ["laravel_queue_batch_id"],
        "unique": true,
        "name": "xfer_jobs_batch_uniq_idx",
        "predicate": "laravel_queue_batch_id IS NOT NULL",
        "description": "Pointer to Laravel `job_batches` row is one-to-one."
      }
    ]
  },
  "required": [
    "id",
    "causer_type",
    "causer_id",
    "kind",
    "entity",
    "status",
    "counters",
    "notify_channels",
    "notify_locale",
    "retention_tier",
    "queue_name",
    "shards_total",
    "shards_completed",
    "progress_percent",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^xfer_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": ["string", "null"], "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "causer_type": { "type": "string" },
    "causer_id": { "type": "string" },
    "kind": { "type": "string", "enum": ["import", "export", "sample"] },
    "entity": { "type": "string", "maxLength": 128 },
    "mode": { "type": ["string", "null"], "enum": ["append", "upsert", "replace", "delete", null] },
    "format": { "type": ["string", "null"], "enum": ["csv", "xlsx", "json", "pdf", null] },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "succeeded",
        "partially_succeeded",
        "failed",
        "cancelling",
        "cancelled"
      ]
    },
    "counters": {
      "type": "object",
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "created": { "type": "integer", "minimum": 0 },
        "updated": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "deleted": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false,
      "required": ["total", "created", "updated", "skipped", "failed", "deleted"]
    },
    "params": { "type": ["object", "null"] },
    "filters": { "type": ["object", "null"] },
    "mapping_profile_id": {
      "type": ["string", "null"],
      "pattern": "^xmap_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "source_filename": { "type": ["string", "null"], "maxLength": 255 },
    "source_file_size_bytes": { "type": ["integer", "null"], "minimum": 0 },
    "source_file_hash": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "source_artifact_id": {
      "type": ["string", "null"],
      "pattern": "^xart_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "result_artifact_id": {
      "type": ["string", "null"],
      "pattern": "^xart_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "errors_artifact_id": {
      "type": ["string", "null"],
      "pattern": "^xart_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "notify_channels": {
      "type": "array",
      "items": { "type": "string", "enum": ["mail", "broadcast", "database", "push", "sms"] },
      "uniqueItems": true,
      "maxItems": 5
    },
    "notify_locale": { "type": "string", "maxLength": 8 },
    "retention_tier": { "type": "string", "enum": ["short", "medium", "long"] },
    "queue_connection": { "type": ["string", "null"], "maxLength": 64 },
    "queue_name": { "type": "string", "maxLength": 64 },
    "laravel_queue_batch_id": { "type": ["string", "null"], "format": "uuid" },
    "shards_total": { "type": "integer", "minimum": 1 },
    "shards_completed": { "type": "integer", "minimum": 0 },
    "progress_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
    "started_at": { "type": ["string", "null"], "format": "date-time" },
    "finished_at": { "type": ["string", "null"], "format": "date-time" },
    "last_progress_at": { "type": ["string", "null"], "format": "date-time" },
    "artifact_purged_at": { "type": ["string", "null"], "format": "date-time" },
    "last_error_message": { "type": ["string", "null"] },
    "last_error_code": { "type": ["string", "null"], "maxLength": 64 },
    "cancelled_by_type": { "type": ["string", "null"] },
    "cancelled_by_id": { "type": ["string", "null"] },
    "cancel_reason": { "type": ["string", "null"], "maxLength": 255 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "deleted_at": { "type": ["string", "null"], "format": "date-time" }
  },
  "additionalProperties": false,
  "x-wire": {
    "envelope": "spatie-data",
    "wrap": "data",
    "mapper": "SnakeCaseMapper",
    "hidden": ["source_file_hash", "laravel_queue_batch_id"],
    "computed": [
      {
        "name": "is_terminal",
        "expression": "in_array(status, ['succeeded', 'partially_succeeded', 'failed', 'cancelled'], true)"
      },
      {
        "name": "has_result_artifact",
        "expression": "result_artifact_id !== null && artifact_purged_at === null"
      },
      {
        "name": "has_errors_artifact",
        "expression": "errors_artifact_id !== null && artifact_purged_at === null"
      },
      {
        "name": "duration_seconds",
        "expression": "started_at && finished_at ? (finished_at - started_at) : null"
      }
    ]
  }
}
