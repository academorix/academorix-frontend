{
  "id": "stackra://modules/transfer/errors",
  "$version": 1,
  "title": "transfer \u2014 error codes",
  "namespace": "transfer",
  "errors": [
    {
      "code": "TRANSFER_KILL_SWITCHED",
      "http": 503,
      "retryable": true,
      "user_facing": true,
      "audit_severity": "alert",
      "i18n_key": "transfer.errors.kill_switched",
      "description": "One of the transfer.* kill switches is off. Message names which."
    },
    {
      "code": "TRANSFER_QUEUE_DISABLED",
      "http": 503,
      "retryable": true,
      "user_facing": true,
      "audit_severity": "alert",
      "i18n_key": "transfer.errors.queue_disabled",
      "description": "transfer.queue kill switch is off. All dispatch rejected."
    },
    {
      "code": "TRANSFER_ENTITY_UNKNOWN",
      "http": 404,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "transfer.errors.entity_unknown",
      "description": "Entity key not present in EntityRegistry. Either the domain module isn't installed or its #[Importable] / #[Exportable] attribute wasn't discovered."
    },
    {
      "code": "TRANSFER_ENTITY_NOT_IMPORTABLE",
      "http": 422,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "transfer.errors.entity_not_importable"
    },
    {
      "code": "TRANSFER_ENTITY_NOT_EXPORTABLE",
      "http": 422,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "transfer.errors.entity_not_exportable"
    },
    {
      "code": "TRANSFER_ENTITY_NOT_SAMPLEABLE",
      "http": 422,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "transfer.errors.entity_not_sampleable"
    },
    {
      "code": "TRANSFER_FORMAT_UNSUPPORTED",
      "http": 422,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "transfer.errors.format_unsupported",
      "description": "Requested format not in the entity's #[Importable/Exportable].formats list."
    },
    {
      "code": "TRANSFER_MODE_NOT_ALLOWED",
      "http": 403,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "notice",
      "i18n_key": "transfer.errors.mode_not_allowed",
      "description": "Import mode blocked by feature toggle (transfer.mode_replace / mode_delete) or entitlement (transfer.can_run_replace_mode / can_run_delete_mode)."
    },
    {
      "code": "TRANSFER_FILE_TOO_LARGE",
      "http": 413,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "transfer.errors.file_too_large",
      "description": "Uploaded file exceeds transfer.max_file_size_bytes entitlement."
    },
    {
      "code": "TRANSFER_ROW_LIMIT_EXCEEDED",
      "http": 422,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "transfer.errors.row_limit_exceeded",
      "description": "File row count exceeds transfer.max_rows_per_import / max_rows_per_export entitlement."
    },
    {
      "code": "TRANSFER_CONCURRENCY_LIMIT_EXCEEDED",
      "http": 429,
      "retryable": true,
      "user_facing": true,
      "audit_severity": "notice",
      "i18n_key": "transfer.errors.concurrency_limit_exceeded",
      "description": "Tenant already has transfer.max_concurrent_jobs in queued / running. Retry after one completes."
    },
    {
      "code": "TRANSFER_SYNC_THRESHOLD_EXCEEDED",
      "http": 413,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "transfer.errors.sync_threshold_exceeded",
      "description": "POST /exports/stream would exceed entity.syncThreshold. Use the async POST /exports endpoint."
    },
    {
      "code": "TRANSFER_JOB_NOT_FOUND",
      "http": 404,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "transfer.errors.job_not_found"
    },
    {
      "code": "TRANSFER_JOB_NOT_CANCELLABLE",
      "http": 409,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "transfer.errors.job_not_cancellable",
      "description": "Job is in a terminal state (succeeded / partially_succeeded / failed / cancelled)."
    },
    {
      "code": "TRANSFER_JOB_NOT_RETRYABLE",
      "http": 409,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "transfer.errors.job_not_retryable"
    },
    {
      "code": "TRANSFER_INVALID_STATE_TRANSITION",
      "http": 409,
      "retryable": false,
      "user_facing": false,
      "audit_severity": "alert",
      "i18n_key": "transfer.errors.invalid_state_transition",
      "description": "State machine violation caught by XferJobObserver. Bug \u2014 pages ops."
    },
    {
      "code": "TRANSFER_SHARD_NOT_FOUND",
      "http": 404,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "transfer.errors.shard_not_found"
    },
    {
      "code": "TRANSFER_SHARD_NOT_RETRYABLE",
      "http": 409,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "transfer.errors.shard_not_retryable",
      "description": "Shard is not in failed state, or the parent job is not in failed / partially_succeeded state."
    },
    {
      "code": "TRANSFER_ARTIFACT_NOT_FOUND",
      "http": 404,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "transfer.errors.artifact_not_found"
    },
    {
      "code": "TRANSFER_ARTIFACT_PURGED",
      "http": 410,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "transfer.errors.artifact_purged",
      "description": "Artifact retention expired \u2014 file has been deleted. XferJob record survives; details still viewable."
    },
    {
      "code": "TRANSFER_ARTIFACT_LINK_INVALID",
      "http": 403,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "notice",
      "i18n_key": "transfer.errors.artifact_link_invalid",
      "description": "Signed URL signature mismatch or tampered."
    },
    {
      "code": "TRANSFER_ARTIFACT_LINK_EXPIRED",
      "http": 410,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "transfer.errors.artifact_link_expired",
      "description": "Signed URL past its TTL. User requests a fresh link from GET /jobs/{id}/download."
    },
    {
      "code": "TRANSFER_MAPPING_PROFILE_NOT_FOUND",
      "http": 404,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "transfer.errors.mapping_profile_not_found"
    },
    {
      "code": "TRANSFER_MAPPING_PROFILE_INVALID",
      "http": 422,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "transfer.errors.mapping_profile_invalid",
      "description": "Header map references an attribute that isn't declared on the target entity."
    },
    {
      "code": "TRANSFER_DUPLICATE_ROW",
      "http": 422,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "transfer.errors.duplicate_row",
      "description": "Row-level. Append-mode import found a row matching a unique-by column."
    },
    {
      "code": "TRANSFER_LOOKUP_FAILED",
      "http": 422,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "transfer.errors.lookup_failed",
      "description": "Row-level. A #[ImportField(lookup: ...)] could not resolve the referenced record. Detail names the field + missing value."
    },
    {
      "code": "TRANSFER_CSV_MALFORMED",
      "http": 422,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "transfer.errors.csv_malformed",
      "description": "Non-UTF8 bytes, unmatched quoting, or a header row that doesn't match any declared column."
    },
    {
      "code": "TRANSFER_ENCODING_UNSUPPORTED",
      "http": 415,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "transfer.errors.encoding_unsupported",
      "description": "File charset detected but not supported. We auto-convert Windows-1252 + MacRoman + UTF-16; other charsets rejected."
    },
    {
      "code": "TRANSFER_TENANT_MISMATCH",
      "http": 403,
      "retryable": false,
      "user_facing": false,
      "audit_severity": "alert",
      "i18n_key": "transfer.errors.tenant_mismatch",
      "description": "Import row carried a tenant_id column with a value not matching the current tenant. Refused at row level \u2014 tenant_id is never trusted from the file."
    },
    {
      "code": "TRANSFER_STORAGE_FAILURE",
      "http": 500,
      "retryable": true,
      "user_facing": false,
      "audit_severity": "alert",
      "i18n_key": "transfer.errors.storage_failure",
      "description": "Underlying filesystem disk error. Pages ops."
    },
    {
      "code": "TRANSFER_LARAVEL_EXCEL_FAILURE",
      "http": 500,
      "retryable": true,
      "user_facing": false,
      "audit_severity": "alert",
      "i18n_key": "transfer.errors.laravel_excel_failure",
      "description": "maatwebsite/excel threw. Wrapped so upstream doesn't see the vendor exception."
    }
  ]
}
