{
  "id": "stackra://modules/telemetry/config",
  "$version": 1,
  "title": "telemetry \u2014 developer configuration",
  "configFile": "config/telemetry.php",
  "envPrefixes": ["OTEL_", "LOG_", "LOKI_", "DATADOG_"],
  "underlying_package_config": "config/opentelemetry.php (keepsuit) \u2014 we do NOT override its keys directly; instead, publish our own config that keepsuit reads at boot.",
  "sections": {
    "resource": {
      "path_prefix": "telemetry.resource",
      "keys": [
        {
          "path": "telemetry.resource.service_name",
          "type": "string",
          "env": "OTEL_SERVICE_NAME",
          "default": "stackra"
        },
        {
          "path": "telemetry.resource.service_namespace",
          "type": "string",
          "env": "OTEL_SERVICE_NAMESPACE",
          "default": "stackra"
        },
        {
          "path": "telemetry.resource.service_version",
          "type": "string",
          "env": "APP_VERSION",
          "description": "Set by build pipeline to git-sha short + build tag."
        },
        {
          "path": "telemetry.resource.deployment_environment",
          "type": "string",
          "env": "APP_ENV",
          "default": "local"
        }
      ]
    },
    "otel_exporter": {
      "path_prefix": "telemetry.otel.exporter",
      "keys": [
        {
          "path": "telemetry.otel.exporter.protocol",
          "type": "string",
          "env": "OTEL_EXPORTER_OTLP_PROTOCOL",
          "default": "http/protobuf",
          "enum": ["http/protobuf", "grpc"]
        },
        {
          "path": "telemetry.otel.exporter.endpoint",
          "type": "string",
          "env": "OTEL_EXPORTER_OTLP_ENDPOINT",
          "default": "http://localhost:4318"
        },
        {
          "path": "telemetry.otel.exporter.headers",
          "type": "string",
          "env": "OTEL_EXPORTER_OTLP_HEADERS",
          "description": "Comma-separated key=value pairs. Common: `api-key=xxx` for DataDog / Honeycomb."
        },
        {
          "path": "telemetry.otel.exporter.timeout_ms",
          "type": "int",
          "env": "OTEL_EXPORTER_OTLP_TIMEOUT",
          "default": 10000
        },
        {
          "path": "telemetry.otel.exporter.compression",
          "type": "string",
          "default": "gzip",
          "enum": ["gzip", "none"]
        }
      ]
    },
    "otel_sampling": {
      "path_prefix": "telemetry.otel.sampling",
      "keys": [
        {
          "path": "telemetry.otel.sampling.strategy",
          "type": "string",
          "env": "OTEL_TRACES_SAMPLER",
          "default": "parentbased_traceidratio"
        },
        {
          "path": "telemetry.otel.sampling.ratio",
          "type": "float",
          "env": "OTEL_TRACES_SAMPLER_ARG",
          "default": 0.1,
          "description": "Fraction of new traces sampled. 0.1 = 10%. In dev bump to 1.0."
        }
      ]
    },
    "otel_batch_processor": {
      "path_prefix": "telemetry.otel.batch_processor",
      "keys": [
        { "path": "telemetry.otel.batch_processor.max_queue_size", "type": "int", "default": 2048 },
        {
          "path": "telemetry.otel.batch_processor.schedule_delay_ms",
          "type": "int",
          "default": 5000
        },
        {
          "path": "telemetry.otel.batch_processor.max_export_batch_size",
          "type": "int",
          "default": 512
        }
      ]
    },
    "otel_auto_instrumentation": {
      "path_prefix": "telemetry.otel.auto",
      "keys": [
        { "path": "telemetry.otel.auto.http_server", "type": "bool", "default": true },
        { "path": "telemetry.otel.auto.http_client", "type": "bool", "default": true },
        { "path": "telemetry.otel.auto.db", "type": "bool", "default": true },
        { "path": "telemetry.otel.auto.queue", "type": "bool", "default": true },
        { "path": "telemetry.otel.auto.cache", "type": "bool", "default": false },
        { "path": "telemetry.otel.auto.view", "type": "bool", "default": false }
      ]
    },
    "otel_propagators": {
      "path_prefix": "telemetry.otel.propagators",
      "keys": [
        {
          "path": "telemetry.otel.propagators",
          "type": "array",
          "default": ["tracecontext", "baggage", "b3"],
          "description": "Enabled context propagators. Order matters \u2014 first-match wins on extract."
        }
      ]
    },
    "logs_default_channel": {
      "path_prefix": "telemetry.logs.default_channel",
      "keys": [
        {
          "path": "telemetry.logs.default_channel",
          "type": "string",
          "env": "LOG_CHANNEL",
          "default": "stack"
        }
      ]
    },
    "logs_sinks": {
      "path_prefix": "telemetry.logs.sinks",
      "keys": [
        {
          "path": "telemetry.logs.sinks.stdout.enabled",
          "type": "bool",
          "env": "LOG_STDOUT_ENABLED",
          "default": true
        },
        {
          "path": "telemetry.logs.sinks.file.enabled",
          "type": "bool",
          "env": "LOG_FILE_ENABLED",
          "default": true
        },
        {
          "path": "telemetry.logs.sinks.file.path",
          "type": "string",
          "default": "storage/logs/stackra.log"
        },
        { "path": "telemetry.logs.sinks.file.days", "type": "int", "default": 14 },
        {
          "path": "telemetry.logs.sinks.loki.enabled",
          "type": "bool",
          "env": "LOG_LOKI_ENABLED",
          "default": false
        },
        { "path": "telemetry.logs.sinks.loki.endpoint", "type": "string", "env": "LOKI_ENDPOINT" },
        {
          "path": "telemetry.logs.sinks.loki.tenant_id",
          "type": "string",
          "env": "LOKI_TENANT_ID",
          "description": "X-Scope-OrgID header for multi-tenant Loki."
        },
        {
          "path": "telemetry.logs.sinks.datadog.enabled",
          "type": "bool",
          "env": "LOG_DATADOG_ENABLED",
          "default": false
        },
        {
          "path": "telemetry.logs.sinks.datadog.api_key",
          "type": "string",
          "env": "DATADOG_API_KEY"
        },
        {
          "path": "telemetry.logs.sinks.datadog.site",
          "type": "string",
          "env": "DATADOG_SITE",
          "default": "datadoghq.com"
        }
      ]
    },
    "logs_sampling": {
      "path_prefix": "telemetry.logs.sampling",
      "keys": [
        {
          "path": "telemetry.logs.sampling.debug_ratio",
          "type": "float",
          "default": 0.1,
          "description": "Fraction of debug records kept when sampling enabled."
        },
        {
          "path": "telemetry.logs.sampling.info_ratio",
          "type": "float",
          "default": 1.0,
          "description": "info+ never dropped by default."
        },
        {
          "path": "telemetry.logs.sampling.warning_and_above",
          "type": "float",
          "default": 1.0,
          "description": "Locked at 1.0 \u2014 warnings + errors + criticals never sampled."
        }
      ]
    },
    "logs_trace_correlation": {
      "path_prefix": "telemetry.logs.trace_correlation",
      "keys": [
        { "path": "telemetry.logs.trace_correlation.enabled", "type": "bool", "default": true },
        {
          "path": "telemetry.logs.trace_correlation.keys",
          "type": "object",
          "default": { "trace_id": "trace_id", "span_id": "span_id" },
          "description": "Field names in the emitted record. Different backends prefer different names \u2014 e.g. DataDog wants dd.trace_id."
        }
      ]
    },
    "logs_emit_events": {
      "path_prefix": "telemetry.logs.emit_events",
      "keys": [
        {
          "path": "telemetry.logs.emit_events",
          "type": "bool",
          "env": "LOG_EMIT_EVENTS",
          "default": false,
          "description": "Fire LogRecordEmitted / LogPipelineErrored events. Debug builds only \u2014 adds overhead."
        }
      ]
    },
    "redact_shared": {
      "path_prefix": "telemetry.redact",
      "description": "Redaction rules SHARED across otel span attributes AND log records. The two signals used to duplicate this config; now it's one source of truth. Sub-signals can override via their own `redact_override` block below.",
      "keys": [
        {
          "path": "telemetry.redact.keys",
          "type": "array",
          "default": [
            "password",
            "password_confirmation",
            "secret",
            "token",
            "api_key",
            "credit_card",
            "card_number",
            "cvv",
            "ssn",
            "authorization",
            "cookie",
            "x-api-key",
            "private_key"
          ]
        },
        {
          "path": "telemetry.redact.patterns",
          "type": "array",
          "default": [
            {
              "name": "credit_card",
              "regex": "\\b(?:\\d[ -]*?){13,19}\\b",
              "replacement": "[REDACTED_CARD]"
            },
            {
              "name": "ssn_us",
              "regex": "\\b\\d{3}-\\d{2}-\\d{4}\\b",
              "replacement": "[REDACTED_SSN]"
            },
            {
              "name": "iban",
              "regex": "[A-Z]{2}\\d{2}[A-Z0-9]{4,30}",
              "replacement": "[REDACTED_IBAN]"
            }
          ]
        },
        {
          "path": "telemetry.redact.ip_in_production",
          "type": "bool",
          "env": "TELEMETRY_REDACT_IP_IN_PROD",
          "default": true,
          "description": "Redact http.client_ip in production. Keep false in dev + staging."
        },
        {
          "path": "telemetry.redact.pii_in_dev",
          "type": "bool",
          "env": "TELEMETRY_REDACT_PII_IN_DEV",
          "default": false
        }
      ]
    }
  }
}
