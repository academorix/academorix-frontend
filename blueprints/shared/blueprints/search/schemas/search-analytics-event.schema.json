{
  "id": "stackra://modules/search/schemas/search-analytics-event",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "SearchAnalyticsEvent",
  "description": "One search-related interaction \u2014 a query fired, a no-results occurrence, an autocomplete suggest, or a click-through. High-cardinality table, retention-tiered, pruned aggressively. Feeds the admin analytics dashboard + no-results monitoring + top-queries panel.",
  "type": "object",
  "x-module": "search",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "search_analytics_events",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "sae_",
    "incrementing": false,
    "model": "Stackra\\Search\\Models\\SearchAnalyticsEvent",
    "interface": "Stackra\\Search\\Contracts\\Data\\SearchAnalyticsEventInterface",
    "implements": ["Stackra\\Search\\Contracts\\Data\\SearchAnalyticsEventInterface"],
    "traits": ["HasUlids", "BelongsToTenant"],
    "casts": {
      "kind": "Stackra\\Search\\Enums\\SearchAnalyticsKind",
      "index_names": "array",
      "result_count": "integer",
      "clicked_position": "integer",
      "took_ms": "integer",
      "had_typo_correction": "boolean",
      "was_from_saved_query": "boolean"
    },
    "hidden": ["query"],
    "guarded": ["id", "tenant_id", "created_at"],
    "notes": "No SoftDeletes \u2014 analytics rows are hard-pruned on retention. No HasActivityLog / HasAudit \u2014 query volume is not audit material; only long-running sync jobs are."
  },
  "x-database": {
    "engine": "postgres",
    "description": "Append-only telemetry table. Every search interaction inserts one row via `RecordSearchAnalyticsEventJob`. The `query` column is PII-sensitive (confidential per data-classes.json); the `query_hash` allows top-queries / no-results aggregation without exposing raw values.",
    "columns": {
      "id": {
        "type": "string",
        "length": 64,
        "primary": true,
        "description": "Prefixed ULID: `sae_<26 chars>`."
      },
      "tenant_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": {
          "table": "tenants",
          "column": "id",
          "onUpdate": "cascade",
          "onDelete": "cascade"
        },
        "description": "Tenant scope. Null for anonymous / pre-tenant queries."
      },
      "search_session_id": {
        "type": "uuid",
        "nullable": true,
        "description": "Groups events within one search session (query \u2192 suggest \u2192 click). Generated client-side."
      },
      "kind": {
        "type": "string",
        "length": 24,
        "nullable": false,
        "description": "Enum: query / no_results / click_through / suggest."
      },
      "user_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": {
          "table": "users",
          "column": "id",
          "onUpdate": "cascade",
          "onDelete": "set null"
        },
        "description": "Nullable for anonymous searches (e.g. public tenant marketing pages if we allow them). Set null on user erasure (GDPR Art. 17)."
      },
      "query": {
        "type": "text",
        "nullable": true,
        "description": "The raw search term. PII-sensitive \u2014 hidden on the wire. Retained only for retention window then hard-purged."
      },
      "query_hash": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "description": "SHA-256 of the normalised query (lowercased + trimmed). Enables aggregation without exposing raw text."
      },
      "index_names": {
        "type": "jsonb",
        "nullable": false,
        "default": "'[]'",
        "description": "Array of index names queried in this interaction (multi-model queries hit several)."
      },
      "engine": {
        "type": "string",
        "length": 32,
        "nullable": false,
        "description": "Enum: meilisearch / postgres-fts / pgvector / elasticsearch. Which engine served this query."
      },
      "result_count": { "type": "integer", "nullable": false, "default": "0" },
      "clicked_result_type": {
        "type": "string",
        "length": 128,
        "nullable": true,
        "description": "For kind=click_through: the morph type of the clicked result."
      },
      "clicked_result_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "description": "For kind=click_through: the id of the clicked result."
      },
      "clicked_position": {
        "type": "integer",
        "nullable": true,
        "description": "For kind=click_through: 1-based position of the clicked hit in the result list."
      },
      "took_ms": {
        "type": "integer",
        "nullable": false,
        "default": "0",
        "description": "Server-side latency in ms."
      },
      "had_typo_correction": { "type": "boolean", "nullable": false, "default": "false" },
      "was_from_saved_query": { "type": "boolean", "nullable": false, "default": "false" },
      "saved_query_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": {
          "table": "search_saved_queries",
          "column": "id",
          "onUpdate": "cascade",
          "onDelete": "set null"
        }
      },
      "retention_tier": { "type": "string", "length": 16, "nullable": false, "default": "'short'" },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "created_at"],
        "unique": false,
        "name": "search_analytics_events_tenant_time_idx",
        "description": "Primary read path for dashboard queries."
      },
      {
        "columns": ["tenant_id", "kind", "created_at"],
        "unique": false,
        "name": "search_analytics_events_kind_time_idx",
        "description": "Filter by kind (top-queries vs no-results vs click-through)."
      },
      {
        "columns": ["query_hash", "tenant_id"],
        "unique": false,
        "name": "search_analytics_events_query_hash_idx",
        "description": "Top-queries aggregation."
      },
      {
        "columns": ["retention_tier", "created_at"],
        "unique": false,
        "name": "search_analytics_events_retention_scan_idx",
        "description": "PruneSearchAnalyticsJob scan predicate."
      },
      {
        "columns": ["search_session_id"],
        "unique": false,
        "name": "search_analytics_events_session_idx",
        "predicate": "search_session_id IS NOT NULL"
      }
    ]
  },
  "required": [
    "id",
    "kind",
    "query_hash",
    "index_names",
    "engine",
    "result_count",
    "took_ms",
    "had_typo_correction",
    "was_from_saved_query",
    "retention_tier",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^sae_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": ["string", "null"], "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "search_session_id": { "type": ["string", "null"], "format": "uuid" },
    "kind": { "type": "string", "enum": ["query", "no_results", "click_through", "suggest"] },
    "user_id": { "type": ["string", "null"], "pattern": "^usr_[0-9A-HJKMNP-TV-Z]{26}$" },
    "query": { "type": ["string", "null"] },
    "query_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "index_names": { "type": "array", "items": { "type": "string", "maxLength": 128 } },
    "engine": {
      "type": "string",
      "enum": ["meilisearch", "postgres-fts", "pgvector", "elasticsearch"]
    },
    "result_count": { "type": "integer", "minimum": 0 },
    "clicked_result_type": { "type": ["string", "null"] },
    "clicked_result_id": { "type": ["string", "null"] },
    "clicked_position": { "type": ["integer", "null"], "minimum": 1 },
    "took_ms": { "type": "integer", "minimum": 0 },
    "had_typo_correction": { "type": "boolean" },
    "was_from_saved_query": { "type": "boolean" },
    "saved_query_id": { "type": ["string", "null"], "pattern": "^sq_[0-9A-HJKMNP-TV-Z]{26}$" },
    "retention_tier": { "type": "string", "enum": ["short", "medium", "long"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false,
  "x-wire": {
    "envelope": "spatie-data",
    "wrap": "data",
    "mapper": "SnakeCaseMapper",
    "hidden": ["query"],
    "computed": []
  }
}
