{
  "id": "search.search-sync-job-progress",
  "title": "Search sync job progress",
  "version": 1,
  "kind": "SduiWidget",
  "description": "Progress bar + counter breakdown for a SearchSyncJob. Subscribes to `user.{userId}.search` broadcast for live updates when `subscribeBroadcast=true`.",
  "props": {
    "job": {
      "type": "object",
      "description": "SearchSyncJob DTO with progress_percent + counters + status."
    },
    "subscribeBroadcast": { "type": "boolean", "default": true },
    "compact": { "type": "boolean", "default": false }
  },
  "dataSources": [
    {
      "name": "liveJob",
      "kind": "broadcast.subscribe",
      "channel": { "$expr": "'user.' + auth.userId + '.search'" },
      "events": ["SearchSyncJobProgress", "SearchSyncJobShardCompleted"],
      "filter": { "$expr": "payload.search_sync_job_id === props.job.id" },
      "seed": { "$ref": "props.job" },
      "reduce": {
        "$expr": "{ ...state, progress_percent: payload.progress_percent ?? state.progress_percent, counters: payload.counters ?? state.counters }"
      },
      "enabled": { "$ref": "props.subscribeBroadcast" }
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-2" },
      "children": [
        {
          "kind": "ProgressBar",
          "bindings": {
            "value": { "$ref": "liveJob.progress_percent" },
            "max": 100,
            "variant": {
              "$expr": "liveJob.status === 'failed' ? 'danger' : liveJob.status === 'partially_succeeded' ? 'warning' : 'default'"
            }
          }
        },
        {
          "kind": "View",
          "props": { "className": "flex flex-wrap gap-3 text-xs text-muted" },
          "bindings": { "hidden": { "$ref": "props.compact" } },
          "children": [
            {
              "kind": "Text",
              "bindings": {
                "children": { "$expr": "t('search.counters.total',   {n: liveJob.counters.total})" }
              }
            },
            {
              "kind": "Text",
              "bindings": {
                "children": {
                  "$expr": "t('search.counters.indexed', {n: liveJob.counters.indexed})"
                }
              }
            },
            {
              "kind": "Text",
              "bindings": {
                "children": {
                  "$expr": "t('search.counters.updated', {n: liveJob.counters.updated})"
                }
              }
            },
            {
              "kind": "Text",
              "bindings": {
                "children": {
                  "$expr": "t('search.counters.skipped', {n: liveJob.counters.skipped})"
                },
                "className": "text-warning"
              }
            },
            {
              "kind": "Text",
              "bindings": {
                "children": {
                  "$expr": "t('search.counters.failed',  {n: liveJob.counters.failed})"
                },
                "className": "text-danger"
              }
            }
          ]
        }
      ]
    }
  ]
}
