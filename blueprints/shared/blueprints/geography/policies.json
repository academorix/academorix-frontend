{
  "id": "academorix://modules/geography/policies",
  "$version": 1,
  "title": "geography \u2014 authorization policies",
  "description": "Read policies accept nullable Authenticatable so anonymous requests pass. Write policies gate to platform admin only.",
  "policies": [
    {
      "model": "Country",
      "class": "Academorix\\Geography\\Policies\\CountryPolicy",
      "abilities": [
        { "action": "viewAny", "permission": null, "scope": "public" },
        { "action": "view", "permission": null, "scope": "public" },
        { "action": "platformCreate", "permission": "platform.geography.manage" },
        { "action": "platformUpdate", "permission": "platform.geography.manage" },
        { "action": "platformDelete", "permission": "platform.geography.manage" }
      ]
    },
    {
      "model": "State",
      "class": "Academorix\\Geography\\Policies\\StatePolicy",
      "abilities": [
        { "action": "viewAny", "permission": null },
        { "action": "view", "permission": null },
        { "action": "platformCreate", "permission": "platform.geography.manage" },
        { "action": "platformUpdate", "permission": "platform.geography.manage" },
        { "action": "platformDelete", "permission": "platform.geography.manage" }
      ]
    },
    {
      "model": "City",
      "class": "Academorix\\Geography\\Policies\\CityPolicy",
      "abilities": [
        { "action": "viewAny", "permission": null },
        { "action": "view", "permission": null },
        { "action": "platformCreate", "permission": "platform.geography.manage" },
        { "action": "platformUpdate", "permission": "platform.geography.manage" },
        { "action": "platformDelete", "permission": "platform.geography.manage" }
      ]
    },
    {
      "model": "Currency",
      "class": "Academorix\\Geography\\Policies\\CurrencyPolicy",
      "abilities": [
        { "action": "viewAny", "permission": null },
        { "action": "view", "permission": null },
        { "action": "platformCreate", "permission": "platform.geography.manage" },
        { "action": "platformUpdate", "permission": "platform.geography.manage" },
        { "action": "platformDelete", "permission": "platform.geography.manage" }
      ]
    },
    {
      "model": "Language",
      "class": "Academorix\\Geography\\Policies\\LanguagePolicy",
      "abilities": [
        { "action": "viewAny", "permission": null },
        { "action": "view", "permission": null },
        { "action": "platformCreate", "permission": "platform.geography.manage" },
        { "action": "platformUpdate", "permission": "platform.geography.manage" },
        { "action": "platformDelete", "permission": "platform.geography.manage" }
      ]
    },
    {
      "model": "Timezone",
      "class": "Academorix\\Geography\\Policies\\TimezonePolicy",
      "abilities": [
        { "action": "viewAny", "permission": null },
        { "action": "view", "permission": null },
        { "action": "platformCreate", "permission": "platform.geography.manage" },
        { "action": "platformUpdate", "permission": "platform.geography.manage" },
        { "action": "platformDelete", "permission": "platform.geography.manage" }
      ]
    }
  ],
  "geolocate": {
    "check": "geography.geolocate",
    "description": "Not a model policy \u2014 a straight permission check via auth:sanctum + throttle:geolocate."
  }
}
