{
  "id": "stackra://modules/geography/routes",
  "$version": 1,
  "title": "geography \u2014 HTTP routes",
  "description": "Two derived groups. Reference-catalog reads are PUBLIC (no auth) \u2014 marketing pages + signup + tenant UIs all depend on them. `/geolocate` is authed + rate-limited because it can trigger outbound `ip-api.com` traffic on cache miss.",
  "groups": [
    {
      "name": "public-catalog",
      "prefix": "/api/v1/geography",
      "middleware": [
        "request.id",
        "cors.public",
        "versioning.resolve",
        "world.locale",
        "geography.cache",
        "response.envelope"
      ],
      "hosts": ["tenant", "central"],
      "description": "PUBLIC read routes. Policies accept nullable Authenticatable so viewAny/view never fires the auth gate. Anonymous bursts absorbed by response cache.",
      "routes": [
        {
          "method": "GET",
          "path": "/countries",
          "controller": "Stackra\\Geography\\Http\\Controllers\\CountryController@index",
          "permission": null,
          "description": "?filter[region]=Europe supported."
        },
        {
          "method": "GET",
          "path": "/countries/{country}",
          "controller": "Stackra\\Geography\\Http\\Controllers\\CountryController@show",
          "permission": null,
          "description": "Path binding: numeric PK OR ISO2."
        },
        {
          "method": "GET",
          "path": "/countries/{country}/states",
          "controller": "Stackra\\Geography\\Http\\Controllers\\StateController@indexForCountry",
          "permission": null
        },
        {
          "method": "GET",
          "path": "/countries/{country}/cities",
          "controller": "Stackra\\Geography\\Http\\Controllers\\CityController@indexForCountry",
          "permission": null
        },
        {
          "method": "GET",
          "path": "/countries/{country}/timezones",
          "controller": "Stackra\\Geography\\Http\\Controllers\\TimezoneController@indexForCountry",
          "permission": null
        },
        {
          "method": "GET",
          "path": "/states",
          "controller": "Stackra\\Geography\\Http\\Controllers\\StateController@index",
          "permission": null,
          "description": "Requires ?filter[country_id]= to avoid full-table scan."
        },
        {
          "method": "GET",
          "path": "/states/{state}",
          "controller": "Stackra\\Geography\\Http\\Controllers\\StateController@show",
          "permission": null
        },
        {
          "method": "GET",
          "path": "/states/{state}/cities",
          "controller": "Stackra\\Geography\\Http\\Controllers\\CityController@indexForState",
          "permission": null
        },
        {
          "method": "GET",
          "path": "/cities",
          "controller": "Stackra\\Geography\\Http\\Controllers\\CityController@index",
          "permission": null,
          "description": "Requires ?filter[country_id]= OR ?filter[state_id]= (repository refuses unscoped calls)."
        },
        {
          "method": "GET",
          "path": "/cities/{city}",
          "controller": "Stackra\\Geography\\Http\\Controllers\\CityController@show",
          "permission": null
        },
        {
          "method": "GET",
          "path": "/currencies",
          "controller": "Stackra\\Geography\\Http\\Controllers\\CurrencyController@index",
          "permission": null
        },
        {
          "method": "GET",
          "path": "/currencies/{currency}",
          "controller": "Stackra\\Geography\\Http\\Controllers\\CurrencyController@show",
          "permission": null,
          "description": "Path binding: numeric PK OR ISO-4217 code."
        },
        {
          "method": "GET",
          "path": "/languages",
          "controller": "Stackra\\Geography\\Http\\Controllers\\LanguageController@index",
          "permission": null
        },
        {
          "method": "GET",
          "path": "/languages/{language}",
          "controller": "Stackra\\Geography\\Http\\Controllers\\LanguageController@show",
          "permission": null,
          "description": "Path binding: numeric PK OR ISO-639-1 code."
        },
        {
          "method": "GET",
          "path": "/timezones",
          "controller": "Stackra\\Geography\\Http\\Controllers\\TimezoneController@index",
          "permission": null
        },
        {
          "method": "GET",
          "path": "/timezones/{timezone}",
          "controller": "Stackra\\Geography\\Http\\Controllers\\TimezoneController@show",
          "permission": null,
          "description": "Path binding: numeric PK OR URL-encoded IANA name."
        }
      ]
    },
    {
      "name": "geolocate",
      "prefix": "/api/v1/geography",
      "middleware": [
        "request.id",
        "cors.strict",
        "versioning.resolve",
        "auth:sanctum",
        "throttle:geolocate",
        "world.locale",
        "response.envelope"
      ],
      "hosts": ["tenant", "central"],
      "description": "IP\u2192location. Authed. 10 req/min per user default. Response cached per (ip, locale) for 1h in Redis.",
      "routes": [
        {
          "method": "GET",
          "path": "/geolocate",
          "controller": "Stackra\\Geography\\Http\\Controllers\\GeolocateController@__invoke",
          "permission": "geography.geolocate",
          "description": "Query params: ?ip=1.2.3.4 (defaults to request IP). Returns GeolocationData."
        }
      ]
    },
    {
      "name": "platform-catalog-write",
      "prefix": "/api/v1/platform/geography",
      "middleware": [
        "request.id",
        "cors.strict",
        "versioning.resolve",
        "auth:platform_admin",
        "throttle:foundation-platform",
        "world.locale",
        "response.envelope"
      ],
      "hosts": ["platform-admin"],
      "description": "Write surface for hotfixing vendor rows. RARE \u2014 the seeder is the source of truth. Overrides persist across `world:install --force` because we check `updated_by IS NOT NULL` before overwriting.",
      "routes": [
        {
          "method": "POST",
          "path": "/countries",
          "controller": "Stackra\\Geography\\Http\\Controllers\\Platform\\CountryController@store",
          "permission": "platform.geography.manage"
        },
        {
          "method": "PATCH",
          "path": "/countries/{country}",
          "controller": "Stackra\\Geography\\Http\\Controllers\\Platform\\CountryController@update",
          "permission": "platform.geography.manage"
        },
        {
          "method": "DELETE",
          "path": "/countries/{country}",
          "controller": "Stackra\\Geography\\Http\\Controllers\\Platform\\CountryController@destroy",
          "permission": "platform.geography.manage",
          "description": "Sets status=0 (soft archive). Never hard-deletes \u2014 downstream FK integrity."
        },
        {
          "method": "POST",
          "path": "/states",
          "controller": "Stackra\\Geography\\Http\\Controllers\\Platform\\StateController@store",
          "permission": "platform.geography.manage"
        },
        {
          "method": "PATCH",
          "path": "/states/{state}",
          "controller": "Stackra\\Geography\\Http\\Controllers\\Platform\\StateController@update",
          "permission": "platform.geography.manage"
        },
        {
          "method": "DELETE",
          "path": "/states/{state}",
          "controller": "Stackra\\Geography\\Http\\Controllers\\Platform\\StateController@destroy",
          "permission": "platform.geography.manage"
        },
        {
          "method": "POST",
          "path": "/cities",
          "controller": "Stackra\\Geography\\Http\\Controllers\\Platform\\CityController@store",
          "permission": "platform.geography.manage"
        },
        {
          "method": "PATCH",
          "path": "/cities/{city}",
          "controller": "Stackra\\Geography\\Http\\Controllers\\Platform\\CityController@update",
          "permission": "platform.geography.manage"
        },
        {
          "method": "DELETE",
          "path": "/cities/{city}",
          "controller": "Stackra\\Geography\\Http\\Controllers\\Platform\\CityController@destroy",
          "permission": "platform.geography.manage"
        },
        {
          "method": "POST",
          "path": "/currencies",
          "controller": "Stackra\\Geography\\Http\\Controllers\\Platform\\CurrencyController@store",
          "permission": "platform.geography.manage"
        },
        {
          "method": "PATCH",
          "path": "/currencies/{currency}",
          "controller": "Stackra\\Geography\\Http\\Controllers\\Platform\\CurrencyController@update",
          "permission": "platform.geography.manage"
        },
        {
          "method": "DELETE",
          "path": "/currencies/{currency}",
          "controller": "Stackra\\Geography\\Http\\Controllers\\Platform\\CurrencyController@destroy",
          "permission": "platform.geography.manage"
        },
        {
          "method": "POST",
          "path": "/languages",
          "controller": "Stackra\\Geography\\Http\\Controllers\\Platform\\LanguageController@store",
          "permission": "platform.geography.manage"
        },
        {
          "method": "PATCH",
          "path": "/languages/{language}",
          "controller": "Stackra\\Geography\\Http\\Controllers\\Platform\\LanguageController@update",
          "permission": "platform.geography.manage"
        },
        {
          "method": "DELETE",
          "path": "/languages/{language}",
          "controller": "Stackra\\Geography\\Http\\Controllers\\Platform\\LanguageController@destroy",
          "permission": "platform.geography.manage"
        },
        {
          "method": "POST",
          "path": "/timezones",
          "controller": "Stackra\\Geography\\Http\\Controllers\\Platform\\TimezoneController@store",
          "permission": "platform.geography.manage"
        },
        {
          "method": "PATCH",
          "path": "/timezones/{timezone}",
          "controller": "Stackra\\Geography\\Http\\Controllers\\Platform\\TimezoneController@update",
          "permission": "platform.geography.manage"
        },
        {
          "method": "DELETE",
          "path": "/timezones/{timezone}",
          "controller": "Stackra\\Geography\\Http\\Controllers\\Platform\\TimezoneController@destroy",
          "permission": "platform.geography.manage"
        }
      ]
    }
  ]
}
