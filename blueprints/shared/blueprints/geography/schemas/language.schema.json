  "additionalProperties": true,
  "x-wire": {
    "envelope": "spatie-data",
    "wrap": "data",
    "mapper": "SnakeCaseMapper",
    "resource_class": "Stackra\\Geography\\Data\\Resources\\LanguageResourceData"
  },
  "x-route-binding": {
    "strategy": "resolveRouteBinding",
