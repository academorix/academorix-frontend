      },
      "name": { "type": "string", "description": "English name (e.g. 'French')." },
      "native": {
        "type": "string",
        "nullable": true,
        "description": "Native-script name (`Fran\u00e7ais`, `\u65e5\u672c\u8a9e`, `\u0627\u0644\u0639\u0631\u0628\u064a\u0629`)."
      },
      "dir": {
        "type": "string",
        "length": 3,
        "nullable": true,
        "description": "Text direction: ltr / rtl."
      },
      "is_rtl": { "type": "boolean", "description": "Denormalised RTL flag." }
    }
  },
  "required": ["id", "code", "name"],
  "properties": {
    "id": { "type": "integer" },
    "country_id": { "type": ["integer", "null"] },
