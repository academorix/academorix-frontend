{
  "id": "stackra://modules/geography/schemas/language",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "Language",
  "description": "ISO-639 language reference row. Vendor-owned schema. Single source of truth for language display metadata across the platform. Referenced by `localization::PlatformLanguage` (formerly `localization::Language`) via `platform_languages.geography_language_id` since the Wave 5 dedupe refactor \u2014 see module.json.naming_note + module.json.referenced_by. Route binding accepts numeric PK OR ISO-639-1 code (lowercase).",
  "type": "object",
  "x-module": "geography",
  "x-vendor": {
    "package": "nnjeim/world",
    "vendor_model": "Nnjeim\\World\\Models\\Language",
    "we_own_migration": false,
    "we_own_seeder": false
  },
  "x-eloquent": {
    "baseClass": "Nnjeim\\World\\Models\\Language",
    "table": "languages",
    "primaryKey": "id",
    "keyType": "int",
    "incrementing": true,
    "timestamps": false,
    "model": "Stackra\\Geography\\Models\\Language",
    "interface": "Stackra\\Geography\\Contracts\\Data\\LanguageInterface",
    "implements": ["Stackra\\Geography\\Contracts\\Data\\LanguageInterface"],
    "traits": ["HasFactory", "Filterable"],
    "observers": ["LanguageObserver"]
  },
  "x-database": {
    "engine": "any (vendor-supported)",
    "vendor_owned": true,
    "columns_summary": {
      "id": { "type": "integer", "primary": true },
      "country_id": {
        "type": "integer",
        "nullable": true,
        "description": "Primary country association (nullable \u2014 many languages span multiple countries)."
      },
      "code": {
        "type": "string",
        "length": 2,
