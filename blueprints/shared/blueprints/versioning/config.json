{
  "id": "stackra://modules/versioning/config",
  "$version": 1,
  "title": "versioning \u2014 developer configuration",
  "description": "Deploy-static config. Mirrors `config/versioning.php`.",
  "configFile": "config/versioning.php",
  "envPrefix": "VERSIONING_",
  "sections": {
    "default": {
      "keys": [
        {
          "path": "versioning.default",
          "type": "string",
          "default": "v1",
          "env": "VERSIONING_DEFAULT",
          "description": "Fallback version slug when the resolver chain returns null. Must match an ApiVersion row with is_default=true."
        }
      ]
    },
    "resolvers": {
      "description": "Version resolver chain configuration.",
      "keys": [
        {
          "path": "versioning.resolvers.order",
          "type": "array<string>",
          "default": ["url", "header", "webhook", "graphql", "query"],
          "description": "Ordered list of resolvers. First non-null wins."
        },
        {
          "path": "versioning.resolvers.url.prefix",
          "type": "string",
          "default": "/api",
          "description": "URL prefix under which versions are recognised. /api/v1/... resolves to v1."
        },
        {
          "path": "versioning.resolvers.header.accept_pattern",
          "type": "string",
          "default": "application/vnd.stackra.{version}+json",
          "description": "Accept header pattern. {version} is the capture group."
        },
        {
          "path": "versioning.resolvers.query.enabled_environments",
          "type": "array<string>",
          "default": ["local", "testing", "staging"],
          "description": "Environments where the query resolver is enabled. Production excluded unless versioning.query_resolver_in_production feature is granted."
        },
        { "path": "versioning.resolvers.query.param_name", "type": "string", "default": "version" },
        {
          "path": "versioning.resolvers.webhook.subscription_column",
          "type": "string",
          "default": "api_version",
          "description": "The column on WebhookSubscription that pins the version."
        },
        {
          "path": "versioning.resolvers.graphql.directive_name",
          "type": "string",
          "default": "api",
          "description": "GraphQL directive: @api(version: v2). Prefix + name customisable."
        }
      ]
    },
    "schemes": {
      "description": "Version scheme adapters.",
      "keys": [
        {
          "path": "versioning.schemes.default",
          "type": "string",
          "default": "semver",
          "enum": ["semver", "calver"]
        },
        {
          "path": "versioning.schemes.available",
          "type": "array<string>",
          "default": ["semver", "calver"]
        }
      ]
    },
    "sunset": {
      "description": "Sunset behaviour.",
      "keys": [
        {
          "path": "versioning.sunset.default_notice_days",
          "type": "int",
          "default": 180,
          "description": "Default sunset_at offset when deprecating without explicit --sunset-at."
        },
        {
          "path": "versioning.sunset.reminder_windows_days",
          "type": "array<int>",
          "default": [30, 7, 3, 1],
          "description": "Reminder notices auto-published this many days before sunset."
        },
        {
          "path": "versioning.sunset.enforce_410",
          "type": "bool",
          "default": true,
          "description": "Sunset versions respond 410 Gone. Off \u2014 sunset versions serve with only Sunset header (emergency override; feature-flag guarded)."
        }
      ]
    },
    "headers": {
      "description": "Response header emission.",
      "keys": [
        { "path": "versioning.headers.api_version", "type": "string", "default": "X-API-Version" },
        { "path": "versioning.headers.deprecation", "type": "string", "default": "Deprecation" },
        { "path": "versioning.headers.sunset", "type": "string", "default": "Sunset" },
        {
          "path": "versioning.headers.link_successor_rel",
          "type": "string",
          "default": "successor-version"
        }
      ]
    },
    "transformers": {
      "description": "Payload transformer registry.",
      "keys": [
        {
          "path": "versioning.transformers.compiler_cache_path",
          "type": "string",
          "default": "bootstrap/cache/versioning-transformers.php",
          "description": "Compiled transformer registry \u2014 written at build time by the versioning compiler."
        },
        {
          "path": "versioning.transformers.max_chain_length",
          "type": "int",
          "default": 10,
          "description": "Refuse chains longer than N hops. Prevents runaway transformation costs across major version drift."
        }
      ]
    },
    "analytics": {
      "keys": [
        {
          "path": "versioning.analytics.usage_sample_rate",
          "type": "float",
          "default": 0.01,
          "description": "Sampling rate for the 'Api Version Used' analytics event (0.0\u20131.0). Default 1% \u2014 signal without cost."
        }
      ]
    }
  }
}
