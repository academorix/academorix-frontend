{
  "id": "stackra://modules/versioning/analytics",
  "$version": 1,
  "title": "versioning \u2014 product analytics events",
  "description": "Product analytics events for version lifecycle. Consent tier: functional (versioning is service functionality, not marketing insight).",
  "sink": "segment",
  "consentTiers": ["essential", "functional", "analytics", "marketing"],
  "events": [
    {
      "name": "Api Version Released",
      "kind": "track",
      "consent_required": "functional",
      "properties": ["version_slug", "scheme", "is_default"]
    },
    {
      "name": "Api Version Deprecated",
      "kind": "track",
      "consent_required": "functional",
      "properties": [
        "version_slug",
        "sunset_at",
        "migration_target_slug",
        "affected_subscription_count"
      ]
    },
    {
      "name": "Api Version Sunset",
      "kind": "track",
      "consent_required": "functional",
      "properties": ["version_slug", "auto_upgrade_performed", "affected_subscription_count"]
    },
    {
      "name": "Api Version Used",
      "kind": "track",
      "consent_required": "analytics",
      "properties": ["tenant_id", "version_slug", "surface", "resolver", "is_deprecated"],
      "description": "Sampled at 1% by default \u2014 configurable via config('versioning.analytics.usage_sample_rate'). At 100% this event is chatty; sampling gives the migration-progress signal without cost."
    },
    {
      "name": "Deprecation Notice Published",
      "kind": "track",
      "consent_required": "functional",
      "properties": [
        "notice_type",
        "version_slug",
        "notify_customers",
        "affected_endpoint_count",
        "affected_event_count"
      ]
    },
    {
      "name": "Deprecation Notice Delivered",
      "kind": "track",
      "consent_required": "functional",
      "properties": ["notice_id", "version_slug", "channel"],
      "description": "Fired once per (tenant, channel) after ApiDeprecationNotification delivered."
    },
    {
      "name": "Subscription Auto Upgraded",
      "kind": "track",
      "consent_required": "functional",
      "properties": ["subscription_id", "from_version", "to_version", "outcome"]
    }
  ]
}
