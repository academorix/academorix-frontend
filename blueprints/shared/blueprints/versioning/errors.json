{
  "id": "stackra://modules/versioning/errors",
  "$version": 1,
  "title": "versioning \u2014 error codes",
  "description": "Module-scoped errors. Namespace: VERSIONING_.",
  "namespace": "versioning",
  "errors": [
    {
      "code": "VERSIONING_VERSION_NOT_FOUND",
      "http": 406,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "versioning.errors.version_not_found",
      "description": "Requested version doesn't exist. Body includes available versions."
    },
    {
      "code": "VERSIONING_VERSION_DEPRECATED",
      "http": 200,
      "retryable": false,
      "user_facing": false,
      "audit_severity": "info",
      "i18n_key": "versioning.errors.version_deprecated",
      "description": "Not surfaced as an error \u2014 request succeeds. Deprecation header + Sunset header emitted. Logged for migration-progress metrics."
    },
    {
      "code": "VERSIONING_VERSION_SUNSET",
      "http": 410,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "warn",
      "i18n_key": "versioning.errors.version_sunset",
      "description": "410 Gone. Body includes migration_guide_url + Link: rel=successor-version header. Sunset header emitted for archaeology."
    },
    {
      "code": "VERSIONING_TRANSFORMER_MISSING",
      "http": 500,
      "retryable": false,
      "user_facing": false,
      "audit_severity": "alert",
      "i18n_key": "versioning.errors.transformer_missing",
      "description": "PayloadTransformerRegistry has no chain from X to Y for the requested (surface, event). Webhook delivery fails; subscription auto-paused. Pages ops."
    },
    {
      "code": "VERSIONING_INCOMPATIBLE_TRANSFORMATION",
      "http": 422,
      "retryable": false,
      "user_facing": false,
      "audit_severity": "alert",
      "i18n_key": "versioning.errors.incompatible_transformation",
      "description": "Transformer chain resolved but a transformer threw an exception (bad payload shape, unknown field). Delivery fails; webhook subscription paused for admin review."
    },
    {
      "code": "VERSIONING_INVALID_STATE_TRANSITION",
      "http": 409,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "warn",
      "i18n_key": "versioning.errors.invalid_state_transition",
      "description": "Attempted an illegal state transition (draft \u2192 sunset, or released \u2192 draft). State machine refused."
    },
    {
      "code": "VERSIONING_MIGRATION_TARGET_INVALID",
      "http": 422,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "warn",
      "i18n_key": "versioning.errors.migration_target_invalid",
      "description": "migration_target_slug references self, non-existent version, or a version that's itself sunset."
    },
    {
      "code": "VERSIONING_MULTIPLE_DEFAULTS",
      "http": 500,
      "retryable": false,
      "user_facing": false,
      "audit_severity": "alert",
      "i18n_key": "versioning.errors.multiple_defaults",
      "description": "Data integrity: more than one ApiVersion has is_default=true. Shouldn't happen \u2014 partial unique index enforces. If it does, pages ops immediately."
    },
    {
      "code": "VERSIONING_NO_DEFAULT",
      "http": 500,
      "retryable": false,
      "user_facing": false,
      "audit_severity": "alert",
      "i18n_key": "versioning.errors.no_default",
      "description": "No ApiVersion has is_default=true. Resolver falls through with no fallback. Pages ops."
    },
    {
      "code": "VERSIONING_SUNSET_NOT_YET_DUE",
      "http": 409,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "versioning.errors.sunset_not_yet_due",
      "description": "Manual `versioning:sunset` invoked before sunset_at reached. Requires --force flag."
    },
    {
      "code": "VERSIONING_NOTICE_ALREADY_PUBLISHED",
      "http": 409,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "versioning.errors.notice_already_published",
      "description": "Attempted publish on a notice already in state=published. Idempotent no-op response with published_at timestamp."
    },
    {
      "code": "VERSIONING_NOTICE_PUBLISHED_EDIT_REFUSED",
      "http": 409,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "warn",
      "i18n_key": "versioning.errors.notice_published_edit_refused",
      "description": "Attempted text edit on a published notice by non-super_admin. Refused \u2014 create a revised draft + publish."
    },
    {
      "code": "VERSIONING_SUBSCRIPTION_REFERENCES_VERSION",
      "http": 409,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "versioning.errors.subscription_references_version",
      "description": "Attempted delete on an ApiVersion referenced by one or more WebhookSubscriptions. Refused. Body includes affected subscription count."
    },
    {
      "code": "VERSIONING_INVALID_VERSION_SLUG",
      "http": 422,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "versioning.errors.invalid_version_slug",
      "description": "Slug fails validation (reserved slug, invalid format, or would collide with existing)."
    }
  ]
}
