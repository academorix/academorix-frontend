{
  "id": "academorix://modules/localization/permissions",
  "$version": 1,
  "title": "localization \u2014 permissions",
  "seeder": "Academorix\\Localization\\Database\\Seeders\\LocalizationPermissionSeeder",
  "isSystem": true,
  "permissions": [
    { "name": "languages.viewAny", "guard": "sanctum", "seededOn": ["member", "admin", "owner"] },
    { "name": "languages.view", "guard": "sanctum", "seededOn": ["member", "admin", "owner"] },
    {
      "name": "tenant_locales.viewAny",
      "guard": "sanctum",
      "seededOn": ["member", "admin", "owner"]
    },
    {
      "name": "tenant_locales.view",
      "guard": "sanctum",
      "seededOn": ["member", "admin", "owner"]
    },
    { "name": "tenant_locales.manage", "guard": "sanctum", "seededOn": ["admin", "owner"] },
    {
      "name": "translations.viewAny",
      "guard": "sanctum",
      "seededOn": ["member", "admin", "owner", "translation_reviewer"]
    },
    {
      "name": "translations.view",
      "guard": "sanctum",
      "seededOn": ["member", "admin", "owner", "translation_reviewer"]
    },
    {
      "name": "translations.create",
      "guard": "sanctum",
      "seededOn": ["admin", "owner", "translation_reviewer"]
    },
    {
      "name": "translations.update",
      "guard": "sanctum",
      "seededOn": ["admin", "owner", "translation_reviewer"]
    },
    { "name": "translations.delete", "guard": "sanctum", "seededOn": ["admin", "owner"] },
    {
      "name": "translations.verify",
      "guard": "sanctum",
      "description": "Mark AI translations as human-verified.",
      "seededOn": ["admin", "owner", "translation_reviewer"]
    },
    {
      "name": "translation_jobs.viewAny",
      "guard": "sanctum",
      "seededOn": ["admin", "owner", "translation_reviewer"]
    },
    {
      "name": "translation_jobs.view",
      "guard": "sanctum",
      "seededOn": ["admin", "owner", "translation_reviewer"]
    },
    { "name": "translation_jobs.create", "guard": "sanctum", "seededOn": ["admin", "owner"] },
    { "name": "translation_jobs.cancel", "guard": "sanctum", "seededOn": ["admin", "owner"] },
    {
      "name": "platform.languages.viewAny",
      "guard": "platform_admin",
      "seededOn": ["super_admin", "ops", "product"]
    },
    {
      "name": "platform.languages.view",
      "guard": "platform_admin",
      "seededOn": ["super_admin", "ops", "product"]
    },
    {
      "name": "platform.languages.create",
      "guard": "platform_admin",
      "seededOn": ["super_admin", "product"]
    },
    {
      "name": "platform.languages.update",
      "guard": "platform_admin",
      "seededOn": ["super_admin", "product"]
    },
    {
      "name": "platform.languages.archive",
      "guard": "platform_admin",
      "seededOn": ["super_admin"]
    },
    {
      "name": "platform.translations.viewAny",
      "guard": "platform_admin",
      "seededOn": ["super_admin", "ops", "product"]
    }
  ]
}
