{
  "id": "stackra://modules/localization/schemas/translation-job",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "TranslationJob",
  "description": "Audit + progress row for one bulk-translation batch. Powers the tenant UI's 'Translate all missing to French' button and the platform admin's cross-tenant translation ops.",
  "type": "object",
  "x-module": "localization",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "translation_jobs",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "tjb_",
    "incrementing": false,
    "model": "Stackra\\Localization\\Models\\TranslationJob",
    "interface": "Stackra\\Localization\\Contracts\\Data\\TranslationJobInterface",
    "implements": ["Stackra\\Localization\\Contracts\\Data\\TranslationJobInterface"],
    "traits": [
      "HasFactory",
      "HasUlids",
      "BelongsToTenant",
      "HasMetadata",
      "HasUserstamps",
      "Filterable"
    ],
    "casts": {
      "state": "TranslationJobState",
      "started_at": "datetime",
      "completed_at": "datetime",
      "failed_at": "datetime",
      "keys_total": "integer",
      "keys_translated": "integer",
      "keys_failed": "integer",
      "keys_skipped": "integer",
      "entitlement_units_consumed": "integer",
      "namespaces": "array",
      "target_locale_codes": "array",
      "metadata": "array"
    },
    "appends": ["progress_ratio", "duration_ms"],
    "observers": ["TranslationJobObserver"],
    "hidden": [],
    "guarded": []
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": {
        "type": "string",
        "length": 64,
        "primary": true,
        "description": "Prefixed ULID: `tjb_<26 chars>`."
      },
      "tenant_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "kind": {
        "type": "string",
        "length": 32,
        "nullable": false,
        "description": "Enum: bulk_namespace / bulk_missing / bulk_stale / import / single_key. What triggered this job."
      },
      "state": {
        "type": "string",
        "length": 24,
        "nullable": false,
        "default": "'queued'",
        "description": "Enum: queued / running / completed / failed / cancelled."
      },
      "source_locale_code": {
        "type": "string",
        "length": 12,
        "nullable": false,
        "description": "Origin locale (usually default_locale)."
      },
      "target_locale_codes": {
        "type": "jsonb",
        "nullable": false,
        "description": "Array of locale codes to translate into. E.g. ['fr', 'es', 'ar']."
      },
      "namespaces": {
        "type": "jsonb",
        "nullable": true,
        "description": "Array of namespaces + groups to include. Null = all."
      },
      "driver": {
        "type": "string",
        "length": 32,
        "nullable": false,
        "description": "openai / google / deepl / aws-translate / azure-translator."
      },
      "driver_model": { "type": "string", "length": 64, "nullable": true },
      "keys_total": { "type": "integer", "nullable": false, "default": 0 },
      "keys_translated": { "type": "integer", "nullable": false, "default": 0 },
      "keys_failed": { "type": "integer", "nullable": false, "default": 0 },
      "keys_skipped": { "type": "integer", "nullable": false, "default": 0 },
      "entitlement_units_consumed": {
        "type": "integer",
        "nullable": false,
        "default": 0,
        "description": "Cumulative amount deducted from localization.ai_translations.month during this job."
      },
      "started_at": { "type": "timestamptz", "nullable": true },
      "completed_at": { "type": "timestamptz", "nullable": true },
      "failed_at": { "type": "timestamptz", "nullable": true },
      "failure_reason": { "type": "text", "nullable": true },
      "requested_by": {
        "type": "uuid",
        "nullable": true,
        "description": "User ULID that triggered the job. Null for system-scheduled jobs."
      },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_by": { "type": "uuid", "nullable": true },
      "updated_by": { "type": "uuid", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "state"],
        "unique": false,
        "name": "translation_jobs_tenant_state_idx"
      },
      {
        "columns": ["tenant_id", "created_at"],
        "unique": false,
        "name": "translation_jobs_tenant_created_idx"
      }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "kind",
    "state",
    "source_locale_code",
    "target_locale_codes",
    "driver",
    "keys_total",
    "keys_translated",
    "keys_failed",
    "keys_skipped",
    "entitlement_units_consumed",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^tjb_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": "string", "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "kind": {
      "type": "string",
      "enum": ["bulk_namespace", "bulk_missing", "bulk_stale", "import", "single_key"]
    },
    "state": {
      "type": "string",
      "enum": ["queued", "running", "completed", "failed", "cancelled"]
    },
    "source_locale_code": { "type": "string" },
    "target_locale_codes": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "namespaces": { "type": ["array", "null"], "items": { "type": "string" } },
    "driver": {
      "type": "string",
      "enum": ["openai", "google", "deepl", "aws-translate", "azure-translator", "null"]
    },
    "driver_model": { "type": ["string", "null"] },
    "keys_total": { "type": "integer", "minimum": 0 },
    "keys_translated": { "type": "integer", "minimum": 0 },
    "keys_failed": { "type": "integer", "minimum": 0 },
    "keys_skipped": { "type": "integer", "minimum": 0 },
    "entitlement_units_consumed": { "type": "integer", "minimum": 0 },
    "started_at": { "type": ["string", "null"], "format": "date-time" },
    "completed_at": { "type": ["string", "null"], "format": "date-time" },
    "failed_at": { "type": ["string", "null"], "format": "date-time" },
    "failure_reason": { "type": ["string", "null"] },
    "requested_by": { "type": ["string", "null"], "format": "uuid" },
    "progress_ratio": {
      "type": "number",
      "description": "Computed. keys_translated / keys_total."
    },
    "duration_ms": {
      "type": ["integer", "null"],
      "description": "Computed. completed_at - started_at in ms."
    },
    "metadata": { "type": ["object", "null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false,
  "x-wire": {
    "envelope": "spatie-data",
    "wrap": "data",
    "mapper": "SnakeCaseMapper",
    "computed": ["progress_ratio", "duration_ms"]
  }
}
