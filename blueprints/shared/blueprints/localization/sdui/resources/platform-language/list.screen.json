{
  "id": "localization.resources.platform-language.list",
  "title": "Platform languages",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/platform/languages",
  "host": "platform-admin",
  "audience": "platform_admin",
  "resource": { "module": "localization", "entity": "platform-language", "action": "list" },
  "requiresPermission": "platform.languages.viewAny",
  "notes": [
    "The URL prefix stays `/platform/languages` for wire-stable API paths (Refine resource name = 'platform-languages' per module.json.hosts). Display fields (name, native_name, direction, flag_emoji) are computed accessors on PlatformLanguage that chain through the FK'd geography::Language + geography::Country \u2014 no duplicated columns to render."
  ],
  "dataSources": [
    {
      "name": "platformLanguages",
      "kind": "http.get",
      "url": "/api/v1/platform/languages?include=geographyLanguage,geographyCountry",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-center justify-between" },
          "children": [
            {
              "kind": "View",
              "children": [
                {
                  "kind": "Text",
                  "props": {
                    "as": "h1",
                    "className": "text-2xl font-semibold",
                    "children": "Platform languages"
                  }
                },
                {
                  "kind": "Text",
                  "props": {
                    "className": "text-sm text-muted",
                    "children": "BCP 47 tags Academorix officially supports. Each row references a `geography::Language` row for ISO-639 metadata + optionally a `geography::Country` for regional variants. Tenancy enable a subset via TenantLocale."
                  }
                }
              ]
            },
            {
              "kind": "Button",
              "props": { "variant": "primary", "leadingIcon": "plus", "children": "Add language" },
              "actions": { "onPress": { "kind": "navigate", "to": "/platform/languages/create" } },
              "requiresPermission": "platform.languages.create"
            }
          ]
        },
        {
          "kind": "Toolbar",
          "children": [
            {
              "kind": "SearchField",
              "props": { "placeholder": "BCP 47 code, name, or native name", "name": "q" }
            },
            {
              "kind": "Select",
              "props": { "name": "direction", "placeholder": "All directions", "clearable": true },
              "options": [
                { "key": "ltr", "label": "LTR" },
                { "key": "rtl", "label": "RTL" }
              ]
            },
            {
              "kind": "Toggle",
              "props": { "name": "is_active_on_platform", "label": "Active only" }
            },
            { "kind": "Toggle", "props": { "name": "is_beta", "label": "Beta only" } }
          ]
        },
        {
          "kind": "Table",
          "columns": [
            {
              "key": "flag_emoji",
              "header": "",
              "cell": {
                "kind": "Text",
                "props": { "className": "text-xl" },
                "bindings": { "children": { "$ref": "row.flag_emoji" } }
              },
              "note": "Computed accessor reading through PlatformLanguage \u2192 geography::Country.emoji. Null for base languages that span many countries."
            },
            {
              "key": "bcp47_code",
              "header": "Code",
              "cell": {
                "kind": "Link",
                "propsExpr": "{ to: '/platform/languages/' + row.id, children: row.bcp47_code, className: 'font-mono text-xs' }"
              },
              "note": "The stable BCP 47 tag persisted on this row. Distinct from geography::Language.code (ISO-639-1) \u2014 e.g. `fr-CA` here vs `fr` there."
            },
            {
              "key": "name",
              "header": "Name",
              "note": "Computed accessor \u2192 geography::Language.name."
            },
            {
              "key": "native_name",
              "header": "Native",
              "note": "Computed accessor \u2192 geography::Language.native."
            },
            {
              "key": "direction",
              "header": "Dir",
              "cell": {
                "kind": "Chip",
                "props": { "size": "xs" },
                "bindings": {
                  "variant": { "$expr": "row.direction === 'rtl' ? 'warning' : 'neutral'" },
                  "children": { "$ref": "row.direction" }
                }
              },
              "note": "Computed accessor \u2192 geography::Language.is_rtl / dir."
            },
            {
              "key": "script_code",
              "header": "Script",
              "note": "ISO 15924 code stored on PlatformLanguage (the only display field genuinely additive over geography)."
            },
            {
              "key": "status",
              "header": "Status",
              "cell": {
                "kind": "View",
                "props": { "className": "flex items-center gap-1" },
                "children": [
                  {
                    "kind": "Chip",
                    "props": { "size": "xs", "variant": "success" },
                    "bindings": {
                      "hidden": { "$expr": "!row.is_active_on_platform" },
                      "children": "Active"
                    }
                  },
                  {
                    "kind": "Chip",
                    "props": { "size": "xs", "variant": "warning" },
                    "bindings": { "hidden": { "$expr": "!row.is_beta" }, "children": "Beta" }
                  },
                  {
                    "kind": "Chip",
                    "props": { "size": "xs", "variant": "neutral" },
                    "bindings": {
                      "hidden": { "$expr": "row.is_active_on_platform" },
                      "children": "Inactive"
                    }
                  }
                ]
              }
            }
          ],
          "bindings": { "rows": { "$ref": "platformLanguages" } }
        }
      ]
    }
  ]
}
