{
  "id": "academorix://modules/localization/analytics",
  "$version": 1,
  "title": "localization \u2014 product analytics",
  "sink": "segment",
  "consentTiers": ["essential", "functional", "analytics", "marketing"],
  "events": [
    {
      "name": "Locale Changed",
      "kind": "track",
      "consent_required": "functional",
      "properties": ["tenant_id", "user_id", "from_locale", "to_locale"],
      "description": "User changed their preferred locale."
    },
    {
      "name": "Tenant Locale Enabled",
      "kind": "track",
      "consent_required": "functional",
      "properties": ["tenant_id", "locale_code", "is_default"],
      "description": "Admin enabled a new locale on the tenant."
    },
    {
      "name": "Tenant Locale Disabled",
      "kind": "track",
      "consent_required": "functional",
      "properties": ["tenant_id", "locale_code"]
    },
    {
      "name": "Translation Bulk Job Started",
      "kind": "track",
      "consent_required": "functional",
      "properties": ["tenant_id", "kind", "driver", "target_locale_count"],
      "description": "Tenant admin kicked off a bulk translation."
    },
    {
      "name": "Translation Bulk Job Completed",
      "kind": "track",
      "consent_required": "functional",
      "properties": ["tenant_id", "kind", "duration_ms", "keys_translated", "keys_failed"]
    },
    {
      "name": "Translation Manually Overridden",
      "kind": "track",
      "consent_required": "functional",
      "properties": ["tenant_id", "locale_code", "namespace"]
    }
  ]
}
