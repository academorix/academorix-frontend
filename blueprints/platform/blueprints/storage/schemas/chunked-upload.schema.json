{
  "id": "academorix://modules/storage/schemas/chunked-upload",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "ChunkedUpload",
  "description": "In-flight multipart / tus.io state. Client initiates via POST /api/v1/files/chunked, uploads chunks against upload_url, and finalises when uploaded_bytes = total_size_bytes. Reconnect-safe: on client crash, GET the ChunkedUpload row and receive the ledger of uploaded chunks so only missing chunks need re-upload. State machine: initiating \u2192 uploading \u2192 finalizing \u2192 completed | aborted | expired.",
  "type": "object",
  "x-module": "storage",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "chunked_uploads",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "cup_",
    "incrementing": false,
    "model": "Academorix\\Storage\\Models\\ChunkedUpload",
    "interface": "Academorix\\Storage\\Contracts\\Data\\ChunkedUploadInterface",
    "implements": ["Academorix\\Storage\\Contracts\\Data\\ChunkedUploadInterface"],
    "traits": [
      "HasFactory",
      "HasUlids",
      "BelongsToTenant",
      "HasMetadata",
      "HasUserstamps",
      "Filterable",
      "SoftDeletes"
    ],
    "casts": {
      "state": "ChunkedUploadState",
      "total_size_bytes": "integer",
      "uploaded_bytes": "integer",
      "chunks": "array",
      "expires_at": "datetime",
      "initiated_at": "datetime",
      "finalized_at": "datetime",
      "metadata": "array"
    },
    "appends": ["progress_pct", "missing_chunks_count"],
    "observers": ["ChunkedUploadObserver"],
    "hidden": ["upload_url", "provider_upload_id"],
    "guarded": []
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": {
        "type": "string",
        "length": 64,
        "primary": true,
        "description": "Prefixed ULID: `cup_<26 chars>`."
      },
      "tenant_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "owner_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "users", "column": "id", "onDelete": "cascade" },
        "description": "In-flight uploads deleted on owner removal."
      },
      "target_kind": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "description": "The file kind this upload will resolve to. Enforces mime + max_size at chunk-upload time."
      },
      "target_fileable_type": {
        "type": "string",
        "length": 128,
        "nullable": true,
        "description": "Optional polymorphic parent. Nullable for standalone uploads."
      },
      "target_fileable_id": { "type": "string", "length": 64, "nullable": true },
      "protocol": {
        "type": "string",
        "length": 16,
        "nullable": false,
        "description": "Enum: `tus` (tus.io) or `s3_multipart`. Chosen based on driver + config."
      },
      "upload_url": {
        "type": "string",
        "length": 2048,
        "nullable": false,
        "description": "Provider-generated URL the client PATCHes / PUTs chunks against. NOT exposed on read; returned only on initiate."
      },
      "provider_upload_id": {
        "type": "string",
        "length": 255,
        "nullable": true,
        "description": "Provider-specific handle (S3 UploadId, tus resource id). Used by the coordinator to reconcile server-side state."
      },
      "filename": {
        "type": "string",
        "length": 500,
        "nullable": false,
        "description": "Client-declared filename. Preserved on the resulting File."
      },
      "declared_mime_type": {
        "type": "string",
        "length": 128,
        "nullable": false,
        "description": "Client-declared MIME. Verified against actual sniff on finalize."
      },
      "declared_sha256": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "description": "Client's expected SHA-256 of the full byte range. When set, finalize verifies + rejects on mismatch."
      },
      "total_size_bytes": {
        "type": "bigint",
        "nullable": false,
        "description": "Client-declared total bytes. Enforced against the file kind's max_size at initiate."
      },
      "uploaded_bytes": {
        "type": "bigint",
        "nullable": false,
        "default": 0,
        "description": "Sum of chunk sizes uploaded so far. Progress = uploaded_bytes / total_size_bytes."
      },
      "chunks": {
        "type": "jsonb",
        "nullable": false,
        "default": "'[]'::jsonb",
        "description": "Per-chunk ledger. Shape: [{index: int, size: int, sha256: string, etag: string | null, uploaded_at: iso8601}]. Written by the chunk-upload handler; read by the resume + finalize handlers."
      },
      "chunk_size_bytes": {
        "type": "integer",
        "nullable": false,
        "default": 5242880,
        "description": "Expected chunk size in bytes. Default 5MB. tus.io honours the server suggestion; S3 multipart enforces min 5MB except for the last chunk."
      },
      "state": {
        "type": "string",
        "length": 16,
        "nullable": false,
        "default": "'initiating'",
        "description": "Enum: initiating / uploading / finalizing / completed / aborted / expired."
      },
      "expires_at": {
        "type": "timestamptz",
        "nullable": false,
        "description": "TTL applied at initiate. Default 24h. Expired uploads are hard-deleted by PurgeAbortedChunkedUploadsJob."
      },
      "initiated_at": { "type": "timestamptz", "nullable": false },
      "finalized_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "Set when the state transitions to completed / aborted / expired."
      },
      "abort_reason": {
        "type": "string",
        "length": 128,
        "nullable": true,
        "description": "Populated on state=aborted. Enum: user_cancelled / expired / size_mismatch / sha256_mismatch / mime_mismatch / quota_exceeded / virus_found / provider_error."
      },
      "resulting_file_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": { "table": "files", "column": "id", "onDelete": "set null" },
        "description": "Set on successful finalize. NULL until then."
      },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_by": { "type": "uuid", "nullable": true },
      "updated_by": { "type": "uuid", "nullable": true },
      "deleted_by": { "type": "uuid", "nullable": true },
      "deleted_at": { "type": "timestamptz", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "owner_id", "state"],
        "unique": false,
        "name": "chunked_uploads_tenant_owner_state_idx"
      },
      {
        "columns": ["state", "expires_at"],
        "unique": false,
        "name": "chunked_uploads_state_expires_idx",
        "description": "PurgeAbortedChunkedUploadsJob sweep."
      },
      {
        "columns": ["provider_upload_id"],
        "unique": true,
        "name": "chunked_uploads_provider_unique",
        "predicate": "provider_upload_id IS NOT NULL",
        "description": "Ensures every provider handle maps to at most one row."
      }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "owner_id",
    "target_kind",
    "protocol",
    "upload_url",
    "filename",
    "declared_mime_type",
    "total_size_bytes",
    "uploaded_bytes",
    "chunks",
    "chunk_size_bytes",
    "state",
    "expires_at",
    "initiated_at",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^cup_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": "string", "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "owner_id": { "type": "string" },
    "target_kind": { "type": "string", "pattern": "^[a-z][a-z0-9_]{0,62}$" },
    "target_fileable_type": { "type": ["string", "null"] },
    "target_fileable_id": { "type": ["string", "null"] },
    "protocol": { "type": "string", "enum": ["tus", "s3_multipart"] },
    "upload_url": {
      "type": "string",
      "format": "uri",
      "description": "Only present in the response body of the initiate call; hidden on subsequent reads."
    },
    "provider_upload_id": { "type": ["string", "null"] },
    "filename": { "type": "string", "minLength": 1, "maxLength": 500 },
    "declared_mime_type": { "type": "string", "pattern": "^[a-z-]+/[a-z0-9.+-]+$" },
    "declared_sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "total_size_bytes": { "type": "integer", "minimum": 1 },
    "uploaded_bytes": { "type": "integer", "minimum": 0 },
    "chunks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["index", "size", "uploaded_at"],
        "properties": {
          "index": { "type": "integer", "minimum": 0 },
          "size": { "type": "integer", "minimum": 1 },
          "sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
          "etag": { "type": ["string", "null"] },
          "uploaded_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "chunk_size_bytes": {
      "type": "integer",
      "minimum": 262144,
      "maximum": 5368709120,
      "description": "256KB to 5GB. tus + S3 both cap at 5GB."
    },
    "state": {
      "type": "string",
      "enum": ["initiating", "uploading", "finalizing", "completed", "aborted", "expired"]
    },
    "expires_at": { "type": "string", "format": "date-time" },
    "initiated_at": { "type": "string", "format": "date-time" },
    "finalized_at": { "type": ["string", "null"], "format": "date-time" },
    "abort_reason": {
      "type": ["string", "null"],
      "enum": [
        null,
        "user_cancelled",
        "expired",
        "size_mismatch",
        "sha256_mismatch",
        "mime_mismatch",
        "quota_exceeded",
        "virus_found",
        "provider_error"
      ]
    },
    "resulting_file_id": { "type": ["string", "null"], "pattern": "^fil_[0-9A-HJKMNP-TV-Z]{26}$" },
    "progress_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Computed. uploaded_bytes / total_size_bytes * 100."
    },
    "missing_chunks_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Computed. Number of chunks the client still needs to upload."
    },
    "metadata": { "type": ["object", "null"] },
    "created_by": { "type": ["string", "null"] },
    "updated_by": { "type": ["string", "null"] },
    "deleted_by": { "type": ["string", "null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "deleted_at": { "type": ["string", "null"], "format": "date-time" }
  },
  "additionalProperties": false,
  "x-wire": {
    "envelope": "spatie-data",
    "wrap": "data",
    "mapper": "SnakeCaseMapper",
    "hidden": ["upload_url", "provider_upload_id", "created_by", "updated_by", "deleted_by"],
    "computed": ["progress_pct", "missing_chunks_count"],
    "notes": [
      "upload_url is HIDDEN on subsequent reads but INCLUDED on the initiate response (the only time the client legitimately needs it)."
    ]
  }
}
