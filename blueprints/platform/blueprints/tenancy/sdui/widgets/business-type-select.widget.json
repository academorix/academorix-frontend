{
  "id": "tenants.widgets.business-type-select",
  "title": "Business type select",
  "version": 1,
  "kind": "SduiWidget",
  "description": "Async Select bound to /api/v1/business-types. Each option renders with icon + terminology preview (e.g. `athletes` \u2192 `Students`). Used at tenant register + platform-admin tenant create.",
  "props": {
    "name": { "type": "string", "default": "business_type", "description": "Form field name." },
    "label": { "type": "string", "default": "Business type" },
    "isRequired": { "type": "boolean", "default": true },
    "defaultValue": { "type": "string", "description": "BusinessType key (e.g. 'academy', 'gym')." }
  },
  "dataSources": [
    {
      "name": "businessTypes",
      "kind": "http.get",
      "url": "/api/v1/business-types",
      "unwrap": "data",
      "cache": { "ttlSeconds": 3600 }
    }
  ],
  "nodes": [
    {
      "id": "select",
      "kind": "Select",
      "props": {
        "name": "props.name",
        "label": "props.label",
        "isRequired": "props.isRequired"
      },
      "bindings": {
        "defaultValue": { "$ref": "props.defaultValue" },
        "options": {
          "$expr": "businessTypes.map(bt => ({ key: bt.key, label: bt.display_name }))"
        },
        "isLoading": { "$ref": "businessTypes.isLoading" }
      },
      "itemRenderer": {
        "kind": "View",
        "props": { "className": "flex items-center gap-3 py-1" },
        "children": [
          {
            "kind": "Icon",
            "props": { "className": "size-5 text-muted" },
            "bindings": { "icon": { "$ref": "row.icon" } }
          },
          {
            "kind": "View",
            "props": { "className": "flex flex-col flex-1 min-w-0" },
            "children": [
              {
                "kind": "Text",
                "props": { "className": "text-sm font-medium" },
                "bindings": { "children": { "$ref": "row.display_name" } }
              },
              {
                "kind": "Text",
                "props": { "className": "text-xs text-muted truncate" },
                "bindings": {
                  "children": {
                    "$expr": "'Athletes \u2192 ' + (row.terminology?.athletes || 'Athletes') + ' \u00b7 Coaches \u2192 ' + (row.terminology?.coaches || 'Coaches')"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
