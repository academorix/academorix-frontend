{
  "id": "academorix://modules/tenancy/schemas/tenant-contact",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "TenantContact",
  "description": "Named contact per Tenant, per role. GDPR Art. 30 (Records of Processing) requires a legally-distinct Data Protection Officer contact; enterprise MSAs specify a legal-notice address; billing collects invoices at a different address. A single `owner_user_id` conflates roles that legally must be different people. This table separates them.",
  "type": "object",
  "x-module": "tenants",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "tenant_contacts",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "wct_",
    "incrementing": false,
    "model": "Academorix\\Tenancy\\Models\\TenantContact",
    "interface": "Academorix\\Tenancy\\Contracts\\Data\\TenantContactInterface",
    "implements": ["Academorix\\Tenancy\\Contracts\\Data\\TenantContactInterface"],
    "traits": [
      "HasFactory",
      "HasUlids",
      "BelongsToTenant",
      "HasMetadata",
      "HasUserstamps",
      "HasAuditable",
      "SoftDeletes"
    ],
    "casts": {
      "address": "array",
      "verified_at": "datetime",
      "is_primary": "boolean",
      "metadata": "array"
    },
    "appends": ["full_address"],
    "observers": ["TenantContactObserver"],
    "hidden": ["metadata"],
    "guarded": []
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 64, "primary": true },
      "tenant_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": {
          "table": "tenants",
          "column": "id",
          "onUpdate": "cascade",
          "onDelete": "cascade"
        }
      },
      "kind": {
        "type": "string",
        "length": 16,
        "nullable": false,
        "description": "Enum: `billing`, `legal`, `technical`, `dpo`, `security`, `support`, `owner`. `dpo` is required for GDPR-subject tenants."
      },
      "name": {
        "type": "string",
        "length": 200,
        "nullable": false,
        "description": "Person or team name (e.g. 'Aisha Rahman' or 'Data Protection Team')."
      },
      "email": { "type": "string", "length": 320, "nullable": false },
      "phone": { "type": "string", "length": 32, "nullable": true },
      "job_title": { "type": "string", "length": 200, "nullable": true },
      "address": {
        "type": "jsonb",
        "nullable": true,
        "description": "Structured address bag: `{line1, line2, city, region, postal_code, country_code}`."
      },
      "notes": { "type": "text", "nullable": true },
      "is_primary": {
        "type": "boolean",
        "nullable": false,
        "default": false,
        "description": "Exactly one primary per (tenant_id, kind) tuple. Enforced by partial unique index."
      },
      "verified_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "Email verification timestamp. Required for `legal` and `dpo` kinds before the tenant can be marked `active`."
      },
      "metadata": {
        "type": "jsonb",
        "nullable": true,
        "description": "Free-form platform notes on this contact — consent captures, review dates, escalation notes. From HasMetadata."
      },
      "created_by": { "type": "uuid", "nullable": true },
      "updated_by": { "type": "uuid", "nullable": true },
      "deleted_by": { "type": "uuid", "nullable": true },
      "deleted_at": { "type": "timestamptz", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "kind", "is_primary"],
        "unique": true,
        "name": "tenant_contacts_primary_unique",
        "predicate": "is_primary = TRUE AND deleted_at IS NULL"
      },
      {
        "columns": ["tenant_id", "kind"],
        "unique": false,
        "name": "tenant_contacts_tenant_kind_index"
      },
      {
        "columns": ["email"],
        "unique": false,
        "name": "tenant_contacts_email_index"
      }
    ]
  },
  "required": ["id", "tenant_id", "kind", "name", "email", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string", "pattern": "^wct_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": "string", "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "kind": {
      "type": "string",
      "enum": ["billing", "legal", "technical", "dpo", "security", "support", "owner"]
    },
    "name": { "type": "string", "minLength": 1, "maxLength": 200 },
    "email": { "type": "string", "format": "email", "maxLength": 320 },
    "phone": { "type": ["string", "null"], "maxLength": 32 },
    "job_title": { "type": ["string", "null"], "maxLength": 200 },
    "address": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "line1": { "type": "string" },
        "line2": { "type": ["string", "null"] },
        "city": { "type": "string" },
        "region": { "type": ["string", "null"] },
        "postal_code": { "type": ["string", "null"] },
        "country_code": { "type": "string", "pattern": "^[A-Z]{2}$" }
      },
      "required": ["line1", "city", "country_code"]
    },
    "notes": { "type": ["string", "null"] },
    "is_primary": { "type": "boolean", "default": false },
    "verified_at": { "type": ["string", "null"], "format": "date-time" },
    "full_address": { "type": ["string", "null"], "description": "Computed one-line address." },
    "metadata": { "type": ["object", "null"], "additionalProperties": true },
    "created_by": { "type": ["string", "null"], "format": "uuid" },
    "updated_by": { "type": ["string", "null"], "format": "uuid" },
    "deleted_by": { "type": ["string", "null"], "format": "uuid" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "deleted_at": { "type": ["string", "null"], "format": "date-time" }
  },
  "additionalProperties": false,
  "x-wire": {
    "envelope": "spatie-data",
    "wrap": "data",
    "mapper": "SnakeCaseMapper",
    "hidden": ["metadata", "created_by", "updated_by", "deleted_by"],
    "computed": ["full_address"]
  }
}
