{
  "$version": 1,
  "name": "credentials",
  "alias": "credentials",
  "namespace": "Stackra\\Credentials",
  "description": "NFC / RFID / QR credentials for physical check-in per blueprint §13.7. Ships THREE owned entities: `Credential` (per-holder registration — UID (MIFARE/NTAG) + polymorphic holder Athlete/Staff + status issued→active→lost/revoked→replaced), `Gate` (NFC/RFID reader per branch — label + last_heartbeat_at + physical location), `CheckinLog` (raw check-in event — UID + gate_id + timestamp; 2-second debounce; feeds sports/attendance via AttendanceIngestListener). SECURITY: NFC UID is CLONABLE and NOT SECRET — fine for attendance convenience, NEVER for payments or sensitive-area access. Pair with PIN or authenticated NTAG for higher assurance. Contract: Android NFC app → POST /attendance/checkin { uid, gate } → resolve to member → mark attendance (method=nfc).",
  "keywords": [
    "credentials",
    "nfc",
    "rfid",
    "wristband",
    "card",
    "checkin",
    "gate",
    "mifare",
    "ntag",
    "wave-2"
  ],
  "priority": 73,
  "providers": ["Stackra\\Credentials\\Providers\\CredentialsServiceProvider"],
  "files": [],
  "dependencies": [
    "foundation",
    "tenancy",
    "application",
    "user",
    "athlete",
    "staff",
    "branch",
    "attendance",
    "notifications"
  ],
  "extendedBy": [],
  "planned_consumers": ["digital-passes", "offline-sync", "ai"],
  "contributes": {
    "traits": ["HasCredential"],
    "attributes": [],
    "blueprints": ["credential", "gate", "checkin-log"],
    "middleware": ["credentials.rate-limit-checkin"],
    "events": [
      "CredentialIssued",
      "CredentialActivated",
      "CredentialLost",
      "CredentialRevoked",
      "CredentialReplaced",
      "CheckinRecorded",
      "CheckoutRecorded",
      "GateHeartbeatMissed"
    ],
    "policies": ["CredentialPolicy", "GatePolicy", "CheckinLogPolicy"],
    "hooks": ["DebounceCheckin", "ForwardCheckinToAttendance", "AlertOnGateHeartbeatMissed"],
    "commands": [
      "credentials:list",
      "credentials:issue",
      "credentials:revoke",
      "gates:list",
      "gates:heartbeat"
    ],
    "jobs": ["MonitorGateHeartbeatsJob", "PurgeStaleCheckinLogsJob"],
    "notifications": [
      "CredentialIssuedNotification",
      "CredentialLostNotification",
      "GateOfflineNotification"
    ],
    "broadcasts": ["tenant.{tenantId}.gates"],
    "observers": ["CredentialObserver", "GateObserver", "CheckinLogObserver"],
    "rules": ["valid_uid_format", "valid_credential_status", "one_active_credential_per_holder"],
    "casts": ["CredentialStatus", "CredentialKind"],
    "views": [],
    "lang": ["credentials"],
    "config": ["credentials"],
    "macros": [],
    "bindings": [
      "CredentialRepository",
      "GateHeartbeatMonitor",
      "CheckinDebouncer",
      "AttendanceIngestListener"
    ],
    "resources": ["credential", "gate", "checkin-log"]
  },
  "hosts": {
    "tenant": {
      "routes": [
        "POST /api/v1/attendance/checkin",
        "POST /api/v1/attendance/checkout",
        "GET /api/v1/credentials",
        "POST /api/v1/credentials",
        "GET /api/v1/credentials/{credential}",
        "POST /api/v1/credentials/{credential}/revoke",
        "POST /api/v1/credentials/{credential}/replace",
        "GET /api/v1/gates",
        "POST /api/v1/gates",
        "POST /api/v1/gates/{gate}/heartbeat"
      ]
    },
    "platform-admin": {
      "routes": ["GET /api/v1/platform/credentials", "GET /api/v1/platform/gates"]
    }
  }
}
