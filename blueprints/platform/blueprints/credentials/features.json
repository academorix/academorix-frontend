{
  "id": "academorix://modules/credentials/features",
  "$version": 1,
  "title": "credentials — feature keys",
  "features": [
    {
      "key": "credentials.core",
      "displayName": "Access credentials",
      "description": "Master feature — issue NFC/RFID/QR credentials + operate gates.",
      "defaultEnabled": false,
      "planTiers": ["medium", "enterprise"]
    },
    {
      "key": "credentials.nfc_tags",
      "displayName": "NFC tag credentials",
      "description": "13.56 MHz NFC-A tags (student wristbands / cards).",
      "defaultEnabled": false,
      "planTiers": ["medium", "enterprise"]
    },
    {
      "key": "credentials.rfid_tags",
      "displayName": "RFID tag credentials",
      "description": "125 kHz LF / 900 MHz UHF tags (long-range gates + parking). Enterprise.",
      "defaultEnabled": false,
      "planTiers": ["enterprise"]
    },
    {
      "key": "credentials.qr_codes",
      "displayName": "QR code credentials",
      "description": "Signed-JWT QR codes (wallet passes + printable badges).",
      "defaultEnabled": true,
      "planTiers": ["medium", "enterprise"]
    },
    {
      "key": "credentials.wallet_pass_integration",
      "displayName": "Apple/Google Wallet passes",
      "description": "Consumed via finance/digital-passes. Wallet Pass credentials linked to a WalletPass row.",
      "defaultEnabled": false,
      "planTiers": ["medium", "enterprise"]
    },
    {
      "key": "credentials.clone_detection",
      "displayName": "Clone-UID detection",
      "description": "Impossible-travel-time algorithm detects cloned NFC tags across gates. Enterprise + K-12 compliance.",
      "defaultEnabled": false,
      "planTiers": ["enterprise"]
    },
    {
      "key": "credentials.pin_multi_factor",
      "displayName": "PIN as second factor",
      "description": "Gate scans require PIN in addition to credential — for high-assurance use (medical clearance gates, payment gates). Enterprise.",
      "defaultEnabled": false,
      "planTiers": ["enterprise"]
    },
    {
      "key": "credentials.gate_offline_mode",
      "displayName": "Offline gate cache",
      "description": "Gate device caches credential registry for offline operation. Syncs when back online. Enterprise.",
      "defaultEnabled": false,
      "planTiers": ["enterprise"]
    }
  ]
}
