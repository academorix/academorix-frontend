{
  "id": "academorix://modules/credentials/events",
  "$version": 1,
  "title": "credentials — published events",
  "namespace": "Academorix\\Platform\\Credentials\\Events",
  "dispatchMode": "afterCommit",
  "description": "NFC/RFID + QR check-in substrate. Gate scans are HIGH-VOLUME on peak entry (200+ scans/hour per gate). Every scan forwards to sports/attendance via ForwardScanToAttendance hook; failed scans NEVER open the gate.",
  "events": [
    {
      "name": "CredentialIssued",
      "trigger": "New Credential row committed. Kind IN nfc_tag / rfid_tag / qr_code / wallet_pass. Serial + status='active'.",
      "consumers": [
        "audit::WriteToAuditLog",
        "activity::WriteToActivityLog",
        "notifications::NotifyCredentialIssued"
      ],
      "payload": {
        "credential_id": "ULID (cre_*)",
        "tenant_id": "ULID",
        "holder_type": "'athlete'|'staff'|'user'",
        "holder_id": "ULID",
        "kind": "'nfc_tag'|'rfid_tag'|'qr_code'|'wallet_pass'",
        "serial": "string",
        "issued_by_user_id": "ULID"
      }
    },
    {
      "name": "CredentialRevoked",
      "trigger": "status: active → revoked. Gate scans against the credential now fail.",
      "consumers": [
        "audit::WriteToAuditLog",
        "cache::InvalidateCredentialCache",
        "notifications::NotifyCredentialRevoked"
      ],
      "payload": {
        "credential_id": "ULID",
        "revoked_by_user_id": "ULID",
        "reason": "'lost'|'stolen'|'expired'|'holder_left'|'security'|'other'",
        "reason_note": "string|null"
      }
    },
    {
      "name": "CredentialLost",
      "trigger": "P1 event. Holder reported lost/stolen. Auto-triggers CredentialRevoked.",
      "consumers": ["audit::WriteToAuditLog", "jobs::AutoRevokeLostCredentialJob"],
      "payload": {
        "credential_id": "ULID",
        "reported_by_user_id": "ULID",
        "circumstances": "string"
      }
    },
    {
      "name": "GateScanAccepted",
      "trigger": "HIGH VOLUME. Valid credential scanned at gate. Forwarded to attendance module.",
      "consumers": [
        "attendance::ForwardScanToAttendance",
        "activity::WriteToActivityLog (sampled 10%)",
        "realtime::BroadcastGateActivity"
      ],
      "payload": {
        "scan_id": "ULID (gts_*)",
        "credential_id": "ULID",
        "gate_id": "ULID",
        "scanned_at": "ISO 8601",
        "device_id": "ULID"
      }
    },
    {
      "name": "GateScanRefused",
      "trigger": "P1 event. Scan failed — revoked / expired / cloned / unknown credential. Gate does NOT open.",
      "consumers": [
        "audit::WriteToAuditLog (retention 1yr)",
        "activity::WriteToActivityLog",
        "notifications::AlertOnRefusedScanRate",
        "realtime::BroadcastGateAlert"
      ],
      "payload": {
        "credential_id": "ULID|null",
        "gate_id": "ULID",
        "attempted_at": "ISO 8601",
        "reason_code": "'revoked'|'expired'|'unknown'|'wrong_tenant'|'cloned_uid_detected'|'holder_left'|'no_active_membership'|'safeguarding_hold'|'device_offline'|'invalid_signature'"
      }
    },
    {
      "name": "CloneUidDetected",
      "trigger": "P0 event. Same NFC UID scanned at two gates within impossible time window. Security incident.",
      "consumers": [
        "audit::WriteToAuditLog (retention 7yr)",
        "safeguarding::CreateSecurityIncident",
        "notifications::AlertSecurityOfficer",
        "jobs::AutoRevokeSuspectedCloneJob"
      ],
      "payload": {
        "credential_id": "ULID",
        "gate_a_id": "ULID",
        "gate_a_time": "ISO 8601",
        "gate_b_id": "ULID",
        "gate_b_time": "ISO 8601",
        "distance_km": "float",
        "min_travel_seconds_required": "int"
      }
    },
    {
      "name": "GateOnline",
      "trigger": "Gate device heartbeat received. status: offline → online.",
      "consumers": ["realtime::UpdateGateStatus"],
      "payload": { "gate_id": "ULID (gte_*)", "device_id": "ULID", "connected_at": "ISO 8601" }
    },
    {
      "name": "GateOffline",
      "trigger": "P1 event. Gate device stopped heartbeating. status: online → offline. Alert ops.",
      "consumers": ["audit::WriteToAuditLog", "notifications::AlertOpsGateOffline"],
      "payload": { "gate_id": "ULID", "device_id": "ULID", "last_seen_at": "ISO 8601" }
    },
    {
      "name": "GateConfigured",
      "trigger": "Gate settings updated (mode, allowed_credential_kinds, entry_rules).",
      "consumers": ["audit::WriteToAuditLog", "realtime::PushGateConfig"],
      "payload": {
        "gate_id": "ULID",
        "configured_by_user_id": "ULID",
        "mode": "'entry'|'exit'|'both'"
      }
    }
  ]
}
