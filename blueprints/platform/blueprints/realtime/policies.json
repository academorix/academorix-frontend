{
  "id": "stackra://modules/realtime/policies",
  "$version": 1,
  "title": "realtime — authorization policies",
  "description": "Two policies. Channel registration is admin-only (BroadcastChannel rows are seeded by boot scan). Subscription policy governs who can subscribe to which channel — the per-channel authorize callback is the OTHER gate.",
  "policies": [
    {
      "model": "BroadcastChannel",
      "class": "Stackra\\Realtime\\Policies\\BroadcastChannelPolicy",
      "abilities": [
        {
          "action": "viewAny",
          "permission": "realtime.channels.viewAny",
          "scope": "admin + owner"
        },
        { "action": "view", "permission": "realtime.channels.view" },
        {
          "action": "platformViewAny",
          "permission": "platform.realtime.channels.viewAny",
          "guard": "platform_admin"
        }
      ]
    },
    {
      "model": "BroadcastSubscription",
      "class": "Stackra\\Realtime\\Policies\\BroadcastSubscriptionPolicy",
      "abilities": [
        {
          "action": "viewAny",
          "permission": "realtime.subscriptions.viewAny",
          "scope": "user sees own subscriptions; admin sees tenant-wide"
        },
        { "action": "view", "permission": "realtime.subscriptions.view" },
        {
          "action": "platformViewAny",
          "permission": "platform.realtime.subscriptions.viewAny",
          "guard": "platform_admin"
        }
      ]
    }
  ]
}
