{
  "id": "academorix://modules/webhook/schemas/webhook-subscription",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "WebhookSubscription",
  "description": "One customer-registered subscription: destination (HTTPS URL / EventBridge / PubSub / mTLS) + events subscribed to + api_version pin + signing secret + rotation grace secret + rate limit + backoff strategy + auto-disable state. State machine: active \u2192 paused \u2192 disabled. Secret + secret_previous are `restricted` tier (encrypted at rest via AWS KMS).",
  "type": "object",
  "x-module": "webhook",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "webhook_subscriptions",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "wsub_",
    "incrementing": false,
    "model": "Academorix\\Webhook\\Models\\WebhookSubscription",
    "interface": "Academorix\\Webhook\\Contracts\\Data\\WebhookSubscriptionInterface",
    "implements": ["Academorix\\Webhook\\Contracts\\Data\\WebhookSubscriptionInterface"],
    "traits": [
      "HasFactory",
      "HasUlids",
      "HasStates",
      "HasSystemFlag",
      "BelongsToTenant",
      "BelongsToApplication",
      "HasMetadata",
      "HasUserstamps",
      "HasAuditable",
      "HasVersions",
      "Filterable",
      "Searchable",
      "SoftDeletes"
    ],
    "casts": {
      "state": "WebhookSubscriptionState",
      "events": "array",
      "destination_config": "DestinationConfigCast",
      "backoff_config": "BackoffConfigCast",
      "verify_ssl": "boolean",
      "compress_payload": "boolean",
      "is_system": "boolean",
      "consecutive_failure_last_at": "datetime",
      "secret_previous_expires_at": "datetime",
      "disabled_at": "datetime",
      "metadata": "array"
    },
    "appends": ["is_active", "is_paused", "is_disabled", "has_rotation_grace"],
    "observers": ["WebhookSubscriptionObserver"],
    "hidden": ["secret", "secret_previous", "metadata"],
    "guarded": [],
    "dontVersionFields": [
      "secret",
      "secret_previous",
      "consecutive_failure_count",
      "consecutive_failure_last_at",
      "updated_at"
    ],
    "keepOldVersions": 100,
    "encrypted": ["secret", "secret_previous"]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": {
        "type": "string",
        "length": 64,
        "primary": true,
        "description": "Prefixed ULID: `wsub_<26 chars>`."
      },
      "tenant_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": {
          "table": "tenants",
          "column": "id",
          "onUpdate": "cascade",
          "onDelete": "cascade"
        }
      },
      "application_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": {
          "table": "applications",
          "column": "id",
          "onUpdate": "cascade",
          "onDelete": "restrict"
        }
      },
      "name": {
        "type": "string",
        "length": 200,
        "nullable": false,
        "description": "Human label. Powers admin listings + audit reports."
      },
      "description": { "type": "text", "nullable": true },
      "destination": {
        "type": "string",
        "length": 32,
        "nullable": false,
        "default": "https",
        "description": "Destination driver name. Enum resolved at boot from WebhookDestinationRegistry. Ships: https, eventbridge, pubsub, mtls-https."
      },
      "destination_config": {
        "type": "jsonb",
        "nullable": false,
        "description": "Per-destination config. Validated on save via driver's Config validator. E.g. {url} for https; {region, event_bus_name, source} for eventbridge; {project_id, topic_name} for pubsub; {url, client_cert_path, client_key_path, ca_bundle_path} for mtls."
      },
      "events": {
        "type": "jsonb",
        "nullable": false,
        "default": "[]",
        "description": "Array of event names this subscription receives. Empty [] = catch-all (rare, admin only). Wildcards supported: 'invitation.*' matches all invitation events."
      },
      "api_version": {
        "type": "string",
        "length": 32,
        "nullable": true,
        "foreign": {
          "table": "api_versions",
          "column": "slug",
          "onUpdate": "cascade",
          "onDelete": "set null"
        },
        "description": "Pin to a specific ApiVersion for payload shape. Null = follow publisher's current version. Referenced version must be in state=released or deprecated at subscription create time."
      },
      "http_verb": {
        "type": "string",
        "length": 8,
        "nullable": false,
        "default": "POST",
        "description": "HTTPS destination only. Enum: POST, PUT, PATCH."
      },
      "state": {
        "type": "string",
        "length": 16,
        "nullable": false,
        "default": "active",
        "description": "spatie state: active, paused (manual), disabled (auto \u2014 410 / consecutive_failure_threshold)."
      },
      "secret": {
        "type": "text",
        "nullable": false,
        "description": "HMAC signing secret. AES-256 encrypted at rest via Laravel encrypted cast + KMS. Never returned by API responses (hidden array)."
      },
      "secret_previous": {
        "type": "text",
        "nullable": true,
        "description": "Rotation grace: previous secret during the grace window. Encrypted."
      },
      "secret_previous_expires_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "End of the rotation grace window. Nulled + secret_previous cleared when passed."
      },
      "timeout_seconds": { "type": "unsignedSmallInteger", "nullable": false, "default": 30 },
      "max_attempts": {
        "type": "unsignedSmallInteger",
        "nullable": false,
        "default": 5,
        "description": "Retries per delivery. Per-subscription override of config default."
      },
      "backoff_strategy": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "default": "static",
        "description": "BackoffStrategy name. Ships: static, retry-after-aware."
      },
      "backoff_config": {
        "type": "jsonb",
        "nullable": true,
        "description": "Per-strategy config. E.g. static: {seconds: [10, 60, 300, 900, 3600]}."
      },
      "rate_limit_per_minute": {
        "type": "unsignedInteger",
        "nullable": true,
        "description": "Requests/min per subscription. Null = unlimited. Enforced pre-dispatch."
      },
      "verify_ssl": {
        "type": "boolean",
        "nullable": false,
        "default": true,
        "description": "HTTPS destination only. False = skip cert verification (dev only)."
      },
      "compress_payload": {
        "type": "boolean",
        "nullable": false,
        "default": false,
        "description": "Gzip request body. Sets Content-Encoding: gzip."
      },
      "user_agent": {
        "type": "string",
        "length": 200,
        "nullable": false,
        "default": "Academorix-Webhook/1.0"
      },
      "filter_expression": {
        "type": "text",
        "nullable": true,
        "description": "Optional expression that receives event payload + returns bool. When present, evaluated per event; false = skip delivery. Uses symfony/expression-language. Empty = deliver everything matching the events array."
      },
      "consecutive_failure_count": {
        "type": "unsignedInteger",
        "nullable": false,
        "default": 0,
        "description": "Denormalised. Increments on every failure, resets on every success. When >= consecutive_failure_threshold, subscription auto-disables."
      },
      "consecutive_failure_last_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "Last failure time. Used for auto-disable-threshold decision + admin diagnostics."
      },
      "consecutive_failure_threshold": {
        "type": "unsignedSmallInteger",
        "nullable": false,
        "default": 30,
        "description": "Auto-disable when consecutive_failure_count reaches this. Per-subscription override of global config."
      },
      "disabled_at": { "type": "timestamptz", "nullable": true },
      "disabled_reason": {
        "type": "string",
        "length": 32,
        "nullable": true,
        "description": "Enum: gone_410, failure_threshold, manual, api_version_sunset, tenant_suspended."
      },
      "is_system": {
        "type": "boolean",
        "nullable": false,
        "default": false,
        "description": "Platform-seeded subscriptions (e.g. audit-log receiver for compliance module). is_system=true blocks tenant-side edits."
      },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_by": { "type": "uuid", "nullable": true },
      "updated_by": { "type": "uuid", "nullable": true },
      "deleted_by": { "type": "uuid", "nullable": true },
      "deleted_at": { "type": "timestamptz", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "state"],
        "unique": false,
        "name": "webhook_subscriptions_tenant_state_index",
        "description": "Primary read path: list active subscriptions for tenant on dispatch."
      },
      {
        "columns": ["state", "consecutive_failure_count"],
        "unique": false,
        "name": "webhook_subscriptions_failure_scan_index",
        "predicate": "state = 'active'",
        "description": "Scan for near-threshold subscriptions."
      },
      {
        "columns": ["api_version"],
        "unique": false,
        "name": "webhook_subscriptions_api_version_index"
      },
      {
        "columns": ["destination"],
        "unique": false,
        "name": "webhook_subscriptions_destination_index"
      },
      {
        "columns": ["secret_previous_expires_at"],
        "unique": false,
        "name": "webhook_subscriptions_rotation_scan_index",
        "predicate": "secret_previous IS NOT NULL",
        "description": "Scan for expired rotation grace windows to clear secret_previous."
      },
      {
        "columns": ["events"],
        "unique": false,
        "name": "webhook_subscriptions_events_gin_index",
        "type": "GIN",
        "description": "GIN index on the jsonb events array. Powers WebhookEventDispatcher fanout: events @> ['invitation.sent']."
      }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "name",
    "destination",
    "destination_config",
    "events",
    "http_verb",
    "state",
    "secret",
    "timeout_seconds",
    "max_attempts",
    "backoff_strategy",
    "verify_ssl",
    "compress_payload",
    "user_agent",
    "consecutive_failure_count",
    "consecutive_failure_threshold",
    "is_system",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^wsub_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": "string", "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "application_id": { "type": ["string", "null"], "pattern": "^app_[0-9A-HJKMNP-TV-Z]{26}$" },
    "name": { "type": "string", "maxLength": 200 },
    "description": { "type": ["string", "null"] },
    "destination": { "type": "string", "enum": ["https", "eventbridge", "pubsub", "mtls-https"] },
    "destination_config": { "type": "object", "additionalProperties": true },
    "events": { "type": "array", "items": { "type": "string" } },
    "api_version": { "type": ["string", "null"], "maxLength": 32 },
    "http_verb": { "type": "string", "enum": ["POST", "PUT", "PATCH"] },
    "state": { "type": "string", "enum": ["active", "paused", "disabled"] },
    "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 300 },
    "max_attempts": { "type": "integer", "minimum": 1, "maximum": 10 },
    "backoff_strategy": { "type": "string", "maxLength": 64 },
    "backoff_config": { "type": ["object", "null"], "additionalProperties": true },
    "rate_limit_per_minute": { "type": ["integer", "null"], "minimum": 1, "maximum": 100000 },
    "verify_ssl": { "type": "boolean" },
    "compress_payload": { "type": "boolean" },
    "user_agent": { "type": "string", "maxLength": 200 },
    "filter_expression": { "type": ["string", "null"] },
    "consecutive_failure_count": { "type": "integer", "minimum": 0 },
    "consecutive_failure_last_at": { "type": ["string", "null"], "format": "date-time" },
    "consecutive_failure_threshold": { "type": "integer", "minimum": 1, "maximum": 1000 },
    "disabled_at": { "type": ["string", "null"], "format": "date-time" },
    "disabled_reason": {
      "type": ["string", "null"],
      "enum": [
        "gone_410",
        "failure_threshold",
        "manual",
        "api_version_sunset",
        "tenant_suspended",
        null
      ]
    },
    "is_system": { "type": "boolean" },
    "is_active": { "type": "boolean", "description": "Computed. state === 'active'." },
    "is_paused": { "type": "boolean", "description": "Computed. state === 'paused'." },
    "is_disabled": { "type": "boolean", "description": "Computed. state === 'disabled'." },
    "has_rotation_grace": {
      "type": "boolean",
      "description": "Computed. secret_previous IS NOT NULL AND secret_previous_expires_at > now()."
    },
    "metadata": { "type": ["object", "null"], "additionalProperties": true },
    "created_by": { "type": ["string", "null"], "format": "uuid" },
    "updated_by": { "type": ["string", "null"], "format": "uuid" },
    "deleted_by": { "type": ["string", "null"], "format": "uuid" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "deleted_at": { "type": ["string", "null"], "format": "date-time" }
  },
  "additionalProperties": false,
  "x-wire": {
    "envelope": "spatie-data",
    "wrap": "data",
    "mapper": "SnakeCaseMapper",
    "hidden": ["secret", "secret_previous", "metadata", "created_by", "updated_by", "deleted_by"],
    "computed": ["is_active", "is_paused", "is_disabled", "has_rotation_grace"]
  }
}
