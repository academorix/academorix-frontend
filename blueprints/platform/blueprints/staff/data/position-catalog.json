{
  "$version": 1,
  "title": "Staff position catalog — canonical positions",
  "description": "Reference catalog of common staff positions. The `staff.position` column is FREE-TEXT (any string up to 128 chars), but this catalog is offered as auto-complete suggestions in the SDUI hire flow + used by the platform-side pay-equity signal to bucket positions for cross-tenant benchmarking. Tenants are free to author their own position titles — this catalog is a starting library, not a validation whitelist.",
  "bucket_mapping_note": "Analytics events use `position_bucket` (coaching / reception / management / support / other) instead of the raw position string to keep label cardinality bounded. Every entry here maps to exactly one bucket.",
