{
  "id": "academorix://modules/teams/errors",
  "$version": 1,
  "title": "teams — error codes",
  "namespace": "teams",
  "errors": [
    {
      "code": "TEAM_NOT_FOUND",
      "http": 404,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "teams.errors.team_not_found"
    },
    {
      "code": "TEAM_FEATURE_NOT_ENTITLED",
      "http": 402,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "teams.errors.team_feature_not_entitled",
      "description": "Tenant lacks the `teams` entitlement (unusual — every tier defaults on). Response includes upgrade CTA in meta.upgrade_url."
    },
    {
      "code": "TEAM_QUOTA_EXCEEDED",
