{
  "id": "teams.capacity-usage-bar",
  "title": "Team capacity usage bar",
  "version": 1,
  "kind": "SduiWidget",
  "description": "Progress bar showing team's active roster count against its capacity + waitlist. Warns visually when approaching capacity, refuses (via aria-live message) at cap. Never relies on colour alone — always shows numbers + a status text.",
  "props": {
    "active_count": { "type": "integer", "required": true },
    "capacity": {
      "type": "integer",
      "required": false,
      "description": "Null = no cap; renders 'unlimited' label."
    },
    "waitlist_size": {
      "type": "integer",
      "required": false,
      "description": "Optional waitlist beyond capacity."
    },
    "size": { "type": "string", "default": "md", "enum": ["sm", "md", "lg"] }
  },
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-1" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-center justify-between text-sm" },
          "children": [
            {
              "kind": "Text",
              "bindings": {
                "children": {
                  "$expr": "props.capacity ? props.active_count + ' of ' + props.capacity : props.active_count + ' members'"
                }
              }
            },
            {
              "kind": "Text",
              "props": { "className": "text-muted" },
              "bindings": {
                "hidden": { "$expr": "!props.capacity" },
                "children": {
                  "$expr": "props.active_count >= props.capacity ? (props.waitlist_size ? 'Full — waitlist open' : 'Full') : (props.capacity - props.active_count) + ' spots left'"
                }
              }
            }
          ]
        },
        {
          "kind": "ProgressBar",
          "bindings": {
            "value": {
              "$expr": "props.capacity ? (props.active_count / props.capacity) * 100 : 0"
            },
            "variant": {
              "$expr": "!props.capacity ? 'neutral' : (props.active_count >= props.capacity ? 'danger' : (props.active_count / props.capacity >= 0.9 ? 'warning' : 'success'))"
            }
          },
          "props": {
            "size": { "$ref": "props.size" },
            "hidden": { "$expr": "!props.capacity" }
          }
        },
        {
          "kind": "Text",
          "props": { "className": "text-xs text-muted", "aria-live": "polite" },
          "bindings": {
            "hidden": {
              "$expr": "!(props.active_count >= (props.capacity || 0) && props.waitlist_size)"
            },
            "children": { "$expr": "'Waitlist: up to ' + props.waitlist_size + ' more spots'" }
          }
        }
      ]
    }
  ]
}
