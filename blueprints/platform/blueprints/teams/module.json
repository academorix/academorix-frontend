{
  "$version": 1,
  "name": "teams",
  "alias": "teams",
  "namespace": "Academorix\\Teams",
  "description": "Group of humans practicing / playing / attending under a Branch. Sport-agnostic — a gym runs its classes as Teams, a school runs its cohorts as Teams, an academy runs its squads as Teams. Owns four tables: (1) `teams` — the aggregate (name + branch + optional season + optional age_group + optional sport_key label), (2) `team_members` — polymorphic roster row (member_type + member_id points at Athlete / Coach / Staff / User depending on business shape; polymorphic because the same roster shape serves academies, gyms, and schools), (3) `team_trials` — probationary-period tracking for prospective members trying out for the Team, (4) `event_teams` — Team's participation in an Event (event_id references Wave 3 `events` table; nullable pre-Wave-3). Every Team belongs to Tenant + Organization + Branch — Season + AgeGroup are optional labels populated when the tenant subscribes to the Wave 3 sports domain. Ships: Team model with hasMany members/trials/event-participations; polymorphic HasMember trait; team_slot entitlement (Small=10, Medium=100, Enterprise=null); TeamCapacityExceeded refusal on roster add; TeamMemberActiveInvariant nightly reconciler; PolymorphicTeamMemberResolver runtime helper.",
  "keywords": [
    "team",
    "teams",
    "squad",
    "class",
    "cohort",
    "group",
    "crew",
    "roster",
    "team-member",
    "trial",
    "tryout",
    "event-team",
    "participation",
    "coach",
    "captain",
    "jersey",
    "position",
    "capacity",
    "waitlist",
    "polymorphic",
    "age-eligibility",
    "gender-eligibility",
    "sport-agnostic",
    "tenant",
    "branch",
    "organization",
    "wave-2"
  ],
  "priority": 50,
  "providers": ["Academorix\\Teams\\Providers\\TeamsServiceProvider"],
  "files": [],
  "dependencies": [
    "foundation",
    "tenancy",
    "application",
    "organization",
    "region",
    "branch",
    "user",
    "entitlements"
  ],
  "extendedBy": [],
  "planned_consumers": [
    "sports (Wave 3 — Athlete + Coach + Season + AgeGroup + Event modules; will FK-constrain season_id / age_group_id / event_id + populate the polymorphic member_type='athlete' + 'coach' branches)",
    "finance (Wave 4 — trial fee payments + team-related invoicing)",
    "notifications (roster changes, trial reminders, schedule updates, coach changes)",
    "attendance (Wave 3 — session attendance is filtered by team.active_members())",
    "session (Wave 3 — Session composes ResourceBooking for a Team's practice slot)",
    "event (Wave 3 — Event.event_teams becomes the write-side FK for tournament participation)"
  ],
  "contributes": {
    "traits": [
      "BelongsToTeam",
      "HasTeamMembers",
      "HasTeamTrials",
      "HasEventParticipation",
      "PolymorphicTeamMember"
    ],
    "attributes": ["AsTeamListener", "AsTeamMemberListener", "AsTrialListener"],
    "blueprints": ["teams", "team_members", "team_trials", "event_teams"],
    "middleware": ["team.resolve_active"],
    "events": [
      "TeamCreated",
      "TeamUpdated",
      "TeamStatusChanged",
      "TeamCapacityChanged",
      "TeamScheduleChanged",
      "TeamCoachChanged",
      "TeamRegistrationOpened",
      "TeamRegistrationClosed",
      "TeamArchived",
      "TeamRestored",
      "TeamDeleted",
      "TeamMemberJoined",
      "TeamMemberLeft",
      "TeamMemberRoleChanged",
      "TeamMemberStatusChanged",
      "TeamMemberJerseyChanged",
      "TeamMemberPositionChanged",
      "TeamMemberSuspended",
      "TeamMemberInjured",
      "TrialScheduled",
      "TrialStarted",
      "TrialCompleted",
      "TrialConvertedToMember",
      "TrialRejected",
      "TrialNoShow",
      "TrialCancelled",
      "EventTeamRegistered",
      "EventTeamWithdrew",
      "EventTeamCheckedIn",
      "EventTeamResultRecorded"
    ],
    "policies": ["TeamPolicy", "TeamMemberPolicy", "TrialPolicy", "EventTeamPolicy"],
    "hooks": [
      "PreventTeamOrphansOnBranchClosed",
      "CascadeMembersOnTeamArchived",
      "PurgeTeamsForErasedTenant"
    ],
    "commands": [
      "team:list",
      "team:describe",
      "team:create",
      "team:set-default",
      "team:pause",
      "team:resume",
      "team:archive",
      "team:reopen-registration",
      "team:close-registration",
      "team-member:list",
      "team-member:add",
      "team-member:remove",
      "team-member:change-role",
      "team-member:mark-injured",
      "team-member:mark-graduated",
      "trial:list",
      "trial:schedule",
      "trial:complete",
      "trial:convert",
      "trial:reject",
      "trial:cancel",
      "event-team:list",
      "event-team:register",
      "event-team:withdraw",
      "event-team:check-in",
      "event-team:record-result"
    ],
    "jobs": [
      "ReconcileTeamMemberActiveInvariantJob",
      "CloseExpiredTrialsJob",
      "ConvertConfirmedTrialsJob",
      "NotifyTrialistPreTrialJob",
      "PurgeArchivedTeamsJob",
      "OpenClosePendingRegistrationsJob"
    ],
    "notifications": [
      "TeamMemberJoinedNotification",
      "TeamMemberLeftNotification",
      "TeamRegistrationOpeningNotification",
      "TeamScheduleChangedNotification",
      "TrialScheduledNotification",
      "TrialDecisionNotification",
      "TeamCoachChangedNotification"
    ],
    "broadcasts": [
      "tenant.{tenantId}.teams",
      "team.{teamId}.members",
      "team.{teamId}.trials"
    ],
    "observers": ["TeamObserver", "TeamMemberObserver", "TrialObserver", "EventTeamObserver"],
    "rules": [
      "valid_hex_color",
      "valid_e164_phone",
      "valid_url",
      "valid_gender_category",
      "valid_age_range",
      "valid_capacity",
      "valid_schedule_pattern",
      "valid_result_shape",
      "team_member_polymorphic_target_exists"
    ],
    "casts": [
      "TeamType",
      "TeamStatus",
      "CompetitiveLevel",
      "GenderCategory",
      "TeamMemberRole",
      "TeamMemberStatus",
      "TeamMemberLeftReason",
      "TrialType",
      "TrialStatus",
      "TrialPaymentStatus",
      "EventTeamParticipationType",
      "SchedulePattern",
      "EventResult"
    ],
    "views": [],
    "lang": ["teams"],
    "config": ["teams"],
    "macros": ["Request::activeTeam", "Request::activeTeamId"],
    "bindings": [
      "TeamRepository",
      "TeamMemberRepository",
      "TrialRepository",
      "EventTeamRepository",
      "TeamProvisioner",
      "PolymorphicTeamMemberResolver",
      "CapacityGate",
      "AgeEligibilityGate",
      "GenderEligibilityGate",
      "TrialToMemberConverter",
      "ScheduleEvaluator"
    ],
    "resources": ["team", "team-member", "team-trial", "event-team"]
  },
  "hosts": {
    "tenant": {
      "description": "Tenant-facing team catalogue + roster management + trial workflow + event participation. Every route requires the `teams` entitlement. Trial + event-team routes additionally require the tenant's tier to include those sub-features (`team_trials` and `team_event_participation` — Medium+).",
      "routes": [
        "GET /api/v1/teams",
        "POST /api/v1/teams",
        "GET /api/v1/teams/{team}",
        "PATCH /api/v1/teams/{team}",
        "DELETE /api/v1/teams/{team}",
        "POST /api/v1/teams/{team}/set-default",
        "POST /api/v1/teams/{team}/pause",
        "POST /api/v1/teams/{team}/resume",
        "POST /api/v1/teams/{team}/archive",
        "POST /api/v1/teams/{team}/reopen-registration",
        "POST /api/v1/teams/{team}/close-registration",
        "GET /api/v1/teams/{team}/schedule",
        "PATCH /api/v1/teams/{team}/schedule",
        "GET /api/v1/teams/{team}/roster",
        "GET /api/v1/teams/{team}/members",
        "POST /api/v1/teams/{team}/members",
        "GET /api/v1/teams/{team}/members/{member}",
        "PATCH /api/v1/teams/{team}/members/{member}",
        "DELETE /api/v1/teams/{team}/members/{member}",
        "POST /api/v1/teams/{team}/members/{member}/change-role",
        "POST /api/v1/teams/{team}/members/{member}/mark-injured",
        "POST /api/v1/teams/{team}/members/{member}/mark-graduated",
        "GET /api/v1/teams/{team}/trials",
        "POST /api/v1/teams/{team}/trials",
        "GET /api/v1/teams/{team}/trials/{trial}",
        "PATCH /api/v1/teams/{team}/trials/{trial}",
        "DELETE /api/v1/teams/{team}/trials/{trial}",
        "POST /api/v1/teams/{team}/trials/{trial}/complete",
        "POST /api/v1/teams/{team}/trials/{trial}/convert",
        "POST /api/v1/teams/{team}/trials/{trial}/reject",
        "POST /api/v1/teams/{team}/trials/{trial}/cancel",
        "GET /api/v1/teams/{team}/event-teams",
        "POST /api/v1/teams/{team}/event-teams",
        "GET /api/v1/teams/{team}/event-teams/{eventTeam}",
        "PATCH /api/v1/teams/{team}/event-teams/{eventTeam}",
