        "POST /api/v1/teams/{team}/event-teams/{eventTeam}/check-in",
        "POST /api/v1/teams/{team}/event-teams/{eventTeam}/record-result"
      ]
    },
    "platform-admin": {
      "description": "Cross-tenant read + force-close for support tooling.",
      "routes": [
        "GET /api/v1/platform/teams",
        "GET /api/v1/platform/teams/{team}",
        "POST /api/v1/platform/teams/{team}/force-close"
      ]
    }
  }
}
