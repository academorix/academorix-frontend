{
  "id": "facility.resources.facility.create",
  "title": "New facility",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/facilities/new",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "facility", "entity": "facility", "action": "create" },
  "requiresPermission": "facilities.create",
  "requiresEntitlement": "facilities",
  "dataSources": [
    {
      "name": "branches",
      "kind": "http.get",
      "url": "/api/v1/branches?filter[status]=active",
      "unwrap": "data",
      "cache": { "ttlSeconds": 300 }
    },
    {
      "name": "facilityTypeCatalog",
      "kind": "static",
      "path": "modules/facility/data/facility-type-catalog.json"
    },
    {
      "name": "availabilitySamples",
      "kind": "static",
      "path": "modules/facility/data/availability-samples.json"
    },
    {
      "name": "pricingExamples",
      "kind": "static",
      "path": "modules/facility/data/pricing-model-examples.json"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-6 p-6 max-w-3xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "children": [
            {
              "kind": "Text",
              "props": {
                "as": "h1",
                "className": "text-2xl font-semibold",
                "children": "New facility"
              }
            },
            {
              "kind": "Text",
              "props": {
                "className": "text-sm text-muted",
                "children": "Create a bookable resource inside one of your branches."
              }
            }
          ]
        },
        {
          "kind": "Wizard",
          "props": { "className": "w-full" },
          "steps": [
            {
              "id": "basics",
              "label": "Basics",
              "children": [
                {
                  "kind": "ComboBox",
                  "props": { "label": "Branch", "menuTrigger": "focus", "isRequired": true },
                  "bindings": { "items": { "$ref": "branches" } },
                  "form": { "field": "branch_id" }
                },
                {
                  "kind": "TextField",
                  "props": { "label": "Name", "placeholder": "Court 1 — Basketball", "isRequired": true },
                  "form": { "field": "name" }
                },
                {
                  "kind": "TextField",
                  "props": { "label": "Slug", "placeholder": "court-1-basketball", "helpText": "Auto-generated from name; edit to customise." },
                  "form": { "field": "slug" }
                },
                {
                  "kind": "TextArea",
                  "props": { "label": "Description", "placeholder": "Wooden floor, adjustable rims, three-point line" },
                  "form": { "field": "description" }
                },
                {
                  "kind": "ComboBox",
                  "props": { "label": "Facility type", "menuTrigger": "focus", "isRequired": true },
                  "bindings": { "items": { "$ref": "facilityTypeCatalog.types" } },
                  "form": { "field": "facility_type" }
                },
                {
                  "kind": "ComboBox",
                  "props": { "label": "Sport category", "menuTrigger": "focus", "helpText": "Leave empty for sport-agnostic facilities (rooms, studios)." },
                  "bindings": {
                    "items": {
                      "$expr": "facilityTypeCatalog.types.find(t => t.facility_type === form.facility_type)?.compatible_sports?.map(s => ({ id: s, label: s })) ?? []"
                    }
                  },
                  "form": { "field": "sport_category" }
                },
                {
                  "kind": "NumberField",
                  "props": { "label": "Capacity (persons)", "minValue": 1, "defaultValue": 1 },
                  "form": { "field": "capacity_persons" }
                }
              ]
            },
            {
              "id": "duration",
              "label": "Duration & slot",
              "children": [
                {
                  "kind": "NumberField",
                  "props": { "label": "Min booking duration (min)", "defaultValue": 60, "step": 15, "minValue": 15 },
                  "form": { "field": "min_booking_duration_minutes" }
                },
                {
                  "kind": "NumberField",
                  "props": { "label": "Max booking duration (min)", "defaultValue": 240, "step": 15, "minValue": 30 },
                  "form": { "field": "max_booking_duration_minutes" }
                },
                {
                  "kind": "ComboBox",
                  "props": { "label": "Slot step", "menuTrigger": "focus", "isRequired": true, "defaultSelectedKey": 30 },
                  "props_items": [
                    { "id": 15, "label": "15 min" },
                    { "id": 30, "label": "30 min" },
                    { "id": 60, "label": "1 hour" },
                    { "id": 120, "label": "2 hours" }
                  ],
                  "form": { "field": "booking_slot_step_minutes" }
                },
                {
                  "kind": "NumberField",
                  "props": { "label": "Advance booking window (days)", "defaultValue": 30, "minValue": 1, "maxValue": 365 },
                  "form": { "field": "advance_booking_window_days" }
                },
                {
                  "kind": "NumberField",
                  "props": { "label": "Cancellation notice (hours)", "defaultValue": 24, "minValue": 0, "maxValue": 168 },
                  "form": { "field": "cancellation_notice_hours" }
                }
              ]
            },
            {
              "id": "availability",
              "label": "Availability",
              "children": [
                {
                  "kind": "ComboBox",
                  "props": { "label": "Preset", "menuTrigger": "focus", "helpText": "Pick a preset then fine-tune below." },
                  "bindings": {
                    "items": { "$expr": "availabilitySamples.samples.map(s => ({ id: s.id, label: s.name }))" }
                  },
                  "actions": {
                    "onSelectionChange": {
                      "kind": "form.set",
                      "field": "availability_json",
                      "valueExpr": "availabilitySamples.samples.find(s => s.id === $selectedKey)?.availability_json"
                    }
                  }
                },
                {
                  "kind": "Widget",
                  "widget": "facility.availability-editor",
                  "props": {},
                  "form": { "field": "availability_json" }
                }
              ]
            },
            {
              "id": "pricing",
              "label": "Pricing",
              "children": [
                {
                  "kind": "ComboBox",
                  "props": { "label": "Pricing model", "menuTrigger": "focus", "isRequired": true, "defaultSelectedKey": "per_hour" },
                  "props_items": [
                    { "id": "per_hour", "label": "Per hour" },
                    { "id": "per_slot", "label": "Per slot (flat rate)" },
                    { "id": "per_person", "label": "Per person" },
                    { "id": "included_in_membership", "label": "Included in membership (no charge)" }
                  ],
                  "form": { "field": "pricing_json.model" }
                },
                {
                  "kind": "Widget",
                  "widget": "facility.pricing-tier-editor",
                  "props": {},
                  "bindings": {
                    "hidden": { "$expr": "form.pricing_json.model === 'included_in_membership'" }
                  },
                  "form": { "field": "pricing_json.tiers" }
                }
              ]
            }
          ],
          "actions": {
            "onSubmit": {
              "kind": "http.post",
              "url": "/api/v1/facilities",
              "bodyExpr": "form",
              "onSuccess": {
                "kind": "navigate",
                "toExpr": "'/tenant/facilities/' + $response.data.id"
              }
            }
          }
        }
      ]
    }
  ]
}
