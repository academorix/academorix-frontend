      "FacilityUpdated",
      "FacilityStatusChanged",
      "FacilityPricingUpdated",
      "FacilityBlackoutAdded",
      "FacilityBlackoutRemoved",
      "FacilityAvailabilityChanged",
      "FacilityRetired",
