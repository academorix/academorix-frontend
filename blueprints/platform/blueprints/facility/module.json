      "BookingCheckedIn",
      "DayPassIssued",
      "DayPassConsumed",
      "DayPassExpired",
      "DayPassRefunded",
      "PassIssued",
      "PassCreditConsumed",
      "PassExhausted",
      "PassExpired",
      "PassTransferred",
      "PassRevoked"
    ],
    "policies": ["FacilityPolicy", "ResourceBookingPolicy", "DayPassPolicy", "PassPolicy"],
    "hooks": [
