{
  "id": "academorix://modules/workflow/approvals/schemas/approval-decision",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "ApprovalDecision",
  "description": "Every approve/reject decision by an approver. Write-once — updates + deletes are refused with ApprovalSecurityViolation. approver_id MUST be in the parent requirement's resolved_approvers (three independent enforcement layers). request_ip_hash stored as SHA-256 (never plaintext). Retained forever per compliance — never redacted or purged except via parent-cascade on tenant erasure.",
  "type": "object",
  "x-module": "approvals",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "approval_decisions",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "apd_",
    "incrementing": false,
    "model": "Academorix\\Approval\\Models\\ApprovalDecision",
    "interface": "Academorix\\Approval\\Contracts\\Data\\ApprovalDecisionInterface",
    "implements": ["Academorix\\Approval\\Contracts\\Data\\ApprovalDecisionInterface"],
    "traits": ["HasFactory", "HasUlids", "BelongsToTenant", "HasMetadata", "Filterable"],
    "casts": {
      "decision": "ApprovalDecisionType",
      "decided_at": "datetime",
      "metadata": "array"
    },
    "appends": ["is_delegated"],
    "observers": ["ApprovalDecisionObserver"],
    "hidden": ["request_ip_hash"],
    "guarded": []
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 64, "primary": true, "description": "Prefixed ULID: `apd_<26>`." },
      "approval_requirement_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "approval_requirements", "column": "id", "onDelete": "cascade" }
      },
      "tenant_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "approver_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "users", "column": "id", "onDelete": "restrict" },
        "description": "MUST be in parent requirement.resolved_approvers. Enforced by observer + middleware + validation rule (three layers)."
      },
      "delegated_from_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": { "table": "users", "column": "id", "onDelete": "restrict" },
        "description": "Set when the approver was substituted via an active RoleDelegation. Null when the approver was the direct resolved user."
      },
      "decision": {
        "type": "string",
        "length": 16,
        "nullable": false,
        "description": "Enum: approve | reject."
      },
      "comment": {
        "type": "text",
        "nullable": true,
        "description": "Optional for approve; REQUIRED for reject (min 10 chars — SOC 2 evidence). Max 1000 chars."
      },
      "decided_at": { "type": "timestamptz", "nullable": false },
      "request_ip_hash": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "description": "SHA-256(request()->ip()). Never plaintext. Redacted on wire projection."
      },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["approval_requirement_id", "approver_id"],
        "unique": true,
        "name": "approval_decisions_composite_unique",
        "description": "One decision per approver per requirement. Guarantees the observer's caller_is_approver invariant."
      },
      {
        "columns": ["approval_requirement_id", "decision"],
        "unique": false,
        "name": "approval_decisions_quorum_eval_idx",
        "description": "QuorumEvaluator's scan path — count approves + rejects per requirement."
      },
      {
        "columns": ["approver_id", "decided_at"],
        "unique": false,
        "name": "approval_decisions_by_approver_idx",
        "description": "User::approvalsDecided() relation + 'my activity' feed."
      }
    ]
  },
  "required": ["id", "approval_requirement_id", "tenant_id", "approver_id", "decision", "decided_at", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string", "pattern": "^apd_[0-9A-HJKMNP-TV-Z]{26}$" },
    "approval_requirement_id": { "type": "string", "pattern": "^apr_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": "string", "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "approver_id": { "type": "string" },
    "delegated_from_id": { "type": ["string", "null"] },
    "decision": { "type": "string", "enum": ["approve", "reject"] },
    "comment": { "type": ["string", "null"], "maxLength": 1000 },
    "decided_at": { "type": "string", "format": "date-time" },
    "request_ip_hash": { "type": ["string", "null"] },
    "is_delegated": { "type": "boolean", "description": "Computed. delegated_from_id IS NOT NULL." },
    "metadata": { "type": ["object", "null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false,
  "x-wire": {
    "envelope": "spatie-data",
    "wrap": "data",
    "mapper": "SnakeCaseMapper",
    "computed": ["is_delegated"],
    "never_projected": ["request_ip_hash"]
  }
}
