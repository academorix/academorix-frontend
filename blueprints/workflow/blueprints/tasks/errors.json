    },
    {
      "code": "TASK_STATE_INVALID",
      "http": 409,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "tasks.errors.task_state_invalid"
    },
    {
      "code": "TASK_TERMINAL_STATE",
      "http": 409,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "tasks.errors.task_terminal",
      "description": "Cannot modify a completed or cancelled task."
    },
    {
      "code": "TASK_ASSIGNMENT_NOT_FOUND",
      "http": 404,
      "retryable": false,
      "user_facing": true,
