{
  "id": "academorix://modules/gateway/errors",
  "$version": 1,
  "title": "gateway — error codes",
  "namespace": "gateway",
  "errors": [
    { "code": "GATEWAY_NOT_FOUND", "http": 404, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "gateway.errors.not_found" },
    { "code": "GATEWAY_ALREADY_EXISTS", "http": 409, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "gateway.errors.already_exists", "description": "Tenant already has an active gateway configured for this provider. Deactivate the existing one first." },
    { "code": "GATEWAY_INVALID_CREDENTIALS", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "warn", "i18n_key": "gateway.errors.invalid_credentials", "description": "Provider rejected the credentials on connection test." },
    { "code": "GATEWAY_CONNECT_ACCOUNT_REQUIRED", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "gateway.errors.connect_account_required", "description": "mode=connect requires connect_account_id." },
    { "code": "GATEWAY_UNSUPPORTED_PROVIDER", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "gateway.errors.unsupported_provider", "description": "Provider is not yet supported by this Academorix version." },
    { "code": "GATEWAY_HAS_ACTIVE_METHODS", "http": 409, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "gateway.errors.has_active_methods", "description": "Cannot delete a gateway with active payment_methods. Deactivate methods first." },
    { "code": "PAYMENT_METHOD_NOT_FOUND", "http": 404, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "gateway.errors.payment_method_not_found" },
    { "code": "PAYMENT_METHOD_EXPIRED", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "gateway.errors.payment_method_expired", "description": "Card exp_month + exp_year in the past. Add a new method to continue." },
    { "code": "WEBHOOK_SIGNATURE_INVALID", "http": 401, "retryable": false, "user_facing": false, "audit_severity": "warn", "i18n_key": "gateway.errors.webhook_signature_invalid", "description": "HMAC verification failed. Never expose signature details to the caller." },
    { "code": "WEBHOOK_ALREADY_PROCESSED", "http": 200, "retryable": false, "user_facing": false, "audit_severity": "info", "i18n_key": "gateway.errors.webhook_already_processed", "description": "Idempotent no-op — the (tenant_id, provider, provider_event_id) tuple was seen before. Return 200 not 409 so the provider doesn't retry." },
    { "code": "WEBHOOK_MAX_RETRIES_EXCEEDED", "http": 500, "retryable": false, "user_facing": false, "audit_severity": "warn", "i18n_key": "gateway.errors.max_retries_exceeded", "description": "Retry ladder exhausted. Event moved to dead_letter status; ops must replay after fixing the root cause." }
  ]
}
