{
  "id": "membership.resources.membership-plan.list",
  "title": "Membership plans",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/membership-plans",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "membership", "entity": "membership-plan", "action": "list" },
  "requiresPermission": "membership_plans.viewAny",
  "dataSources": [
    { "name": "plans", "kind": "http.get", "url": "/api/v1/membership-plans", "unwrap": "data", "queryFromFilters": true },
    { "name": "branches", "kind": "http.get", "url": "/api/v1/branches?filter[is_active]=true", "unwrap": "data", "cache": { "ttlSeconds": 300 } },
    { "name": "age_groups", "kind": "http.get", "url": "/api/v1/age-groups", "unwrap": "data", "cache": { "ttlSeconds": 300 } },
    { "name": "plan_slot_entitlement", "kind": "http.get", "url": "/api/v1/entitlements/membership_plan_slot", "unwrap": "data" }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-7xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "kind": "View",
              "children": [
                { "kind": "Text", "props": { "as": "h1", "className": "text-2xl font-semibold", "children": "Membership plans" } },
                { "kind": "Text", "props": { "className": "text-sm text-muted", "children": "Your subscription catalog — the SKUs customers choose from at signup." } }
              ]
            },
            {
              "kind": "View",
              "props": { "className": "flex items-center gap-3" },
              "children": [
                {
                  "kind": "Widget",
                  "widget": "entitlements.entitlement-usage-bar",
                  "props": { "cap": { "$ref": "plan_slot_entitlement.value_cap" }, "used": { "$ref": "plan_slot_entitlement.value_used" }, "size": "sm", "label": "Plans in catalog" }
                },
                {
                  "kind": "Button",
                  "props": { "variant": "secondary", "leadingIcon": "document-duplicate", "children": "Start from template" },
                  "actions": { "onPress": { "kind": "modal.open", "modal": "membership.plan-template-picker" } },
                  "requiresPermission": "membership_plans.create"
                },
                {
                  "kind": "Button",
                  "props": { "variant": "primary", "leadingIcon": "plus", "children": "New plan" },
                  "actions": { "onPress": { "kind": "navigate", "to": "/tenant/membership-plans/create" } },
                  "bindings": { "disabled": { "$ref": "plan_slot_entitlement.is_exceeded" } },
                  "requiresPermission": "membership_plans.create"
                }
              ]
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "flex items-center gap-2 py-2 flex-wrap" },
          "children": [
            {
              "kind": "ComboBox",
              "props": { "label": "Branch", "menuTrigger": "focus", "className": "min-w-56" },
              "bindings": { "items": { "$ref": "branches" } },
              "actions": { "onSelectionChange": { "kind": "filter.set", "field": "branch_id", "valueExpr": "$selectedKey" } }
            },
            {
              "kind": "ComboBox",
              "props": { "label": "Age group", "menuTrigger": "focus", "className": "min-w-56" },
              "bindings": { "items": { "$ref": "age_groups" } },
              "actions": { "onSelectionChange": { "kind": "filter.set", "field": "age_group_id", "valueExpr": "$selectedKey" } }
            },
            {
              "kind": "Switch",
              "props": { "label": "Active only", "defaultSelected": true },
              "actions": { "onChange": { "kind": "filter.set", "field": "is_active", "valueExpr": "$value ? true : null" } }
            }
          ]
        },
        {
          "kind": "Table",
          "props": { "aria-label": "Plan catalog" },
          "bindings": { "rows": { "$ref": "plans" }, "isLoading": { "$ref": "plans.isLoading" } },
          "emptyState": {
            "kind": "View",
            "props": { "className": "text-center py-12" },
            "children": [
              { "kind": "Icon", "props": { "name": "rectangle-stack", "className": "size-12 mx-auto text-muted" } },
              { "kind": "Text", "props": { "className": "mt-4 text-lg font-medium", "children": "No plans yet" } },
              { "kind": "Text", "props": { "className": "mt-1 text-sm text-muted", "children": "Create your first plan to start capturing memberships." } }
            ]
          },
          "columns": [
            { "key": "name", "label": "Name", "renderer": { "kind": "Text", "props": { "className": "font-medium" }, "bindings": { "children": { "$ref": "row.name" } } } },
            {
              "key": "price",
              "label": "Price",
              "renderer": {
                "kind": "Text",
                "props": { "className": "tabular-nums font-semibold" },
                "bindings": { "childrenExpr": "$formatCurrency(row.price_cents, row.currency) + ' / ' + row.billing_interval" }
              }
            },
            {
              "key": "passes",
              "label": "Passes",
              "renderer": {
                "kind": "Text",
                "props": { "className": "text-sm" },
                "bindings": { "childrenExpr": "row.passes_per_period ? row.passes_per_period + ' per period' : 'Unlimited'" }
              }
            },
            {
              "key": "trial",
              "label": "Trial",
              "renderer": {
                "kind": "Text",
                "props": { "className": "text-sm" },
                "bindings": { "childrenExpr": "row.trial_days > 0 ? row.trial_days + ' days' : '—'" }
              }
            },
            {
              "key": "capacity",
              "label": "Capacity",
              "renderer": {
                "kind": "View",
                "props": { "className": "flex items-center gap-2 text-sm" },
                "children": [
                  {
                    "kind": "Text",
                    "props": { "className": "tabular-nums" },
                    "bindings": {
                      "childrenExpr": "row.max_active_members ? row.current_active_members + ' / ' + row.max_active_members : row.current_active_members + ' / ∞'"
                    }
                  },
                  {
                    "kind": "Chip",
                    "propsExpr": "{ size: 'xs', variant: 'danger' }",
                    "bindings": { "hidden": { "$expr": "!row.is_at_capacity" } },
                    "children": [{ "kind": "Text", "props": { "children": "Full" } }]
                  }
                ]
              }
            },
            {
              "key": "is_active",
              "label": "Active",
              "renderer": {
                "kind": "Chip",
                "propsExpr": "{ size: 'sm', variant: row.is_active ? 'success' : 'neutral' }",
                "children": [{ "kind": "Text", "propsExpr": "{ children: row.is_active ? 'Active' : 'Archived' }" }]
              }
            }
          ],
          "rowActions": { "onPress": { "kind": "navigate", "toExpr": "'/tenant/membership-plans/' + row.id" } }
        }
      ]
    }
  ]
}
