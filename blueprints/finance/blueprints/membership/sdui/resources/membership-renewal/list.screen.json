{
  "id": "membership.resources.membership-renewal.list",
  "title": "Membership renewals",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/memberships/renewals",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "membership", "entity": "membership-renewal", "action": "list" },
  "requiresPermission": "membership_renewals.viewAny",
  "dataSources": [
    { "name": "renewals", "kind": "http.get", "url": "/api/v1/membership-renewals", "unwrap": "data", "queryFromFilters": true }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-7xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "kind": "View",
              "children": [
                { "kind": "Text", "props": { "as": "h1", "className": "text-2xl font-semibold", "children": "Renewals" } },
                { "kind": "Text", "props": { "className": "text-sm text-muted", "children": "Every billing attempt — successes, failures, retries, and terminal outcomes. Append-only audit log." } }
              ]
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "flex items-center gap-2 py-2 flex-wrap" },
          "children": [
            {
              "kind": "ComboBox",
              "props": { "label": "Status", "menuTrigger": "focus", "className": "min-w-48" },
              "props_items": [
                { "id": "pending", "label": "Pending" },
                { "id": "attempting", "label": "Attempting" },
                { "id": "succeeded", "label": "Succeeded" },
                { "id": "failed_transient", "label": "Failed (retrying)" },
                { "id": "failed_permanent", "label": "Failed (terminal)" },
                { "id": "cancelled", "label": "Cancelled" }
              ],
              "actions": { "onSelectionChange": { "kind": "filter.set", "field": "status", "valueExpr": "$selectedKey" } }
            },
            {
              "kind": "ComboBox",
              "props": { "label": "Attempt", "menuTrigger": "focus", "className": "min-w-40" },
              "props_items": [
                { "id": "1", "label": "Attempt 1 (initial)" },
                { "id": "2", "label": "Attempt 2 (retry)" },
                { "id": "3", "label": "Attempt 3 (retry)" },
                { "id": "4", "label": "Attempt 4 (final)" }
              ],
              "actions": { "onSelectionChange": { "kind": "filter.set", "field": "attempt_number", "valueExpr": "$selectedKey" } }
            }
          ]
        },
        {
          "kind": "Table",
          "props": { "aria-label": "Renewals table" },
          "bindings": { "rows": { "$ref": "renewals" }, "isLoading": { "$ref": "renewals.isLoading" } },
          "emptyState": {
            "kind": "View",
            "props": { "className": "text-center py-12" },
            "children": [
              { "kind": "Icon", "props": { "name": "arrow-path", "className": "size-12 mx-auto text-muted" } },
              { "kind": "Text", "props": { "className": "mt-4 text-lg font-medium", "children": "No renewals" } }
            ]
          },
          "columns": [
            {
              "key": "membership",
              "label": "Membership",
              "renderer": {
                "kind": "Link",
                "propsExpr": "{ hrefExpr: '/tenant/memberships/' + row.membership_id }",
                "children": [
                  { "kind": "Text", "bindings": { "childrenExpr": "row.membership.athlete_display_name + ' — ' + row.membership.plan_display_name" } }
                ]
              }
            },
            {
              "key": "period_starts_at",
              "label": "Period",
              "renderer": {
                "kind": "Text",
                "props": { "className": "tabular-nums text-sm" },
                "bindings": { "childrenExpr": "$formatDate(row.period_starts_at, 'D MMM') + ' → ' + $formatDate(row.period_ends_at, 'D MMM YYYY')" }
              }
            },
            {
              "key": "attempt_number",
              "label": "Attempt",
              "renderer": {
                "kind": "Chip",
                "propsExpr": "{ size: 'sm', variant: row.attempt_number === 1 ? 'info' : row.attempt_number === 4 ? 'danger' : 'warning' }",
                "children": [{ "kind": "Text", "propsExpr": "{ children: '#' + row.attempt_number }" }]
              }
            },
            {
              "key": "status",
              "label": "Status",
              "renderer": {
                "kind": "Chip",
                "propsExpr": "{ size: 'sm', variant: row.status === 'succeeded' ? 'success' : row.status === 'failed_transient' ? 'warning' : row.status === 'failed_permanent' ? 'danger' : row.status === 'attempting' ? 'info' : 'neutral' }",
                "children": [{ "kind": "Text", "propsExpr": "{ children: row.status.replace('_', ' ') }" }]
              }
            },
            {
              "key": "amount",
              "label": "Amount",
              "renderer": {
                "kind": "Text",
                "props": { "className": "tabular-nums font-semibold" },
                "bindings": { "childrenExpr": "$formatCurrency(row.total_amount_cents, row.currency)" }
              }
            },
            {
              "key": "next_attempt_at",
              "label": "Next attempt",
              "renderer": {
                "kind": "Text",
                "props": { "className": "text-sm" },
                "bindings": {
                  "childrenExpr": "row.next_attempt_at ? $formatDate(row.next_attempt_at, 'D MMM YYYY') : '—'"
                }
              }
            },
            {
              "key": "failure_reason",
              "label": "Failure",
              "renderer": {
                "kind": "Text",
                "props": { "className": "text-xs text-danger-500 max-w-64 truncate" },
                "bindings": { "children": { "$ref": "row.failure_reason" }, "hidden": { "$expr": "!row.failure_reason" } }
              }
            }
          ]
        }
      ]
    }
  ]
}
