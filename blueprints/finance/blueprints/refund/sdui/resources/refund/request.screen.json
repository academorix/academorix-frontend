{
  "id": "refund.resources.refund.request",
  "title": "Request refund",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/refunds/new",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "refund", "entity": "refund", "action": "request" },
  "requiresPermission": "refunds.request",
  "requiresEntitlement": "refund_capture",
  "dataSources": [
    {
      "name": "eligible_payments",
      "kind": "http.get",
      "url": "/api/v1/payments/mine?filter[has_refundable_amount]=1&limit=50",
      "unwrap": "data",
      "condition": { "$expr": "auth.user.role === 'customer' || auth.user.role === 'member'" }
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-3xl mx-auto" },
      "children": [
        { "kind": "Text", "props": { "as": "h1", "className": "text-2xl font-semibold", "children": "Request a refund" } },
        { "kind": "Text", "props": { "className": "text-sm text-muted", "children": "Refunds are typically processed within 5-10 business days for card payments." } },
        {
          "kind": "Wizard",
          "props": { "id": "refund-request-wizard" },
          "steps": [
            {
              "id": "select-payment",
              "label": "Select payment",
              "children": [
                {
                  "kind": "ComboBox",
                  "props": { "label": "Payment", "menuTrigger": "focus", "placeholder": "Search payments..." },
                  "bindings": { "items": { "$ref": "eligible_payments" } },
                  "itemRenderer": {
                    "kind": "Text",
                    "bindings": {
                      "children": {
                        "$expr": "item.reference + ' — ' + formatCurrency(item.amount_cents, item.currency) + ' — ' + formatDate(item.processed_at, 'short')"
                      }
                    }
                  },
                  "actions": {
                    "onSelectionChange": { "kind": "form.set", "field": "payment_id", "valueExpr": "$selectedKey" }
                  }
                }
              ]
            },
            {
              "id": "amount-type",
              "label": "Amount + type",
              "children": [
                {
                  "kind": "NumberField",
                  "props": { "label": "Amount", "step": 0.01 },
                  "bindings": {
                    "maxValue": { "$expr": "getPaymentRefundableAmount(form.payment_id) / 100" },
                    "value": { "$ref": "form.amount_display" }
                  },
                  "actions": {
                    "onChange": { "kind": "form.set", "field": "amount_cents", "valueExpr": "Math.round($value * 100)" }
                  }
                },
                {
                  "kind": "RadioGroup",
                  "props": { "label": "Refund type" },
                  "children": [
                    {
                      "kind": "Radio",
                      "props": { "value": "full", "label": "Full refund", "description": "Refund the entire remaining amount." }
                    },
                    {
                      "kind": "Radio",
                      "props": { "value": "partial", "label": "Partial refund", "description": "Refund a specific amount." },
                      "bindings": { "hidden": { "$expr": "!hasEntitlement('refund_partial')" } }
                    },
                    {
                      "kind": "Radio",
                      "props": { "value": "prorated", "label": "Prorated refund", "description": "For cancelled memberships — refund the unused period." },
                      "bindings": { "hidden": { "$expr": "!hasEntitlement('refund_prorated')" } }
                    }
                  ],
                  "actions": {
                    "onChange": { "kind": "form.set", "field": "refund_type", "valueExpr": "$value" }
                  }
                },
                {
                  "kind": "Widget",
                  "widget": "refund.proration-preview",
                  "bindings": {
                    "hidden": { "$expr": "form.refund_type !== 'prorated'" },
                    "paymentId": { "$ref": "form.payment_id" },
                    "cancellationDate": { "$ref": "form.cancellation_date" }
                  }
                }
              ]
            },
            {
              "id": "reason",
              "label": "Reason",
              "children": [
                {
                  "kind": "Widget",
                  "widget": "refund.reason-picker",
                  "props": { "audience": "customer" },
                  "bindings": {
                    "value": { "$ref": "form.reason" }
                  },
                  "actions": {
                    "onSelectionChange": { "kind": "form.set", "field": "reason", "valueExpr": "$selectedKey" }
                  }
                },
                {
                  "kind": "TextArea",
                  "props": { "label": "Reason detail", "placeholder": "Tell us more about why you're requesting this refund..." },
                  "bindings": { "value": { "$ref": "form.reason_note" } },
                  "actions": { "onChange": { "kind": "form.set", "field": "reason_note", "valueExpr": "$value" } }
                }
              ]
            },
            {
              "id": "refunded-to",
              "label": "Refund destination",
              "children": [
                {
                  "kind": "RadioGroup",
                  "props": { "label": "Refund to" },
                  "children": [
                    { "kind": "Radio", "props": { "value": "original_payment_method", "label": "Original payment method (recommended)" } },
                    { "kind": "Radio", "props": { "value": "customer_balance", "label": "Store credit (customer balance)" } }
                  ],
                  "actions": {
                    "onChange": { "kind": "form.set", "field": "refunded_to", "valueExpr": "$value" }
                  }
                }
              ]
            },
            {
              "id": "review",
              "label": "Review",
              "children": [
                {
                  "kind": "Alert",
                  "props": { "variant": "info" },
                  "bindings": {
                    "hidden": { "$expr": "!(form.amount_cents > getConfig('refund.approval.threshold_amount_cents') || hasStaleThreshold(form.payment_id))" }
                  },
                  "children": [
                    { "kind": "Text", "props": { "className": "font-medium", "children": "Approval required" } },
                    { "kind": "Text", "props": { "children": "This refund requires approval based on the amount or age. You'll be notified once an admin reviews it." } }
                  ]
                },
                {
                  "kind": "DescriptionList",
                  "bindings": {
                    "items": {
                      "$expr": "[{ label: 'Payment', value: form.payment_id }, { label: 'Amount', value: formatCurrency(form.amount_cents, form.currency) }, { label: 'Type', value: form.refund_type }, { label: 'Reason', value: form.reason }, { label: 'Refunded to', value: form.refunded_to }]"
                    }
                  }
                },
                {
                  "kind": "Button",
                  "props": { "variant": "primary", "children": "Request refund" },
                  "actions": {
                    "onPress": {
                      "kind": "http.post",
                      "url": "/api/v1/refunds",
                      "body": { "$ref": "form" },
                      "onSuccess": {
                        "kind": "navigate",
                        "toExpr": "'/tenant/refunds/' + response.data.id"
                      }
                    }
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
