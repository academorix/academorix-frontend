{
  "id": "invoice.resources.invoice.view",
  "title": "Invoice detail",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/invoices/{invoice_id}",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "invoice", "entity": "invoice", "action": "view" },
  "requiresPermission": "invoice.invoices.view",
  "requiresEntitlement": "invoice_capture",
  "dataSources": [
    {
      "name": "invoice",
      "kind": "http.get",
      "urlExpr": "'/api/v1/invoices/' + $route.invoice_id",
      "unwrap": "data"
    },
    {
      "name": "lines",
      "kind": "http.get",
      "urlExpr": "'/api/v1/invoices/' + $route.invoice_id + '/lines'",
      "unwrap": "data"
    },
    {
      "name": "credit_notes",
      "kind": "http.get",
      "url": "/api/v1/credit-notes",
      "unwrap": "data",
      "queryFromValues": { "original_invoice_id": "$route.invoice_id" }
    },
    {
      "name": "audit_trail",
      "kind": "http.get",
      "urlExpr": "'/api/v1/audit-trail/invoice/' + $route.invoice_id",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-6 p-6 max-w-5xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "kind": "View",
              "children": [
                {
                  "kind": "View",
                  "props": { "className": "flex items-center gap-3" },
                  "children": [
                    { "kind": "Text", "props": { "as": "h1", "className": "text-2xl font-semibold" }, "bindings": { "children": { "$ref": "invoice.invoice_number" } } },
                    { "kind": "Widget", "widget": "invoice.invoice-status-chip", "bindings": { "status": { "$ref": "invoice.status" } } }
                  ]
                },
                {
                  "kind": "View",
                  "props": { "className": "flex items-center gap-4 mt-1 text-sm text-muted" },
                  "children": [
                    { "kind": "Text", "props": { "children": "Issued " }, "children_ref": { "$ref": "invoice.issue_date" } },
                    { "kind": "Text", "props": { "children": " · " } },
                    { "kind": "Widget", "widget": "invoice.payment-terms-badge", "bindings": { "invoice": { "$ref": "invoice" } } }
                  ]
                }
              ]
            },
            {
              "kind": "View",
              "props": { "className": "flex items-center gap-2" },
              "children": [
                {
                  "kind": "Button",
                  "props": { "variant": "secondary", "children": "View PDF", "icon": "document-arrow-down" },
                  "actions": { "onPress": { "kind": "http.get", "urlExpr": "'/api/v1/invoices/' + $route.invoice_id + '/pdf'", "openInNewTab": true } }
                },
                {
                  "kind": "Button",
                  "props": { "variant": "primary", "children": "Finalize" },
                  "visibleWhen": "invoice.status == 'draft'",
                  "requiresPermission": "invoice.invoices.finalize",
                  "actions": {
                    "onPress": {
                      "kind": "http.post",
                      "urlExpr": "'/api/v1/invoices/' + $route.invoice_id + '/finalize'",
                      "confirm": { "title": "Finalize invoice?", "message": "This freezes totals + generates the PDF + sends to customer. Cannot be undone." }
                    }
                  }
                },
                {
                  "kind": "Button",
                  "props": { "variant": "secondary", "children": "Send" },
                  "visibleWhen": "invoice.status == 'open' && !invoice.sent_at",
                  "requiresPermission": "invoice.invoices.send",
                  "actions": {
                    "onPress": { "kind": "http.post", "urlExpr": "'/api/v1/invoices/' + $route.invoice_id + '/send'" }
                  }
                },
                {
                  "kind": "Button",
                  "props": { "variant": "secondary", "children": "Resend" },
                  "visibleWhen": "invoice.status IN ['open', 'partially_paid', 'pastdue']",
                  "requiresPermission": "invoice.invoices.resend",
                  "actions": {
                    "onPress": { "kind": "http.post", "urlExpr": "'/api/v1/invoices/' + $route.invoice_id + '/resend'" }
                  }
                },
                {
                  "kind": "Button",
                  "props": { "variant": "danger", "children": "Void" },
                  "visibleWhen": "invoice.status IN ['draft', 'open', 'partially_paid'] && invoice.amount_paid_cents == 0",
                  "requiresPermission": "invoice.invoices.void",
                  "actions": {
                    "onPress": {
                      "kind": "modal.open",
                      "modal": "invoice.void-dialog",
                      "bindings": { "invoice_id": "$route.invoice_id" }
                    }
                  }
                },
                {
                  "kind": "Button",
                  "props": { "variant": "secondary", "children": "Issue credit note" },
                  "visibleWhen": "invoice.status IN ['paid', 'partially_paid', 'refunded', 'disputed', 'written_off']",
                  "requiresPermission": "invoice.credit-notes.create",
                  "actions": {
                    "onPress": { "kind": "navigate", "toExpr": "'/tenant/credit-notes/create?original_invoice_id=' + $route.invoice_id" }
                  }
                }
              ]
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "grid grid-cols-2 gap-6" },
          "children": [
            {
              "kind": "Card",
              "props": { "title": "Bill to" },
              "children": [
                { "kind": "Text", "props": { "className": "font-medium" }, "bindings": { "children": { "$ref": "invoice.billing_address.name" } } },
                { "kind": "Text", "props": { "className": "text-sm" }, "bindings": { "children": { "$ref": "invoice.billing_address.street" } } },
                { "kind": "Text", "props": { "className": "text-sm text-muted" }, "bindings": { "children": { "$expr": "invoice.billing_address.city + ', ' + invoice.billing_address.postal_code + ' ' + invoice.billing_address.country" } } },
                { "kind": "Text", "props": { "className": "text-sm text-muted" }, "bindings": { "children": { "$ref": "invoice.billing_address.email" } } }
              ]
            },
            {
              "kind": "Card",
              "props": { "title": "Invoice details" },
              "children": [
                { "kind": "DefinitionList", "props": {
                  "items": [
                    { "label": "Series", "valueRef": "invoice.invoice_series" },
                    { "label": "Payment terms", "valueRef": "invoice.payment_terms" },
                    { "label": "Currency", "valueRef": "invoice.currency" },
                    { "label": "Customer tax ID", "valueRef": "invoice.customer_tax_id", "visibleWhen": "invoice.customer_tax_id != null" }
                  ]
                } }
              ]
            }
          ]
        },
        {
          "kind": "Card",
          "props": { "title": "Line items" },
          "children": [
            {
              "kind": "DataGrid",
              "bindings": {
                "items": { "$ref": "lines" },
                "isLoading": { "$ref": "lines.isLoading" }
              },
              "props": {
                "className": "w-full",
                "columns": [
                  { "field": "line_number", "label": "#", "width": 60 },
                  { "field": "description", "label": "Description", "width": 380 },
                  { "field": "item_type", "label": "Type", "width": 140 },
                  { "field": "quantity", "label": "Qty", "width": 80, "align": "right" },
                  { "field": "unit_price_cents", "label": "Unit price", "width": 120, "renderer": { "kind": "Text", "formatter": "currency", "currencyField": "unit_currency", "align": "right" } },
                  { "field": "tax_amount_cents", "label": "Tax", "width": 100, "renderer": { "kind": "Text", "formatter": "currency", "currencyField": "unit_currency", "align": "right" } },
                  { "field": "total_cents", "label": "Total", "width": 120, "renderer": { "kind": "Text", "formatter": "currency", "currencyField": "unit_currency", "align": "right" } }
                ]
              }
            },
            {
              "kind": "View",
              "props": { "className": "flex justify-end mt-4" },
              "children": [
                {
                  "kind": "DefinitionList",
                  "props": {
                    "align": "right",
                    "items": [
                      { "label": "Subtotal", "valueRef": "invoice.subtotal_cents", "formatter": "currency", "currencyField": "invoice.currency" },
                      { "label": "Discount", "valueRef": "invoice.discount_amount_cents", "formatter": "currency", "currencyField": "invoice.currency", "visibleWhen": "invoice.discount_amount_cents > 0" },
                      { "label": "Tax", "valueRef": "invoice.tax_amount_cents", "formatter": "currency", "currencyField": "invoice.currency" },
                      { "label": "Total", "valueRef": "invoice.total_cents", "formatter": "currency", "currencyField": "invoice.currency", "emphasized": true },
                      { "label": "Amount paid", "valueRef": "invoice.amount_paid_cents", "formatter": "currency", "currencyField": "invoice.currency" },
                      { "label": "Amount due", "valueRef": "invoice.amount_due_cents", "formatter": "currency", "currencyField": "invoice.currency", "emphasized": true }
                    ]
                  }
                }
              ]
            }
          ]
        },
        {
          "kind": "Card",
          "props": { "title": "Credit notes" },
          "visibleWhen": "credit_notes.length > 0",
          "children": [
            {
              "kind": "DataGrid",
              "bindings": { "items": { "$ref": "credit_notes" } },
              "props": {
                "columns": [
                  { "field": "credit_note_number", "label": "Number", "width": 160 },
                  { "field": "reason", "label": "Reason", "width": 140 },
                  { "field": "amount_cents", "label": "Amount", "width": 120, "renderer": { "kind": "Text", "formatter": "currency", "currencyField": "currency", "align": "right" } },
                  { "field": "status", "label": "Status", "width": 100 },
                  { "field": "issue_date", "label": "Issued", "width": 120, "formatter": "date" }
                ],
                "onRowPress": {
                  "kind": "navigate",
                  "toExpr": "'/tenant/credit-notes/' + row.id"
                }
              }
            }
          ]
        },
        {
          "kind": "Card",
          "props": { "title": "Activity" },
          "children": [
            {
              "kind": "Timeline",
              "bindings": { "items": { "$ref": "audit_trail" } },
              "props": {
                "iconResolver": "invoice.audit-icon",
                "titleField": "action_display",
                "subtitleField": "actor_display",
                "timestampField": "created_at",
                "detailField": "changes_summary"
              }
            }
          ]
        }
      ]
    }
  ]
}
