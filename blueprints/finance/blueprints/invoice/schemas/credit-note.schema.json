{
  "id": "academorix://modules/invoice/schemas/credit-note",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "CreditNote",
  "description": "Reversal invoice for refunds/adjustments/write-offs. Belongs to `Tenant` + `Invoice` (RESTRICT via original_invoice_id). IMMUTABLE after issuance — every field except status + applied_to_* + pdf_url is frozen. NO SoftDeletes — hard-deleted only via TenantErased FK CASCADE (after compliance archive). Retained INDEFINITELY. NEVER carries `application_id`, `region_id`, `organization_id`, `branch_id`, or `scope_node_id`.",
  "type": "object",
  "x-module": "invoice",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "credit_notes",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "crn_",
    "incrementing": false,
    "model": "Academorix\\Finance\\Invoice\\Models\\CreditNote",
    "interface": "Academorix\\Finance\\Invoice\\Contracts\\Data\\CreditNoteInterface",
    "implements": ["Academorix\\Finance\\Invoice\\Contracts\\Data\\CreditNoteInterface"],
    "traits": [
      "HasFactory",
      "HasUlids",
      "BelongsToTenant",
      "BelongsToInvoice",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "HasActivityLog",
      "Filterable",
      "Searchable"
    ],
    "casts": {
      "status": "CreditNoteStatus",
      "reason": "CreditNoteReason",
      "amount_cents": "integer",
      "tax_amount_cents": "integer",
      "issue_date": "date",
      "applied_at": "datetime",
      "voided_at": "datetime"
    },
    "observers": ["CreditNoteObserver"],
    "appends": ["is_immutable"]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": {
        "type": "string",
        "length": 64,
        "primary": true,
        "description": "Prefixed ULID: `crn_<26>`."
      },
      "tenant_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "credit_note_number": {
        "type": "string",
        "length": 32,
        "nullable": false,
        "description": "Sequential per tenant per year. Format: 'CN-{YYYY}-{seq:06}'. Generated via Postgres advisory lock."
      },
      "original_invoice_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "invoices", "column": "id", "onDelete": "restrict" },
        "description": "The paid invoice this credit note reverses. RESTRICT — invoices cannot be hard-deleted while credit notes reference them."
      },
      "reason": {
        "type": "string",
        "length": 48,
        "nullable": false,
        "description": "Enum: refund / adjustment / write_off / duplicate / customer_dispute_resolved / accounting_correction."
      },
      "reason_note": {
        "type": "text",
        "nullable": true,
        "description": "Free-form explanation. Required when reason IN ('adjustment', 'customer_dispute_resolved', 'accounting_correction')."
      },
      "amount_cents": {
        "type": "bigint",
        "nullable": false,
        "description": "Always POSITIVE. Represents the credit issued back to the customer."
      },
      "currency": {
        "type": "string",
        "length": 3,
        "nullable": false,
        "description": "Must match original_invoice.currency."
      },
      "tax_amount_cents": {
        "type": "bigint",
        "nullable": false,
        "default": 0,
        "description": "Proportional tax reversal: (amount_cents / original_invoice.total_cents) × original_invoice.tax_amount_cents. Rounded via bankers'."
      },
      "issue_date": {
        "type": "date",
        "nullable": false,
        "description": "Frozen at creation. Never mutated."
      },
      "issued_by_user_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "users", "column": "id", "onDelete": "restrict" },
        "description": "The admin who issued. RESTRICT for audit integrity."
      },
      "applied_to_type": {
        "type": "string",
        "length": 96,
        "nullable": true,
        "description": "Polymorphic target when applied: refund::Refund / invoice::Invoice / user::UserBalance."
      },
      "applied_to_id": { "type": "string", "length": 64, "nullable": true },
      "pdf_url": {
        "type": "string",
        "length": 512,
        "nullable": true,
        "description": "Signed S3 URL to the credit-note PDF. Regenerated per viewer request."
      },
      "status": {
        "type": "string",
        "length": 24,
        "nullable": false,
        "default": "'draft'",
        "description": "Enum: draft / issued / applied / voided."
      },
      "applied_at": { "type": "timestamptz", "nullable": true },
      "voided_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "Set only when status transitions draft → voided. issued/applied credit notes are IMMUTABLE."
      },
      "void_reason": { "type": "string", "length": 256, "nullable": true },
      "created_by": { "type": "string", "length": 64, "nullable": true },
      "updated_by": { "type": "string", "length": 64, "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "credit_note_number"],
        "unique": true,
        "name": "credit_notes_tenant_number_unique"
      },
      {
        "columns": ["tenant_id", "original_invoice_id"],
        "name": "credit_notes_original_invoice_idx"
      },
      {
        "columns": ["tenant_id", "status", "issue_date"],
        "name": "credit_notes_status_recent_idx"
      },
      {
        "columns": ["applied_to_type", "applied_to_id"],
        "name": "credit_notes_applied_to_idx",
        "predicate": "applied_to_id IS NOT NULL"
      }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "credit_note_number",
    "original_invoice_id",
    "reason",
    "amount_cents",
    "currency",
    "tax_amount_cents",
    "issue_date",
    "issued_by_user_id",
    "status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^crn_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": "string", "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "credit_note_number": { "type": "string", "pattern": "^CN-[0-9]{4}-[0-9]{6}$" },
    "original_invoice_id": { "type": "string", "pattern": "^ivc_[0-9A-HJKMNP-TV-Z]{26}$" },
    "reason": {
      "type": "string",
      "enum": [
        "refund",
        "adjustment",
        "write_off",
        "duplicate",
        "customer_dispute_resolved",
        "accounting_correction"
      ]
    },
    "reason_note": { "type": ["string", "null"] },
    "amount_cents": { "type": "integer", "exclusiveMinimum": 0 },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "tax_amount_cents": { "type": "integer", "minimum": 0 },
    "issue_date": { "type": "string", "format": "date" },
    "issued_by_user_id": { "type": "string", "pattern": "^usr_[0-9A-HJKMNP-TV-Z]{26}$" },
    "applied_to_type": { "type": ["string", "null"] },
    "applied_to_id": { "type": ["string", "null"] },
    "pdf_url": { "type": ["string", "null"], "maxLength": 512 },
    "status": { "type": "string", "enum": ["draft", "issued", "applied", "voided"] },
    "applied_at": { "type": ["string", "null"], "format": "date-time" },
    "voided_at": { "type": ["string", "null"], "format": "date-time" },
    "void_reason": { "type": ["string", "null"], "maxLength": 256 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "x-invariants": [
    "amount_cents > 0 (always positive representation)",
    "currency == original_invoice.currency",
    "amount_cents + SUM(other_credit_notes for original_invoice_id) <= original_invoice.total_cents (cannot over-credit)",
    "original_invoice.status must be IN ('paid', 'partially_paid', 'refunded', 'disputed', 'written_off') at credit note creation",
    "issue_date + amount_cents + currency + original_invoice_id + credit_note_number + reason are IMMUTABLE after create",
    "status transitions: draft → issued (PDF ready) → applied (target set); OR draft → voided (only draft may be voided)",
    "issued or applied credit notes cannot be voided or modified",
    "reason IN ('adjustment', 'customer_dispute_resolved', 'accounting_correction') requires reason_note",
    "credit_note_number is unique per tenant WHERE deleted_at IS NULL",
    "issued_by_user_id must hold admin+finance role"
  ]
}
