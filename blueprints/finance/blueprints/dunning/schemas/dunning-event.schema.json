{
  "id": "academorix://modules/dunning/schemas/dunning-event",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "DunningEvent",
  "description": "Timeline entry for a dunning_run: retry_attempted, retry_succeeded, retry_failed, notification_sent, escalated_step, cancelled, exhausted, paused, resumed. Belongs to Tenant + DunningRun (cascade). Immutable once created. NEVER carries application_id, region_id, organization_id, or scope_node_id.",
  "type": "object",
  "x-module": "dunning",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "dunning_events",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "dev_",
    "incrementing": false,
    "model": "Academorix\\Finance\\Dunning\\Models\\DunningEvent",
    "interface": "Academorix\\Finance\\Dunning\\Contracts\\Data\\DunningEventInterface",
    "implements": ["Academorix\\Finance\\Dunning\\Contracts\\Data\\DunningEventInterface"],
    "traits": ["HasFactory", "HasUlids", "BelongsToTenant", "HasMetadata", "HasUserstamps", "Auditable"],
    "casts": {
      "kind": "DunningEventKind",
      "step_index": "integer",
      "payload_json": "array",
      "metadata": "array"
    },
    "observers": ["DunningEventObserver"]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 64, "primary": true, "description": "Prefixed ULID: `dev_<26>`." },
      "tenant_id": { "type": "string", "length": 64, "nullable": false, "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" } },
      "dunning_run_id": { "type": "string", "length": 64, "nullable": false, "foreign": { "table": "dunning_runs", "column": "id", "onDelete": "cascade" } },
      "kind": { "type": "string", "length": 32, "nullable": false, "description": "Enum: run_started / step_reached / retry_attempted / retry_succeeded / retry_failed / notification_sent / escalated_step / run_paused / run_resumed / run_cancelled / run_exhausted / run_resolved." },
      "step_index": { "type": "integer", "nullable": true },
      "message": { "type": "string", "length": 500, "nullable": false, "description": "Human-readable one-liner." },
      "payload_json": { "type": "jsonb", "nullable": true, "description": "Kind-specific detail (retry response, notification template, escalation payload)." },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_by": { "type": "string", "length": 64, "nullable": true },
      "updated_by": { "type": "string", "length": 64, "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      { "columns": ["tenant_id", "dunning_run_id", "created_at"], "name": "dunning_events_run_time_idx" },
      { "columns": ["tenant_id", "kind", "created_at"], "name": "dunning_events_kind_time_idx" }
    ]
  },
  "required": ["id", "tenant_id", "dunning_run_id", "kind", "message", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string", "pattern": "^dev_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": "string", "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "dunning_run_id": { "type": "string", "pattern": "^drn_[0-9A-HJKMNP-TV-Z]{26}$" },
    "kind": { "type": "string", "enum": ["run_started", "step_reached", "retry_attempted", "retry_succeeded", "retry_failed", "notification_sent", "escalated_step", "run_paused", "run_resumed", "run_cancelled", "run_exhausted", "run_resolved"] },
    "message": { "type": "string", "maxLength": 500 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
