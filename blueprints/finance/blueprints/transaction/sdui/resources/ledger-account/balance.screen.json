{
  "id": "transaction.resources.ledger-account.balance",
  "title": "Account balance",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/finance/ledger/accounts/:account",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "transaction", "entity": "ledger-account", "action": "balance" },
  "requiresPermission": "transaction.ledger.account_balance.view",
  "requiresEntitlement": "transaction_capture",
  "dataSources": [
    {
      "name": "account",
      "kind": "http.get",
      "url": "/api/v1/ledger/accounts/:account",
      "unwrap": "data"
    },
    {
      "name": "recent_entries",
      "kind": "http.get",
      "url": "/api/v1/ledger/accounts/:account/history?limit=25",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-6 p-6 max-w-6xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "children": [
            { "kind": "Text", "props": { "as": "h1", "className": "text-2xl font-semibold" }, "bindings": { "children": { "$ref": "account.display_name" } } },
            { "kind": "Text", "props": { "className": "text-sm text-muted font-mono" }, "bindings": { "children": { "$expr": "'account: ' + $ref('account.account') + ' — ' + $ref('account.regulator_category')" } } }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "grid grid-cols-3 gap-4" },
          "children": [
            {
              "kind": "Card",
              "props": { "className": "p-6" },
              "children": [
                { "kind": "Text", "props": { "className": "text-sm text-muted", "children": "Current balance" } },
                { "kind": "Text", "props": { "as": "div", "className": "text-3xl font-mono font-semibold mt-2", "formatter": "currency" }, "bindings": { "children": { "$ref": "account.current_balance_cents" }, "currency": { "$ref": "account.currency" } } }
              ]
            },
            {
              "kind": "Card",
              "props": { "className": "p-6" },
              "children": [
                { "kind": "Text", "props": { "className": "text-sm text-muted", "children": "Threshold state" } },
                {
                  "kind": "Chip",
                  "bindings": { "variant": { "$expr": "$ref('account.threshold_state') === 'normal' ? 'default' : ($ref('account.threshold_state') === 'above_high_watermark' ? 'warning' : 'danger')" }, "children": { "$ref": "account.threshold_state" } },
                  "props": { "className": "mt-2 text-lg" }
                },
                {
                  "kind": "Text",
                  "props": { "className": "text-xs text-muted mt-2" },
                  "bindings": {
                    "hidden": { "$expr": "$ref('account.threshold_state') === 'normal'" },
                    "children": { "$expr": "$ref('account.threshold_state') === 'above_high_watermark' ? ('High watermark: ' + $currency($ref('account.high_watermark_cents'), $ref('account.currency'))) : ('Low watermark: ' + $currency($ref('account.low_watermark_cents'), $ref('account.currency')))" }
                  }
                }
              ]
            },
            {
              "kind": "Card",
              "props": { "className": "p-6" },
              "children": [
                { "kind": "Text", "props": { "className": "text-sm text-muted", "children": "Regulator category" } },
                { "kind": "Text", "props": { "className": "text-lg mt-2 capitalize" }, "bindings": { "children": { "$ref": "account.regulator_category" } } },
                { "kind": "Text", "props": { "className": "text-xs text-muted mt-2" }, "bindings": { "children": { "$expr": "$ref('account.typical_balance') === 'debit' ? 'Debits increase; credits decrease.' : 'Credits increase; debits decrease.'" } } }
              ]
            }
          ]
        },
        {
          "kind": "Card",
          "props": { "className": "p-6" },
          "children": [
            {
              "kind": "View",
              "props": { "className": "flex items-center justify-between mb-4" },
              "children": [
                { "kind": "Text", "props": { "as": "h2", "className": "text-lg font-medium", "children": "Recent entries" } },
                {
                  "kind": "Button",
                  "props": { "variant": "outline", "size": "sm", "children": "View full history", "leadingIcon": "arrow-right" },
                  "actions": { "onPress": { "kind": "navigate", "toExpr": "'/tenant/finance/ledger/accounts/' + $ref('account.account') + '/history'" } }
                }
              ]
            },
            {
              "kind": "DataGrid",
              "bindings": { "items": { "$ref": "recent_entries" } },
              "props": {
                "className": "w-full",
                "columns": [
                  { "field": "created_at", "label": "Recorded", "width": 160, "formatter": "datetime-relative" },
                  { "field": "transaction_number", "label": "Transaction", "width": 180, "renderer": { "kind": "Link", "toExpr": "'/tenant/finance/transactions/' + row.transaction_id", "className": "font-mono text-sm" } },
                  { "field": "debit_cents", "label": "Debit", "width": 140, "renderer": { "kind": "Text", "formatter": "currency", "className": "text-right font-mono", "conditionalHidden": { "$expr": "row.debit_cents === 0" } } },
                  { "field": "credit_cents", "label": "Credit", "width": 140, "renderer": { "kind": "Text", "formatter": "currency", "className": "text-right font-mono", "conditionalHidden": { "$expr": "row.credit_cents === 0" } } },
                  { "field": "running_balance_cents", "label": "Running balance", "width": 180, "renderer": { "kind": "Text", "formatter": "currency", "className": "text-right font-mono font-semibold" } },
                  { "field": "description", "label": "Description" }
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
