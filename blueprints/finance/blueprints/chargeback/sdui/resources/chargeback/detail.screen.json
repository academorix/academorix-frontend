{
  "id": "chargeback.resources.chargeback.detail",
  "title": "Chargeback detail",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/chargebacks/{chargeback}",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "chargeback", "entity": "chargeback", "action": "view" },
  "requiresPermission": "chargebacks.view",
  "requiresEntitlement": "chargeback_management",
  "dataSources": [
    {
      "name": "chargeback",
      "kind": "http.get",
      "url": "/api/v1/chargebacks/{route.chargeback}?include=payment,invoice,payment_dispute,transaction,fee_transaction,refund,latest_evidence",
      "unwrap": "data"
    },
    {
      "name": "evidence_history",
      "kind": "http.get",
      "url": "/api/v1/chargebacks/{route.chargeback}/evidence",
      "unwrap": "data",
      "when": "hasPermission('chargebacks.view-evidence')"
    }
  ],
  "broadcasts": [
    { "channel": "tenant.{tenantId}.chargebacks", "onEvent": ["*"], "action": "refresh_if_matches", "matchField": "chargeback_id", "matchValue": "{route.chargeback}" }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-6 p-6 max-w-6xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "kind": "View",
              "children": [
                {
                  "kind": "Text",
                  "props": { "as": "h1", "className": "text-2xl font-semibold font-mono" },
                  "bindings": { "children": { "$ref": "chargeback.chargeback_number" } }
                },
                {
                  "kind": "View",
                  "props": { "className": "flex items-center gap-2 mt-2" },
                  "children": [
                    {
                      "kind": "Widget",
                      "widget": "chargeback.chargeback-status-chip",
                      "bindings": {
                        "status": { "$ref": "chargeback.status" },
                        "rdrEligible": { "$ref": "chargeback.rdr_eligible" },
                        "ce3Eligible": { "$ref": "chargeback.ce3_eligible" }
                      }
                    },
                    {
                      "kind": "Widget",
                      "widget": "chargeback.network-badge",
                      "bindings": { "network": { "$ref": "chargeback.network" } }
                    },
                    {
                      "kind": "Chip",
                      "props": { "size": "sm", "variant": "neutral" },
                      "bindings": { "children": { "$ref": "chargeback.reason_code" } }
                    }
                  ]
                }
              ]
            },
            {
              "kind": "View",
              "props": { "className": "flex items-center gap-3" },
              "children": [
                {
                  "kind": "Button",
                  "props": { "variant": "primary", "leadingIcon": "check-circle", "children": "Accept via RDR" },
                  "actions": {
                    "onPress": { "kind": "navigate", "toExpr": "'/tenant/chargebacks/' + chargeback.id + '/accept'" }
                  },
                  "bindings": {
                    "hidden": {
                      "$expr": "!(chargeback.rdr_eligible === true && chargeback.status === 'pending_evidence' && hasPermission('chargebacks.accept'))"
                    }
                  }
                },
                {
                  "kind": "Button",
                  "props": { "variant": "outline", "leadingIcon": "document-check", "children": "Submit evidence" },
                  "actions": {
                    "onPress": { "kind": "navigate", "toExpr": "'/tenant/chargebacks/' + chargeback.id + '/submit-evidence'" }
                  },
                  "bindings": {
                    "hidden": {
                      "$expr": "!(hasPermission('chargebacks.submit-evidence') && ['pending_evidence', 'evidence_submitted'].includes(chargeback.status) && new Date(chargeback.evidence_due_by) > new Date())"
                    }
                  }
                },
                {
                  "kind": "Button",
                  "props": { "variant": "danger-outline", "leadingIcon": "x-mark", "children": "Mark lost" },
                  "actions": {
                    "onPress": { "kind": "navigate", "toExpr": "'/tenant/chargebacks/' + chargeback.id + '/mark-lost'" }
                  },
                  "bindings": {
                    "hidden": {
                      "$expr": "!(hasPermission('chargebacks.mark-lost') && ['pending_evidence', 'evidence_submitted', 'under_bank_review'].includes(chargeback.status))"
                    }
                  }
                }
              ]
            }
          ]
        },
        {
          "kind": "Alert",
          "props": { "variant": "warning" },
          "bindings": {
            "hidden": {
              "$expr": "!(chargeback.status === 'pending_evidence' && new Date(chargeback.evidence_due_by) > new Date() && (new Date(chargeback.evidence_due_by) - new Date()) / (1000 * 60 * 60 * 24) < 7)"
            }
          },
          "children": [
            { "kind": "Text", "props": { "className": "font-medium", "children": "Evidence deadline approaching" } },
            {
              "kind": "Text",
              "props": { "className": "text-sm" },
              "bindings": {
                "children": {
                  "$expr": "'Evidence must be submitted by ' + formatDate(chargeback.evidence_due_by, 'long') + '. Missing the deadline will result in auto-loss.'"
                }
              }
            }
          ]
        },
        {
          "kind": "Alert",
          "props": { "variant": "danger" },
          "bindings": {
            "hidden": {
              "$expr": "!(['lost', 'expired'].includes(chargeback.status) && (!chargeback.transaction_id || !chargeback.fee_transaction_id))"
            }
          },
          "children": [
            { "kind": "Text", "props": { "className": "font-medium", "children": "Finalization is pending" } },
            {
              "kind": "Text",
              "props": { "className": "text-sm", "children": "The offsetting transaction + network fee are being recorded. Refresh in a minute or contact support if this persists." }
            }
          ]
        },
        {
          "kind": "Tabs",
          "props": { "aria-label": "Chargeback detail sections" },
          "children": [
            {
              "kind": "Tabs.Tab",
              "props": { "id": "timeline", "title": "Timeline" },
              "children": [
                {
                  "kind": "View",
                  "props": { "className": "flex flex-col gap-3 py-4" },
                  "children": [
                    { "kind": "Text", "props": { "className": "text-sm text-muted", "children": "State transitions + notifications + webhook receipts." } }
                  ]
                }
              ]
            },
            {
              "kind": "Tabs.Tab",
              "props": { "id": "evidence", "title": "Evidence" },
              "children": [
                {
                  "kind": "View",
                  "props": { "className": "flex flex-col gap-3 py-4" },
                  "bindings": { "hidden": { "$expr": "!hasPermission('chargebacks.view-evidence')" } },
                  "children": [
                    {
                      "kind": "Grid",
                      "props": { "className": "grid grid-cols-1 gap-4" },
                      "bindings": {
                        "items": { "$ref": "evidence_history" }
                      },
                      "emptyState": {
                        "kind": "Text",
                        "props": { "className": "text-sm text-muted", "children": "No evidence submissions yet." }
                      },
                      "itemRenderer": {
                        "kind": "Card",
                        "props": { "className": "p-4" },
                        "children": [
                          {
                            "kind": "View",
                            "props": { "className": "flex items-start justify-between gap-2" },
                            "children": [
                              {
                                "kind": "Text",
                                "props": { "className": "font-medium" },
                                "bindings": {
                                  "children": { "$expr": "'Attempt #' + row.submission_attempt_number" }
                                }
                              },
                              {
                                "kind": "Widget",
                                "widget": "chargeback.evidence-completeness-indicator",
                                "bindings": {
                                  "percent": { "$ref": "row.completeness_percent" }
                                }
                              }
                            ]
                          },
                          {
                            "kind": "Text",
                            "props": { "className": "text-xs text-muted mt-2" },
                            "bindings": {
                              "children": { "$expr": "'Submitted ' + formatDate(row.submitted_at, 'relative')" }
                            }
                          }
                        ]
                      }
                    }
                  ]
                }
              ]
            },
            {
              "kind": "Tabs.Tab",
              "props": { "id": "details", "title": "Details" },
              "children": [
                {
                  "kind": "View",
                  "props": { "className": "flex flex-col gap-3 py-4" },
                  "children": [
                    { "kind": "Text", "props": { "className": "font-medium", "children": "Amount" } },
                    {
                      "kind": "Text",
                      "props": { "className": "text-sm" },
                      "bindings": {
                        "children": {
                          "$expr": "hasPermission('chargebacks.view-financials') ? (formatCurrency(chargeback.amount_cents, chargeback.currency) + ' + ' + formatCurrency(chargeback.fee_cents, chargeback.currency) + ' fee') : '••••'"
                        }
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
