{
  "id": "platform-user.on-call-current",
  "title": "Current on-call",
  "version": 1,
  "kind": "SduiWidget",
  "description": "Sidebar widget on the platform-admin dashboard. Shows the currently-on-call PlatformUser (avatar + display_name + department) + shift remaining. Auto-refreshes every 60s (matches OnCallResolver cache TTL). Renders `null` when the resolver is disabled OR no shift is active.",
  "props": {
    "size": { "type": "string", "default": "md", "enum": ["sm", "md", "lg"] },
    "department": {
      "type": ["string", "null"],
      "default": null,
      "description": "Scope to one department; null = platform-wide."
    }
  },
  "dataSources": [
    {
      "name": "onCall",
      "kind": "http.get",
      "urlExpr": "props.department ? ('/api/v1/platform/platform-users/on-call/current?department=' + props.department) : '/api/v1/platform/platform-users/on-call/current'",
      "unwrap": "data",
      "cache": { "ttlSeconds": 60 },
      "refresh": { "intervalSeconds": 60 }
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "Card",
      "props": { "className": "p-3 flex items-center gap-3" },
      "bindings": { "hidden": { "$expr": "!onCall?.current_shift" } },
      "children": [
        {
          "kind": "Widget",
          "widget": "platform-user.platform-user-avatar",
          "propsExpr": "{ platformUserId: onCall.current_shift.platform_user_id, size: props.size }"
        },
        {
          "kind": "View",
          "props": { "className": "flex flex-col flex-1" },
          "children": [
            {
              "kind": "View",
              "props": { "className": "flex items-center gap-2" },
              "children": [
                {
                  "kind": "Text",
                  "props": { "className": "text-xs uppercase text-muted", "children": "On-call" }
                },
                {
                  "kind": "Text",
                  "props": { "className": "font-medium" },
                  "bindings": { "children": { "$ref": "onCall.current_shift.display_name" } }
                }
              ]
            },
            {
              "kind": "Text",
              "props": { "className": "text-xs text-muted" },
              "bindings": {
                "children": {
                  "$expr": "'until ' + onCall.current_shift.shift_end_at + ' (' + onCall.source + ')'"
                }
              }
            }
          ]
        },
        {
          "kind": "Button",
          "props": {
            "variant": "ghost",
            "size": "sm",
            "isIconOnly": true,
            "children": { "kind": "Icon", "props": { "name": "phone" } }
          },
          "actions": {
            "onPress": {
              "kind": "external.link",
              "urlExpr": "'tel:' + onCall.current_shift.phone_e164"
            }
          },
          "requiresPermission": "platform.on_call.view"
        }
      ]
    }
  ]
}
