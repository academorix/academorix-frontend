{
  "id": "academorix://modules/auth/schemas/auth-password-reset",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "PasswordReset",
  "description": "One-time-use password reset token. Bound to a specific Identity via identity_id. 15-minute TTL from issue. Consumed atomically on POST /auth/password/reset \u2014 re-presenting a consumed token returns the generic invalid-token error.",
  "type": "object",
  "x-module": "auth",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "auth_password_resets",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "apr_",
    "incrementing": false,
    "model": "Academorix\\Auth\\Models\\PasswordReset",
    "traits": ["HasFactory", "HasUlids", "HasUserstamps", "HasActivityLog", "Filterable"],
    "casts": {
      "expires_at": "datetime",
      "consumed_at": "datetime"
    },
    "appends": ["is_expired", "is_consumed"],
    "hidden": ["token_hash", "ip_address_hash", "user_agent_hash"]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 30, "primary": true },
      "identity_id": { "type": "string", "length": 30, "nullable": false, "description": "FK to identities.id ON DELETE CASCADE." },
      "token_hash": { "type": "text", "nullable": false, "description": "SHA-256 hash. Plaintext returned once in the emailed link." },
      "expires_at": { "type": "timestamptz", "nullable": false },
      "consumed_at": { "type": "timestamptz", "nullable": true },
      "ip_address_hash": { "type": "text", "nullable": true },
      "user_agent_hash": { "type": "text", "nullable": true },
      "created_by": { "type": "uuid", "nullable": true },
      "updated_by": { "type": "uuid", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      { "columns": ["token_hash"], "unique": true, "name": "auth_password_resets_hash_unique" },
      { "columns": ["identity_id"], "unique": false, "name": "auth_password_resets_identity_idx" },
      { "columns": ["expires_at"], "unique": false, "predicate": "consumed_at IS NULL", "name": "auth_password_resets_active_expiry_idx" }
    ]
  },
  "required": ["id", "identity_id", "token_hash", "expires_at", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string", "pattern": "^apr_[0-9A-HJKMNP-TV-Z]{26}$" },
    "identity_id": { "type": "string", "pattern": "^idn_[0-9A-HJKMNP-TV-Z]{26}$" },
    "expires_at": { "type": "string", "format": "date-time" },
    "consumed_at": { "type": ["string", "null"], "format": "date-time" },
    "is_expired": { "type": "boolean" },
    "is_consumed": { "type": "boolean" }
  },
  "additionalProperties": false,
  "x-wire": {
    "envelope": "none",
    "note": "PasswordReset is NEVER returned to the client. The plaintext token is included ONCE in the emailed reset link; the row is server-side-only.",
    "never_projected": ["token_hash", "ip_address_hash", "user_agent_hash"]
  }
}
