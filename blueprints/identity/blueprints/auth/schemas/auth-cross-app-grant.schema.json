{
  "id": "stackra://modules/auth/schemas/auth-cross-app-grant",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "CrossAppGrant",
  "description": "One-time-use cross-Application SSO grant. Issued on the source Application via /auth/cross-app/grant; exchanged on the target Application via /auth/cross-app/exchange. 300-second TTL. Consumed atomically on exchange \u2014 re-presenting a consumed grant returns the generic invalid-grant error.",
  "type": "object",
  "x-module": "auth",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "auth_cross_app_grants",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "acg_",
    "incrementing": false,
    "model": "Stackra\\Auth\\Models\\CrossAppGrant",
    "traits": ["HasFactory", "HasUlids", "HasUserstamps", "HasActivityLog", "Filterable"],
    "casts": {
      "expires_at": "datetime",
      "consumed_at": "datetime"
    },
    "appends": ["is_expired", "is_consumed", "is_redeemable"],
    "hidden": ["token_hash"]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 30, "primary": true },
      "identity_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "description": "FK to identities.id ON DELETE CASCADE. The Identity being cross-authenticated."
      },
      "source_application_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "description": "FK to applications.id ON DELETE RESTRICT. The Application the grant was issued from."
      },
      "target_application_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "description": "FK to applications.id ON DELETE RESTRICT. The Application the grant is redeemable on."
      },
      "token_hash": {
        "type": "text",
        "nullable": false,
        "description": "SHA-256 hash. Plaintext returned once at issue."
      },
      "expires_at": { "type": "timestamptz", "nullable": false },
      "consumed_at": { "type": "timestamptz", "nullable": true },
      "created_by": { "type": "uuid", "nullable": true },
      "updated_by": { "type": "uuid", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      { "columns": ["token_hash"], "unique": true, "name": "auth_cross_app_grants_hash_unique" },
      { "columns": ["identity_id"], "unique": false, "name": "auth_cross_app_grants_identity_idx" },
      {
        "columns": ["target_application_id"],
        "unique": false,
        "name": "auth_cross_app_grants_target_app_idx"
      },
      {
        "columns": ["expires_at"],
        "unique": false,
        "predicate": "consumed_at IS NULL",
        "name": "auth_cross_app_grants_active_expiry_idx"
      }
    ]
  },
  "required": [
    "id",
    "identity_id",
    "source_application_id",
    "target_application_id",
    "token_hash",
    "expires_at",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^acg_[0-9A-HJKMNP-TV-Z]{26}$" },
    "identity_id": { "type": "string", "pattern": "^idn_[0-9A-HJKMNP-TV-Z]{26}$" },
    "source_application_id": { "type": "string" },
    "target_application_id": { "type": "string" },
    "expires_at": { "type": "string", "format": "date-time" },
    "consumed_at": { "type": ["string", "null"], "format": "date-time" },
    "is_expired": { "type": "boolean" },
    "is_consumed": { "type": "boolean" },
    "is_redeemable": { "type": "boolean" }
  },
  "additionalProperties": false,
  "x-wire": {
    "envelope": "none",
    "note": "Grant row NEVER returned. The grant plaintext is included ONCE in the CrossAppGrantResult wrapper at issue-time.",
    "never_projected": ["token_hash", "identity_id"]
  }
}
