{
  "id": "analytics.resources.analytics-provider-config.edit",
  "title": "Edit analytics provider",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/analytics/providers/{id}/edit",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "analytics", "entity": "analytics-provider-config", "action": "edit" },
  "requiresPermission": "analytics.providers.update",
  "params": [{ "name": "id", "type": "string", "in": "path", "required": true }],
  "dataSources": [
    {
      "name": "provider",
      "kind": "http.get",
      "urlExpr": "'/api/v1/analytics/providers/' + params.id",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-6 p-6 max-w-3xl mx-auto" },
      "children": [
        {
          "kind": "Link",
          "props": {
            "leadingIcon": "arrow-left",
            "children": "Back to providers",
            "className": "text-sm text-muted"
          },
          "actions": { "onPress": { "kind": "navigate", "to": "/tenant/analytics/providers" } }
        },
        {
          "kind": "View",
          "props": { "className": "flex items-center gap-3" },
          "children": [
            {
              "kind": "Widget",
              "widget": "analytics.analytics-provider-badge",
              "props": { "provider": { "$ref": "provider.provider" }, "size": "lg" }
            },
            {
              "kind": "Text",
              "props": { "as": "h1", "className": "text-2xl font-semibold" },
              "bindings": { "children": { "$ref": "provider.name" } }
            }
          ]
        },
        {
          "kind": "Card",
          "props": { "className": "p-6" },
          "children": [
            {
              "kind": "Text",
              "props": {
                "as": "h2",
                "className": "text-sm font-semibold text-muted uppercase tracking-wide mb-3",
                "children": "General"
              }
            },
            {
              "kind": "TextField",
              "props": { "label": "Display name", "name": "name" },
              "bindings": { "defaultValue": { "$ref": "provider.name" } }
            },
            {
              "kind": "Toggle",
              "props": { "label": "Active", "name": "is_active" },
              "bindings": { "defaultValue": { "$ref": "provider.is_active" } }
            },
            {
              "kind": "Toggle",
              "props": { "label": "Test mode", "name": "test_mode" },
              "bindings": { "defaultValue": { "$ref": "provider.test_mode" } }
            }
          ]
        },
        {
          "kind": "Card",
          "props": { "className": "p-6" },
          "children": [
            {
              "kind": "Text",
              "props": {
                "as": "h2",
                "className": "text-sm font-semibold text-muted uppercase tracking-wide mb-3",
                "children": "Sampling"
              }
            },
            {
              "kind": "Alert",
              "props": {
                "variant": "warning",
                "children": "Enterprise entitlement required to customise sampling for this provider."
              },
              "bindings": {
                "hidden": {
                  "$expr": "identity.entitlements.analytics_sampling_config || provider.provider === 'posthog' || provider.provider === 'custom_webhook'"
                }
              }
            },
            {
              "kind": "NumberField",
              "props": {
                "label": "Sampling rate",
                "name": "sampling_rate",
                "min": 0,
                "max": 1,
                "step": 0.01
              },
              "bindings": {
                "defaultValue": { "$ref": "provider.sampling_rate" },
                "isDisabled": {
                  "$expr": "!identity.entitlements.analytics_sampling_config && provider.provider !== 'posthog' && provider.provider !== 'custom_webhook'"
                }
              }
            }
          ]
        },
        {
          "kind": "Card",
          "props": { "className": "p-6" },
          "children": [
            {
              "kind": "Text",
              "props": {
                "as": "h2",
                "className": "text-sm font-semibold text-muted uppercase tracking-wide mb-3",
                "children": "Enabled event types"
              }
            },
            {
              "kind": "TagField",
              "props": { "label": "Patterns", "name": "enabled_event_types" },
              "bindings": { "defaultValue": { "$ref": "provider.enabled_event_types" } }
            }
          ]
        },
        {
          "kind": "Card",
          "props": { "className": "p-6" },
          "bindings": {
            "hidden": { "$expr": "!identity.entitlements.analytics_batch_configuration" }
          },
          "children": [
            {
              "kind": "Text",
              "props": {
                "as": "h2",
                "className": "text-sm font-semibold text-muted uppercase tracking-wide mb-3",
                "children": "Batching (Enterprise)"
              }
            },
            {
              "kind": "NumberField",
              "props": { "label": "Batch size", "name": "batch_config.size", "min": 1 },
              "bindings": { "defaultValue": { "$ref": "provider.batch_config.size" } }
            },
            {
              "kind": "NumberField",
              "props": {
                "label": "Flush interval (ms)",
                "name": "batch_config.flush_interval_ms",
                "min": 100,
                "step": 100
              },
              "bindings": { "defaultValue": { "$ref": "provider.batch_config.flush_interval_ms" } }
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "flex justify-end gap-2" },
          "children": [
            {
              "kind": "Button",
              "props": { "variant": "ghost", "children": "Cancel" },
              "actions": { "onPress": { "kind": "navigate", "to": "/tenant/analytics/providers" } }
            },
            {
              "kind": "Button",
              "props": { "variant": "primary", "children": "Save changes" },
              "actions": {
                "onPress": {
                  "kind": "http.patch",
                  "urlExpr": "'/api/v1/analytics/providers/' + params.id",
                  "bodyFromState": true,
                  "onSuccess": [
                    { "kind": "toast.success", "message": "Provider updated" },
                    { "kind": "navigate", "to": "/tenant/analytics/providers" }
                  ]
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
