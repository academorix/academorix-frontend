{
  "id": "attribution.resources.attribution.view",
  "title": "Attribution",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/attributions/:attributionId",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "attribution", "entity": "attribution", "action": "view" },
  "requiresPermission": "attribution.view",
  "requiresEntitlement": "attribution_capture",
  "dataSources": [
    {
      "name": "attribution",
      "kind": "http.get",
      "urlExpr": "'/api/v1/attributions/' + params.attributionId",
      "unwrap": "data"
    },
    {
      "name": "touchpoints",
      "kind": "http.get",
      "urlExpr": "'/api/v1/attributions/' + params.attributionId + '/touchpoints?limit=25'",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-5xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "kind": "View",
              "children": [
                {
                  "kind": "Text",
                  "props": { "as": "h1", "className": "text-2xl font-semibold" },
                  "bindings": {
                    "children": {
                      "$expr": "'Attribution for ' + attribution.subject_type + ' ' + attribution.subject_id"
                    }
                  }
                },
                {
                  "kind": "View",
                  "props": { "className": "flex items-center gap-2 mt-2" },
                  "children": [
                    {
                      "kind": "Chip",
                      "bindings": {
                        "variant": {
                          "$expr": "attribution.lifecycle_state === 'converted' ? 'success' : (attribution.lifecycle_state === 'churned' ? 'neutral' : (attribution.lifecycle_state === 'identified' ? 'info' : 'warning'))"
                        },
                        "children": { "$ref": "attribution.lifecycle_state" }
                      }
                    },
                    {
                      "kind": "Text",
                      "props": { "className": "text-sm text-muted" },
                      "bindings": {
                        "children": {
                          "$expr": "attribution.touchpoint_count + ' touchpoints, ' + attribution.conversion_touchpoint_count + ' conversions'"
                        }
                      }
                    }
                  ]
                }
              ]
            },
            {
              "kind": "View",
              "props": { "className": "flex items-center gap-2" },
              "children": [
                {
                  "kind": "Button",
                  "props": {
                    "variant": "secondary",
                    "leadingIcon": "arrow-path-rounded-square",
                    "children": "Merge"
                  },
                  "actions": {
                    "onPress": {
                      "kind": "navigate",
                      "toExpr": "'/tenant/attributions/' + params.attributionId + '/merge'"
                    }
                  },
                  "requiresPermission": "attribution.merge",
                  "requiresEntitlement": "attribution_merge",
                  "bindings": { "hidden": { "$expr": "attribution.subject_type === 'anonymous_session'" } }
                },
                {
                  "kind": "Button",
                  "props": {
                    "variant": "danger",
                    "leadingIcon": "trash",
                    "children": "Reset (GDPR)"
                  },
                  "actions": {
                    "onPress": {
                      "kind": "navigate",
                      "toExpr": "'/tenant/attributions/' + params.attributionId + '/reset'"
                    }
                  },
                  "requiresPermission": "attribution.reset"
                }
              ]
            }
          ]
        },
        {
          "kind": "Grid",
          "props": { "className": "grid grid-cols-1 md:grid-cols-2 gap-4" },
          "children": [
            {
              "kind": "Card",
              "props": { "className": "p-4" },
              "children": [
                { "kind": "Text", "props": { "className": "text-sm font-semibold uppercase text-muted mb-3", "children": "First touch" } },
                {
                  "kind": "Widget",
                  "widget": "attribution.attribution-source-chip",
                  "bindings": {
                    "source": { "$ref": "attribution.first_touch_source" },
                    "bucket": { "$ref": "attribution.first_touch_source_bucket" }
                  }
                },
                {
                  "kind": "View",
                  "props": { "className": "flex flex-col gap-1 mt-3 text-sm" },
                  "children": [
                    { "kind": "Text", "bindings": { "children": { "$expr": "'Medium: ' + (attribution.first_touch_medium || '—')" } } },
                    { "kind": "Text", "bindings": { "children": { "$expr": "'Campaign: ' + (attribution.first_touch_campaign || '—')" } } },
                    { "kind": "Text", "bindings": { "children": { "$expr": "'Content: ' + (attribution.first_touch_content || '—')" } } },
                    { "kind": "Text", "bindings": { "children": { "$expr": "'Term: ' + (attribution.first_touch_term || '—')" } } },
                    { "kind": "Text", "props": { "className": "text-xs text-muted mt-2 truncate" }, "bindings": { "children": { "$expr": "'Landing: ' + attribution.first_touch_landing_page" } } },
                    { "kind": "Text", "props": { "className": "text-xs text-muted" }, "bindings": { "children": { "$expr": "'At: ' + attribution.first_touch_at" } } }
                  ]
                }
              ]
            },
            {
              "kind": "Card",
              "props": { "className": "p-4" },
              "children": [
                { "kind": "Text", "props": { "className": "text-sm font-semibold uppercase text-muted mb-3", "children": "Last touch" } },
                {
                  "kind": "Widget",
                  "widget": "attribution.attribution-source-chip",
                  "bindings": {
                    "source": { "$ref": "attribution.last_touch_source" },
                    "bucket": { "$ref": "attribution.last_touch_source_bucket" }
                  }
                },
                {
                  "kind": "View",
                  "props": { "className": "flex flex-col gap-1 mt-3 text-sm" },
                  "children": [
                    { "kind": "Text", "bindings": { "children": { "$expr": "'Medium: ' + (attribution.last_touch_medium || '—')" } } },
                    { "kind": "Text", "bindings": { "children": { "$expr": "'Campaign: ' + (attribution.last_touch_campaign || '—')" } } },
                    { "kind": "Text", "props": { "className": "text-xs text-muted mt-2 truncate" }, "bindings": { "children": { "$expr": "'Landing: ' + attribution.last_touch_landing_page" } } },
                    { "kind": "Text", "props": { "className": "text-xs text-muted" }, "bindings": { "children": { "$expr": "'At: ' + attribution.last_touch_at" } } }
                  ]
                }
              ]
            }
          ]
        },
        {
          "kind": "Card",
          "props": { "className": "p-4" },
          "children": [
            {
              "kind": "View",
              "props": { "className": "flex items-center justify-between mb-3" },
              "children": [
                { "kind": "Text", "props": { "className": "text-sm font-semibold uppercase text-muted", "children": "Touchpoint timeline" } },
                {
                  "kind": "Text",
                  "props": { "className": "text-xs text-muted" },
                  "bindings": {
                    "children": { "$expr": "'Last 25 of ' + attribution.touchpoint_count" }
                  }
                }
              ]
            },
            {
              "kind": "Widget",
              "widget": "attribution.attribution-timeline",
              "bindings": {
                "touchpoints": { "$ref": "touchpoints" }
              }
            }
          ]
        },
        {
          "kind": "Card",
          "props": { "className": "p-4" },
          "children": [
            { "kind": "Text", "props": { "className": "text-sm font-semibold uppercase text-muted mb-3", "children": "Device + consent snapshot" } },
            {
              "kind": "Grid",
              "props": { "className": "grid grid-cols-2 gap-2 text-sm" },
              "children": [
                { "kind": "Text", "bindings": { "children": { "$expr": "'Device: ' + attribution.last_touch_device.device_type" } } },
                { "kind": "Text", "bindings": { "children": { "$expr": "'Browser: ' + attribution.last_touch_device.browser" } } },
                { "kind": "Text", "bindings": { "children": { "$expr": "'OS: ' + attribution.last_touch_device.os" } } },
                { "kind": "Text", "bindings": { "children": { "$expr": "'Mobile: ' + (attribution.last_touch_device.is_mobile ? 'Yes' : 'No')" } } },
                { "kind": "Text", "bindings": { "children": { "$expr": "'Marketing consent: ' + (attribution.consent_at_capture.marketing ? '✓' : '✗')" } } },
                { "kind": "Text", "bindings": { "children": { "$expr": "'Advertising consent: ' + (attribution.consent_at_capture.advertising ? '✓' : '✗')" } } },
                { "kind": "Text", "bindings": { "children": { "$expr": "'Personalized ads: ' + (attribution.consent_at_capture.personalized_advertising ? '✓' : '✗')" } } },
                { "kind": "Text", "bindings": { "children": { "$expr": "'Functional: ' + (attribution.consent_at_capture.functional ? '✓' : '✗')" } } }
              ]
            }
          ]
        }
      ]
    }
  ]
}
