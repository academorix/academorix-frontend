      "aliases": ["medium", "medium.com"],
      "referrer_patterns": ["medium.com"],
      "bucket_organic": "referral"
    },
    {
      "canonical": "quora",
      "aliases": ["quora", "quora.com"],
      "referrer_patterns": ["quora.com"],
      "bucket_organic": "referral"
    },
    {
      "canonical": "stackoverflow",
      "aliases": ["stackoverflow", "stack-overflow"],
      "referrer_patterns": ["stackoverflow.com"],
      "bucket_organic": "referral"
    },
    {
      "canonical": "capterra",
      "aliases": ["capterra"],
      "referrer_patterns": ["capterra.com"],
      "bucket_organic": "referral"
    },
    {
      "canonical": "g2",
      "aliases": ["g2", "g2crowd", "g2.com"],
      "referrer_patterns": ["g2.com"],
      "bucket_organic": "referral"
    },
    {
      "canonical": "trustpilot",
      "aliases": ["trustpilot"],
      "referrer_patterns": ["trustpilot.com"],
      "bucket_organic": "referral"
    },
    {
      "canonical": "trustradius",
      "aliases": ["trustradius"],
      "referrer_patterns": ["trustradius.com"],
      "bucket_organic": "referral"
    },
    {
      "canonical": "getapp",
      "aliases": ["getapp"],
      "referrer_patterns": ["getapp.com"],
      "bucket_organic": "referral"
    },
    {
      "canonical": "softwareadvice",
      "aliases": ["softwareadvice"],
      "referrer_patterns": ["softwareadvice.com"],
      "bucket_organic": "referral"
    },
    {
      "canonical": "referral",
      "aliases": ["referral", "friend-referral", "referral-program"],
      "referrer_patterns": [],
      "bucket_organic": "referral",
      "notes": "Sourced from the referrals module's ReferralLinkClicked event."
    },
    {
      "canonical": "direct",
      "aliases": ["direct", "(direct)", "(none)"],
      "referrer_patterns": [],
      "bucket_organic": "direct",
      "notes": "No referrer AND no utm_source. User typed URL or used a bookmark."
    }
  ],
  "bucket_resolution_order": [
    "if click_id.provider_hint is non-null → 'paid' (unconditional)",
    "if utm_medium == 'email' OR source.canonical == 'email' → 'email'",
    "if utm_medium == 'affiliate' OR source.canonical == 'affiliate' → 'affiliate'",
    "if source has bucket_organic == 'social' → 'social'",
    "if source has bucket_organic == 'organic' → 'organic'",
    "if source has bucket_organic == 'referral' → 'referral'",
    "if no referrer AND no utm_source → 'direct'",
    "else → 'unknown'"
  ],
  "notes": [
    "The bucket_organic field is the DEFAULT bucket when no click_id is present. The bucket_paid field is the bucket when a matching click_id IS present.",
    "The bucket_resolution_order is deliberately unambiguous — the FIRST matching rule wins. This prevents click_ids from being missed (paid classification is highest-priority) and prevents email/affiliate from bleeding into organic.",
    "New sources land here first. AttributionSourceBucketer.bucket() reads this file at boot; unknown sources fall through to bucket_organic='unknown' — which surfaces in analytics as a signal to expand the catalog."
  ]
}
