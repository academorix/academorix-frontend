    },
    {
      "canonical": "reddit",
      "aliases": ["reddit", "reddit.com"],
      "referrer_patterns": ["reddit.com", "old.reddit.com"],
      "bucket_organic": "social",
      "bucket_paid": "paid"
    },
    {
      "canonical": "youtube",
      "aliases": ["youtube", "youtube.com", "youtu.be"],
      "referrer_patterns": ["youtube.com", "m.youtube.com", "youtu.be"],
      "bucket_organic": "social",
      "bucket_paid": "paid"
    },
    {
      "canonical": "whatsapp",
      "aliases": ["whatsapp", "whatsapp.com"],
      "referrer_patterns": ["whatsapp.com", "wa.me"],
      "bucket_organic": "social"
    },
    {
      "canonical": "telegram",
      "aliases": ["telegram", "telegram.org"],
      "referrer_patterns": ["telegram.org", "t.me"],
      "bucket_organic": "social"
    },
    {
      "canonical": "email",
      "aliases": ["email", "newsletter", "mailchimp", "sendgrid", "postmark", "mailgun", "sendinblue", "campaign-monitor", "convertkit"],
      "referrer_patterns": [],
      "bucket_organic": "email",
      "bucket_paid": "email",
      "notes": "Any source with utm_medium=email OR a known email-tracking cookie present."
    },
    {
      "canonical": "affiliate",
      "aliases": ["affiliate", "referred_by", "cj-affiliate", "impact", "rakuten", "awin", "sharesale"],
      "referrer_patterns": [],
