      "aliases": ["facebook", "fb", "facebook.com", "meta"],
      "referrer_patterns": ["facebook.com", "m.facebook.com", "l.facebook.com"],
      "bucket_organic": "social",
      "bucket_paid": "paid",
      "notes": "click_id.fbclid presence indicates paid ad."
    },
    {
      "canonical": "instagram",
      "aliases": ["instagram", "ig", "instagram.com"],
      "referrer_patterns": ["instagram.com", "l.instagram.com"],
      "bucket_organic": "social",
      "bucket_paid": "paid"
    },
    {
      "canonical": "twitter",
      "aliases": ["twitter", "x", "x.com", "twitter.com"],
      "referrer_patterns": ["twitter.com", "x.com", "t.co"],
      "bucket_organic": "social",
      "bucket_paid": "paid"
    },
    {
      "canonical": "linkedin",
      "aliases": ["linkedin", "linkedin.com"],
      "referrer_patterns": ["linkedin.com", "lnkd.in"],
      "bucket_organic": "social",
      "bucket_paid": "paid"
    },
    {
      "canonical": "tiktok",
      "aliases": ["tiktok", "tiktok.com"],
      "referrer_patterns": ["tiktok.com"],
      "bucket_organic": "social",
      "bucket_paid": "paid",
      "notes": "click_id.ttclid presence indicates paid ad."
    },
    {
