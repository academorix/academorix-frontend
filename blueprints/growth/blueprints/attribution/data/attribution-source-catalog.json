{
  "$version": 1,
  "title": "Attribution source catalogue + normalization",
  "description": "Canonical mapping of common utm_source + referrer patterns to their normalized source identifier and analytics bucket. Read by ReferrerNormalizer (to canonicalize referrers into a source) and AttributionSourceBucketer (to collapse individual sources into one of 8 buckets for analytics). Add new sources here as they emerge — the bucket assignment is the load-bearing decision.",
  "buckets": {
    "paid": {
      "display_name": "Paid",
      "description": "Paid ad clicks — always accompanied by a click_id (gclid / fbclid / etc.). Non-null click_id.provider_hint auto-classifies to paid regardless of utm_source."
    },
    "organic": {
      "display_name": "Organic search",
      "description": "Unpaid search-engine referrals. Referrer contains google.com / bing.com / duckduckgo.com / yahoo.com / etc. without a click_id."
    },
    "social": {
      "display_name": "Social",
      "description": "Unpaid social-network referrals. Referrer from facebook.com / twitter.com / instagram.com / linkedin.com / tiktok.com / etc."
    },
    "referral": {
      "display_name": "Referral",
      "description": "Non-social, non-search third-party referrals. Blog links, partner sites, review sites."
    },
    "direct": {
      "display_name": "Direct",
      "description": "No referrer. User typed the URL or used a bookmark."
    },
    "email": {
      "display_name": "Email",
      "description": "Click from an email link. utm_medium=email, or referrer from a known email-tracking domain, or the email-tracking-token cookie present."
    },
    "affiliate": {
      "display_name": "Affiliate",
      "description": "Referral from an affiliate network. utm_medium=affiliate."
    },
    "unknown": {
      "display_name": "Unknown",
      "description": "Fallback when no bucket applies. Should be rare — investigate spikes."
    }
  },
  "sources": [
    {
      "canonical": "google",
      "aliases": ["google", "google-ads", "google-search", "adwords", "google_paid"],
      "referrer_patterns": ["google.com", "google.co.uk", "google.ca", "google.de", "google.fr", "google.es", "google.it", "google.com.br", "google.co.jp", "google.co.in"],
      "bucket_organic": "organic",
      "bucket_paid": "paid",
      "notes": "The bucket depends on click_id.gclid presence: gclid present → paid; absent → organic."
    },
    {
      "canonical": "bing",
      "aliases": ["bing", "microsoft", "microsoft-ads", "bing-ads"],
      "referrer_patterns": ["bing.com"],
      "bucket_organic": "organic",
      "bucket_paid": "paid"
    },
    {
      "canonical": "duckduckgo",
      "aliases": ["duckduckgo", "ddg"],
      "referrer_patterns": ["duckduckgo.com"],
      "bucket_organic": "organic",
      "bucket_paid": "paid"
    },
    {
      "canonical": "yahoo",
      "aliases": ["yahoo", "yahoo-search"],
      "referrer_patterns": ["yahoo.com", "search.yahoo.com"],
      "bucket_organic": "organic",
      "bucket_paid": "paid"
    },
    {
      "canonical": "baidu",
      "aliases": ["baidu"],
      "referrer_patterns": ["baidu.com"],
      "bucket_organic": "organic",
      "bucket_paid": "paid"
    },
    {
      "canonical": "yandex",
      "aliases": ["yandex"],
