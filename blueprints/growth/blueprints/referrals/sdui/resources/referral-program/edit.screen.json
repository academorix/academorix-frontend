{
  "id": "referrals.resources.referral-program.edit",
  "title": "Edit referral program",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/referral-programs/:programId/edit",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "referrals", "entity": "referral-program", "action": "edit" },
  "requiresPermission": "referral_programs.update",
  "requiresEntitlement": "referrals_capture",
  "dataSources": [
    {
      "name": "program",
      "kind": "http.get",
      "urlExpr": "'/api/v1/referral-programs/' + $params.programId",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-6 p-6 max-w-3xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "children": [
            {
              "kind": "Text",
              "props": { "as": "h1", "className": "text-2xl font-semibold" },
              "bindings": { "children": { "$expr": "'Edit ' + program.name" } }
            },
            {
              "kind": "Widget",
              "widget": "referrals.referral-status-chip",
              "bindings": { "status": { "$ref": "program.status" } }
            }
          ]
        },
        {
          "kind": "Alert",
          "props": {
            "variant": "warning",
            "children": "Reward configuration (type, amount, currency, vesting rule) is LOCKED once any referral commits to this program. Only labels + fraud/eligibility config + budget cap remain editable."
          },
          "bindings": {
            "hidden": { "$expr": "program.rewards_issued_count === 0" }
          }
        },
        {
          "kind": "Tabs",
          "props": { "defaultValue": "basics" },
          "items": [
            {
              "id": "basics",
              "label": "Basics",
              "children": [
                {
                  "kind": "TextField",
                  "props": { "label": "Program name", "isRequired": true },
                  "bindings": { "defaultValue": { "$ref": "program.name" } },
                  "form": { "field": "name" }
                },
                {
                  "kind": "TextArea",
                  "props": { "label": "Description" },
                  "bindings": { "defaultValue": { "$ref": "program.description" } },
                  "form": { "field": "description" }
                },
                {
                  "kind": "TextField",
                  "props": { "label": "Terms URL" },
                  "bindings": { "defaultValue": { "$ref": "program.terms_url" } },
                  "form": { "field": "terms_url" }
                }
              ]
            },
            {
              "id": "limits",
              "label": "Limits & fraud",
              "children": [
                {
                  "kind": "NumberField",
                  "props": { "label": "Max rewards per referrer (lifetime)", "minValue": 1 },
                  "bindings": { "defaultValue": { "$ref": "program.max_rewards_per_referrer" } },
                  "form": { "field": "max_rewards_per_referrer" }
                },
                {
                  "kind": "NumberField",
                  "props": { "label": "Max rewards per referrer (per 30d)", "minValue": 1 },
                  "bindings": { "defaultValue": { "$ref": "program.max_rewards_per_period" } },
                  "form": { "field": "max_rewards_per_period" }
                },
                {
                  "kind": "NumberField",
                  "props": { "label": "Program budget cap (cents)", "minValue": 1 },
                  "bindings": { "defaultValue": { "$ref": "program.max_rewards_per_program" } },
                  "form": { "field": "max_rewards_per_program" }
                },
                {
                  "kind": "NumberField",
                  "props": { "label": "Fraud hard-block threshold", "minValue": 0, "maxValue": 100 },
                  "bindings": { "defaultValue": { "$ref": "program.fraud_config.hard_block_threshold" } },
                  "form": { "field": "fraud_config.hard_block_threshold" }
                }
              ]
            },
            {
              "id": "actions",
              "label": "Actions",
              "children": [
                {
                  "kind": "Card",
                  "props": { "className": "p-4" },
                  "children": [
                    { "kind": "Text", "props": { "as": "h3", "className": "font-semibold", "children": "Lifecycle" } },
                    {
                      "kind": "View",
                      "props": { "className": "flex flex-col gap-2 mt-3" },
                      "children": [
                        {
                          "kind": "Button",
                          "props": { "variant": "primary", "leadingIcon": "play", "children": "Activate" },
                          "bindings": { "hidden": { "$expr": "program.status === 'active'" } },
                          "actions": {
                            "onPress": {
                              "kind": "http.post",
                              "urlExpr": "'/api/v1/referral-programs/' + program.id + '/activate'",
                              "onSuccess": { "kind": "reload" }
                            }
                          },
                          "requiresPermission": "referral_programs.activate"
                        },
                        {
                          "kind": "Button",
                          "props": { "variant": "warning", "leadingIcon": "pause", "children": "Pause" },
                          "bindings": { "hidden": { "$expr": "program.status !== 'active'" } },
                          "actions": {
                            "onPress": {
                              "kind": "modal.open",
                              "modal": "pause-program-confirm",
                              "propsExpr": "{ programId: program.id }"
                            }
                          },
                          "requiresPermission": "referral_programs.pause"
                        },
                        {
                          "kind": "Button",
                          "props": { "variant": "danger", "leadingIcon": "archive-box", "children": "Archive" },
                          "actions": {
                            "onPress": {
                              "kind": "modal.open",
                              "modal": "archive-program-confirm",
                              "propsExpr": "{ programId: program.id }"
                            }
                          },
                          "requiresPermission": "referral_programs.archive"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "flex justify-end gap-2 pt-4" },
          "children": [
            {
              "kind": "Button",
              "props": { "variant": "ghost", "children": "Cancel" },
              "actions": { "onPress": { "kind": "navigate.back" } }
            },
            {
              "kind": "Button",
              "props": { "variant": "primary", "children": "Save changes" },
              "actions": {
                "onPress": {
                  "kind": "http.patch",
                  "urlExpr": "'/api/v1/referral-programs/' + program.id",
                  "bodyExpr": "form",
                  "onSuccess": { "kind": "navigate.back" }
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
