{
  "id": "referrals.resources.referral.detail",
  "title": "Referral detail",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/referrals/:referralId",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "referrals", "entity": "referral", "action": "show" },
  "requiresPermission": "referrals.view",
  "requiresEntitlement": "referrals_capture",
  "dataSources": [
    {
      "name": "referral",
      "kind": "http.get",
      "urlExpr": "'/api/v1/referrals/' + $params.referralId + '?include=program,code,rewards,fraud_flags'",
      "unwrap": "data"
    },
    {
      "name": "manualOverrideEntitlement",
      "kind": "http.get",
      "url": "/api/v1/entitlements/referrals_manual_override",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-6 p-6 max-w-5xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "kind": "View",
              "children": [
                {
                  "kind": "Text",
                  "props": { "as": "h1", "className": "text-2xl font-semibold" },
                  "bindings": { "children": { "$expr": "'Referral ' + referral.id" } }
                },
                {
                  "kind": "Text",
                  "props": { "className": "text-sm text-muted" },
                  "bindings": { "children": { "$expr": "referral.program.name" } }
                }
              ]
            },
            {
              "kind": "View",
              "props": { "className": "flex items-center gap-2" },
              "children": [
                {
                  "kind": "Widget",
                  "widget": "referrals.referral-status-chip",
                  "bindings": { "status": { "$ref": "referral.status" } }
                }
              ]
            }
          ]
        },
        {
          "kind": "Widget",
          "widget": "referrals.vesting-timeline",
          "bindings": {
            "referral": { "$ref": "referral" },
            "reward": { "$expr": "referral.rewards && referral.rewards[0]" }
          }
        },
        {
          "kind": "Grid",
          "props": { "className": "grid grid-cols-1 lg:grid-cols-2 gap-4" },
          "children": [
            {
              "kind": "Card",
              "props": { "className": "p-4" },
              "children": [
                {
                  "kind": "Text",
                  "props": { "as": "h3", "className": "font-semibold mb-3", "children": "Parties" }
                },
                {
                  "kind": "View",
                  "props": { "className": "flex flex-col gap-2 text-sm" },
                  "children": [
                    {
                      "kind": "View",
                      "children": [
                        {
                          "kind": "Text",
                          "props": { "className": "text-xs text-muted", "children": "Referrer" }
                        },
                        {
                          "kind": "Text",
                          "props": { "className": "font-medium" },
                          "bindings": {
                            "children": {
                              "$expr": "referral.referrer?.display_name || referral.referrer_id"
                            }
                          }
                        }
                      ]
                    },
                    {
                      "kind": "View",
                      "children": [
                        {
                          "kind": "Text",
                          "props": { "className": "text-xs text-muted", "children": "Referred" }
                        },
                        {
                          "kind": "Text",
                          "props": { "className": "font-medium" },
                          "bindings": {
                            "children": {
                              "$expr": "referral.referred?.display_name || referral.referred_email || '—'"
                            }
                          }
                        }
                      ]
                    },
                    {
                      "kind": "View",
                      "children": [
                        {
                          "kind": "Text",
                          "props": { "className": "text-xs text-muted", "children": "Code used" }
                        },
                        {
                          "kind": "Text",
                          "props": { "className": "font-mono" },
                          "bindings": {
                            "children": {
                              "$expr": "referral.code?.code || 'Attribution only (no code)'"
                            }
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "kind": "Card",
              "props": { "className": "p-4" },
              "children": [
                {
                  "kind": "Text",
                  "props": {
                    "as": "h3",
                    "className": "font-semibold mb-3",
                    "children": "Attribution snapshot"
                  }
                },
                {
                  "kind": "View",
                  "props": { "className": "flex flex-col gap-2 text-sm" },
                  "children": [
                    {
                      "kind": "View",
                      "children": [
                        {
                          "kind": "Text",
                          "props": { "className": "text-xs text-muted", "children": "UTM source" }
                        },
                        {
                          "kind": "Text",
                          "bindings": {
                            "children": {
                              "$expr": "referral.attribution_snapshot?.last_touch?.source || '—'"
                            }
                          }
                        }
                      ]
                    },
                    {
                      "kind": "View",
                      "children": [
                        {
                          "kind": "Text",
                          "props": { "className": "text-xs text-muted", "children": "Campaign" }
                        },
                        {
                          "kind": "Text",
                          "bindings": {
                            "children": {
                              "$expr": "referral.attribution_snapshot?.last_touch?.campaign || '—'"
                            }
                          }
                        }
                      ]
                    },
                    {
                      "kind": "View",
                      "children": [
                        {
                          "kind": "Text",
                          "props": {
                            "className": "text-xs text-muted",
                            "children": "Click ID provider"
                          }
                        },
                        {
                          "kind": "Chip",
                          "props": { "size": "xs" },
                          "bindings": {
                            "children": {
                              "$expr": "referral.attribution_snapshot?.last_touch?.click_id?.provider_hint || 'none'"
                            }
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "kind": "Card",
          "props": { "className": "p-4" },
          "bindings": {
            "hidden": { "$expr": "!referral.rewards || referral.rewards.length === 0" }
          },
          "children": [
            {
              "kind": "Text",
              "props": { "as": "h3", "className": "font-semibold mb-3", "children": "Rewards" }
            },
            {
              "kind": "View",
              "props": { "className": "flex flex-col gap-2" },
              "bindings": { "items": { "$ref": "referral.rewards" } },
              "itemRenderer": {
                "kind": "View",
                "props": {
                  "className": "flex items-center justify-between border-b py-2 last:border-0"
                },
                "children": [
                  {
                    "kind": "Widget",
                    "widget": "referrals.reward-badge",
                    "bindings": {
                      "rewardType": { "$ref": "row.reward_type" },
                      "rewardAmount": { "$ref": "row.reward_amount" },
                      "rewardCurrency": { "$ref": "row.reward_currency" },
                      "recipientRole": { "$ref": "row.recipient_role" }
                    }
                  },
                  {
                    "kind": "Chip",
                    "bindings": {
                      "variant": {
                        "$expr": "({ pending: 'neutral', vesting: 'warning', vested: 'info', materialized: 'success', paid: 'success', cancelled: 'neutral', clawback: 'danger' })[row.status]"
                      },
                      "children": { "$ref": "row.status" }
                    }
                  }
                ]
              }
            }
          ]
        },
        {
          "kind": "Card",
          "props": { "className": "p-4 border-warning" },
          "bindings": {
            "hidden": { "$expr": "!referral.fraud_flags || referral.fraud_flags.length === 0" }
          },
          "children": [
            {
              "kind": "Text",
              "props": {
                "as": "h3",
                "className": "font-semibold mb-3 text-warning",
                "children": "Fraud flags"
              }
            },
            {
              "kind": "View",
              "props": { "className": "flex flex-col gap-2" },
              "bindings": { "items": { "$ref": "referral.fraud_flags" } },
              "itemRenderer": {
                "kind": "View",
                "props": {
                  "className": "flex items-center justify-between border-b py-2 last:border-0"
                },
                "children": [
                  {
                    "kind": "Text",
                    "bindings": { "children": { "$expr": "row.flag_type.replace(/_/g, ' ')" } }
                  },
                  {
                    "kind": "Widget",
                    "widget": "referrals.fraud-severity-chip",
                    "bindings": {
                      "severity": { "$ref": "row.severity" },
                      "disposition": { "$expr": "row.disposition || 'unreviewed'" },
                      "confidence": { "$ref": "row.confidence" },
                      "size": "xs"
                    }
                  }
                ]
              }
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "flex justify-end gap-2 pt-4" },
          "children": [
            {
              "kind": "Button",
              "props": {
                "variant": "warning",
                "leadingIcon": "x-mark",
                "children": "Cancel referral"
              },
              "bindings": {
                "hidden": {
                  "$expr": "['rewarded','cancelled','expired','fraudulent'].includes(referral.status)"
                }
              },
              "actions": {
                "onPress": {
                  "kind": "modal.open",
                  "modal": "cancel-referral-confirm",
                  "propsExpr": "{ referralId: referral.id }"
                }
              },
              "requiresPermission": "referrals.cancel"
            },
            {
              "kind": "Button",
              "props": { "variant": "primary", "leadingIcon": "bolt", "children": "Force-vest" },
              "bindings": {
                "hidden": {
                  "$expr": "!manualOverrideEntitlement.enabled || !['trigger_pending','vesting'].includes(referral.status)"
                }
              },
              "actions": {
                "onPress": {
                  "kind": "modal.open",
                  "modal": "force-vest-confirm",
                  "propsExpr": "{ referralId: referral.id }"
                }
              },
              "requiresPermission": "referrals.force-vest"
            }
          ]
        }
      ]
    }
  ]
}
