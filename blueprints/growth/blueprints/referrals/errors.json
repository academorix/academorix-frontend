    { "code": "REFERRAL_REWARD_INVALID_PARENT_STATUS", "http": 409, "retryable": false, "user_facing": false, "audit_severity": "warn", "i18n_key": "referrals.errors.reward_invalid_parent_status" },
    { "code": "REFERRAL_REWARD_DUPLICATE_ROLE", "http": 409, "retryable": false, "user_facing": false, "audit_severity": "warn", "i18n_key": "referrals.errors.reward_duplicate_role", "description": "The (referral_id, recipient_role) unique index refused a second reward for the same role. Prevents double-materialization on retry." },
