    { "code": "REFERRAL_PROGRAM_REWARD_LOCKED", "http": 409, "retryable": false, "user_facing": true, "audit_severity": "warn", "i18n_key": "referrals.errors.program_reward_locked", "description": "Reward config cannot be edited while any referral is in-flight. Pause and complete existing referrals first." },
