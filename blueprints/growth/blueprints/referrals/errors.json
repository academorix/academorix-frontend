    { "code": "REFERRAL_REWARD_INVALID_STATUS_TRANSITION", "http": 409, "retryable": false, "user_facing": false, "audit_severity": "info", "i18n_key": "referrals.errors.reward_invalid_status_transition" },
    { "code": "REFERRAL_REWARD_DOUBLE_MATERIALIZATION", "http": 500, "retryable": false, "user_facing": false, "audit_severity": "critical", "i18n_key": "referrals.errors.reward_double_materialization", "description": "P1 signal. Attempted to set finance_credit_id twice on the same reward. Should never surface." },
    { "code": "REFERRAL_REWARD_ALREADY_CLAWED_BACK", "http": 409, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "referrals.errors.reward_already_clawed_back" },
    { "code": "REFERRAL_FRAUD_FLAG_NOT_FOUND", "http": 404, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "referrals.errors.fraud_flag_not_found" },
    { "code": "REFERRAL_FRAUD_FLAG_IMMUTABLE", "http": 409, "retryable": false, "user_facing": false, "audit_severity": "warn", "i18n_key": "referrals.errors.fraud_flag_immutable", "description": "Detection findings are immutable — only disposition + reviewed fields are mutable." },
    { "code": "REFERRAL_FRAUD_FLAG_ALREADY_REVIEWED", "http": 409, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "referrals.errors.fraud_flag_already_reviewed" },
    { "code": "REFERRAL_INVITATION_RATE_LIMIT", "http": 429, "retryable": true, "user_facing": true, "audit_severity": "info", "i18n_key": "referrals.errors.invitation_rate_limit", "description": "> 100 invitations/day per user. Retry the next day." },
