    { "code": "REFERRAL_INVALID_STATUS_TRANSITION", "http": 409, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "referrals.errors.invalid_status_transition" },
    { "code": "REFERRAL_ATTRIBUTION_SNAPSHOT_IMMUTABLE", "http": 409, "retryable": false, "user_facing": false, "audit_severity": "critical", "i18n_key": "referrals.errors.attribution_snapshot_immutable", "description": "Attempt to mutate the attribution_snapshot after create. Should never surface — the observer refuses." },
    { "code": "REFERRAL_ATOMICITY_FAILED", "http": 500, "retryable": false, "user_facing": false, "audit_severity": "critical", "i18n_key": "referrals.errors.atomicity_failed", "description": "P1 signal. The vested-transition + reward creation transaction failed. Every fire is a data-integrity incident." },
