    { "code": "REFERRAL_ADVANCED_REWARD_NOT_ENTITLED", "http": 402, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "referrals.errors.advanced_reward_not_entitled", "description": "Advanced reward types require Medium+ tier (`referrals_advanced_reward_types`)." },
    { "code": "REFERRAL_DOUBLE_SIDED_NOT_ENTITLED", "http": 402, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "referrals.errors.double_sided_not_entitled" },
    { "code": "REFERRAL_MANUAL_OVERRIDE_NOT_ENTITLED", "http": 402, "retryable": false, "user_facing": true, "audit_severity": "warn", "i18n_key": "referrals.errors.manual_override_not_entitled", "description": "force-vest + fraud manual-override require Enterprise `referrals_manual_override`." },
    { "code": "REFERRAL_PROGRAM_BUDGET_CAP_NOT_ENTITLED", "http": 402, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "referrals.errors.program_budget_cap_not_entitled" },
