    { "code": "REFERRAL_CODE_QUOTA_EXCEEDED", "http": 402, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "referrals.errors.code_quota_exceeded", "description": "Small tenants cannot create campaign codes; only user_scoped codes are auto-issued." },
    { "code": "REFERRAL_PROGRAM_INVALID_DATE_RANGE", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "referrals.errors.program_invalid_date_range" },
