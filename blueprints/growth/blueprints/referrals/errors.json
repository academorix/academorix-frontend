    { "code": "REFERRAL_PROGRAM_INVALID_ELIGIBILITY_CONFIG", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "referrals.errors.program_invalid_eligibility_config" },
    { "code": "REFERRAL_PROGRAM_REWARD_TYPE_AMOUNT_MISMATCH", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "referrals.errors.program_reward_type_amount_mismatch", "description": "reward_type + reward_amount + reward_currency combination is invalid (e.g. percent_discount=150; fixed_amount without currency)." },
