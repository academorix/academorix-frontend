    { "code": "REFERRAL_INVITATION_SUPPRESSED", "http": 200, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "referrals.errors.invitation_suppressed", "description": "Silent-success. The recipient email is on the tenant's suppression list (previous unsubscribe). Returns 200 to avoid enumeration." },
    { "code": "REFERRAL_INVITATION_DISPOSABLE_EMAIL", "http": 200, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "referrals.errors.invitation_disposable_email", "description": "Silent-success. Delivery refused because the recipient email is a known disposable-email domain." }
