{
  "id": "academorix://modules/monitoring/schemas/monitoring-incident",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "MonitoringIncident",
  "description": "Grouped alert timeline. Belongs to Tenant. Groups multiple related alerts within a 5-min window. Carries `tenant_id` only. NEVER carries `application_id`, `region_id`, `organization_id`, or `scope_node_id`.",
  "type": "object",
  "x-module": "monitoring",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "monitoring_incidents",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "mci_",
    "incrementing": false,
    "model": "Academorix\\Observability\\Monitoring\\Models\\MonitoringIncident",
    "interface": "Academorix\\Observability\\Monitoring\\Contracts\\Data\\MonitoringIncidentInterface",
    "implements": [
      "Academorix\\Observability\\Monitoring\\Contracts\\Data\\MonitoringIncidentInterface"
    ],
    "traits": [
      "HasFactory",
      "HasUlids",
      "BelongsToTenant",
      "HasMonitoringAlerts",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "HasActivityLog",
      "Filterable",
      "Searchable",
      "SoftDeletes"
    ],
    "casts": {
      "severity": "MonitoringSeverity",
      "status": "MonitoringIncidentStatus",
      "opened_at": "datetime",
      "acknowledged_at": "datetime",
      "resolved_at": "datetime",
      "affected_services": "array",
      "alert_count": "integer",
      "notify_provider_configs": "array",
      "oncall_page_config": "array",
      "metadata": "array"
    },
    "observers": ["MonitoringIncidentObserver"],
    "appends": ["is_terminal", "time_to_ack_seconds", "time_to_resolve_seconds"]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 64, "primary": true },
      "tenant_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "title": {
        "type": "string",
        "length": 256,
        "nullable": false,
        "description": "Human-readable title (e.g. 'Database latency spike')."
      },
      "description": {
        "type": "text",
        "nullable": true,
        "description": "Ops-authored details."
      },
      "severity": {
        "type": "string",
        "length": 8,
        "nullable": false,
        "description": "Enum matching alert severity. Set at open + immutable."
      },
      "status": {
        "type": "string",
        "length": 16,
        "nullable": false,
        "default": "'open'",
        "description": "Enum: open / acknowledged / investigating / mitigating / resolved / postmortem."
      },
      "opened_at": { "type": "timestamptz", "nullable": false },
      "acknowledged_at": { "type": "timestamptz", "nullable": true },
      "acknowledged_by_user_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": { "table": "users", "column": "id", "onDelete": "restrict" }
      },
      "resolved_at": { "type": "timestamptz", "nullable": true },
      "resolved_by": {
        "type": "string",
        "length": 8,
        "nullable": true,
        "description": "Enum: auto / manual."
      },
      "resolved_by_user_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": { "table": "users", "column": "id", "onDelete": "restrict" }
      },
      "postmortem_url": {
        "type": "string",
        "length": 512,
        "nullable": true,
        "description": "Internal doc link for the P1 postmortem."
      },
      "affected_services": {
        "type": "jsonb",
        "nullable": false,
        "default": "'[]'::jsonb",
        "description": "jsonb array of service names. Used by the incident-grouper to co-locate related alerts."
      },
      "alert_count": {
        "type": "integer",
        "nullable": false,
        "default": 0,
        "description": "Denormalized. Count of attached alerts."
      },
      "notify_provider_configs": {
        "type": "jsonb",
        "nullable": false,
        "default": "'[]'::jsonb",
        "description": "jsonb array of MonitoringProviderConfig ULIDs. Fan-out targets for status transitions."
      },
      "oncall_page_config": {
        "type": "jsonb",
        "nullable": false,
        "default": "'{}'::jsonb",
        "description": "Shape: { primary_provider: <config_id>, escalation_policy: { after_seconds, escalation_provider: <config_id> } }."
      },
      "escalation_count": {
        "type": "integer",
        "nullable": false,
        "default": 0,
        "description": "Denormalized. Number of escalations fired."
      },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_by": { "type": "string", "length": 64, "nullable": true },
      "updated_by": { "type": "string", "length": 64, "nullable": true },
      "deleted_by": { "type": "string", "length": 64, "nullable": true },
      "deleted_at": { "type": "timestamptz", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "status", "opened_at"],
        "name": "monitoring_incidents_status_idx"
      },
      {
        "columns": ["tenant_id", "severity", "status"],
        "name": "monitoring_incidents_severity_idx"
      },
      {
        "columns": ["opened_at"],
        "name": "monitoring_incidents_grouping_window_idx",
        "predicate": "status IN ('open', 'acknowledged', 'investigating', 'mitigating')"
      }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "title",
    "severity",
    "status",
    "opened_at",
    "affected_services",
    "alert_count",
    "notify_provider_configs",
    "oncall_page_config",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^mci_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": "string", "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "title": { "type": "string", "minLength": 1, "maxLength": 256 },
    "description": { "type": ["string", "null"] },
    "severity": { "type": "string", "enum": ["p1", "p2", "p3", "p4"] },
    "status": {
      "type": "string",
      "enum": ["open", "acknowledged", "investigating", "mitigating", "resolved", "postmortem"]
    },
    "opened_at": { "type": "string", "format": "date-time" },
    "acknowledged_at": { "type": ["string", "null"], "format": "date-time" },
    "acknowledged_by_user_id": { "type": ["string", "null"] },
    "resolved_at": { "type": ["string", "null"], "format": "date-time" },
    "resolved_by": { "type": ["string", "null"], "enum": ["auto", "manual", null] },
    "resolved_by_user_id": { "type": ["string", "null"] },
    "postmortem_url": { "type": ["string", "null"], "format": "uri" },
    "affected_services": { "type": "array", "items": { "type": "string" } },
    "alert_count": { "type": "integer", "minimum": 0 },
    "notify_provider_configs": {
      "type": "array",
      "items": { "type": "string", "pattern": "^mpr_[0-9A-HJKMNP-TV-Z]{26}$" }
    },
    "oncall_page_config": {
      "type": "object",
      "properties": {
        "primary_provider": {
          "type": ["string", "null"],
          "pattern": "^mpr_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        "escalation_policy": {
          "type": ["object", "null"],
          "properties": {
            "after_seconds": { "type": "integer", "minimum": 60 },
            "escalation_provider": { "type": "string", "pattern": "^mpr_[0-9A-HJKMNP-TV-Z]{26}$" }
          }
        }
      }
    },
    "escalation_count": { "type": "integer", "minimum": 0 },
    "metadata": { "type": ["object", "null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "x-invariants": [
    "state transitions: open → acknowledged | resolved; acknowledged → investigating | mitigating | resolved; investigating → mitigating | resolved; mitigating → resolved; resolved → postmortem (P1 only); postmortem terminal",
    "severity immutable after create",
    "alert_count is monotonically non-decreasing",
    "resolved_at IS NOT NULL WHEN status IN (resolved, postmortem)",
    "resolved_by='manual' requires resolved_by_user_id present",
    "hard-delete refused when status != 'resolved' + 90-day soft-delete grace + P1 refused when tenant holds monitoring_extended_retention"
  ]
}
