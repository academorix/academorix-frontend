{
  "id": "stackra://modules/monitoring/schemas/health-check-run",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "HealthCheckRun",
  "description": "Per-execution health check result. Belongs to HealthCheck + Tenant. Append-only after create. Carries `tenant_id` + `health_check_id`. NEVER carries `application_id`, `region_id`, `organization_id`, or `scope_node_id`.",
  "type": "object",
  "x-module": "monitoring",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "health_check_runs",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "hcr_",
    "incrementing": false,
    "model": "Stackra\\Observability\\Monitoring\\Models\\HealthCheckRun",
    "interface": "Stackra\\Observability\\Monitoring\\Contracts\\Data\\HealthCheckRunInterface",
    "implements": [
      "Stackra\\Observability\\Monitoring\\Contracts\\Data\\HealthCheckRunInterface"
    ],
    "traits": [
      "HasFactory",
      "HasUlids",
      "BelongsToTenant",
      "BelongsToHealthCheck",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "Filterable"
    ],
    "casts": {
      "status": "HealthCheckStatus",
      "latency_ms": "integer",
      "response_body": "array",
      "error_details": "array",
      "run_at": "datetime",
      "metadata": "array"
    },
    "observers": ["HealthCheckRunObserver"],
    "appends": ["is_terminal", "age_seconds"]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": {
        "type": "string",
        "length": 64,
        "primary": true,
        "description": "Prefixed ULID: `hcr_<26>`."
      },
      "tenant_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "health_check_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "health_checks", "column": "id", "onDelete": "restrict" }
      },
      "status": {
        "type": "string",
        "length": 16,
        "nullable": false,
        "description": "Enum: healthy / degraded / unhealthy / timeout / error."
      },
      "latency_ms": {
        "type": "integer",
        "nullable": true,
        "description": "End-to-end probe latency (start of probe → response received). NULL when the probe errored before receiving a response."
      },
      "response_body": {
        "type": "jsonb",
        "nullable": true,
        "description": "Truncated to 8KB. PII regex-redacted at write. May contain HTTP response body, DB query result, redis PING PONG, etc."
      },
      "error_details": {
        "type": "jsonb",
        "nullable": true,
        "description": "Shape: { error_code, error_message, exception_class?, exit_code? }. error_message truncated to 2KB."
      },
      "run_at": {
        "type": "timestamptz",
        "nullable": false,
        "description": "When the probe ran (start-of-probe timestamp)."
      },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_by": { "type": "string", "length": 64, "nullable": true },
      "updated_by": { "type": "string", "length": 64, "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "health_check_id", "run_at"],
        "name": "health_check_runs_check_history_idx"
      },
      { "columns": ["tenant_id", "status", "run_at"], "name": "health_check_runs_status_idx" },
      {
        "columns": ["created_at"],
        "name": "health_check_runs_retention_idx",
        "description": "Used by PurgeExpiredHealthCheckRunsJob."
      }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "health_check_id",
    "status",
    "run_at",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^hcr_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": "string", "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "health_check_id": { "type": "string", "pattern": "^hck_[0-9A-HJKMNP-TV-Z]{26}$" },
    "status": {
      "type": "string",
      "enum": ["healthy", "degraded", "unhealthy", "timeout", "error"]
    },
    "latency_ms": { "type": ["integer", "null"], "minimum": 0 },
    "response_body": { "type": ["object", "null"] },
    "error_details": {
      "type": ["object", "null"],
      "properties": {
        "error_code": { "type": ["string", "null"] },
        "error_message": { "type": ["string", "null"], "maxLength": 2048 },
        "exception_class": { "type": ["string", "null"] },
        "exit_code": { "type": ["integer", "null"] }
      }
    },
    "run_at": { "type": "string", "format": "date-time" },
    "metadata": { "type": ["object", "null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "x-invariants": [
    "append-only after create",
    "response_body scanned for PII regex + redacted with '[REDACTED]'",
    "response_body truncated to 8192 bytes",
    "error_details.error_message truncated to 2048 chars",
    "run_at is set on insert + immutable",
    "status enum is one-way — once persisted, cannot mutate"
  ]
}
