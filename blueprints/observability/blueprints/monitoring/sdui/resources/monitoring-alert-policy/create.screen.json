{
  "id": "monitoring.resources.monitoring-alert-policy.create",
  "title": "Add alert policy",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/monitoring/alert-policies/new",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "monitoring", "entity": "monitoring-alert-policy", "action": "create" },
  "requiresPermission": "monitoring.alert_policies.create",
  "requiresEntitlement": "monitoring_capture",
  "dataSources": [
    {
      "name": "signal_types",
      "kind": "http.get",
      "url": "/api/v1/monitoring/alert-policies/signal-types",
      "unwrap": "data"
    },
    {
      "name": "providers",
      "kind": "http.get",
      "url": "/api/v1/monitoring/providers?filter[is_active]=1",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "MultiStepForm",
      "props": { "className": "max-w-3xl mx-auto p-6" },
      "children": [
        {
          "kind": "Step",
          "props": { "title": "Signal", "description": "What are you watching?" },
          "children": [
            {
              "kind": "Input",
              "props": { "label": "Policy name", "placeholder": "5xx rate high" },
              "actions": {
                "onChange": { "kind": "form.set", "field": "name", "valueExpr": "$value" }
              }
            },
            {
              "kind": "Select",
              "props": { "label": "Signal type" },
              "bindings": { "options": { "$ref": "signal_types" } },
              "actions": {
                "onSelectionChange": {
                  "kind": "form.set",
                  "field": "signal_type",
                  "valueExpr": "$selectedKey"
                }
              }
            },
            {
              "kind": "Input",
              "props": {
                "label": "Signal source",
                "description": "For health_check_status: health_check.slug. For metric signals: metric-name pattern."
              },
              "actions": {
                "onChange": { "kind": "form.set", "field": "signal_source", "valueExpr": "$value" }
              }
            }
          ]
        },
        {
          "kind": "Step",
          "props": { "title": "Threshold", "description": "When to fire." },
          "children": [
            {
              "kind": "Select",
              "props": {
                "label": "Operator",
                "options": ["greater_than", "less_than", "equals", "not_equals"]
              },
              "actions": {
                "onSelectionChange": {
                  "kind": "form.set",
                  "field": "threshold_operator",
                  "valueExpr": "$selectedKey"
                }
              }
            },
            {
              "kind": "Input",
              "props": { "label": "Value", "type": "number" },
              "actions": {
                "onChange": {
                  "kind": "form.set",
                  "field": "threshold_value",
                  "valueExpr": "$value"
                }
              }
            },
            {
              "kind": "Select",
              "props": { "label": "Unit", "options": ["percent", "ms", "count", "bytes"] },
              "actions": {
                "onSelectionChange": {
                  "kind": "form.set",
                  "field": "threshold_unit",
                  "valueExpr": "$selectedKey"
                }
              }
            },
            {
              "kind": "Slider",
              "props": {
                "label": "Window (seconds)",
                "min": 60,
                "max": 3600,
                "step": 60,
                "defaultValue": 300
              },
              "actions": {
                "onChange": { "kind": "form.set", "field": "window_seconds", "valueExpr": "$value" }
              }
            },
            {
              "kind": "Slider",
              "props": {
                "label": "Consecutive breaches required",
                "min": 1,
                "max": 10,
                "defaultValue": 2
              },
              "actions": {
                "onChange": {
                  "kind": "form.set",
                  "field": "consecutive_breaches_required",
                  "valueExpr": "$value"
                }
              }
            }
          ]
        },
        {
          "kind": "Step",
          "props": { "title": "Severity + routing" },
          "children": [
            {
              "kind": "RadioGroup",
              "props": {
                "label": "Severity",
                "options": [
                  { "value": "p1", "label": "P1 — Critical (pages on-call)" },
                  { "value": "p2", "label": "P2 — High" },
                  { "value": "p3", "label": "P3 — Medium" },
                  { "value": "p4", "label": "P4 — Info (dashboard-only)" }
                ]
              },
              "actions": {
                "onChange": { "kind": "form.set", "field": "severity", "valueExpr": "$value" }
              }
            },
            {
              "kind": "MultiSelect",
              "props": { "label": "Notify these providers" },
              "bindings": { "options": { "$ref": "providers" } },
              "actions": {
                "onSelectionChange": {
                  "kind": "form.set",
                  "field": "notify_provider_configs",
                  "valueExpr": "$selectedKeys"
                }
              }
            }
          ]
        },
        {
          "kind": "Step",
          "props": { "title": "Suppression" },
          "children": [
            {
              "kind": "Switch",
              "props": { "label": "Suppress after hours" },
              "actions": {
                "onChange": {
                  "kind": "form.set",
                  "field": "suppression_config.after_hours_suppress",
                  "valueExpr": "$value"
                }
              }
            },
            {
              "kind": "Switch",
              "props": { "label": "Suppress on weekends" },
              "actions": {
                "onChange": {
                  "kind": "form.set",
                  "field": "suppression_config.weekend_suppress",
                  "valueExpr": "$value"
                }
              }
            }
          ]
        },
        {
          "kind": "Step",
          "props": { "title": "Confirm" },
          "children": [
            {
              "kind": "Button",
              "props": { "variant": "primary", "size": "lg", "children": "Create alert policy" },
              "actions": {
                "onPress": {
                  "kind": "http.post",
                  "url": "/api/v1/monitoring/alert-policies",
                  "body": "{{form}}",
                  "onSuccess": { "kind": "navigate", "to": "/tenant/monitoring/alert-policies" }
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
