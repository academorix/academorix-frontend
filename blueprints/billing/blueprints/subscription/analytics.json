{
  "id": "academorix://modules/subscription/analytics",
  "$version": 1,
  "title": "subscription \u2014 product analytics",
  "sink": "segment",
  "consentTiers": ["essential", "functional", "analytics", "marketing"],
  "events": [
    {
      "name": "Checkout Started",
      "kind": "track",
      "consent_required": "functional",
      "properties": ["tenant_id", "plan_id", "from_plan_id", "provider"],
      "description": "User clicked upgrade. Feeds conversion funnel."
    },
    {
      "name": "Checkout Completed",
      "kind": "track",
      "consent_required": "functional",
      "properties": ["tenant_id", "plan_id", "amount", "currency", "provider"],
      "description": "Payment succeeded. Marketing pixel fires here."
    },
    {
      "name": "Checkout Abandoned",
      "kind": "track",
      "consent_required": "functional",
      "properties": ["tenant_id", "plan_id", "step"],
      "description": "User dropped out of checkout. Powers cart-abandonment recovery emails."
    },
    {
      "name": "Plan Swapped",
      "kind": "track",
      "consent_required": "functional",
      "properties": ["tenant_id", "from_plan_id", "to_plan_id", "direction"],
      "description": "direction: upgrade / downgrade / lateral."
    },
    {
      "name": "Trial Started",
      "kind": "track",
      "consent_required": "functional",
      "properties": ["tenant_id", "plan_id", "trial_days"]
    },
    {
      "name": "Trial Converted",
      "kind": "track",
      "consent_required": "functional",
      "properties": ["tenant_id", "plan_id", "trial_days_used"]
    },
    {
      "name": "Trial Ended Without Conversion",
      "kind": "track",
      "consent_required": "functional",
      "properties": ["tenant_id", "plan_id", "trial_days_used"]
    },
    {
      "name": "Subscription Cancelled",
      "kind": "track",
      "consent_required": "functional",
      "properties": ["tenant_id", "plan_id", "reason_bucket", "cancel_at_period_end"],
      "description": "Cancellation reason bucket for retention analysis."
    },
    {
      "name": "Subscription Reinstated",
      "kind": "track",
      "consent_required": "functional",
      "properties": ["tenant_id", "plan_id"],
      "description": "Cancellation reversed. Powers win-back analytics."
    },
    {
      "name": "Payment Failed",
      "kind": "track",
      "consent_required": "functional",
      "properties": ["tenant_id", "plan_id", "failure_reason", "consecutive_failures"]
    },
    {
      "name": "Tenant Suspended",
      "kind": "track",
      "consent_required": "functional",
      "properties": ["tenant_id", "plan_id", "days_past_due"],
      "description": "Grace exhausted. Terminal dunning event."
    }
  ]
}
