{
  "id": "academorix://modules/entitlements/settings",
  "$version": 1,
  "title": "entitlements \u2014 settings",
  "description": "Tenant-facing settings for the entitlements platform. One #[AsSetting] class published under group key `entitlements`.",
  "storedIn": "settings",
  "reference": { "contract": "academorix://modules/settings/attributes" },
  "groups": [
    {
      "key": "entitlements",
      "class": "Academorix\\Entitlements\\Settings\\EntitlementsSettings",
      "label": "Quotas + usage",
      "description": "Tenant-facing quota notification preferences.",
      "icon": "chart-bar-square",
      "scope": "tenant",
      "public": false,
      "sortOrder": 23,
      "permission": "entitlements.viewAny",
      "sections": [
        {
          "label": "Notifications",
          "description": "Which quota events send tenant-owner notifications.",
          "icon": "bell-alert",
          "sortOrder": 1,
          "fields": [
            {
              "name": "notify_approaching_cap",
              "controlType": "toggle",
              "label": "Notify when approaching cap (80%)",
              "defaultValue": true,
              "validation": ["boolean"],
              "sortOrder": 1
            },
            {
              "name": "notify_exceeded_cap",
              "controlType": "toggle",
              "label": "Notify when cap exceeded",
              "defaultValue": true,
              "validation": ["boolean"],
              "sortOrder": 2,
              "readOnly": true,
              "helpText": "Cannot disable \u2014 exceeded caps block operations, owner must know."
            },
            {
              "name": "notify_period_reset",
              "controlType": "toggle",
              "label": "Notify on period reset",
              "defaultValue": false,
              "validation": ["boolean"],
              "sortOrder": 3,
              "helpText": "Off by default (noisy)."
            }
          ]
        },
        {
          "label": "Dashboard preferences",
          "icon": "adjustments-horizontal",
          "sortOrder": 2,
          "fields": [
            {
              "name": "dashboard_default_period",
              "controlType": "select",
              "label": "Usage chart default period",
              "defaultValue": "month",
              "options": {
                "day": "Last 24 hours",
                "week": "Last 7 days",
                "month": "Last 30 days",
                "quarter": "Last 90 days"
              },
              "validation": ["required", "string", "in:day,week,month,quarter"],
              "sortOrder": 1
            }
          ]
        }
      ]
    }
  ]
}
