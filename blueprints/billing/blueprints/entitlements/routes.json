{
  "id": "stackra://modules/entitlements/routes",
  "$version": 1,
  "title": "entitlements \u2014 HTTP routes",
  "description": "Tenant-facing read surface (tenant sees own quotas) + platform-admin override + reset surface.",
  "groups": [
    {
      "name": "tenant-entitlements",
      "prefix": "/api/v1/entitlements",
      "middleware": [
        "request.id",
        "cors.strict",
        "versioning.resolve",
        "auth:sanctum",
        "tenant.resolve",
        "throttle:foundation-base",
        "response.envelope"
      ],
      "hosts": ["tenant"],
      "description": "Read-only. Tenant admins see their own quotas. Also embedded in /auth/me.data.quota_summary.",
      "routes": [
        {
          "method": "GET",
          "path": "/",
          "controller": "Stackra\\Entitlements\\Http\\Controllers\\Tenant\\EntitlementController@index",
          "permission": "entitlements.viewAny"
        },
        {
          "method": "GET",
          "path": "/{key}",
          "controller": "Stackra\\Entitlements\\Http\\Controllers\\Tenant\\EntitlementController@show",
          "permission": "entitlements.view",
          "description": "Detail for one entitlement key including remaining + reset time."
        },
        {
          "method": "GET",
          "path": "/{key}/usage",
          "controller": "Stackra\\Entitlements\\Http\\Controllers\\Tenant\\EntitlementController@usage",
          "permission": "entitlements.view",
          "description": "Aggregate usage over time. Powers usage-chart widget. filter[bucket]=day|hour|month."
        }
      ]
    },
    {
      "name": "platform-entitlements",
      "prefix": "/api/v1/platform/entitlements",
      "middleware": [
        "request.id",
        "cors.strict",
        "versioning.resolve",
        "auth:platform_admin",
        "throttle:foundation-platform",
        "response.envelope"
      ],
      "hosts": ["central_admin"],
      "description": "Cross-tenant inspection + override management.",
      "routes": [
        {
          "method": "GET",
          "path": "/",
          "controller": "Stackra\\Entitlements\\Http\\Controllers\\Platform\\EntitlementController@index",
          "permission": "platform.entitlements.viewAny"
        },
        {
          "method": "GET",
          "path": "/{tenant}/{key}",
          "controller": "Stackra\\Entitlements\\Http\\Controllers\\Platform\\EntitlementController@show",
          "permission": "platform.entitlements.view"
        },
        {
          "method": "PATCH",
          "path": "/{tenant}/{key}",
          "controller": "Stackra\\Entitlements\\Http\\Controllers\\Platform\\EntitlementController@override",
          "permission": "platform.entitlements.override",
          "description": "Body: { value_cap, is_unlimited, notes }. Sets is_platform_overridden=true so it survives plan syncs."
        },
        {
          "method": "POST",
          "path": "/{tenant}/reset/{key}",
          "controller": "Stackra\\Entitlements\\Http\\Controllers\\Platform\\EntitlementController@reset",
          "permission": "platform.entitlements.reset",
          "description": "Force reset value_used to 0 for a pool. Used for support credits."
        },
        {
          "method": "POST",
          "path": "/{tenant}/sync-plan",
          "controller": "Stackra\\Entitlements\\Http\\Controllers\\Platform\\EntitlementController@syncPlan",
          "permission": "platform.entitlements.sync",
          "description": "Force re-sync from Plan.default_entitlements. Dispatches SyncEntitlementsFromPlanJob."
        }
      ]
    }
  ]
}
