{
  "id": "academorix://modules/entitlements/policies",
  "$version": 1,
  "title": "entitlements \u2014 authorization policies",
  "policies": [
    {
      "model": "Entitlement",
      "class": "Academorix\\Entitlements\\Policies\\EntitlementPolicy",
      "abilities": [
        {
          "action": "viewAny",
          "permission": "entitlements.viewAny",
          "scope": "any tenant member sees own tenant's quotas"
        },
        { "action": "view", "permission": "entitlements.view" },
        {
          "action": "platformViewAny",
          "permission": "platform.entitlements.viewAny",
          "scope": "platform admin cross-tenant"
        },
        { "action": "platformView", "permission": "platform.entitlements.view" },
        {
          "action": "platformOverride",
          "permission": "platform.entitlements.override",
          "scope": "platform ops team \u2014 enterprise contract overrides. Every use audit-logged."
        },
        {
          "action": "platformReset",
          "permission": "platform.entitlements.reset",
          "scope": "support credit workflow. Every use audit-logged."
        },
        { "action": "platformSync", "permission": "platform.entitlements.sync" }
      ]
    },
    {
      "model": "EntitlementUsage",
      "class": "Academorix\\Entitlements\\Policies\\EntitlementUsagePolicy",
      "abilities": [
        {
          "action": "viewAny",
          "permission": "entitlements.usage.viewAny",
          "scope": "tenant admin sees own usage timeline"
        },
        { "action": "view", "permission": "entitlements.usage.view" },
        {
          "action": "platformViewAny",
          "permission": "platform.entitlements.usage.viewAny",
          "scope": "billing team investigation"
        }
      ]
    }
  ]
}
