{
  "id": "academorix://modules/athlete-enrollment/traits",
  "$version": 1,
  "title": "athlete-enrollment — trait composition",
  "description": "Two owned traits — BelongsToAthleteEnrollment for downstream models with enrollment_id FK, HasEnrollmentHistory on Athlete for the reverse-relation accessors.",
  "owned": [
    {
      "trait": "Academorix\\Sports\\AthleteEnrollment\\Concerns\\BelongsToAthleteEnrollment",
      "description": "Mixed into downstream models that carry an `enrollment_id` FK. Adds `enrollment()` belongsTo + query scope + cross-tenant guard.",
      "public": true,
      "usedBy": [
        "attendance::AttendanceRecord (Wave 4+)",
        "finance::Membership (Wave 4+)",
        "event::EventParticipant (Wave 3+)"
      ]
    },
    {
      "trait": "Academorix\\Sports\\AthleteEnrollment\\Concerns\\HasEnrollmentHistory",
      "description": "Composed onto the Athlete model. Adds `enrollments()` (hasMany), `activeEnrollments()` (status IN active/confirmed), `enrollmentHistory()` (all including terminal states), `currentTeams()` (distinct teams from active enrollments).",
      "public": true,
      "usedBy": ["athlete::Athlete"]
    }
  ],
  "consumed": {
    "framework": [
      { "trait": "Illuminate\\Database\\Eloquent\\Factories\\HasFactory" },
      { "trait": "Illuminate\\Database\\Eloquent\\Concerns\\HasUlids" },
      { "trait": "Illuminate\\Database\\Eloquent\\SoftDeletes" }
    ],
    "foundation": [
      { "trait": "Academorix\\Foundation\\Concerns\\HasPrefixedUlid" },
      { "trait": "Academorix\\Foundation\\Concerns\\HasUserstamps" },
      { "trait": "Academorix\\Foundation\\Concerns\\HasMetadata" },
      { "trait": "Academorix\\Foundation\\Concerns\\Filterable" },
      { "trait": "Academorix\\Foundation\\Concerns\\Searchable" }
    ],
    "tenants": [{ "trait": "Academorix\\Tenancy\\Concerns\\BelongsToTenant" }],
    "branch": [{ "trait": "Academorix\\Branch\\Concerns\\BelongsToBranch" }],
    "teams": [{ "trait": "Academorix\\Teams\\Concerns\\BelongsToTeam" }],
    "athlete": [{ "trait": "Academorix\\Sports\\Athlete\\Concerns\\BelongsToAthlete" }],
    "season": [{ "trait": "Academorix\\Sports\\Season\\Concerns\\BelongsToSeason" }],
    "audit": [{ "trait": "Academorix\\Audit\\Concerns\\Auditable" }],
    "activity": [{ "trait": "Academorix\\Activity\\Concerns\\HasActivityLog" }]
  },
  "composition": {
    "athleteEnrollment": {
      "traits": [
        "HasFactory",
        "HasPrefixedUlid",
        "BelongsToTenant",
        "BelongsToBranch",
        "BelongsToTeam",
        "BelongsToAthlete",
        "BelongsToSeason",
        "HasMetadata",
        "HasUserstamps",
        "Auditable",
        "HasActivityLog",
        "Filterable",
        "Searchable",
        "SoftDeletes"
      ],
      "notes": "Order matters. BelongsToTenant precedes all scope-observing traits. Then Branch → Team → Athlete → Season (structural hierarchy: branch owns team; team owns roster; athlete is subject; season is temporal). No BelongsToOrganization / BelongsToRegion — cascade through branch."
    }
  }
}
