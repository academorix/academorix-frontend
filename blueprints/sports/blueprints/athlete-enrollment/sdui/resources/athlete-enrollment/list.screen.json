{
  "id": "athlete_enrollment.resources.athlete-enrollment.list",
  "title": "Enrollments",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/enrollments",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "athlete-enrollment", "entity": "athlete-enrollment", "action": "list" },
  "requiresPermission": "enrollments.viewAny",
  "dataSources": [
    {
      "name": "enrollments",
      "kind": "http.get",
      "url": "/api/v1/enrollments",
      "unwrap": "data",
      "queryFromFilters": true
    },
    {
      "name": "teams",
      "kind": "http.get",
      "url": "/api/v1/teams?filter[status]=active",
      "unwrap": "data",
      "cache": { "ttlSeconds": 300 }
    },
    {
      "name": "seasons",
      "kind": "http.get",
      "url": "/api/v1/seasons?filter[status]=registration_open,in_progress",
      "unwrap": "data",
      "cache": { "ttlSeconds": 300 }
    },
    {
      "name": "slot_entitlement",
      "kind": "http.get",
      "url": "/api/v1/entitlements/athlete_enrollment_slot",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-7xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "kind": "View",
              "children": [
                {
                  "kind": "Text",
                  "props": {
                    "as": "h1",
                    "className": "text-2xl font-semibold",
                    "children": "Enrollments"
                  }
                },
                {
                  "kind": "Text",
                  "props": {
                    "className": "text-sm text-muted",
                    "children": "Athletes on your rosters — active enrollments + waitlist + completed history."
                  }
                }
              ]
            },
            {
              "kind": "View",
              "props": { "className": "flex items-center gap-3" },
              "children": [
                {
                  "kind": "Widget",
                  "widget": "entitlements.entitlement-usage-bar",
                  "props": {
                    "cap": { "$ref": "slot_entitlement.value_cap" },
                    "used": { "$ref": "slot_entitlement.value_used" },
                    "size": "sm",
                    "label": "Enrollment slots this season"
                  }
                },
                {
                  "kind": "Button",
                  "props": {
                    "variant": "primary",
                    "leadingIcon": "plus",
                    "children": "Submit enrollment"
                  },
                  "actions": {
                    "onPress": { "kind": "navigate", "to": "/tenant/enrollments/submit" }
                  },
                  "bindings": { "disabled": { "$ref": "slot_entitlement.is_exceeded" } },
                  "requiresPermission": "enrollments.create"
                }
              ]
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "flex items-center gap-2 py-2 flex-wrap" },
          "children": [
            {
              "kind": "ComboBox",
              "props": { "label": "Team", "menuTrigger": "focus", "className": "min-w-56" },
              "bindings": { "items": { "$ref": "teams" } },
              "actions": {
                "onSelectionChange": {
                  "kind": "filter.set",
                  "field": "team_id",
                  "valueExpr": "$selectedKey"
                }
              }
            },
            {
              "kind": "ComboBox",
              "props": { "label": "Season", "menuTrigger": "focus", "className": "min-w-56" },
              "bindings": { "items": { "$ref": "seasons" } },
              "actions": {
                "onSelectionChange": {
                  "kind": "filter.set",
                  "field": "season_id",
                  "valueExpr": "$selectedKey"
                }
              }
            },
            {
              "kind": "ComboBox",
              "props": { "label": "Status", "menuTrigger": "focus", "className": "min-w-48" },
              "props_items": [
                { "id": "submitted", "label": "Submitted" },
                { "id": "payment_pending", "label": "Payment pending" },
                { "id": "consent_pending", "label": "Consent pending" },
                { "id": "confirmed", "label": "Confirmed" },
                { "id": "active", "label": "Active" },
                { "id": "waitlisted", "label": "Waitlisted" },
                { "id": "completed", "label": "Completed" },
                { "id": "withdrawn", "label": "Withdrawn" },
                { "id": "expelled", "label": "Expelled" },
                { "id": "expired", "label": "Expired" }
              ],
              "actions": {
                "onSelectionChange": {
                  "kind": "filter.set",
                  "field": "status",
                  "valueExpr": "$selectedKey"
                }
              }
            }
          ]
        },
        {
          "kind": "Table",
          "props": { "aria-label": "Enrollments table" },
          "bindings": {
            "rows": { "$ref": "enrollments" },
            "isLoading": { "$ref": "enrollments.isLoading" }
          },
          "emptyState": {
            "kind": "View",
            "props": { "className": "text-center py-12" },
            "children": [
              {
                "kind": "Icon",
                "props": {
                  "name": "clipboard-document-list",
                  "className": "size-12 mx-auto text-muted"
                }
              },
              {
                "kind": "Text",
                "props": { "className": "mt-4 text-lg font-medium", "children": "No enrollments" }
              }
            ]
          },
          "columns": [
            {
              "key": "athlete",
              "label": "Athlete",
              "renderer": {
                "kind": "View",
                "props": { "className": "flex items-center gap-2" },
                "children": [
                  {
                    "kind": "Text",
                    "props": { "className": "font-medium" },
                    "bindings": { "children": { "$ref": "row.athlete_display_name" } }
                  },
                  {
                    "kind": "Widget",
                    "widget": "athlete.minor-badge",
                    "bindings": { "hidden": { "$expr": "!row.athlete.is_minor" } }
                  }
                ]
              }
            },
            {
              "key": "team_id",
              "label": "Team",
              "renderer": {
                "kind": "Text",
                "bindings": { "children": { "$ref": "row.team_display_name" } }
              }
            },
            {
              "key": "season_id",
              "label": "Season",
              "renderer": {
                "kind": "Text",
                "bindings": { "children": { "$ref": "row.season_display_name" } }
              }
            },
            {
              "key": "status",
              "label": "Status",
              "renderer": {
                "kind": "Widget",
                "widget": "athlete_enrollment.enrollment-status-chip",
                "bindings": { "status": { "$ref": "row.status" } }
              }
            },
            {
              "key": "age_group",
              "label": "Age group (snapshot)",
              "renderer": {
                "kind": "Widget",
                "widget": "athlete.age-group-badge",
                "bindings": { "age_group_id": { "$ref": "row.age_group_snapshot_id" } }
              }
            },
            {
              "key": "waitlist",
              "label": "Waitlist",
              "renderer": {
                "kind": "Widget",
                "widget": "athlete_enrollment.waitlist-position-badge",
                "bindings": {
                  "hidden": { "$expr": "row.status !== 'waitlisted'" },
                  "waitlist_position": { "$ref": "row.waitlist_position" }
                }
              }
            }
          ],
          "rowActions": {
            "onPress": { "kind": "navigate", "toExpr": "'/tenant/enrollments/' + row.id" }
          }
        }
      ]
    }
  ]
}
