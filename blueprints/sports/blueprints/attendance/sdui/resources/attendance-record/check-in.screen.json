{
  "id": "attendance.resources.attendance-record.check-in",
  "title": "Record check-in",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/attendance/check-in",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "attendance", "entity": "attendance-record", "action": "create" },
  "requiresPermission": "attendance.create",
  "dataSources": [
    {
      "name": "sessions",
      "kind": "http.get",
      "url": "/api/v1/sessions?filter[status]=scheduled,confirmed,in_progress",
      "unwrap": "data",
      "cache": { "ttlSeconds": 60 }
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-3xl mx-auto" },
      "children": [
        {
          "kind": "Text",
          "props": {
            "as": "h1",
            "className": "text-2xl font-semibold",
            "children": "Record attendance"
          }
        },
        {
          "kind": "Card",
          "children": [
            {
              "kind": "Card.Header",
              "children": [{ "kind": "Text", "props": { "children": "Attendee + session" } }]
            },
            {
              "kind": "Card.Content",
              "props": { "className": "flex flex-col gap-3" },
              "children": [
                {
                  "kind": "ComboBox",
                  "props": { "label": "Session", "menuTrigger": "focus", "isRequired": true },
                  "bindings": { "items": { "$ref": "sessions" } },
                  "actions": {
                    "onSelectionChange": {
                      "kind": "field.set",
                      "field": "session_id",
                      "valueExpr": "$selectedKey"
                    }
                  }
                },
                {
                  "kind": "Widget",
                  "widget": "athlete.athlete-picker",
                  "props": {
                    "label": "Athlete",
                    "isRequired": true,
                    "filterByEnrollmentInSession": true
                  },
                  "bindings": { "session_id": { "$ref": "form.session_id" } },
                  "actions": {
                    "onChange": {
                      "kind": "field.set",
                      "field": "athlete_id",
                      "valueExpr": "$value"
                    }
                  }
                }
              ]
            }
          ]
        },
        {
          "kind": "Card",
          "children": [
            {
              "kind": "Card.Header",
              "children": [{ "kind": "Text", "props": { "children": "Check-in details" } }]
            },
            {
              "kind": "Card.Content",
              "props": { "className": "flex flex-col gap-3" },
              "children": [
                {
                  "kind": "ComboBox",
                  "props": {
                    "label": "Method",
                    "menuTrigger": "focus",
                    "isRequired": true,
                    "defaultSelectedKey": "admin_recorded"
                  },
                  "props_items": [
                    { "id": "admin_recorded", "label": "Admin recorded" },
                    { "id": "coach_verified", "label": "Coach verified" }
                  ],
                  "actions": {
                    "onSelectionChange": {
                      "kind": "field.set",
                      "field": "checked_in_via",
                      "valueExpr": "$selectedKey"
                    }
                  }
                },
                {
                  "kind": "DatePicker",
                  "props": { "label": "Checked in at (defaults to now)", "granularity": "minute" },
                  "actions": {
                    "onChange": {
                      "kind": "field.set",
                      "field": "checked_in_at",
                      "valueExpr": "$value"
                    }
                  }
                },
                {
                  "kind": "ComboBox",
                  "props": {
                    "label": "Initial status",
                    "menuTrigger": "focus",
                    "defaultSelectedKey": "present"
                  },
                  "props_items": [
                    { "id": "present", "label": "Present" },
                    { "id": "late", "label": "Late (explicit)" },
                    { "id": "present_with_note", "label": "Present with note" }
                  ],
                  "actions": {
                    "onSelectionChange": {
                      "kind": "field.set",
                      "field": "status",
                      "valueExpr": "$selectedKey"
                    }
                  }
                }
              ]
            }
          ]
        },
        {
          "kind": "Alert",
          "props": { "variant": "info" },
          "bindings": { "hidden": { "$expr": "!form.session_id || !form.athlete_id" } },
          "children": [
            {
              "kind": "Text",
              "propsExpr": "{ children: 'This check-in will atomically consume 1 pass from the athlete\\'s active membership.' }"
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "flex justify-end gap-2" },
          "children": [
            {
              "kind": "Button",
              "props": { "variant": "secondary", "children": "Cancel" },
              "actions": { "onPress": { "kind": "navigate", "to": "/tenant/attendance" } }
            },
            {
              "kind": "Button",
              "props": { "variant": "primary", "children": "Record check-in" },
              "bindings": { "disabled": { "$expr": "!form.session_id || !form.athlete_id" } },
              "actions": {
                "onPress": {
                  "kind": "http.post",
                  "url": "/api/v1/attendance-records",
                  "bodyFromForm": true,
                  "onSuccess": { "kind": "navigate", "to": "/tenant/attendance" }
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
