{
  "id": "attendance.resources.attendance-record.check-out",
  "title": "Check out",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/attendance/{record}/check-out",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "attendance", "entity": "attendance-record", "action": "check-out" },
  "requiresPermission": "attendance.check-out",
  "dataSources": [
    {
      "name": "record",
      "kind": "http.get",
      "urlTemplate": "/api/v1/attendance-records/{record}",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-3xl mx-auto" },
      "children": [
        {
          "kind": "Text",
          "props": { "as": "h1", "className": "text-2xl font-semibold", "children": "Check out" }
        },
        {
          "kind": "Card",
          "children": [
            {
              "kind": "Card.Header",
              "children": [
                {
                  "kind": "Text",
                  "propsExpr": "{ children: 'Checking out ' + record.athlete_display_name + ' from ' + record.session_display_name }"
                }
              ]
            },
            {
              "kind": "Card.Content",
              "props": { "className": "flex flex-col gap-3" },
              "children": [
                {
                  "kind": "DatePicker",
                  "props": {
                    "label": "Checked out at (defaults to now)",
                    "granularity": "minute",
                    "isRequired": true
                  },
                  "actions": {
                    "onChange": {
                      "kind": "field.set",
                      "field": "checked_out_at",
                      "valueExpr": "$value"
                    }
                  }
                },
                {
                  "kind": "TextArea",
                  "props": {
                    "label": "Left early? Reason (optional)",
                    "maxLength": 256,
                    "rows": 3
                  },
                  "actions": {
                    "onChange": {
                      "kind": "field.set",
                      "field": "left_early_reason",
                      "valueExpr": "$value"
                    }
                  }
                }
              ]
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "flex justify-end gap-2" },
          "children": [
            {
              "kind": "Button",
              "props": { "variant": "secondary", "children": "Cancel" },
              "actions": { "onPress": { "kind": "navigate.back" } }
            },
            {
              "kind": "Button",
              "props": { "variant": "primary", "children": "Check out" },
              "actions": {
                "onPress": {
                  "kind": "http.post",
                  "urlTemplate": "/api/v1/attendance/check-out",
                  "bodyFromForm": true,
                  "extraBody": { "attendance_record_id": "{record}" },
                  "onSuccess": { "kind": "navigate", "to": "/tenant/attendance" }
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
