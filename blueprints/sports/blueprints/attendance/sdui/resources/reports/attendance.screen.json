{
  "id": "attendance.resources.reports.attendance",
  "title": "Attendance report",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/reports/attendance",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "attendance", "entity": "report", "action": "view" },
  "requiresPermission": "reports.attendance.view",
  "requiresFeature": "attendance.analytics",
  "dataSources": [
    { "name": "report", "kind": "http.get", "url": "/api/v1/reports/attendance", "unwrap": "data", "queryFromFilters": true },
    { "name": "branches", "kind": "http.get", "url": "/api/v1/branches?filter[status]=active", "unwrap": "data", "cache": { "ttlSeconds": 300 } },
    { "name": "seasons", "kind": "http.get", "url": "/api/v1/seasons?filter[status]=in_progress,completed", "unwrap": "data", "cache": { "ttlSeconds": 300 } }
  ],
  "featureGate": {
    "kind": "upgrade_required",
    "message": "Attendance analytics is a Medium+ feature. Upgrade your plan to unlock aggregate reports."
  },
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-7xl mx-auto" },
      "children": [
        { "kind": "Text", "props": { "as": "h1", "className": "text-2xl font-semibold", "children": "Attendance report" } },
        {
          "kind": "View",
          "props": { "className": "flex items-center gap-2 py-2 flex-wrap" },
          "children": [
            {
              "kind": "ComboBox",
              "props": { "label": "Branch", "menuTrigger": "focus", "className": "min-w-56" },
              "bindings": { "items": { "$ref": "branches" } },
              "actions": { "onSelectionChange": { "kind": "filter.set", "field": "branch_id", "valueExpr": "$selectedKey" } }
            },
            {
              "kind": "ComboBox",
              "props": { "label": "Season", "menuTrigger": "focus", "className": "min-w-56" },
              "bindings": { "items": { "$ref": "seasons" } },
              "actions": { "onSelectionChange": { "kind": "filter.set", "field": "season_id", "valueExpr": "$selectedKey" } }
            },
            {
              "kind": "ComboBox",
              "props": { "label": "Period", "menuTrigger": "focus", "className": "min-w-48", "defaultSelectedKey": "weekly" },
              "props_items": [
                { "id": "weekly", "label": "Weekly" },
                { "id": "monthly", "label": "Monthly" },
                { "id": "seasonal", "label": "Full season" }
              ],
              "actions": { "onSelectionChange": { "kind": "filter.set", "field": "period", "valueExpr": "$selectedKey" } }
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "grid grid-cols-1 md:grid-cols-3 gap-4" },
          "children": [
            {
              "kind": "Card",
              "children": [
                { "kind": "Card.Header", "children": [{ "kind": "Text", "props": { "children": "Attendance rate" } }] },
                {
                  "kind": "Card.Content",
                  "children": [
                    { "kind": "Text", "props": { "className": "text-3xl font-bold" }, "bindings": { "children": { "$ref": "report.attendance_rate_pct" } } },
                    { "kind": "Text", "props": { "className": "text-sm text-muted" }, "bindings": { "children": { "$ref": "report.attendance_rate_context" } } }
                  ]
                }
              ]
            },
            {
              "kind": "Card",
              "children": [
                { "kind": "Card.Header", "children": [{ "kind": "Text", "props": { "children": "Late rate" } }] },
                {
                  "kind": "Card.Content",
                  "children": [
                    { "kind": "Text", "props": { "className": "text-3xl font-bold" }, "bindings": { "children": { "$ref": "report.late_rate_pct" } } }
                  ]
                }
              ]
            },
            {
              "kind": "Card",
              "children": [
                { "kind": "Card.Header", "children": [{ "kind": "Text", "props": { "children": "Absence rate (unexcused)" } }] },
                {
                  "kind": "Card.Content",
                  "children": [
                    { "kind": "Text", "props": { "className": "text-3xl font-bold text-danger" }, "bindings": { "children": { "$ref": "report.absence_rate_pct" } } }
                  ]
                }
              ]
            }
          ]
        },
        {
          "kind": "Card",
          "children": [
            { "kind": "Card.Header", "children": [{ "kind": "Text", "props": { "children": "Trend over time" } }] },
            {
              "kind": "Card.Content",
              "children": [
                {
                  "kind": "Widget",
                  "widget": "analytics.line-chart",
                  "bindings": { "series": { "$ref": "report.trend_series" } }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
