{
  "id": "attendance.resources.absence-record.list",
  "title": "Absences",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/absences",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "attendance", "entity": "absence-record", "action": "list" },
  "requiresPermission": "absences.viewAny",
  "dataSources": [
    { "name": "absences", "kind": "http.get", "url": "/api/v1/absences", "unwrap": "data", "queryFromFilters": true }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-7xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "kind": "View",
              "children": [
                { "kind": "Text", "props": { "as": "h1", "className": "text-2xl font-semibold", "children": "Absences" } },
                { "kind": "Text", "props": { "className": "text-sm text-muted", "children": "Missed sessions — unexcused, excused, advance-notified." } }
              ]
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "flex items-center gap-2 py-2 flex-wrap" },
          "children": [
            {
              "kind": "ComboBox",
              "props": { "label": "Status", "menuTrigger": "focus", "className": "min-w-48" },
              "props_items": [
                { "id": "unexcused", "label": "Unexcused" },
                { "id": "excused", "label": "Excused" },
                { "id": "no_show_advance_notice_given", "label": "Advance-notified" },
                { "id": "vacation", "label": "Vacation" },
                { "id": "medical", "label": "Medical" },
                { "id": "bereavement", "label": "Bereavement" }
              ],
              "actions": { "onSelectionChange": { "kind": "filter.set", "field": "status", "valueExpr": "$selectedKey" } }
            },
            {
              "kind": "Switch",
              "props": { "label": "Counting toward freeze" },
              "actions": { "onChange": { "kind": "filter.set", "field": "counted_toward_freeze", "valueExpr": "$value ? 'true' : null" } }
            }
          ]
        },
        {
          "kind": "Table",
          "props": { "aria-label": "Absence records" },
          "bindings": { "rows": { "$ref": "absences" } },
          "columns": [
            {
              "key": "athlete",
              "label": "Athlete",
              "renderer": {
                "kind": "View",
                "props": { "className": "flex items-center gap-2" },
                "children": [
                  { "kind": "Text", "props": { "className": "font-medium" }, "bindings": { "children": { "$ref": "row.athlete_display_name" } } },
                  { "kind": "Widget", "widget": "athlete.minor-badge", "bindings": { "hidden": { "$expr": "!row.athlete.is_minor" } } }
                ]
              }
            },
            { "key": "session_id", "label": "Session", "renderer": { "kind": "Text", "bindings": { "children": { "$ref": "row.session_display_name" } } } },
            {
              "key": "status",
              "label": "Status",
              "renderer": {
                "kind": "Chip",
                "propsExpr": "{ variant: row.status === 'unexcused' ? 'danger' : row.status === 'excused' ? 'success' : 'primary', className: 'capitalize' }",
                "children": [{ "kind": "Text", "propsExpr": "{ children: row.status.replace(/_/g, ' ') }" }]
              }
            },
            { "key": "absence_reason", "label": "Reason", "renderer": { "kind": "Text", "bindings": { "children": { "$ref": "row.absence_reason" } } } },
            {
              "key": "reported_source",
              "label": "Source",
              "renderer": {
                "kind": "Chip",
                "propsExpr": "{ variant: 'neutral', size: 'sm' }",
                "children": [
                  { "kind": "Text", "propsExpr": "{ children: row.reported_by_user_id ? 'Self-report' : 'Auto-detected' }" }
                ]
              }
            },
            {
              "key": "counted_toward_freeze",
              "label": "Counts",
              "renderer": {
                "kind": "Chip",
                "propsExpr": "{ variant: row.counted_toward_freeze ? 'warning' : 'neutral', size: 'sm' }",
                "children": [{ "kind": "Text", "propsExpr": "{ children: row.counted_toward_freeze ? 'Yes' : 'No' }" }]
              }
            }
          ],
          "rowActions": {
            "onPress": { "kind": "navigate", "toExpr": "'/tenant/absences/' + row.id" }
          }
        }
      ]
    }
  ]
}
