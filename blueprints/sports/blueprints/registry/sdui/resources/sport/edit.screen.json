{
  "id": "sports-registry.resources.sport.edit",
  "title": "Edit sport",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/settings/sports/{sport}/edit",
  "host": "tenant",
  "audience": "sanctum",
  "resource": { "module": "sports-registry", "entity": "sport", "action": "update" },
  "requiresPermission": "sports.update",
  "notes": [
    "Every platform-seeded row is READ-ONLY on the tenant plane — the whole edit form disables + a banner explains. Only tenant customs (is_platform_seeded=false) are editable.",
    "slug, category, is_platform_seeded, tenant_id are IMMUTABLE post-create — always read-only regardless of tier."
  ],
  "dataSources": [
    {
      "name": "sport",
      "kind": "http.get",
      "urlExpr": "'/api/v1/sports/' + route.sport",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "Form",
      "props": { "className": "flex flex-col gap-6 p-6 max-w-3xl" },
      "actions": {
        "onSubmit": {
          "kind": "http.patch",
          "urlExpr": "'/api/v1/sports/' + route.sport",
          "bodyExpr": "form",
          "onSuccess": { "kind": "navigate", "to": "/settings/sports/{{data.id}}" }
        }
      },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-center gap-2" },
          "children": [
            {
              "kind": "Text",
              "props": { "as": "h1", "className": "text-2xl font-semibold" },
              "bindings": { "children": { "$expr": "'Edit ' + sport.name" } }
            },
            {
              "kind": "Chip",
              "props": { "size": "xs", "variant": "info", "children": "Platform" },
              "bindings": { "hidden": { "$expr": "!sport.is_platform_seeded" } }
            }
          ]
        },
        {
          "kind": "Alert",
          "props": {
            "variant": "info",
            "children": "This is a platform-seeded sport. All fields are read-only on the tenant plane. Platform admins may edit it on the platform-admin surface."
          },
          "bindings": { "hidden": { "$expr": "!sport.is_platform_seeded" } }
        },
        {
          "kind": "Card",
          "children": [
            {
              "kind": "Card.Header",
              "children": [
                {
                  "kind": "Text",
                  "props": {
                    "as": "h2",
                    "className": "text-lg font-medium",
                    "children": "Identity"
                  }
                }
              ]
            },
            {
              "kind": "Card.Content",
              "props": { "className": "flex flex-col gap-4" },
              "children": [
                {
                  "kind": "TextField",
                  "props": { "name": "name", "label": "Name" },
                  "bindings": {
                    "props": {
                      "defaultValue": { "$ref": "sport.name" },
                      "isDisabled": { "$ref": "sport.is_platform_seeded" }
                    }
                  }
                },
                {
                  "kind": "TextField",
                  "props": {
                    "name": "slug",
                    "label": "Slug",
                    "isReadOnly": true,
                    "helpText": "Immutable after creation."
                  },
                  "bindings": { "props": { "defaultValue": { "$ref": "sport.slug" } } }
                },
                {
                  "kind": "TextField",
                  "props": {
                    "name": "category",
                    "label": "Category",
                    "isReadOnly": true,
                    "helpText": "Immutable after creation."
                  },
                  "bindings": { "props": { "defaultValue": { "$ref": "sport.category" } } }
                }
              ]
            }
          ]
        },
        {
          "kind": "Card",
          "children": [
            {
              "kind": "Card.Header",
              "children": [
                {
                  "kind": "Text",
                  "props": {
                    "as": "h2",
                    "className": "text-lg font-medium",
                    "children": "Metadata"
                  }
                }
              ]
            },
            {
              "kind": "Card.Content",
              "props": { "className": "flex flex-col gap-4" },
              "children": [
                {
                  "kind": "TextArea",
                  "props": { "name": "description", "label": "Description" },
                  "bindings": {
                    "props": {
                      "defaultValue": { "$ref": "sport.description" },
                      "isDisabled": { "$ref": "sport.is_platform_seeded" }
                    }
                  }
                },
                {
                  "kind": "TextField",
                  "props": { "name": "governing_body", "label": "Governing body" },
                  "bindings": {
                    "props": {
                      "defaultValue": { "$ref": "sport.governing_body" },
                      "isDisabled": { "$ref": "sport.is_platform_seeded" }
                    }
                  }
                },
                {
                  "kind": "Select",
                  "props": { "name": "gender_typical", "label": "Gender profile" },
                  "options": [
                    { "key": "any", "label": "Any" },
                    { "key": "male_only", "label": "Male-only" },
                    { "key": "female_only", "label": "Female-only" },
                    { "key": "mixed", "label": "Mixed" }
                  ],
                  "bindings": {
                    "props": {
                      "defaultSelectedKey": { "$ref": "sport.gender_typical" },
                      "isDisabled": { "$ref": "sport.is_platform_seeded" }
                    }
                  }
                }
              ]
            }
          ]
        },
        {
          "kind": "Card",
          "children": [
            {
              "kind": "Card.Header",
              "children": [
                {
                  "kind": "Text",
                  "props": {
                    "as": "h2",
                    "className": "text-lg font-medium",
                    "children": "Presentation"
                  }
                }
              ]
            },
            {
              "kind": "Card.Content",
              "props": { "className": "flex flex-col gap-4" },
              "children": [
                {
                  "kind": "ColorField",
                  "props": { "name": "primary_color", "label": "Primary color" },
                  "bindings": {
                    "props": {
                      "defaultValue": { "$ref": "sport.primary_color" },
                      "isDisabled": { "$ref": "sport.is_platform_seeded" }
                    }
                  }
                },
                {
                  "kind": "TextField",
                  "props": { "name": "icon", "label": "Icon (Iconify identifier)" },
                  "bindings": {
                    "props": {
                      "defaultValue": { "$ref": "sport.icon" },
                      "isDisabled": { "$ref": "sport.is_platform_seeded" }
                    }
                  }
                },
                {
                  "kind": "NumberField",
                  "props": { "name": "sort_order", "label": "Sort order", "min": 0, "max": 9999 },
                  "bindings": {
                    "props": {
                      "defaultValue": { "$ref": "sport.sort_order" },
                      "isDisabled": { "$ref": "sport.is_platform_seeded" }
                    }
                  }
                }
              ]
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "flex items-center justify-end gap-2" },
          "children": [
            {
              "kind": "Button",
              "props": { "variant": "ghost", "children": "Cancel" },
              "actions": {
                "onPress": { "kind": "navigate", "to": "/settings/sports/{{sport.id}}" }
              }
            },
            {
              "kind": "Button",
              "props": { "variant": "primary", "type": "submit", "children": "Save changes" },
              "bindings": { "props": { "isDisabled": { "$ref": "sport.is_platform_seeded" } } }
            }
          ]
        }
      ]
    }
  ]
}
