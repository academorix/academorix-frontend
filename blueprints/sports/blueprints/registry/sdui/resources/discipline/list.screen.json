{
  "id": "sports-registry.resources.discipline.list",
  "title": "Disciplines",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/settings/disciplines",
  "host": "tenant",
  "audience": "sanctum",
  "resource": { "module": "sports-registry", "entity": "discipline", "action": "list" },
  "requiresPermission": "disciplines.viewAny",
  "dataSources": [
    { "name": "disciplines", "kind": "http.get", "urlExpr": "'/api/v1/disciplines?include=downstream_reference_count,position_count&sort=sport_id,sort_order,name'", "unwrap": "data" },
    { "name": "me", "kind": "http.get", "url": "/api/auth/me", "unwrap": "data", "cache": { "ttlSeconds": 60 } }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-center justify-between" },
          "children": [
            {
              "kind": "View",
              "children": [
                { "kind": "Text", "props": { "as": "h1", "className": "text-2xl font-semibold", "children": "Disciplines" } },
                { "kind": "Text", "props": { "className": "text-sm text-muted", "children": "Competition formats + variants for every sport. Platform-seeded plus your customs." } }
              ]
            },
            {
              "kind": "Button",
              "props": { "variant": "primary", "leadingIcon": "plus", "children": "Add discipline" },
              "actions": { "onPress": { "kind": "navigate", "to": "/settings/disciplines/create" } },
              "bindings": { "props": { "isDisabled": { "$expr": "!me.entitlements.sports_registry_custom" } } },
              "requiresPermission": "disciplines.create"
            }
          ]
        },
        {
          "kind": "Toolbar",
          "children": [
            { "kind": "SearchField", "props": { "placeholder": "Search discipline name or slug", "name": "q" } },
            { "kind": "$ref", "target": "sports-registry.sport-picker", "props": { "name": "sport_id", "label": "Sport", "clearable": true } },
            {
              "kind": "Select",
              "props": { "name": "format_type", "placeholder": "All formats", "clearable": true },
              "options": [
                { "key": "team", "label": "Team" },
                { "key": "individual", "label": "Individual" },
                { "key": "relay", "label": "Relay" },
                { "key": "pairs", "label": "Pairs" },
                { "key": "squads", "label": "Squads" }
              ]
            },
            { "kind": "Toggle", "props": { "name": "is_active", "label": "Active only" } }
          ]
        },
        {
          "kind": "Table",
          "columns": [
            { "key": "name", "header": "Discipline", "cell": { "kind": "Link", "propsExpr": "{ to: '/settings/disciplines/' + row.id, children: row.name, className: 'font-medium' }" } },
            { "key": "slug", "header": "Slug", "cell": { "kind": "Text", "props": { "className": "font-mono text-xs" }, "bindings": { "children": { "$ref": "row.slug" } } } },
            { "key": "sport", "header": "Sport", "cell": { "kind": "Text", "bindings": { "children": { "$ref": "row.sport.name" } } } },
            { "key": "format_type", "header": "Format", "cell": { "kind": "Chip", "props": { "size": "xs", "variant": "neutral" }, "bindings": { "children": { "$ref": "row.format_type" } } } },
            {
              "key": "player_count",
              "header": "Players",
              "cell": {
                "kind": "Text",
                "props": { "className": "text-xs text-muted" },
                "bindings": { "children": { "$expr": "row.player_count_min + '-' + row.player_count_max" } }
              }
            },
            {
              "key": "flags",
              "header": "Flags",
              "cell": {
                "kind": "View",
                "props": { "className": "flex items-center gap-1" },
                "children": [
                  { "kind": "Chip", "props": { "size": "xs", "variant": "info", "children": "Platform" }, "bindings": { "hidden": { "$expr": "!row.is_platform_seeded" } } },
                  { "kind": "Chip", "props": { "size": "xs", "variant": "accent", "children": "Custom" }, "bindings": { "hidden": { "$expr": "row.is_platform_seeded" } } },
                  { "kind": "Chip", "props": { "size": "xs", "variant": "success", "children": "Active" }, "bindings": { "hidden": { "$expr": "!row.is_active" } } }
                ]
              }
            },
            {
              "key": "counts",
              "header": "Usage",
              "cell": {
                "kind": "Text",
                "props": { "className": "text-xs text-muted" },
                "bindings": { "children": { "$expr": "row.position_count + ' positions · ' + row.downstream_reference_count + ' references'" } }
              }
            }
          ],
          "bindings": { "rows": { "$ref": "disciplines" } }
        }
      ]
    }
  ]
}
