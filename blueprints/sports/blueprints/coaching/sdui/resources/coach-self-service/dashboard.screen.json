{
  "id": "coaching.resources.coach-self-service.dashboard",
  "title": "My coaching dashboard",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/coaches/me",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "coaching", "entity": "coach-self-service", "action": "view" },
  "requiresPermission": "coaching_profiles.view.own",
  "dataSources": [
    {
      "name": "profile",
      "kind": "http.get",
      "url": "/api/v1/coaches/me",
      "unwrap": "data"
    },
    {
      "name": "assignments",
      "kind": "http.get",
      "url": "/api/v1/coaches/me/assignments?filter[active]=true",
      "unwrap": "data"
    },
    {
      "name": "certifications",
      "kind": "http.get",
      "url": "/api/v1/coaches/me/certifications",
      "unwrap": "data"
    },
    {
      "name": "ratings",
      "kind": "http.get",
      "url": "/api/v1/coaches/me/ratings",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-6xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "kind": "View",
              "props": { "className": "flex items-center gap-4" },
              "children": [
                { "kind": "Avatar", "props": { "size": "lg" }, "bindings": { "src": { "$ref": "profile.photo_url_signed" }, "name": { "$ref": "profile.display_name" } } },
                {
                  "kind": "View",
                  "children": [
                    { "kind": "Text", "props": { "as": "h1", "className": "text-2xl font-semibold" }, "bindings": { "children": { "$ref": "profile.display_name" } } },
                    {
                      "kind": "View",
                      "props": { "className": "flex items-center gap-2 mt-1" },
                      "children": [
                        { "kind": "Widget", "widget": "coaching.coach-status-chip", "bindings": { "is_active": { "$ref": "profile.is_active" }, "verified_by_admin_at": { "$ref": "profile.verified_by_admin_at" } } },
                        { "kind": "Chip", "props": { "size": "sm" }, "bindings": { "children": { "$ref": "profile.primary_sport_slug" }, "hidden": { "$expr": "!profile.primary_sport_slug" } } }
                      ]
                    }
                  ]
                }
              ]
            },
            { "kind": "Button", "props": { "variant": "primary", "leadingIcon": "pencil", "children": "Edit profile" }, "actions": { "onPress": { "kind": "navigate", "toExpr": "'/tenant/coaches/me/edit'" } } }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "grid grid-cols-1 md:grid-cols-2 gap-4" },
          "children": [
            {
              "kind": "Card",
              "children": [
                { "kind": "Card.Header", "children": [{ "kind": "Text", "props": { "as": "h2", "className": "font-semibold", "children": "My profile" } }] },
                {
                  "kind": "Card.Content",
                  "children": [
                    { "kind": "Description", "props": { "label": "Coaching since" }, "bindings": { "children": { "$ref": "profile.coaching_since_year" } } },
                    { "kind": "Description", "props": { "label": "Specializations" }, "bindings": { "children": { "$expr": "$ref('profile.specializations').join(', ')" } } },
                    { "kind": "Description", "props": { "label": "Languages" }, "bindings": { "children": { "$expr": "$ref('profile.languages_spoken').join(', ')" } } },
                    { "kind": "Description", "props": { "label": "Accepting new athletes" }, "bindings": { "children": { "$expr": "profile.is_accepting_new_athletes ? 'Yes' : 'No'" } } }
                  ]
                }
              ]
            },
            {
              "kind": "Card",
              "children": [
                { "kind": "Card.Header", "children": [{ "kind": "Text", "props": { "as": "h2", "className": "font-semibold", "children": "Availability" } }] },
                { "kind": "Card.Content", "children": [{ "kind": "Widget", "widget": "coaching.availability-calendar", "bindings": { "availability": { "$ref": "profile.availability" }, "editable": { "$value": false } } }] }
              ]
            }
          ]
        },
        {
          "kind": "Card",
          "children": [
            {
              "kind": "Card.Header",
              "children": [
                {
                  "kind": "View",
                  "props": { "className": "flex items-center justify-between" },
                  "children": [
                    { "kind": "Text", "props": { "as": "h2", "className": "font-semibold", "children": "My upcoming assignments" } },
                    { "kind": "Chip", "props": { "size": "sm" }, "bindings": { "children": { "$expr": "$ref('assignments').length + ' active'" } } }
                  ]
                }
              ]
            },
            {
              "kind": "Card.Content",
              "children": [
                {
                  "kind": "Table",
                  "props": { "aria-label": "My assignments" },
                  "bindings": { "rows": { "$ref": "assignments" } },
                  "emptyState": { "kind": "Text", "props": { "className": "text-sm text-muted text-center py-8", "children": "No active assignments." } },
                  "columns": [
                    { "key": "type", "renderer": { "kind": "Chip", "props": { "size": "xs" }, "bindings": { "children": { "$ref": "row.assignable_type" } } } },
                    { "key": "target", "renderer": { "kind": "Text", "bindings": { "children": { "$ref": "row.assignable_summary" } } } },
                    { "key": "role", "renderer": { "kind": "Chip", "props": { "size": "sm" }, "bindings": { "children": { "$ref": "row.role" } } } },
                    { "key": "start", "renderer": { "kind": "Text", "bindings": { "children": { "$expr": "$formatDate(row.start_date, 'MMM d, yyyy')" } } } },
                    { "key": "end", "renderer": { "kind": "Text", "bindings": { "children": { "$expr": "row.end_date ? $formatDate(row.end_date, 'MMM d, yyyy') : 'Open'" } } } }
                  ]
                }
              ]
            }
          ]
        },
        {
          "kind": "Card",
          "children": [
            {
              "kind": "Card.Header",
              "children": [
                {
                  "kind": "View",
                  "props": { "className": "flex items-center justify-between" },
                  "children": [
                    { "kind": "Text", "props": { "as": "h2", "className": "font-semibold", "children": "My certifications" } },
                    {
                      "kind": "Button",
                      "props": { "size": "sm", "variant": "flat", "leadingIcon": "plus", "children": "Add certification" },
                      "actions": { "onPress": { "kind": "navigate", "toExpr": "'/tenant/coaches/me/certifications/create'" } },
                      "requiresPermission": "coach_certifications.create.own"
                    }
                  ]
                }
              ]
            },
            {
              "kind": "Card.Content",
              "children": [
                {
                  "kind": "Table",
                  "props": { "aria-label": "My certifications" },
                  "bindings": { "rows": { "$ref": "certifications" } },
                  "emptyState": { "kind": "Text", "props": { "className": "text-sm text-muted text-center py-8", "children": "No certifications captured." } },
                  "columns": [
                    { "key": "body", "renderer": { "kind": "Chip", "props": { "size": "sm" }, "bindings": { "children": { "$ref": "row.issuing_body" } } } },
                    { "key": "name", "renderer": { "kind": "Text", "bindings": { "children": { "$ref": "row.certification_name" } } } },
                    { "key": "expiration", "renderer": { "kind": "Widget", "widget": "coaching.certification-expiration-badge", "bindings": { "expires_at": { "$ref": "row.expires_at" }, "days_until_expiry": { "$ref": "row.days_until_expiry" }, "is_expired": { "$ref": "row.is_expired" } } } },
                    { "key": "verified", "renderer": { "kind": "Chip", "props": { "size": "sm" }, "bindings": { "children": { "$expr": "row.is_verified ? 'Verified' : 'Pending'" }, "variant": { "$expr": "row.is_verified ? 'success' : 'warning'" } } } }
                  ]
                }
              ]
            }
          ]
        },
        {
          "kind": "Card",
          "children": [
            { "kind": "Card.Header", "children": [{ "kind": "Text", "props": { "as": "h2", "className": "font-semibold", "children": "My skill ratings" } }] },
            {
              "kind": "Card.Content",
              "children": [
                {
                  "kind": "Table",
                  "props": { "aria-label": "My skill ratings" },
                  "bindings": { "rows": { "$ref": "ratings" } },
                  "emptyState": { "kind": "Text", "props": { "className": "text-sm text-muted text-center py-8", "children": "No ratings recorded yet." } },
                  "columns": [
                    { "key": "ratable", "renderer": { "kind": "View", "props": { "className": "flex items-center gap-2" }, "children": [{ "kind": "Chip", "props": { "size": "xs" }, "bindings": { "children": { "$ref": "row.ratable_type" } } }, { "kind": "Text", "bindings": { "children": { "$ref": "row.ratable_display_name" } } }] } },
                    { "key": "rating", "renderer": { "kind": "Widget", "widget": "coaching.skill-rating-stars", "bindings": { "rating_scale": { "$ref": "row.rating_scale" }, "rating_value": { "$ref": "row.rating_value" } } } },
                    { "key": "rated_at", "renderer": { "kind": "Text", "bindings": { "children": { "$expr": "$formatDate(row.rated_at, 'MMM yyyy')" } } } }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
