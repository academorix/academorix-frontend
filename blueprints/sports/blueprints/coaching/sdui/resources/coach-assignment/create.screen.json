{
  "id": "coaching.resources.coach-assignment.create",
  "title": "New coach assignment",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/coach-assignments/create",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "coaching", "entity": "coach-assignment", "action": "create" },
  "requiresPermission": "coach_assignments.create",
  "dataSources": [
    {
      "name": "coaches",
      "kind": "http.get",
      "url": "/api/v1/coaching-profiles?filter[is_active]=true&filter[verified]=true",
      "unwrap": "data"
    },
    {
      "name": "roleCatalog",
      "kind": "static",
      "value": { "$catalog": "coaching.role-catalog" }
    },
    {
      "name": "sessions",
      "kind": "http.get",
      "url": "/api/v1/sessions?filter[status]=scheduled",
      "unwrap": "data"
    },
    {
      "name": "teams",
      "kind": "http.get",
      "url": "/api/v1/teams?filter[status]=active",
      "unwrap": "data"
    },
    {
      "name": "events",
      "kind": "http.get",
      "url": "/api/v1/events?filter[status]=upcoming",
      "unwrap": "data"
    }
  ],
  "form": {
    "id": "createCoachAssignmentForm",
    "submit": {
      "kind": "http.post",
      "url": "/api/v1/coach-assignments",
      "body": "$form",
      "onSuccess": { "kind": "navigate", "toExpr": "'/tenant/coach-assignments/' + $response.data.id" },
      "onError": { "kind": "toast.error", "message": "Could not create assignment." }
    }
  },
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-2xl mx-auto" },
      "children": [
        { "kind": "Text", "props": { "as": "h1", "className": "text-2xl font-semibold", "children": "New coach assignment" } },
        {
          "kind": "Card",
          "children": [
            { "kind": "Card.Header", "children": [{ "kind": "Text", "props": { "as": "h2", "className": "font-semibold", "children": "Coach" } }] },
            {
              "kind": "Card.Content",
              "children": [
                {
                  "kind": "ComboBox",
                  "props": { "name": "coaching_profile_id", "menuTrigger": "focus" },
                  "children": [
                    { "kind": "Label", "propsExpr": "{ children: 'Coach' }" },
                    { "kind": "ComboBox.InputGroup", "children": [{ "kind": "Input", "props": { "placeholder": "Search coach..." } }, { "kind": "ComboBox.Trigger" }] },
                    {
                      "kind": "ComboBox.Popover",
                      "children": [
                        {
                          "kind": "ListBox",
                          "bindings": { "items": { "$ref": "coaches" } },
                          "children": [
                            {
                              "kind": "ListBox.Item",
                              "propsExpr": "{ id: $item.id, textValue: $item.display_name + ' — ' + $item.primary_sport_slug }",
                              "children": [
                                {
                                  "kind": "View",
                                  "props": { "className": "flex items-center gap-2" },
                                  "children": [
                                    { "kind": "Avatar", "props": { "size": "xs" }, "bindings": { "src": { "$ref": "$item.photo_url_signed" }, "name": { "$ref": "$item.display_name" } } },
                                    {
                                      "kind": "View",
                                      "children": [
                                        { "kind": "Text", "props": { "className": "text-sm font-medium" }, "bindings": { "children": { "$ref": "$item.display_name" } } },
                                        { "kind": "Text", "props": { "className": "text-xs text-muted" }, "bindings": { "children": { "$ref": "$item.primary_sport_slug" } } }
                                      ]
                                    }
                                  ]
                                },
                                { "kind": "ListBox.ItemIndicator" }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "kind": "Card",
          "children": [
            { "kind": "Card.Header", "children": [{ "kind": "Text", "props": { "as": "h2", "className": "font-semibold", "children": "Assignable" } }] },
            {
              "kind": "Card.Content",
              "children": [
                {
                  "kind": "ToggleButtonGroup",
                  "props": { "name": "assignable_type", "aria-label": "Assignable type" },
                  "children": [
                    { "kind": "ToggleButton", "props": { "value": "Session", "children": "Session" } },
                    { "kind": "ToggleButton", "props": { "value": "Team", "children": "Team" } },
                    { "kind": "ToggleButton", "props": { "value": "Event", "children": "Event" } }
                  ]
                },
                {
                  "kind": "ComboBox",
                  "props": { "name": "assignable_id", "menuTrigger": "focus" },
                  "bindings": { "hidden": { "$expr": "!$form.assignable_type" } },
                  "children": [
                    { "kind": "Label", "propsExpr": "{ children: 'Target' }" },
                    { "kind": "ComboBox.InputGroup", "children": [{ "kind": "Input", "props": { "placeholder": "Search..." } }, { "kind": "ComboBox.Trigger" }] },
                    {
                      "kind": "ComboBox.Popover",
                      "children": [
                        {
                          "kind": "ListBox",
                          "bindings": { "items": { "$expr": "$form.assignable_type === 'Session' ? $ref('sessions') : ($form.assignable_type === 'Team' ? $ref('teams') : $ref('events'))" } },
                          "children": [
                            { "kind": "ListBox.Item", "propsExpr": "{ id: $item.id, textValue: $item.title || $item.name }", "children": [{ "kind": "Text", "bindings": { "children": { "$expr": "$item.title || $item.name" } } }, { "kind": "ListBox.ItemIndicator" }] }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "kind": "Card",
          "children": [
            { "kind": "Card.Header", "children": [{ "kind": "Text", "props": { "as": "h2", "className": "font-semibold", "children": "Role & dates" } }] },
            {
              "kind": "Card.Content",
              "children": [
                {
                  "kind": "RadioGroup",
                  "props": { "name": "role", "label": "Role" },
                  "bindings": { "items": { "$ref": "roleCatalog.roles" } },
                  "itemRenderer": {
                    "kind": "RadioGroup.Item",
                    "propsExpr": "{ value: $item.value, children: $item.label + ($item.value === 'head_coach' ? ' (one per target)' : '') }"
                  }
                },
                { "kind": "DateField", "props": { "name": "start_date", "label": "Start date", "isRequired": true } },
                { "kind": "DateField", "props": { "name": "end_date", "label": "End date (optional)" } },
                { "kind": "TextArea", "props": { "name": "notes", "label": "Notes (optional)", "rows": 3 } }
              ]
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "flex justify-end gap-2" },
          "children": [
            { "kind": "Button", "props": { "variant": "flat", "children": "Cancel" }, "actions": { "onPress": { "kind": "navigate", "toExpr": "'/tenant/coach-assignments'" } } },
            { "kind": "Button", "props": { "variant": "primary", "type": "submit", "children": "Create assignment" } }
          ]
        }
      ]
    }
  ]
}
