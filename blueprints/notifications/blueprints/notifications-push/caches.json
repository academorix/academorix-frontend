{
  "id": "academorix://modules/notifications-push/caches",
  "$version": 1,
  "title": "notifications-push \u2014 cache keys + tags",
  "driver": "redis",
  "ownedTags": ["notifications-push"],
  "keys": [
    {
      "pattern": "notifications-push:subscriptions:user:{user_id}:app:{application_id}",
      "description": "Per-(user, app) active subscription list. Read on every push dispatch (hot path).",
      "ttlSeconds": 300,
      "tags": ["notifications-push", "subscription", "user"],
      "invalidatedBy": [
        "PushSubscriptionRegistered event",
        "PushSubscriptionExpired event",
        "PushSubscriptionRevoked event"
      ]
    },
    {
      "pattern": "notifications-push:token_validator:{provider}:{token_fingerprint}",
      "description": "Recent validation result cache. Prevents duplicate dry-runs when a token is re-registered within the TTL.",
      "ttlSeconds": 60,
      "tags": ["notifications-push", "validator"]
    },
    {
      "pattern": "notifications-push:provider_config:{provider}",
      "description": "Provider credentials + endpoint config. Loaded once per boot, refreshed on ConfigReloaded.",
      "ttlSeconds": 3600,
      "tags": ["notifications-push", "provider"],
      "invalidatedBy": ["foundation::ConfigReloaded"]
    }
  ]
}
