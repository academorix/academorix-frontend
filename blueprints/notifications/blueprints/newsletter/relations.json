{
  "id": "stackra://modules/newsletter/relations",
  "$version": 1,
  "title": "newsletter \u2014 model relationships",
  "internal": [
    {
      "from": "Newsletter",
      "kind": "hasMany",
      "to": "NewsletterIssue",
      "foreignKey": "newsletter_id"
    },
    {
      "from": "Newsletter",
      "kind": "hasMany",
      "to": "NewsletterSubscription",
      "foreignKey": "newsletter_id"
    },
    {
      "from": "Newsletter",
      "kind": "hasMany",
      "to": "NewsletterCampaign",
      "foreignKey": "newsletter_id"
    },
    {
      "from": "Newsletter",
      "kind": "hasMany",
      "to": "NewsletterAudience",
      "foreignKey": "newsletter_id"
    },
    {
      "from": "NewsletterIssue",
      "kind": "belongsTo",
      "to": "Newsletter",
      "foreignKey": "newsletter_id",
      "onDelete": "cascade"
    },
    {
      "from": "NewsletterIssue",
      "kind": "hasMany",
      "to": "NewsletterCampaign",
      "foreignKey": "issue_id"
    },
    {
      "from": "NewsletterSubscription",
      "kind": "belongsTo",
      "to": "Newsletter",
      "foreignKey": "newsletter_id",
      "onDelete": "cascade"
    },
    {
      "from": "NewsletterCampaign",
      "kind": "belongsTo",
      "to": "Newsletter",
      "foreignKey": "newsletter_id",
      "onDelete": "cascade"
    },
    {
      "from": "NewsletterCampaign",
      "kind": "belongsTo",
      "to": "NewsletterIssue",
      "foreignKey": "issue_id",
      "onDelete": "restrict",
      "description": "Campaigns for a published issue cannot delete the issue (audit evidence)."
    },
    {
      "from": "NewsletterCampaign",
      "kind": "belongsTo",
      "to": "NewsletterAudience",
      "foreignKey": "audience_id",
      "onDelete": "restrict"
    },
    {
      "from": "NewsletterAudience",
      "kind": "belongsTo",
      "to": "Newsletter",
      "foreignKey": "newsletter_id",
      "onDelete": "cascade"
    }
  ],
  "outbound": [
    {
      "from": "Newsletter",
      "kind": "belongsTo",
      "to": "tenancy::Tenant",
      "foreignKey": "tenant_id",
      "onDelete": "cascade"
    },
    {
      "from": "NewsletterSubscription",
      "kind": "belongsTo",
      "to": "user::User",
      "foreignKey": "user_id",
      "nullable": true,
      "onDelete": "set null",
      "description": "Nullable \u2014 anonymous email-only subscribers are common."
    },
    {
      "from": "NewsletterCampaign",
      "kind": "hasMany",
      "to": "notifications::NotificationDelivery",
      "foreignKey": "meta->campaign_id",
      "morphed": true,
      "description": "Delivery rows created by notifications-mail during send. Look-up via metadata."
    }
  ],
  "inbound": {
    "note": "notifications-mail::MailBounced + MailComplaint listeners look up NewsletterSubscription via delivery metadata to flip subscription state."
  }
}
