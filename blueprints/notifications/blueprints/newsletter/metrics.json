{
  "id": "stackra://modules/newsletter/metrics",
  "$version": 1,
  "title": "newsletter \u2014 OpenTelemetry metrics",
  "instrumentation": "open-telemetry/sdk",
  "namespace": "stackra.newsletter",
  "labelConventions": {
    "always": ["tenant_id"],
    "commonlyAvailable": ["newsletter_id", "campaign_id", "outcome"],
    "forbiddenAsLabels": ["email", "subscription_id", "user_id"]
  },
  "metrics": [
    {
      "name": "stackra.newsletter.subscriptions.gauge",
      "kind": "gauge",
      "unit": "subscriptions",
      "labels": ["tenant_id", "newsletter_id", "state"]
    },
    {
      "name": "stackra.newsletter.subscriptions.added_total",
      "kind": "counter",
      "unit": "subscriptions",
      "labels": ["tenant_id", "newsletter_id", "source"]
    },
    {
      "name": "stackra.newsletter.subscriptions.removed_total",
      "kind": "counter",
      "unit": "subscriptions",
      "labels": ["tenant_id", "newsletter_id", "reason"]
    },
    {
      "name": "stackra.newsletter.confirmation_rate_ratio",
      "kind": "gauge",
      "unit": "ratio",
      "labels": ["tenant_id", "newsletter_id"],
      "description": "confirmed / added over rolling 30d."
    },
    {
      "name": "stackra.newsletter.campaigns.sent_total",
      "kind": "counter",
      "unit": "campaigns",
      "labels": ["tenant_id", "newsletter_id"]
    },
    {
      "name": "stackra.newsletter.campaigns.completion_duration_ms",
      "kind": "histogram",
      "unit": "ms",
      "buckets": [10000, 60000, 300000, 1800000, 3600000, 7200000],
      "labels": ["tenant_id"]
    },
    {
      "name": "stackra.newsletter.campaigns.open_rate_ratio",
      "kind": "gauge",
      "unit": "ratio",
      "labels": ["tenant_id", "newsletter_id"]
    },
    {
      "name": "stackra.newsletter.campaigns.click_rate_ratio",
      "kind": "gauge",
      "unit": "ratio",
      "labels": ["tenant_id", "newsletter_id"]
    },
    {
      "name": "stackra.newsletter.campaigns.bounce_rate_ratio",
      "kind": "gauge",
      "unit": "ratio",
      "labels": ["tenant_id", "newsletter_id"]
    },
    {
      "name": "stackra.newsletter.campaigns.complaint_rate_ratio",
      "kind": "gauge",
      "unit": "ratio",
      "labels": ["tenant_id", "newsletter_id"]
    },
    {
      "name": "stackra.newsletter.reputation_alerts_total",
      "kind": "counter",
      "unit": "alerts",
      "labels": ["tenant_id", "newsletter_id", "threshold"]
    },
    {
      "name": "stackra.newsletter.audience_evaluations_total",
      "kind": "counter",
      "unit": "evaluations",
      "labels": ["outcome"],
      "description": "outcome: refreshed / cached / failed."
    },
    {
      "name": "stackra.newsletter.audience_evaluation_duration_ms",
      "kind": "histogram",
      "unit": "ms",
      "buckets": [10, 100, 1000, 10000, 60000],
      "labels": []
    }
  ]
}
