{
  "id": "stackra://modules/newsletter/caches",
  "$version": 1,
  "title": "newsletter \u2014 cache keys + tags",
  "driver": "redis",
  "ownedTags": ["newsletter"],
  "keys": [
    {
      "pattern": "newsletter:audience:{audience_id}:ids",
      "description": "Materialised subscriber id list. Rewritten by BuildAudienceSegmentJob.",
      "ttlSeconds": 21600,
      "tags": ["newsletter", "audience"],
      "invalidatedBy": [
        "NewsletterSubscriptionConfirmed / Removed events",
        "NewsletterAudienceRefreshed"
      ]
    },
    {
      "pattern": "newsletter:token:{token}",
      "description": "Signed token \u2192 subscription_id reverse lookup. Prevents subscription enumeration.",
      "ttlSeconds": 3600,
      "tags": ["newsletter", "token"]
    },
    {
      "pattern": "newsletter:reputation:{newsletter_id}:rolling",
      "description": "Rolling 30d reputation aggregates \u2014 open_rate, click_rate, bounce_rate, complaint_rate. Powers ReputationMonitor.",
      "ttlSeconds": 3600,
      "tags": ["newsletter", "reputation"]
    },
    {
      "pattern": "newsletter:public_signup_form:{newsletter_id}",
      "description": "Cached public form JSON for the anonymous subscribe page.",
      "ttlSeconds": 300,
      "tags": ["newsletter", "public"]
    }
  ]
}
