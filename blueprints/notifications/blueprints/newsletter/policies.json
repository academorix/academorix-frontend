{
  "id": "academorix://modules/newsletter/policies",
  "$version": 1,
  "title": "newsletter \u2014 authorization policies",
  "policies": [
    {
      "model": "Newsletter",
      "class": "Academorix\\Newsletter\\Policies\\NewsletterPolicy",
      "abilities": [
        { "action": "viewAny", "permission": "newsletters.viewAny" },
        { "action": "view", "permission": "newsletters.view" },
        {
          "action": "create",
          "permission": "newsletters.create",
          "scope": "requires newsletter.publications.max entitlement not exhausted"
        },
        {
          "action": "update",
          "permission": "newsletters.update",
          "scope": "refused for is_system=true unless super_admin"
        },
        {
          "action": "delete",
          "permission": "newsletters.delete",
          "scope": "refused when active campaigns in_progress"
        },
        {
          "action": "manage",
          "permission": "newsletters.manage",
          "scope": "pause / resume / archive"
        }
      ]
    },
    {
      "model": "NewsletterIssue",
      "class": "Academorix\\Newsletter\\Policies\\NewsletterIssuePolicy",
      "abilities": [
        { "action": "viewAny", "permission": "newsletter-issues.viewAny" },
        { "action": "view", "permission": "newsletter-issues.view" },
        { "action": "create", "permission": "newsletter-issues.create" },
        {
          "action": "update",
          "permission": "newsletter-issues.update",
          "scope": "refused when state IN (sending, sent) \u2014 sent issues are historical evidence"
        },
        {
          "action": "delete",
          "permission": "newsletter-issues.delete",
          "scope": "refused for sent + scheduled unless super_admin"
        },
        {
          "action": "publish",
          "permission": "newsletter-issues.publish",
          "scope": "schedule / send-now / cancel"
        }
      ]
    },
    {
      "model": "NewsletterSubscription",
      "class": "Academorix\\Newsletter\\Policies\\NewsletterSubscriptionPolicy",
      "abilities": [
        { "action": "viewAny", "permission": "newsletter-subscriptions.viewAny" },
        { "action": "view", "permission": "newsletter-subscriptions.view" },
        { "action": "create", "permission": "newsletter-subscriptions.create" },
        {
          "action": "update",
          "permission": "newsletter-subscriptions.update",
          "scope": "email + consent_evidence NEVER editable"
        },
        {
          "action": "delete",
          "permission": "newsletter-subscriptions.delete",
          "scope": "soft delete only; permanent delete only for GDPR erasure"
        },
        { "action": "import", "permission": "newsletter-subscriptions.import" },
        { "action": "export", "permission": "newsletter-subscriptions.export" }
      ]
    },
    {
      "model": "NewsletterCampaign",
      "class": "Academorix\\Newsletter\\Policies\\NewsletterCampaignPolicy",
      "abilities": [
        { "action": "viewAny", "permission": "newsletter-campaigns.viewAny" },
        { "action": "view", "permission": "newsletter-campaigns.view" },
        {
          "action": "manage",
          "permission": "newsletter-campaigns.manage",
          "scope": "cancel only \u2014 create happens via issue.schedule"
        }
      ]
    },
    {
      "model": "NewsletterAudience",
      "class": "Academorix\\Newsletter\\Policies\\NewsletterAudiencePolicy",
      "abilities": [
        { "action": "viewAny", "permission": "newsletter-audiences.viewAny" },
        { "action": "view", "permission": "newsletter-audiences.view" },
        { "action": "create", "permission": "newsletter-audiences.create" },
        { "action": "update", "permission": "newsletter-audiences.update" },
        {
          "action": "delete",
          "permission": "newsletter-audiences.delete",
          "scope": "refused for is_default=true"
        }
      ]
    }
  ]
}
