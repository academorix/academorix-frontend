{
  "id": "notifications.resources.notification.show",
  "title": "Notification detail",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/notifications/{id}",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "notifications", "entity": "notification", "action": "show" },
  "requiresPermission": "notifications.view",
  "params": [{ "name": "id", "type": "string", "in": "path", "required": true }],
  "dataSources": [
    {
      "name": "notification",
      "kind": "http.get",
      "urlExpr": "'/api/v1/tenant/notifications/' + params.id + '?include=deliveries,category,template'",
      "unwrap": "data",
      "cache": { "ttlSeconds": 30 }
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-6 p-6 max-w-3xl mx-auto" },
      "children": [
        {
          "id": "back",
          "kind": "Link",
          "props": {
            "leadingIcon": "arrow-left",
            "children": "Back to inbox",
            "className": "text-sm text-muted"
          },
          "actions": { "onPress": { "kind": "navigate", "to": "/tenant/notifications" } }
        },
        {
          "id": "header",
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "id": "title-block",
              "kind": "View",
              "props": { "className": "flex flex-col gap-1" },
              "children": [
                {
                  "id": "category-chip",
                  "kind": "Chip",
                  "props": { "size": "sm", "variant": "info" },
                  "bindings": {
                    "children": {
                      "$expr": "notification.category ? notification.category.display_name : notification.category_slug"
                    }
                  }
                },
                {
                  "id": "subject",
                  "kind": "Text",
                  "props": { "as": "h1", "className": "text-2xl font-semibold" },
                  "bindings": { "children": { "$ref": "notification.subject" } }
                },
                {
                  "id": "meta",
                  "kind": "Text",
                  "props": { "className": "text-sm text-muted" },
                  "bindings": {
                    "children": { "$expr": "'Received ' + formatRelative(notification.created_at)" }
                  }
                }
              ]
            },
            {
              "id": "actions",
              "kind": "View",
              "props": { "className": "flex items-center gap-2" },
              "children": [
                {
                  "id": "mark-seen",
                  "kind": "Button",
                  "props": {
                    "variant": "ghost",
                    "size": "sm",
                    "leadingIcon": "check-circle",
                    "children": "Mark seen"
                  },
                  "bindings": { "isDisabled": { "$ref": "notification.is_seen" } },
                  "actions": {
                    "onPress": {
                      "kind": "http.post",
                      "urlExpr": "'/api/v1/tenant/notifications/' + params.id + '/seen'",
                      "onSuccess": { "kind": "data.refresh", "source": "notification" }
                    }
                  }
                },
                {
                  "id": "archive",
                  "kind": "Button",
                  "props": { "variant": "ghost", "size": "sm", "leadingIcon": "archive-box" },
                  "bindings": { "isDisabled": { "$ref": "notification.is_archived" } },
                  "actions": {
                    "onPress": {
                      "kind": "http.post",
                      "urlExpr": "'/api/v1/tenant/notifications/' + params.id + '/archive'",
                      "confirm": {
                        "title": "Archive this notification?",
                        "description": "It will move out of your active inbox."
                      },
                      "onSuccess": [
                        { "kind": "toast.success", "message": "Archived" },
                        { "kind": "navigate", "to": "/tenant/notifications" }
                      ]
                    }
                  }
                }
              ]
            }
          ]
        },
        {
          "id": "body",
          "kind": "Card",
          "props": { "className": "p-6" },
          "children": [
            {
              "id": "body-html",
              "kind": "HtmlContent",
              "props": { "className": "prose prose-sm max-w-none" },
              "bindings": { "html": { "$ref": "notification.rendered_html" } }
            }
          ]
        },
        {
          "id": "deliveries-section",
          "kind": "View",
          "props": { "className": "flex flex-col gap-3" },
          "children": [
            {
              "id": "deliveries-title",
              "kind": "Text",
              "props": {
                "as": "h2",
                "className": "text-lg font-semibold",
                "children": "Delivery details"
              }
            },
            {
              "id": "deliveries-list",
              "kind": "List",
              "bindings": { "items": { "$ref": "notification.deliveries" } },
              "itemRenderer": {
                "kind": "View",
                "props": {
                  "className": "flex items-center justify-between rounded-lg border border-default p-3"
                },
                "children": [
                  {
                    "id": "channel-and-provider",
                    "kind": "View",
                    "props": { "className": "flex items-center gap-3" },
                    "children": [
                      {
                        "kind": "Widget",
                        "widget": "notifications.channel-icon",
                        "props": { "channel": { "$ref": "row.channel" }, "size": "md" }
                      },
                      {
                        "kind": "View",
                        "props": { "className": "flex flex-col" },
                        "children": [
                          {
                            "kind": "Text",
                            "props": { "className": "text-sm font-medium" },
                            "bindings": { "children": { "$ref": "row.channel" } }
                          },
                          {
                            "kind": "Text",
                            "props": { "className": "text-xs text-muted" },
                            "bindings": {
                              "children": {
                                "$expr": "row.provider ? row.provider : 'no provider yet'"
                              }
                            }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "kind": "Widget",
                    "widget": "notifications.delivery-status-chip",
                    "props": { "state": { "$ref": "row.state" }, "size": "sm" }
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
