{
  "id": "stackra://modules/notifications-sms/entitlements",
  "$version": 1,
  "title": "notifications-sms \u2014 entitlements",
  "reference": {
    "publishedBy": "entitlements",
    "resolvedBy": "GET /api/auth/me \u2192 data.quota_summary",
    "seededFrom": "BusinessType.default_config.entitlements"
  },
  "kinds": [{ "kind": "pool" }, { "kind": "slot" }, { "kind": "boolean" }],
  "entitlements": [
    {
      "key": "notifications.sms.month",
      "kind": "pool",
      "period": "month",
      "unit": "messages",
      "defaultsByPlan": { "free": 0, "team": 200, "enterprise": 5000 },
      "description": "Monthly outbound SMS message count."
    },
    {
      "key": "notifications.sms.cost-cap.monthly_micro_units",
      "kind": "pool",
      "period": "month",
      "unit": "micro_units",
      "defaultsByPlan": { "free": 0, "team": 5000000, "enterprise": 100000000 },
      "description": "Monthly SMS spend cap in micro-currency-units (USD micro-cents by default). team=$50, enterprise=$1000. Refused when exceeded."
    },
    {
      "key": "notifications.sms.per-message-max-cost",
      "kind": "slot",
      "unit": "micro_units",
      "defaultsByPlan": { "free": 100000, "team": 500000, "enterprise": 5000000 },
      "description": "Max cost per message (guardrail against expensive destinations). team=$5/message, enterprise=$50/message."
    },
    {
      "key": "notifications.sms.mms",
      "kind": "boolean",
      "defaultsByPlan": { "free": false, "team": false, "enterprise": true }
    }
  ]
}
