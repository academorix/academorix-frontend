{
  "id": "stackra://modules/invitations/settings",
  "$version": 1,
  "title": "invitations \u2014 settings",
  "description": "Invitation platform settings. Canonical group/section/field taxonomy. One #[AsSetting] class \u2014 `InvitationSettings` \u2014 group key `invitations`. Ships with permission + feature + entitlement gates on individual fields via metadata.",
  "storedIn": "settings",
  "sduiScreen": "sdui/screens/settings-invitations.screen.json",
  "reference": { "contract": "stackra://modules/settings/attributes" },
  "groups": [
    {
      "key": "invitations",
      "class": "Stackra\\Invitations\\Settings\\InvitationSettings",
      "label": "Invitations",
      "description": "Expiry + resends + delivery channels + rate limits + sender identity + acceptance flow.",
      "icon": "envelope-open",
      "scope": "tenant",
      "public": false,
      "sortOrder": 25,
      "permission": "invitations.send",
      "sections": [
        {
          "label": "Expiry",
          "icon": "clock",
          "sortOrder": 1,
          "fields": [
            {
              "name": "expires_after_days",
              "controlType": "number",
              "label": "Default expiry (days)",
              "defaultValue": 14,
              "validation": ["required", "integer", "min:1", "max:90"],
              "min": 1,
              "max": 90,
              "sortOrder": 1,
              "helpText": "How long a new invitation stays valid before it auto-expires.",
              "gates": { "requires_permission": "invitations.send" }
            },
            {
              "name": "send_reminder",
              "controlType": "toggle",
              "label": "Send a reminder 48h before expiry",
              "defaultValue": true,
              "validation": ["boolean"],
              "sortOrder": 2,
              "gates": { "requires_feature_flag": "invitations.reminder-emails" }
            }
          ]
        },
        {
          "label": "Resends",
          "icon": "arrow-path",
          "sortOrder": 2,
          "fields": [
            {
              "name": "max_resends",
              "controlType": "number",
              "label": "Max resends per invitation",
              "defaultValue": 3,
              "validation": ["required", "integer", "min:0", "max:10"],
              "min": 0,
              "max": 10,
              "sortOrder": 1
            }
          ]
        },
        {
          "label": "Delivery channels",
          "description": "Which channels are available to invitees. Some channels require an active integration or an enterprise plan.",
          "icon": "signal",
          "sortOrder": 3,
          "fields": [
            {
              "name": "channels_email",
              "controlType": "toggle",
              "label": "Email (always available)",
              "defaultValue": true,
              "validation": ["boolean"],
              "sortOrder": 1,
              "readOnly": true
            },
            {
              "name": "channels_sms",
              "controlType": "toggle",
              "label": "SMS",
              "defaultValue": false,
              "validation": ["boolean"],
              "sortOrder": 2,
              "gates": {
                "requires_entitlement": "invitations.channels.sms",
                "requires_feature_flag": "invitations.sms-channel"
              }
            },
            {
              "name": "channels_slack",
              "controlType": "toggle",
              "label": "Slack",
              "defaultValue": false,
              "validation": ["boolean"],
              "sortOrder": 3,
              "gates": { "requires_feature_flag": "invitations.slack-channel" }
            }
          ]
        },
        {
          "label": "Sending limits",
          "description": "Per-inviter and per-tenant guardrails to prevent accidental over-sending. Enterprise plans can lift them via ops.",
          "icon": "chart-bar",
          "sortOrder": 4,
          "fields": [
            {
              "name": "throttle_per_inviter_per_day",
              "controlType": "number",
              "label": "Max per inviter per day",
              "defaultValue": 50,
              "validation": ["required", "integer", "min:1", "max:1000"],
              "min": 1,
              "max": 1000,
              "sortOrder": 1,
              "gates": { "requires_entitlement": "invitations.throttle.overrides" }
            },
            {
              "name": "throttle_per_tenant_per_day",
              "controlType": "number",
              "label": "Max per tenant per day",
              "defaultValue": 250,
              "validation": ["required", "integer", "min:1", "max:10000"],
              "min": 1,
              "max": 10000,
              "sortOrder": 2,
              "gates": { "requires_entitlement": "invitations.throttle.overrides" }
            }
          ]
        },
        {
          "label": "Sender identity",
          "description": "How your invitation emails are branded.",
          "icon": "identification",
          "sortOrder": 5,
          "fields": [
            {
              "name": "sender_name",
              "controlType": "text",
              "label": "Sender name",
              "defaultValue": null,
              "validation": ["nullable", "string", "max:200"],
              "sortOrder": 1,
              "helpText": "Empty = tenant name."
            },
            {
              "name": "sender_reply_to",
              "controlType": "email",
              "label": "Reply-to email",
              "defaultValue": null,
              "validation": ["nullable", "email", "max:254"],
              "sortOrder": 2,
              "helpText": "Empty = tenant's billing contact email."
            }
          ]
        },
        {
          "label": "Acceptance flow",
          "icon": "check-badge",
          "sortOrder": 6,
          "fields": [
            {
              "name": "acceptance_require_mfa_for_admins",
              "controlType": "toggle",
              "label": "Require MFA for owner + admin invitations",
              "defaultValue": true,
              "validation": ["boolean"],
              "sortOrder": 1,
              "helpText": "Invitees accepting an owner or admin role must enrol MFA during accept (they cannot skip)."
            },
            {
              "name": "acceptance_require_sso",
              "controlType": "toggle",
              "label": "Force SSO when tenant has SSO",
              "defaultValue": true,
              "validation": ["boolean"],
              "sortOrder": 2,
              "helpText": "Invitations sent to a domain matching the tenant's SSO IdP route through SSO instead of password creation."
            }
          ]
        }
      ]
    }
  ]
}
