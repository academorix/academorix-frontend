{
  "id": "grants.resources.access-grant.show",
  "title": "Grant detail",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/grants/:grantId",
  "host": "tenant",
  "audience": "authenticated",
  "resource": {
    "module": "grants",
    "entity": "access-grant",
    "action": "show"
  },
  "requiresPermission": "grants.viewAny",
  "dataSources": [
    {
      "name": "grant",
      "kind": "http.get",
      "urlExpr": "'/api/v1/grants/' + route.params.grantId + '?include=subject,resource,grantor,revoker'",
      "unwrap": "data",
      "cache": { "ttlSeconds": 60 }
    },
    {
      "name": "grantAuditTrail",
      "kind": "http.get",
      "urlExpr": "'/api/v1/audit-log?filter[auditable_id]=' + route.params.grantId + '&filter[auditable_type]=access_grant&sort=-created_at'",
      "unwrap": "data"
    },
    {
      "name": "grantActivityLog",
      "kind": "http.get",
      "urlExpr": "'/api/v1/activity-log?filter[subject_id]=' + route.params.grantId + '&filter[subject_type]=access_grant&sort=-created_at'",
      "unwrap": "data"
    },
    {
      "name": "identity",
      "kind": "http.get",
      "url": "/api/auth/me",
      "unwrap": "data",
      "cache": { "ttlSeconds": 60 }
    }
  ],
  "subscriptions": [
    {
      "channel": "tenant.{tenantId}.grants",
      "kind": "private",
      "filterExpr": "event.data.id === route.params.grantId",
      "onEvent": { "kind": "data.refresh", "source": "grant" }
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-6 p-6" },
      "children": [
        {
          "id": "header",
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "kind": "View",
              "children": [
                {
                  "kind": "Link",
                  "props": {
                    "to": "/tenant/grants",
                    "className": "text-muted flex items-center gap-1 text-sm",
                    "children": "← Back to grants"
                  }
                },
                {
                  "kind": "View",
                  "props": { "className": "flex items-center gap-3 mt-2" },
                  "children": [
                    {
                      "kind": "Text",
                      "props": { "as": "h1", "className": "text-2xl font-semibold" },
                      "bindings": {
                        "children": {
                          "$expr": "(grant.subject.display_name || grant.subject_id) + ' → ' + (grant.resource.display_label || grant.resource_id)"
                        }
                      }
                    },
                    {
                      "kind": "Widget",
                      "widget": "grants.decision-chip",
                      "props": {
                        "decision": { "$ref": "grant.decision" },
                        "isActive": { "$ref": "grant.is_active" },
                        "isRevoked": { "$ref": "grant.is_revoked" },
                        "isExpired": { "$ref": "grant.is_expired" },
                        "isPermanent": { "$ref": "grant.is_permanent" },
                        "size": "md"
                      }
                    }
                  ]
                },
                {
                  "kind": "Text",
                  "props": { "as": "p", "className": "text-muted text-sm mt-1" },
                  "bindings": {
                    "children": {
                      "$expr": "'Granted ' + formatRelative(grant.granted_at) + ' by ' + (grant.grantor.display_name || 'the system') + ' (' + grant.source + ')'"
                    }
                  }
                }
              ]
            },
            {
              "id": "actions",
              "kind": "View",
              "props": { "className": "flex items-center gap-2" },
              "children": [
                {
                  "kind": "Button",
                  "props": {
                    "variant": "ghost",
                    "size": "sm",
                    "leadingIcon": "shield-check",
                    "children": "Audit resource"
                  },
                  "actions": {
                    "onPress": {
                      "kind": "navigate",
                      "toExpr": "'/tenant/grants/audit/' + grant.resource_type + '/' + grant.resource_id"
                    }
                  }
                },
                {
                  "kind": "Button",
                  "props": {
                    "variant": "ghost",
                    "size": "sm",
                    "leadingIcon": "clock",
                    "children": "Extend"
                  },
                  "bindings": {
                    "isDisabled": {
                      "$expr": "grant.is_terminal || !identity.permissions.includes('grants.manage')"
                    }
                  },
                  "actions": {
                    "onPress": {
                      "kind": "modal.open",
                      "modal": "extend-grant-expiry",
                      "propsExpr": "{ grantId: grant.id, currentExpiresAt: grant.expires_at }"
                    }
                  }
                },
                {
                  "kind": "Button",
                  "props": {
                    "variant": "danger",
                    "size": "sm",
                    "leadingIcon": "ban",
                    "children": "Revoke"
                  },
                  "bindings": {
                    "isDisabled": {
                      "$expr": "grant.is_terminal || (!identity.permissions.includes('grants.manage') && grant.granted_by !== identity.id)"
                    }
                  },
                  "actions": {
                    "onPress": {
                      "kind": "http.delete",
                      "urlExpr": "'/api/v1/grants/' + grant.id",
                      "confirm": {
                        "title": "Revoke this grant?",
                        "description": "The subject will lose these permissions immediately. This action cannot be undone.",
                        "reasonField": {
                          "label": "Reason (required, min 20 chars)",
                          "name": "reason",
                          "kind": "TextArea",
                          "isRequired": true,
                          "minLength": 20
                        }
                      },
                      "onSuccess": {
                        "kind": "sequence",
                        "steps": [
                          { "kind": "toast.success", "message": "Grant revoked" },
                          { "kind": "data.refresh", "source": "grant" }
                        ]
                      }
                    }
                  }
                }
              ]
            }
          ]
        },
        {
          "id": "layout",
          "kind": "View",
          "props": { "className": "grid grid-cols-3 gap-6" },
          "children": [
            {
              "id": "main-column",
              "kind": "View",
              "props": { "className": "col-span-2 flex flex-col gap-6" },
              "children": [
                {
                  "id": "permissions-panel",
                  "kind": "Card",
                  "props": { "className": "p-4" },
                  "children": [
                    {
                      "kind": "Text",
                      "props": {
                        "as": "h2",
                        "className": "text-lg font-semibold mb-3",
                        "children": "Permissions granted"
                      }
                    },
                    {
                      "kind": "List",
                      "props": { "className": "flex flex-wrap gap-2" },
                      "bindings": { "items": { "$ref": "grant.permissions" } },
                      "itemRenderer": {
                        "kind": "Chip",
                        "props": { "variant": "neutral", "size": "sm" },
                        "bindings": { "children": { "$ref": "item" } }
                      }
                    }
                  ]
                },
                {
                  "id": "reason-panel",
                  "kind": "Card",
                  "props": { "className": "p-4" },
                  "children": [
                    {
                      "kind": "Text",
                      "props": {
                        "as": "h2",
                        "className": "text-lg font-semibold mb-2",
                        "children": "Reason for grant"
                      }
                    },
                    {
                      "kind": "Text",
                      "props": {
                        "as": "p",
                        "className": "whitespace-pre-wrap text-sm"
                      },
                      "bindings": { "children": { "$ref": "grant.reason" } }
                    }
                  ]
                },
                {
                  "id": "timeline-panel",
                  "kind": "Card",
                  "props": { "className": "p-4" },
                  "children": [
                    {
                      "kind": "Text",
                      "props": {
                        "as": "h2",
                        "className": "text-lg font-semibold mb-3",
                        "children": "Timeline"
                      }
                    },
                    {
                      "kind": "Timeline",
                      "bindings": {
                        "items": {
                          "$expr": "combineTimelines(grantAuditTrail, grantActivityLog)"
                        }
                      },
                      "itemRenderer": {
                        "kind": "View",
                        "props": { "className": "flex flex-col" },
                        "children": [
                          {
                            "kind": "Text",
                            "props": { "className": "text-sm font-medium" },
                            "bindings": { "children": { "$ref": "row.event_name" } }
                          },
                          {
                            "kind": "Text",
                            "props": { "className": "text-xs text-muted" },
                            "bindings": {
                              "children": {
                                "$expr": "formatRelative(row.occurred_at) + ' by ' + (row.actor?.display_name || 'system')"
                              }
                            }
                          }
                        ]
                      }
                    }
                  ]
                }
              ]
            },
            {
              "id": "sidebar",
              "kind": "View",
              "props": { "className": "flex flex-col gap-4" },
              "children": [
                {
                  "kind": "Card",
                  "props": { "className": "p-4 flex flex-col gap-3" },
                  "children": [
                    {
                      "kind": "Text",
                      "props": {
                        "as": "h3",
                        "className": "text-sm font-semibold uppercase text-muted",
                        "children": "Subject"
                      }
                    },
                    {
                      "kind": "View",
                      "props": { "className": "flex items-center gap-2" },
                      "children": [
                        {
                          "kind": "Avatar",
                          "props": { "size": "md" },
                          "bindings": {
                            "src": { "$ref": "grant.subject.avatar_url" },
                            "label": { "$ref": "grant.subject.display_name" }
                          }
                        },
                        {
                          "kind": "View",
                          "children": [
                            {
                              "kind": "Text",
                              "props": { "className": "font-medium" },
                              "bindings": { "children": { "$ref": "grant.subject.display_name" } }
                            },
                            {
                              "kind": "Text",
                              "props": { "className": "text-xs text-muted" },
                              "bindings": { "children": { "$ref": "grant.subject.email" } }
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "kind": "Card",
                  "props": { "className": "p-4 flex flex-col gap-3" },
                  "children": [
                    {
                      "kind": "Text",
                      "props": {
                        "as": "h3",
                        "className": "text-sm font-semibold uppercase text-muted",
                        "children": "Resource"
                      }
                    },
                    {
                      "kind": "View",
                      "children": [
                        {
                          "kind": "Text",
                          "props": { "className": "font-medium" },
                          "bindings": {
                            "children": {
                              "$expr": "grant.resource.display_label || grant.resource_id"
                            }
                          }
                        },
                        {
                          "kind": "Text",
                          "props": { "className": "text-xs text-muted uppercase" },
                          "bindings": { "children": { "$ref": "grant.resource_type" } }
                        }
                      ]
                    }
                  ]
                },
                {
                  "kind": "Card",
                  "props": { "className": "p-4 flex flex-col gap-3" },
                  "children": [
                    {
                      "kind": "Text",
                      "props": {
                        "as": "h3",
                        "className": "text-sm font-semibold uppercase text-muted",
                        "children": "Lifecycle"
                      }
                    },
                    {
                      "kind": "View",
                      "props": { "className": "flex flex-col gap-2 text-sm" },
                      "children": [
                        {
                          "kind": "View",
                          "props": { "className": "flex justify-between" },
                          "children": [
                            {
                              "kind": "Text",
                              "props": { "className": "text-muted", "children": "Granted" }
                            },
                            {
                              "kind": "Text",
                              "bindings": {
                                "children": { "$expr": "formatDate(grant.granted_at)" }
                              }
                            }
                          ]
                        },
                        {
                          "kind": "View",
                          "props": { "className": "flex justify-between" },
                          "children": [
                            {
                              "kind": "Text",
                              "props": { "className": "text-muted", "children": "Expires" }
                            },
                            {
                              "kind": "Text",
                              "bindings": {
                                "children": {
                                  "$expr": "grant.expires_at ? formatDate(grant.expires_at) : 'Never'"
                                }
                              }
                            }
                          ]
                        },
                        {
                          "kind": "View",
                          "props": { "className": "flex justify-between" },
                          "bindings": { "hidden": { "$expr": "!grant.revoked_at" } },
                          "children": [
                            {
                              "kind": "Text",
                              "props": { "className": "text-muted", "children": "Revoked" }
                            },
                            {
                              "kind": "Text",
                              "bindings": {
                                "children": {
                                  "$expr": "formatDate(grant.revoked_at) + ' by ' + (grant.revoker?.display_name || 'system')"
                                }
                              }
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
