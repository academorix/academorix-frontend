# Dependencies
node_modules
.pnpm-store

# Build output
dist
dist-ssr
build
*.local

# Turborepo
.turbo

# Test / coverage
coverage
*.lcov

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Env files: keep .env.example and .env.production (public VITE_* config),
# ignore local/secret env files.
.env
.env.local
.env.*.local

# Editor / OS
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
!.vscode/extensions.json

# Vercel
.vercel

# Tauri / Rust build artefacts under src-tauri/ — the compiled binary and
# generated codegen (mobile scaffolds, capability schemas) are deterministic
# outputs and must never be committed. Local per-crate .gitignores also
# cover this, but the workspace-level match keeps things safe for
# contributors who bypass the crate ignores.
apps/dashboard/src-tauri/target
apps/dashboard/src-tauri/gen

# Lockfiles from other package managers (this repo standardizes on pnpm)
yarn.lock
package-lock.json
bun.lockb

# Kiro MCP config holds secret tokens (heroui-pro personal token) — keep local
.kiro/settings/mcp.json
.env*.local
