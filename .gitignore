# ── Dependencies ────────────────────────────────────────────────────
node_modules
.pnpm-store

# ── Build output ────────────────────────────────────────────────────
dist
dist-ssr
build
*.local

# ── TypeScript incremental build cache ──────────────────────────────
*.tsbuildinfo

# ── Turborepo ───────────────────────────────────────────────────────
.turbo

# ── Toolchain caches ────────────────────────────────────────────────
.eslintcache
.prettiercache
.stylelintcache
.parcel-cache
.swc
.rollup.cache

# ── Test / coverage ─────────────────────────────────────────────────
coverage
*.lcov
.nyc_output

# ── Logs ────────────────────────────────────────────────────────────
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Env files ───────────────────────────────────────────────────────
# Keep .env.example and .env.production (public VITE_* config), ignore
# local/secret env files.
.env
.env.local
.env.*.local
.env*.local

# ── Doppler local state ─────────────────────────────────────────────
# Doppler CLI keeps per-project state locally that MUST NOT be committed.
.doppler/

# ── Editor / OS ─────────────────────────────────────────────────────
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
!.vscode/extensions.json

# ── Deploy artefacts ────────────────────────────────────────────────
.vercel
.netlify

# ── React Native native build artefacts ─────────────────────────────
apps/*/ios/build
apps/*/ios/Pods
apps/*/android/build
apps/*/android/.gradle
apps/*/android/app/build
apps/*/android/app/release
apps/*/.expo
apps/*/.metro-cache

# ── Tauri / Rust build artefacts ────────────────────────────────────
# Compiled binaries + generated codegen (mobile scaffolds, capability
# schemas) are deterministic outputs — never committed.
apps/*/src-tauri/target
apps/*/src-tauri/gen

# ── Lockfiles from other package managers (this repo standardizes on pnpm) ─
yarn.lock
package-lock.json
bun.lockb

# ── Kiro MCP config holds secret tokens (heroui-pro personal token) — keep local ─
.kiro/settings/mcp.json

# ── Third-party reference material — never committed ────────────────
.ref/
