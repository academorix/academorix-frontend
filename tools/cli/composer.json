{
  "name": "stackra/cli",
  "description": "Stackra workspace CLI — scaffolds projects, packages, and modules.",
  "type": "library",
  "license": "proprietary",
  "require": {
    "php": "^8.3",
    "symfony/console": "^7.2",
    "laravel/prompts": "^0.3",
    "pdphilip/omniterm": "^3.0",
    "illuminate/container": "^11.0|^12.0|^13.0",
    "illuminate/filesystem": "^11.0|^12.0|^13.0",
    "illuminate/events": "^11.0|^12.0|^13.0",
    "illuminate/view": "^11.0|^12.0|^13.0",
    "illuminate/support": "^11.0|^12.0|^13.0",
    "symfony/process": "^7.2",
    "symfony/finder": "^7.2"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.11",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Stackra\\Cli\\": "src/"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Stackra\\Cli\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/stackra"
  ],
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
