{
  "name": "{{ composerName }}",
  "description": "{{ description }}",
  "type": "library",
  "license": "proprietary",
  "authors": [
    {
      "name": "{{ authorName }}",
      "email": "{{ authorEmail }}"
    }
  ],
  "require": {
    "php": "^8.3"
  },
  "autoload": {
    "psr-4": {
      "{{ psrNamespace }}": "{{ srcDir }}"
    }
  },
  "extra": {
    "laravel": {
      "providers": []
    }
  },
  "config": {
    "sort-packages": true
  }
}
