#!/usr/bin/env php
<?php

/**
 * @file academorix
 * @description Entry point for the Academorix workspace CLI.
 *
 *   Loads Composer's autoloader, instantiates {@see \Academorix\Cli\Application},
 *   and delegates to its `run()` method. Non-zero exit codes bubble to the shell
 *   so CI + local scripts can gate on them.
 */

declare(strict_types=1);

$autoloadCandidates = [
    __DIR__.'/../vendor/autoload.php',
    __DIR__.'/../../../vendor/autoload.php',
];

$autoload = null;

foreach ($autoloadCandidates as $candidate) {
    if (file_exists($candidate)) {
        $autoload = $candidate;

        break;
    }
}

if ($autoload === null) {
    fwrite(STDERR, "academorix: could not locate vendor/autoload.php.\n".
        "Run `composer install` in tools/cli first.\n");
    exit(1);
}

require $autoload;

use Academorix\Cli\Application;

exit((new Application)->run());
