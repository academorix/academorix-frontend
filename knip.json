{
  "workspaces": {
    ".": {
      "entry": ["scripts/**/*.{ts,mjs,py}"],
      "project": ["*.{ts,mjs,cjs}"]
    },
    "apps/vite-template": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/laravel-template": {
      "ignore": ["**/*"]
    },
    "apps/react-native-template": {
      "entry": ["App.tsx"],
      "ignore": ["__tests__/**", "ios/**", "android/**"]
    },
    "packages/config/eslint": {
      "entry": ["base.mjs", "react.mjs", "native.mjs", "vite-app.mjs"]
    },
    "packages/config/tailwind": {},
    "packages/config/tsconfig": {},
    "packages/config/typescript": {},
    "packages/config/tsup": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/frontend/*": {
      "entry": ["src/**/index.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/backend/*": {
      "ignore": ["**/*"]
    },
    "packages/sdk/*": {
      "ignore": ["**/*"]
    }
  },
  "rules": {
    "files": "off",
    "exports": "off",
    "types": "off",
    "duplicates": "off",
    "enumMembers": "off",
    "dependencies": "warn",
    "unlisted": "warn",
    "unresolved": "warn",
    "binaries": "warn"
  },
  "ignoreExportsUsedInFile": true,
  "ignoreDependencies": [
    "@stackra/*",
    "@stackra/*",
    "@commitlint/types",
    "@babel/preset-env",
    "@babel/runtime",
    "@react-native/eslint-config",
    "eslint-plugin-node",
    "eslint-plugin-react-hooks",
    "prettier",
    "reflect-metadata",
    "@vivtel/metadata",
    "@testing-library/react",
    "@heroicons/react",
    "@heroui/react",
    "@heroui/styles",
    "@iconify/react",
    "@tanstack/query-core",
    "@tanstack/react-query",
    "@types/react-dom",
    "react-dom",
    "rxjs",
    "zod",
    "react-native",
    "@react-native-community/netinfo",
    "@react-native-async-storage/async-storage"
  ],
  "ignoreBinaries": ["doppler", "docker", "gh", "pint", "phpstan", "pest", "composer", "tauri"]
}
