{
  "workspaces": {
    "apps/dashboard": {
      "ignoreDependencies": ["@heroui/styles", "openapi-fetch"],
      "ignore": ["src/lib/api/**"]
    },
    "apps/landing-page": {
      "ignoreDependencies": [
        "@heroui-pro/react",
        "intl-messageformat",
        "tailwind-variants",
        "@eslint/compat",
        "@eslint/eslintrc",
        "eslint-config-next"
      ],
      "ignore": ["postcss.config.mjs"]
    },
    "packages/api-types": {
      "ignoreDependencies": ["zod"],
      "entry": ["src/{common,enums,errors,ids}.ts", "src/resources/*.ts"]
    },
    "packages/typescript-config": {
      "entry": ["*.json"],
      "ignoreDependencies": ["next"]
    }
  },
  "rules": {
    "files": "off",
    "exports": "off",
    "types": "off",
    "duplicates": "off",
    "enumMembers": "off",
    "dependencies": "error",
    "unlisted": "error",
    "unresolved": "error",
    "binaries": "error"
  },
  "ignoreExportsUsedInFile": true,
  "ignoreBinaries": ["doppler"]
}
