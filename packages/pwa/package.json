{
  "name": "@academorix/pwa",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "PWA + web-security build helpers for the Academorix workspace: manifest builder with locale translations, workbox runtime-caching defaults, security-header baseline (CSP + STS + Permissions-Policy), and factory adapters for vite-plugin-pwa and Serwist. Zero React — safe to import from vite.config.ts and next.config.ts.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./manifest": "./src/manifest/index.ts",
    "./workbox": "./src/workbox/index.ts",
    "./security": "./src/security/index.ts",
    "./vite": "./src/vite/index.ts",
    "./serwist": "./src/serwist/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf .turbo"
  },
  "dependencies": {
    "@academorix/core": "workspace:*"
  },
  "devDependencies": {
    "@academorix/eslint-config": "workspace:*",
    "@academorix/typescript-config": "workspace:*",
    "eslint": "catalog:",
    "typescript": "catalog:"
  }
}
