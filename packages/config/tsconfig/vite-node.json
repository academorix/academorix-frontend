{
  "display": "@stackra/config-tsconfig — vite node (build tooling)",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["node"],
    "target": "ES2022",
    "moduleResolution": "Bundler",
    "noEmit": true
  },
  "include": ["vite.config.ts", "vitest.config.ts", "playwright.config.ts", "plugins/**/*"]
}
