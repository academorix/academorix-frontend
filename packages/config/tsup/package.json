{
  "name": "@academorix/config-tsup",
  "version": "0.1.0",
  "private": true,
  "description": "Shared tsup config helper for the academorix-frontend monorepo. Exports defineBaseConfig(entries, overrides).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist .turbo",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'No source lint - build config'",
    "test": "echo 'No tests - build config'"
  },
  "peerDependencies": {
    "tsup": "catalog:"
  },
  "devDependencies": {
    "@academorix/config-tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "rimraf": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
