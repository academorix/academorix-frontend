{
  "name": "@stackra/config-eslint",
  "version": "0.1.0",
  "private": true,
  "description": "Shared ESLint flat config presets for the stackra-frontend monorepo. Exports base + react + vite-app presets.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./base.mjs",
    "./base": "./base.mjs",
    "./react": "./react.mjs",
    "./native": "./native.mjs",
    "./vite-app": "./vite-app.mjs"
  },
  "files": [
    "base.mjs",
    "react.mjs",
    "native.mjs",
    "vite-app.mjs",
    "README.md"
  ],
  "scripts": {
    "lint": "echo 'This IS the eslint config — nothing to lint here'",
    "typecheck": "echo 'JS module — no TS to check'",
    "test": "echo 'No tests'",
    "build": "echo 'Consumed as-is'"
  },
  "peerDependencies": {
    "eslint": "catalog:"
  },
  "dependencies": {
    "@eslint/js": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-jsx-a11y": "catalog:",
    "eslint-plugin-react": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "eslint-plugin-unicorn": "catalog:",
    "globals": "catalog:",
    "typescript-eslint": "catalog:"
  }
}
