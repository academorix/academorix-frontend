{
  "$schema": "https://gist.githubusercontent.com/academorix-user/073a1ab687cd93ede7ae927b96a025ea/raw/catalog.v1.json",
  "name": "@stackra/realtime",
  "tier": "saas",
  "surfaces": ["core", "react", "testing"],
  "kind": "framework-plumbing",
  "purpose": "Multi-driver realtime WebSocket manager — transport-agnostic, driver-registered, with per-connection channels and typed event emission.",
  "capabilities": [
    "MultipleInstanceManager over named connections",
    "Pluggable drivers (native WebSocket, Socket.IO, Pusher)",
    "Private + presence channel semantics",
    "Backoff + auto-reconnect with resume tokens",
    "React bindings: useChannel, usePresence",
    "Actions subpath for @Broadcast dispatch",
    "Testing subpath with in-memory driver"
  ],
  "when_to_use": "Wiring a browser to a websocket-based realtime service for presence, live queries, or notifications.",
  "when_not_to_use": "For plain HTTP polling use @stackra/query with refetch intervals; for cross-tab-only use @stackra/coordinator.",
  "peer_deps": [
    "@stackra/actions",
    "@stackra/container",
    "@stackra/contracts",
    "@stackra/logger",
    "@stackra/support",
    "@stackra/testing",
    "react",
    "reflect-metadata"
  ],
  "backend_pair": "academorix/realtime",
  "size_gzip_kb": {},
  "maturity": "alpha",
  "owning_agent": "framework-core-builder",
  "docs": ["packages/frontend/realtime/README.md"]
}
