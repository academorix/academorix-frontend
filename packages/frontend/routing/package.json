{
  "name": "@stackra/routing",
  "version": "0.1.0",
  "description": "Client-side routing for the Stackra framework \u2014 guards, middleware, SEO, analytics, breadcrumbs, route modes (page/dialog/drawer/sheet), advanced matchers (subdomain/query/header/hash), and a `defineRoute()` builder that composes with React Router v7.",
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://stackra.com"
  },
  "keywords": [
    "stackra",
    "routing",
    "react-router",
    "spa",
    "seo",
    "aeo",
    "guards",
    "middleware",
    "prerender",
    "client-side"
  ],
  "homepage": "https://github.com/stackra-inc/core/tree/main/routing#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stackra-inc/core.git",
    "directory": "routing"
  },
  "bugs": {
    "url": "https://github.com/stackra-inc/core/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    },
    "./matchers": {
      "types": "./dist/matchers.d.ts",
      "import": "./dist/matchers.mjs",
      "require": "./dist/matchers.js"
    },
    "./seo": {
      "types": "./dist/seo.d.ts",
      "import": "./dist/seo.mjs",
      "require": "./dist/seo.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.mjs",
      "require": "./dist/testing.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.mjs",
      "require": "./dist/vite.js"
    },
    "./console": {
      "types": "./dist/console.d.ts",
      "import": "./dist/console.mjs",
      "require": "./dist/console.js"
    }
  },
  "files": [
    "config",
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist .turbo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "@vivtel/metadata": "catalog:"
  },
  "peerDependencies": {
    "@stackra/console": "workspace:^",
    "@stackra/container": "workspace:^",
    "@stackra/contracts": "workspace:^",
    "@stackra/decorators": "workspace:^",
    "@stackra/error": "workspace:^",
    "@stackra/events": "workspace:^",
    "@stackra/logger": "workspace:^",
    "@stackra/pipeline": "workspace:^",
    "@stackra/support": "workspace:^",
    "@stackra/testing": "workspace:^",
    "@stackra/ui": "workspace:^",
    "@testing-library/react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router": "catalog:",
    "reflect-metadata": "catalog:"
  },
  "peerDependenciesMeta": {
    "@stackra/console": {
      "optional": true
    },
    "@stackra/testing": {
      "optional": true
    },
    "@stackra/ui": {
      "optional": true
    },
    "@testing-library/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@stackra/config-tsconfig": "workspace:*",
    "@stackra/config-tsup": "workspace:*",
    "@stackra/console": "workspace:*",
    "@stackra/container": "workspace:*",
    "@stackra/contracts": "workspace:*",
    "@stackra/decorators": "workspace:*",
    "@stackra/error": "workspace:*",
    "@stackra/events": "workspace:*",
    "@stackra/logger": "workspace:*",
    "@stackra/pipeline": "workspace:*",
    "@stackra/support": "workspace:*",
    "@stackra/testing": "workspace:*",
    "@stackra/ui": "workspace:*",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router": "catalog:",
    "reflect-metadata": "catalog:",
    "rimraf": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
