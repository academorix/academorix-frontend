{
  "extends": "@stackra/config-tsconfig/base",
  "compilerOptions": {
    "types": ["node"],
    "rootDir": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@stackra/routing/react": ["./src/react/index.ts"],
      "@stackra/routing/native": ["./src/native/index.ts"],
      "@stackra/routing/testing": ["./src/testing/index.ts"]
    },
    "outDir": "./dist"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "__tests__"],
  "compileOnSave": false
}
