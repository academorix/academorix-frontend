{
  "name": "@stackra/kbd",
  "version": "0.2.0",
  "description": "Keyboard shortcut registry, command palette, catalog, hints, and customization primitives for Stackra apps. Powered by TanStack Hotkeys + HeroUI Pro Command.",
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://stackra.com"
  },
  "keywords": [
    "stackra",
    "kbd",
    "keyboard",
    "shortcuts",
    "command-palette",
    "hotkeys",
    "react",
    "heroui"
  ],
  "homepage": "https://github.com/stackra-inc/core/tree/main/kbd#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stackra-inc/core.git",
    "directory": "kbd"
  },
  "bugs": {
    "url": "https://github.com/stackra-inc/core/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist .turbo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "peerDependencies": {
    "@heroui-pro/react": "catalog:",
    "@heroui/react": "catalog:",
    "@stackra/container": "workspace:^",
    "@stackra/contracts": "workspace:^",
    "@stackra/events": "workspace:^",
    "@stackra/i18n": "workspace:^",
    "@stackra/logger": "workspace:^",
    "@stackra/state": "workspace:^",
    "@stackra/storage": "workspace:^",
    "@stackra/support": "workspace:^",
    "@stackra/testing": "workspace:^",
    "@stackra/ui": "workspace:^",
    "@tanstack/react-hotkeys": "catalog:",
    "@tanstack/react-store": "catalog:",
    "@tanstack/store": "catalog:",
    "react": "catalog:",
    "reflect-metadata": "*"
  },
  "peerDependenciesMeta": {
    "@heroui-pro/react": {
      "optional": true
    },
    "@heroui/react": {
      "optional": true
    },
    "@stackra/storage": {
      "optional": true
    },
    "@stackra/testing": {
      "optional": true
    },
    "@stackra/ui": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@academorix/config-tsconfig": "workspace:*",
    "@academorix/config-tsup": "workspace:*",
    "@heroui-pro/react": "catalog:",
    "@heroui/react": "catalog:",
    "@stackra/container": "workspace:*",
    "@stackra/contracts": "workspace:*",
    "@stackra/events": "workspace:*",
    "@stackra/i18n": "workspace:*",
    "@stackra/logger": "workspace:*",
    "@stackra/state": "workspace:*",
    "@stackra/storage": "workspace:*",
    "@stackra/support": "workspace:*",
    "@stackra/testing": "workspace:*",
    "@stackra/ui": "workspace:*",
    "@tanstack/react-devtools": "catalog:",
    "@tanstack/react-hotkeys": "catalog:",
    "@tanstack/react-hotkeys-devtools": "catalog:",
    "@tanstack/react-store": "catalog:",
    "@tanstack/store": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "reflect-metadata": "catalog:",
    "rimraf": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
