{
  "name": "@stackra/dashboard",
  "version": "0.1.0",
  "description": "Headless dashboard framework for the Stackra platform \u2014 domain types, storage adapter, widget registry, widget catalogue, React hooks, and DI module. HeroUI-heavy visual components live in consuming apps.",
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://stackra.com"
  },
  "keywords": [
    "stackra",
    "dashboard",
    "widgets",
    "layout",
    "react",
    "headless"
  ],
  "homepage": "https://github.com/stackra-inc/core/tree/main/dashboard#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stackra-inc/core.git",
    "directory": "dashboard"
  },
  "bugs": {
    "url": "https://github.com/stackra-inc/core/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.mjs",
      "require": "./dist/testing.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist .turbo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "@vivtel/metadata": "catalog:"
  },
  "peerDependencies": {
    "@stackra/container": "workspace:^",
    "@stackra/contracts": "workspace:^",
    "@stackra/support": "workspace:^",
    "@stackra/testing": "workspace:^",
    "react": "catalog:",
    "react-dom": "catalog:",
    "reflect-metadata": "catalog:"
  },
  "peerDependenciesMeta": {
    "@stackra/testing": {
      "optional": true
    }
  },
  "devDependencies": {
    "@stackra/config-tsconfig": "workspace:*",
    "@stackra/config-tsup": "workspace:*",
    "@stackra/container": "workspace:*",
    "@stackra/contracts": "workspace:*",
    "@stackra/support": "workspace:*",
    "@stackra/testing": "workspace:*",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vivtel/metadata": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "reflect-metadata": "catalog:",
    "rimraf": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
