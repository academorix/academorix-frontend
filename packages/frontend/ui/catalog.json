{
  "$schema": "https://gist.githubusercontent.com/academorix-user/073a1ab687cd93ede7ae927b96a025ea/raw/catalog.v1.json",
  "name": "@stackra/ui",
  "tier": "saas",
  "surfaces": ["core", "react", "native", "testing"],
  "kind": "feature",
  "purpose": "Client-side UI kit — re-exports HeroUI OSS + Pro components, adds custom composites, hooks, providers, and heroicons subpaths.",
  "capabilities": [
    "@stackra/ui/react re-exports of @heroui/react + @heroui-pro/react",
    "@stackra/ui/native re-exports of heroui-native + heroui-native-pro",
    "Custom composites (RichEditor, Kanban, Chart panels)",
    "Icons subpaths: heroicons (outline/solid/mini/micro), iconify, gravity-ui",
    "TipTap-powered rich text editor",
    "Recharts + Motion + Embla wrapping",
    "Testing subpath with render helpers",
    "Actions subpath for @UiAction dispatch"
  ],
  "when_to_use": "Every visual component in every @stackra app or package must compose through @stackra/ui — never touch HeroUI directly.",
  "when_not_to_use": "For headless behaviour without HeroUI use React Aria; for pure icons use @stackra/ui/icons subpath.",
  "peer_deps": [
    "@heroicons/react",
    "@heroui-pro/react",
    "@heroui/react",
    "@heroui/styles",
    "@iconify/react",
    "@number-flow/react",
    "@stackra/container",
    "@stackra/contracts",
    "@stackra/logger",
    "@stackra/testing",
    "@tiptap/core",
    "@tiptap/extension-link",
    "@tiptap/extension-underline",
    "@tiptap/extensions",
    "@tiptap/pm",
    "@tiptap/react",
    "@tiptap/starter-kit",
    "@tiptap/suggestion",
    "embla-carousel",
    "embla-carousel-react",
    "heroui-native",
    "heroui-native-pro",
    "marked",
    "motion",
    "react",
    "react-aria-components",
    "react-dom",
    "react-markdown",
    "react-native",
    "react-resizable-panels",
    "recharts",
    "remark-breaks",
    "remark-gfm",
    "shiki",
    "streamdown",
    "tailwind-merge",
    "tailwind-variants",
    "tailwindcss"
  ],
  "backend_pair": null,
  "size_gzip_kb": {},
  "maturity": "alpha",
  "owning_agent": "heroui-ui-builder",
  "docs": ["packages/frontend/ui/README.md"]
}
