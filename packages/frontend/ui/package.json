{
  "name": "@stackra/ui",
  "version": "0.1.0",
  "description": "Client-side UI kit for the Stackra framework — re-exports HeroUI OSS and Pro components, adds custom composites, hooks, providers, and heroicons subpaths.",
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://stackra.com"
  },
  "keywords": [
    "stackra",
    "ui",
    "react",
    "heroui",
    "heroui-pro",
    "heroicons",
    "tailwind",
    "components",
    "client-side"
  ],
  "homepage": "https://github.com/stackra-inc/core/tree/main/ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stackra-inc/core.git",
    "directory": "ui"
  },
  "bugs": {
    "url": "https://github.com/stackra-inc/core/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "import": "./dist/native.mjs",
      "require": "./dist/native.js"
    },
    "./actions": {
      "types": "./dist/actions.d.ts",
      "import": "./dist/actions.mjs",
      "require": "./dist/actions.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.mjs",
      "require": "./dist/testing.js"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons/index.mjs",
      "require": "./dist/icons/index.js"
    },
    "./icons/iconify": {
      "types": "./dist/icons/iconify.d.ts",
      "import": "./dist/icons/iconify.mjs",
      "require": "./dist/icons/iconify.js"
    },
    "./icons/gravity-ui": {
      "import": "./dist/icons/gravity-ui.mjs",
      "require": "./dist/icons/gravity-ui.js"
    },
    "./icons/gravity-ui.json": "./src/icons/gravity-ui/icons.json",
    "./icons/heroicon/outline": {
      "types": "./dist/icons/heroicon/outline.d.ts",
      "import": "./dist/icons/heroicon/outline.mjs",
      "require": "./dist/icons/heroicon/outline.js"
    },
    "./icons/heroicon/solid": {
      "types": "./dist/icons/heroicon/solid.d.ts",
      "import": "./dist/icons/heroicon/solid.mjs",
      "require": "./dist/icons/heroicon/solid.js"
    },
    "./icons/heroicon/mini": {
      "types": "./dist/icons/heroicon/mini.d.ts",
      "import": "./dist/icons/heroicon/mini.mjs",
      "require": "./dist/icons/heroicon/mini.js"
    },
    "./icons/heroicon/micro": {
      "types": "./dist/icons/heroicon/micro.d.ts",
      "import": "./dist/icons/heroicon/micro.mjs",
      "require": "./dist/icons/heroicon/micro.js"
    },
    "./react/styles": "./src/react/styles/globals.css",
    "./react/styles/*": "./src/react/styles/*"
  },
  "files": [
    "dist",
    "src/icons/gravity-ui/icons.json",
    "src/react/styles",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist .turbo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "peerDependencies": {
    "@heroicons/react": "catalog:",
    "@heroui-pro/react": "catalog:",
    "@heroui/react": "catalog:",
    "@iconify/react": "catalog:",
    "@stackra/actions": "workspace:^",
    "@stackra/container": "workspace:^",
    "@stackra/contracts": "workspace:^",
    "@stackra/logger": "workspace:^",
    "@stackra/testing": "workspace:^",
    "heroui-native": "^1.0.0",
    "heroui-native-pro": "^1.0.0-beta.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-native": "*",
    "tailwindcss": "catalog:"
  },
  "peerDependenciesMeta": {
    "@heroui-pro/react": {
      "optional": true
    },
    "@iconify/react": {
      "optional": true
    },
    "@stackra/actions": {
      "optional": true
    },
    "@stackra/testing": {
      "optional": true
    },
    "heroui-native": {
      "optional": true
    },
    "heroui-native-pro": {
      "optional": true
    },
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@heroicons/react": "catalog:",
    "@heroui-pro/react": "catalog:",
    "@heroui/react": "catalog:",
    "@iconify/react": "catalog:",
    "@stackra/actions": "workspace:*",
    "@stackra/container": "workspace:*",
    "@stackra/contracts": "workspace:*",
    "@stackra/logger": "workspace:*",
    "@stackra/testing": "workspace:*",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "heroui-native": "^1.0.0",
    "heroui-native-pro": "^1.0.0-beta.1",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-native": "^0.76.0",
    "rimraf": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
