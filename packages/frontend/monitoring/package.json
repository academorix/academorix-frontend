{
  "name": "@stackra/monitoring",
  "version": "0.1.0",
  "description": "Error-monitoring for the Stackra framework \u2014 a consent-agnostic, fan-out manager over pluggable providers (Sentry, console, custom), with auto-registration and React bindings.",
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://stackra.com"
  },
  "keywords": [
    "stackra",
    "monitoring",
    "error-reporting",
    "sentry",
    "observability",
    "react"
  ],
  "homepage": "https://github.com/stackra-inc/core/tree/main/monitoring#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stackra-inc/core.git",
    "directory": "monitoring"
  },
  "bugs": {
    "url": "https://github.com/stackra-inc/core/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.mjs",
      "require": "./dist/testing.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist .turbo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "@vivtel/metadata": "catalog:"
  },
  "peerDependencies": {
    "@sentry/browser": "catalog:",
    "@stackra/container": "workspace:^",
    "@stackra/contracts": "workspace:^",
    "@stackra/logger": "workspace:^",
    "@stackra/support": "workspace:^",
    "@stackra/testing": "workspace:^",
    "react": "catalog:",
    "reflect-metadata": "catalog:"
  },
  "peerDependenciesMeta": {
    "@sentry/browser": {
      "optional": true
    },
    "@stackra/logger": {
      "optional": true
    },
    "@stackra/testing": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@stackra/config-tsconfig": "workspace:*",
    "@stackra/config-tsup": "workspace:*",
    "@stackra/container": "workspace:*",
    "@stackra/contracts": "workspace:*",
    "@stackra/logger": "workspace:*",
    "@stackra/support": "workspace:*",
    "@stackra/testing": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "react": "catalog:",
    "reflect-metadata": "catalog:",
    "rimraf": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
