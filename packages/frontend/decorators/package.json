{
  "name": "@stackra/decorators",
  "version": "0.1.0",
  "description": "Centralised decorator library for the Stackra framework \u2014 generic factories for class-level, method-level, and property-level metadata decorators, plus domain wrappers (@DevtoolsPanel, @DevtoolsInspectorSource, ...). Feature packages import from here to stay decoupled from the runtime loaders that read the stamped metadata.",
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://stackra.com"
  },
  "keywords": [
    "stackra",
    "decorators",
    "metadata",
    "reflect-metadata",
    "dependency-injection",
    "typescript"
  ],
  "homepage": "https://github.com/stackra-inc/core/tree/main/decorators#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stackra-inc/core.git",
    "directory": "decorators"
  },
  "bugs": {
    "url": "https://github.com/stackra-inc/core/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.mjs",
      "require": "./dist/core.js"
    },
    "./devtools": {
      "types": "./dist/devtools.d.ts",
      "import": "./dist/devtools.mjs",
      "require": "./dist/devtools.js"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "import": "./dist/logger.mjs",
      "require": "./dist/logger.js"
    },
    "./events": {
      "types": "./dist/events.d.ts",
      "import": "./dist/events.mjs",
      "require": "./dist/events.js"
    },
    "./cache": {
      "types": "./dist/cache.d.ts",
      "import": "./dist/cache.mjs",
      "require": "./dist/cache.js"
    },
    "./queue": {
      "types": "./dist/queue.d.ts",
      "import": "./dist/queue.mjs",
      "require": "./dist/queue.js"
    },
    "./routing": {
      "types": "./dist/routing.d.ts",
      "import": "./dist/routing.mjs",
      "require": "./dist/routing.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist .turbo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "@vivtel/metadata": "catalog:"
  },
  "peerDependencies": {
    "@stackra/container": "workspace:^",
    "@stackra/contracts": "workspace:^",
    "@stackra/testing": "workspace:^",
    "reflect-metadata": "catalog:"
  },
  "peerDependenciesMeta": {
    "@stackra/testing": {
      "optional": true
    }
  },
  "devDependencies": {
    "@stackra/config-tsconfig": "workspace:*",
    "@stackra/config-tsup": "workspace:*",
    "@stackra/container": "workspace:*",
    "@stackra/contracts": "workspace:*",
    "@stackra/testing": "workspace:*",
    "@types/node": "catalog:",
    "reflect-metadata": "catalog:",
    "rimraf": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
