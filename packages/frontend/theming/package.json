{
  "name": "@stackra/theming",
  "version": "0.1.0",
  "description": "Unified theming system — color mode, named presets, design tokens, runtime switching across web and native.",
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://stackra.com"
  },
  "keywords": [
    "stackra",
    "theming",
    "cross-platform",
    "unified"
  ],
  "homepage": "https://github.com/stackra-inc/core/tree/main/theming#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stackra-inc/core.git",
    "directory": "theming"
  },
  "bugs": {
    "url": "https://github.com/stackra-inc/core/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "import": "./dist/native.mjs",
      "require": "./dist/native.js"
    }
  },
  "files": [
    "config",
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist .turbo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "peerDependencies": {
    "@heroui/react": ">=3.0.0",
    "@react-native-async-storage/async-storage": ">=1.0.0",
    "@stackra/container": "workspace:^",
    "@stackra/contracts": "workspace:^",
    "@stackra/support": "workspace:^",
    "@stackra/testing": "workspace:^",
    "react": "*",
    "react-native": "*",
    "react-native-reanimated": ">=3.0.0",
    "reflect-metadata": "*",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@heroui/react": {
      "optional": true
    },
    "@react-native-async-storage/async-storage": {
      "optional": true
    },
    "@stackra/testing": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-native-reanimated": {
      "optional": true
    }
  },
  "devDependencies": {
    "@heroui/react": "catalog:",
    "@stackra/container": "workspace:*",
    "@stackra/contracts": "workspace:*",
    "@stackra/support": "workspace:*",
    "@stackra/testing": "workspace:*",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-native": "catalog:",
    "reflect-metadata": "catalog:",
    "rimraf": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  }
}
