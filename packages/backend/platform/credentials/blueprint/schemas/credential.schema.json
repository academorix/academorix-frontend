{
  "id": "stackra://modules/credentials/schemas/credential",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "Credential",
  "description": "NFC / RFID / QR credential — UID + polymorphic holder + status. One active per holder.",
  "type": "object",
  "x-module": "credentials",
  "x-eloquent": {
    "table": "credentials",
    "keyPrefix": "cnl_",
    "traits": [
      "HasFactory",
      "HasPrefixedUlid",
      "BelongsToTenant",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "HasActivityLog",
      "Filterable",
      "SoftDeletes"
    ]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 30, "primary": true },
      "tenant_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "uid": {
        "type": "string",
        "length": 128,
        "nullable": false,
        "description": "Hex-encoded NFC/RFID UID (typically 8 or 14 hex chars for MIFARE/NTAG)."
      },
      "kind": {
        "type": "string",
        "length": 16,
        "nullable": false,
        "description": "nfc / rfid / qr / wristband / card."
      },
      "holder_type": {
        "type": "string",
        "length": 32,
        "nullable": false,
        "description": "Polymorphic — athletes / staff."
      },
      "holder_id": { "type": "string", "length": 30, "nullable": false },
      "branch_id": {
        "type": "string",
        "length": 30,
        "nullable": true,
        "foreign": { "table": "branches", "column": "id", "onDelete": "set null" },
        "description": "Branch that issued the credential."
      },
      "issued_at": { "type": "timestamptz", "nullable": false },
      "activated_at": { "type": "timestamptz", "nullable": true },
      "revoked_at": { "type": "timestamptz", "nullable": true },
      "revoked_reason": { "type": "string", "length": 200, "nullable": true },
      "replaced_by_credential_id": {
        "type": "string",
        "length": 30,
        "nullable": true,
        "foreign": { "table": "credentials", "column": "id", "onDelete": "set null" }
      },
      "status": { "type": "string", "length": 16, "nullable": false, "default": "'issued'" },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false },
      "deleted_at": { "type": "timestamptz", "nullable": true }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "uid"],
        "unique": true,
        "name": "credentials_uid_unique",
        "predicate": "deleted_at IS NULL AND status <> 'revoked'"
      },
      {
        "columns": ["tenant_id", "holder_type", "holder_id", "status"],
        "name": "credentials_holder_status_idx"
      }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "uid",
    "kind",
    "holder_type",
    "holder_id",
    "issued_at",
    "status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^cnl_[0-9A-HJKMNP-TV-Z]{26}$" },
    "kind": { "type": "string", "enum": ["nfc", "rfid", "qr", "wristband", "card"] },
    "holder_type": { "type": "string", "enum": ["athletes", "staff"] },
    "status": { "type": "string", "enum": ["issued", "active", "lost", "revoked", "replaced"] }
  },
  "additionalProperties": false,
  "x-invariants": [
    "One ACTIVE credential per (holder_type, holder_id) via partial unique index.",
    "revoked_at + revoked_reason REQUIRED when status IN ('revoked', 'lost').",
    "replaced_by_credential_id REQUIRED when status = 'replaced'."
  ]
}
