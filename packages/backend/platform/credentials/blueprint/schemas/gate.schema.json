{
  "id": "stackra://modules/credentials/schemas/gate",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "Gate",
  "description": "NFC/RFID reader/gate at a branch — label + last_heartbeat_at + location. Offline alert when heartbeat missed > 5m.",
  "type": "object",
  "x-module": "credentials",
  "x-eloquent": {
    "table": "gates",
    "keyPrefix": "gte_",
    "traits": [
      "HasFactory",
      "HasPrefixedUlid",
      "BelongsToTenant",
      "BelongsToBranch",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "Filterable",
      "SoftDeletes"
    ]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 30, "primary": true },
      "tenant_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "branch_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "branches", "column": "id", "onDelete": "cascade" }
      },
      "label": { "type": "string", "length": 100, "nullable": false },
      "location_description": { "type": "string", "length": 200, "nullable": true },
      "device_id": {
        "type": "string",
        "length": 128,
        "nullable": true,
        "description": "Manufacturer/serial identifier."
      },
      "last_heartbeat_at": { "type": "timestamptz", "nullable": true },
      "is_online": { "type": "boolean", "nullable": false, "default": "false" },
      "reader_type": {
        "type": "string",
        "length": 24,
        "nullable": false,
        "description": "nfc / rfid / qr / hybrid."
      },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false },
      "deleted_at": { "type": "timestamptz", "nullable": true }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "branch_id", "label"],
        "unique": true,
        "name": "gates_unique",
        "predicate": "deleted_at IS NULL"
      },
      {
        "columns": ["tenant_id", "last_heartbeat_at"],
        "name": "gates_heartbeat_idx",
        "predicate": "is_online = true"
      }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "branch_id",
    "label",
    "reader_type",
    "is_online",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^gte_[0-9A-HJKMNP-TV-Z]{26}$" },
    "reader_type": { "type": "string", "enum": ["nfc", "rfid", "qr", "hybrid"] }
  },
  "additionalProperties": false
}
