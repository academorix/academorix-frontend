{
  "id": "stackra://modules/credentials/schemas/checkin-log",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "CheckinLog",
  "description": "Raw check-in event from a Gate — UID + gate + timestamp. 2-second debounce for repeat taps. Feeds sports/attendance via AttendanceIngestListener.",
  "type": "object",
  "x-module": "credentials",
  "x-eloquent": {
    "table": "checkin_logs",
    "keyPrefix": "chl_",
    "traits": ["HasFactory", "HasPrefixedUlid", "BelongsToTenant", "HasMetadata", "Filterable"]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 30, "primary": true },
      "tenant_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "gate_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "gates", "column": "id", "onDelete": "restrict" }
      },
      "uid": { "type": "string", "length": 128, "nullable": false },
      "credential_id": {
        "type": "string",
        "length": 30,
        "nullable": true,
        "foreign": { "table": "credentials", "column": "id", "onDelete": "set null" }
      },
      "direction": { "type": "string", "length": 8, "nullable": false, "description": "in / out." },
      "recorded_at": { "type": "timestamptz", "nullable": false },
      "attendance_record_id": {
        "type": "string",
        "length": 30,
        "nullable": true,
        "foreign": { "table": "attendance_records", "column": "id", "onDelete": "set null" }
      },
      "resolved": {
        "type": "boolean",
        "nullable": false,
        "default": "false",
        "description": "TRUE when successfully forwarded to attendance."
      },
      "unresolved_reason": { "type": "string", "length": 200, "nullable": true },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      { "columns": ["tenant_id", "gate_id", "recorded_at"], "name": "checkin_logs_gate_time_idx" },
      { "columns": ["tenant_id", "uid", "recorded_at"], "name": "checkin_logs_uid_time_idx" },
      {
        "columns": ["tenant_id", "resolved"],
        "name": "checkin_logs_resolved_idx",
        "predicate": "resolved = false"
      }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "gate_id",
    "uid",
    "direction",
    "recorded_at",
    "resolved",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^chl_[0-9A-HJKMNP-TV-Z]{26}$" },
    "direction": { "type": "string", "enum": ["in", "out"] }
  },
  "additionalProperties": false
}
