{
  "id": "stackra://modules/credentials/permissions",
  "$version": 1,
  "title": "credentials — permissions",
  "seeder": "Stackra\\Platform\\Credentials\\Database\\Seeders\\CredentialsPermissionSeeder",
  "isSystem": true,
  "description": "Gate authorization is split between DEVICE auth (service accounts + JWT) and USER admin (this permission set). Front desk issues + reports lost; branch_manager + admin manage full lifecycle.",
  "permissions": [
    {
      "name": "credentials.viewAny",
      "guard": "sanctum",
      "seededOn": ["front_desk", "branch_manager", "admin", "owner"]
    },
    {
      "name": "credentials.view",
      "guard": "sanctum",
      "description": "Users see own credentials.",
      "seededOn": [
        "athlete",
        "parent_guardian",
        "coach",
        "medical",
        "front_desk",
        "branch_manager",
        "admin",
        "owner"
      ]
    },
    {
      "name": "credentials.issue",
      "guard": "sanctum",
      "description": "Issue a new credential to a holder.",
      "seededOn": ["front_desk", "branch_manager", "admin", "owner"]
    },
    {
      "name": "credentials.revoke",
      "guard": "sanctum",
      "description": "Front desk can only revoke with reason=lost.",
      "seededOn": ["front_desk", "branch_manager", "admin", "owner"]
    },
    {
      "name": "credentials.report-lost",
      "guard": "sanctum",
      "description": "Report a credential lost/stolen.",
      "seededOn": [
        "athlete",
        "parent_guardian",
        "coach",
        "medical",
        "front_desk",
        "branch_manager",
        "admin",
        "owner"
      ]
    },
    {
      "name": "gates.viewAny",
      "guard": "sanctum",
      "seededOn": ["front_desk", "branch_manager", "admin", "owner"]
    },
    {
      "name": "gates.view",
      "guard": "sanctum",
      "seededOn": ["front_desk", "branch_manager", "admin", "owner"]
    },
    {
      "name": "gates.create",
      "guard": "sanctum",
      "seededOn": ["branch_manager", "admin", "owner"]
    },
    {
      "name": "gates.update",
      "guard": "sanctum",
      "seededOn": ["branch_manager", "admin", "owner"]
    },
    {
      "name": "gates.configure",
      "guard": "sanctum",
      "description": "Change entry rules / modes / allowed credential kinds. High-impact.",
      "seededOn": ["admin", "owner"]
    },
    { "name": "gates.delete", "guard": "sanctum", "seededOn": ["admin", "owner"] },
    {
      "name": "gate-scans.viewAny",
      "guard": "sanctum",
      "description": "Front desk sees current-day scans only.",
      "seededOn": ["front_desk", "branch_manager", "admin", "owner"]
    },
    {
      "name": "gate-scans.view",
      "guard": "sanctum",
      "seededOn": ["front_desk", "branch_manager", "admin", "owner"]
    },
    {
      "name": "gate-scans.security-audit",
      "guard": "sanctum",
      "description": "Full historical scan audit — for security investigations (clone detection).",
      "seededOn": ["admin", "owner"]
    },
    {
      "name": "platform.credentials.audit",
      "guard": "platform_admin",
      "description": "Cross-tenant credential + gate security audit.",
      "seededOn": ["super_admin", "security"]
    },
    {
      "name": "platform.gate-scans.audit",
      "guard": "platform_admin",
      "description": "Cross-tenant scan pattern audit — clone-uid detection tuning.",
      "seededOn": ["super_admin", "security"]
    }
  ]
}
