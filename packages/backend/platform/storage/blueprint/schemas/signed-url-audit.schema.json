{
  "id": "stackra://modules/storage/schemas/signed-url-audit",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "SignedUrlAudit",
  "description": "One row per signed URL issued. Powers revocation + compliance reporting + abuse detection. High-volume (every file preview + download issues one). Hard-purged on retention (default 90 days) \u2014 no SoftDeletes, no HasActivityLog, no HasAuditable so writes stay cheap.",
  "type": "object",
  "x-module": "storage",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "signed_url_audits",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "sua_",
    "incrementing": false,
    "model": "Stackra\\Storage\\Models\\SignedUrlAudit",
    "interface": "Stackra\\Storage\\Contracts\\Data\\SignedUrlAuditInterface",
    "implements": ["Stackra\\Storage\\Contracts\\Data\\SignedUrlAuditInterface"],
    "traits": ["HasFactory", "HasUlids", "BelongsToTenant", "HasMetadata", "Filterable"],
    "casts": {
      "reason": "SignedUrlReason",
      "ttl_seconds": "integer",
      "hit_count": "integer",
      "issued_at": "datetime",
      "expires_at": "datetime",
      "last_hit_at": "datetime",
      "revoked_at": "datetime",
      "metadata": "array"
    },
    "appends": ["is_active", "is_expired"],
    "observers": [],
    "hidden": ["signature_hash"],
    "guarded": []
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": {
        "type": "string",
        "length": 64,
        "primary": true,
        "description": "Prefixed ULID: `sua_<26 chars>`."
      },
      "file_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "files", "column": "id", "onDelete": "cascade" },
        "description": "The file this URL grants access to. Cascade on file erasure."
      },
      "variant_key": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "description": "When the URL points at a variant (thumbnail/medium/hero) rather than the parent file. Null = URL points at the parent."
      },
      "tenant_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "issued_to_user_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": { "table": "users", "column": "id", "onDelete": "set null" },
        "description": "The user the URL was issued to. Nullable for anonymous share links."
      },
      "issued_by_user_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": { "table": "users", "column": "id", "onDelete": "set null" },
        "description": "The user (typically tenant admin) who caused the URL to be issued. Null for system-initiated signs (background exports, digest emails)."
      },
      "reason": {
        "type": "string",
        "length": 24,
        "nullable": false,
        "description": "Enum: download / preview / share / admin_action / export / notification_attachment."
      },
      "signature_hash": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "description": "SHA-256 of the signature portion of the URL. Enables revocation lookup without storing the full URL (which could carry sensitive query params)."
      },
      "ttl_seconds": {
        "type": "integer",
        "nullable": false,
        "description": "Requested TTL. Enforced against per-plan-tier caps."
      },
      "issued_at": { "type": "timestamptz", "nullable": false },
      "expires_at": {
        "type": "timestamptz",
        "nullable": false,
        "description": "issued_at + ttl_seconds. Indexed for the sweep job."
      },
      "ip_lock": {
        "type": "cidr",
        "nullable": true,
        "description": "Optional CIDR IP-lock. URL rejects on mismatch. Set for admin_action reasons."
      },
      "user_lock": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "description": "Optional user-lock. URL rejects unless the requesting session's user matches. Set for restricted-visibility files."
      },
      "one_time_use": {
        "type": "boolean",
        "nullable": false,
        "default": false,
        "description": "When true, URL becomes revoked after the first successful hit."
      },
      "hit_count": {
        "type": "integer",
        "nullable": false,
        "default": 0,
        "description": "Incremented by the storage.audit-hit middleware on every successful redemption."
      },
      "last_hit_at": { "type": "timestamptz", "nullable": true },
      "revoked_at": { "type": "timestamptz", "nullable": true },
      "revoked_reason": {
        "type": "string",
        "length": 128,
        "nullable": true,
        "description": "Free-form: `admin_bulk_revoke`, `expired_by_sweep`, `one_time_use_consumed`, `tenant_erased`."
      },
      "metadata": {
        "type": "jsonb",
        "nullable": true,
        "description": "Free-form context (source route, correlation id, user-agent excerpt)."
      },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["file_id", "expires_at"],
        "unique": false,
        "name": "signed_url_audits_file_expires_idx",
        "description": "Bulk revoke on a file: DELETE / UPDATE SET revoked_at where file_id = X AND expires_at > NOW()."
      },
      {
        "columns": ["signature_hash"],
        "unique": true,
        "name": "signed_url_audits_signature_unique",
        "description": "Redemption lookup path \u2014 the redemption middleware hashes the incoming signature + looks up the audit row."
      },
      {
        "columns": ["expires_at"],
        "unique": false,
        "name": "signed_url_audits_expires_idx",
        "predicate": "revoked_at IS NULL",
        "description": "RevokeExpiredSignedUrlsJob sweep."
      },
      {
        "columns": ["tenant_id", "issued_at"],
        "unique": false,
        "name": "signed_url_audits_tenant_issued_idx",
        "description": "Abuse detection: 'how many signed URLs did tenant X issue in the last hour?'"
      },
      {
        "columns": ["issued_to_user_id", "issued_at"],
        "unique": false,
        "name": "signed_url_audits_user_idx",
        "predicate": "issued_to_user_id IS NOT NULL",
        "description": "DSAR: 'give me every URL issued to user X'."
      }
    ]
  },
  "required": [
    "id",
    "file_id",
    "tenant_id",
    "reason",
    "signature_hash",
    "ttl_seconds",
    "issued_at",
    "expires_at",
    "one_time_use",
    "hit_count",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^sua_[0-9A-HJKMNP-TV-Z]{26}$" },
    "file_id": { "type": "string", "pattern": "^fil_[0-9A-HJKMNP-TV-Z]{26}$" },
    "variant_key": { "type": ["string", "null"], "pattern": "^[a-z][a-z0-9_-]{0,62}$" },
    "tenant_id": { "type": "string", "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "issued_to_user_id": { "type": ["string", "null"] },
    "issued_by_user_id": { "type": ["string", "null"] },
    "reason": {
      "type": "string",
      "enum": ["download", "preview", "share", "admin_action", "export", "notification_attachment"]
    },
    "signature_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "ttl_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2592000,
      "description": "1s to 30d. Per-plan caps enforced at issuance."
    },
    "issued_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "ip_lock": { "type": ["string", "null"], "description": "CIDR block. e.g. `192.0.2.0/24`." },
    "user_lock": { "type": ["string", "null"] },
    "one_time_use": { "type": "boolean" },
    "hit_count": { "type": "integer", "minimum": 0 },
    "last_hit_at": { "type": ["string", "null"], "format": "date-time" },
    "revoked_at": { "type": ["string", "null"], "format": "date-time" },
    "revoked_reason": { "type": ["string", "null"], "maxLength": 128 },
    "is_active": {
      "type": "boolean",
      "description": "Computed. revoked_at IS NULL AND expires_at > NOW() AND (NOT one_time_use OR hit_count = 0)."
    },
    "is_expired": { "type": "boolean", "description": "Computed. expires_at <= NOW()." },
    "metadata": { "type": ["object", "null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false,
  "x-wire": {
    "envelope": "spatie-data",
    "wrap": "data",
    "mapper": "SnakeCaseMapper",
    "hidden": ["signature_hash"],
    "computed": ["is_active", "is_expired"]
  }
}
