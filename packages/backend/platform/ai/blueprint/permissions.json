{
  "id": "stackra://modules/ai/permissions",
  "$version": 1,
  "title": "ai — permissions",
  "seeder": "Stackra\\AI\\Database\\Seeders\\AiPermissionSeeder",
  "isSystem": true,
  "description": "Persona-role bindings sourced from the canonical Tenancy::defaultRoles() catalogue: `owner, admin, branch_manager, coach, athlete, parent_guardian, front_desk, viewer` (base) + `medical` (sports variants). NO head_coach / hr / finance / staff roles — those don't exist in the catalogue. Draft-then-confirm ability + tool write-back gated per persona.",
  "permissions": [
    {
      "name": "ai.conversations.viewAny",
      "guard": "sanctum",
      "seededOn": [
        "athlete",
        "parent_guardian",
        "coach",
        "medical",
        "front_desk",
        "branch_manager",
        "admin",
        "owner"
      ]
    },
    {
      "name": "ai.conversations.view",
      "guard": "sanctum",
      "seededOn": [
        "athlete",
        "parent_guardian",
        "coach",
        "medical",
        "front_desk",
        "branch_manager",
        "admin",
        "owner"
      ]
    },
    {
      "name": "ai.conversations.start",
      "guard": "sanctum",
      "description": "Gated by ai.persona-role middleware — persona checked against caller's roles.",
      "seededOn": [
        "athlete",
        "parent_guardian",
        "coach",
        "medical",
        "front_desk",
        "branch_manager",
        "admin",
        "owner"
      ]
    },
    {
      "name": "ai.conversations.archive",
      "guard": "sanctum",
      "seededOn": [
        "athlete",
        "parent_guardian",
        "coach",
        "medical",
        "front_desk",
        "branch_manager",
        "admin",
        "owner"
      ]
    },
    {
      "name": "ai.conversations.delete",
      "guard": "sanctum",
      "seededOn": [
        "athlete",
        "parent_guardian",
        "coach",
        "medical",
        "front_desk",
        "branch_manager",
        "admin",
        "owner"
      ]
    },

    {
      "name": "ai.personas.CoachAssistantPersona",
      "guard": "sanctum",
      "description": "Persona binding — required to start CoachAssistant conversations.",
      "seededOn": ["coach"]
    },
    {
      "name": "ai.personas.ParentAssistantPersona",
      "guard": "sanctum",
      "seededOn": ["parent_guardian"]
    },
    {
      "name": "ai.personas.AthleteAssistantPersona",
      "guard": "sanctum",
      "description": "Feature-flagged v1.5 deferred.",
      "seededOn": ["athlete"]
    },
    {
      "name": "ai.personas.AdminAssistantPersona",
      "guard": "sanctum",
      "seededOn": ["admin", "owner"]
    },
    {
      "name": "ai.personas.FinanceAssistantPersona",
      "guard": "sanctum",
      "seededOn": ["admin", "owner"]
    },
    {
      "name": "ai.personas.MedicalAssistantPersona",
      "guard": "sanctum",
      "description": "Medical role only. #[NeverAutoWrite]. Always draft-then-confirm.",
      "seededOn": ["medical"]
    },
    {
      "name": "ai.personas.StaffAssistantPersona",
      "guard": "sanctum",
      "seededOn": ["branch_manager"]
    },
    {
      "name": "ai.personas.ReceptionAssistantPersona",
      "guard": "sanctum",
      "seededOn": ["front_desk"]
    },

    {
      "name": "ai.runs.viewAny",
      "guard": "sanctum",
      "seededOn": [
        "athlete",
        "parent_guardian",
        "coach",
        "medical",
        "front_desk",
        "branch_manager",
        "admin",
        "owner"
      ]
    },
    {
      "name": "ai.runs.view",
      "guard": "sanctum",
      "seededOn": [
        "athlete",
        "parent_guardian",
        "coach",
        "medical",
        "front_desk",
        "branch_manager",
        "admin",
        "owner"
      ]
    },
    {
      "name": "ai.runs.cancel",
      "guard": "sanctum",
      "description": "Cancel in-flight run. Sets status='cancelled'.",
      "seededOn": [
        "athlete",
        "parent_guardian",
        "coach",
        "medical",
        "front_desk",
        "branch_manager",
        "admin",
        "owner"
      ]
    },

    {
      "name": "ai.tool-calls.viewAny",
      "guard": "sanctum",
      "seededOn": [
        "athlete",
        "parent_guardian",
        "coach",
        "medical",
        "front_desk",
        "branch_manager",
        "admin",
        "owner"
      ]
    },
    {
      "name": "ai.tool-calls.view",
      "guard": "sanctum",
      "seededOn": [
        "athlete",
        "parent_guardian",
        "coach",
        "medical",
        "front_desk",
        "branch_manager",
        "admin",
        "owner"
      ]
    },

    {
      "name": "ai.drafts.viewAny",
      "guard": "sanctum",
      "seededOn": ["coach", "medical", "front_desk", "branch_manager", "admin", "owner"]
    },
    {
      "name": "ai.drafts.view",
      "guard": "sanctum",
      "seededOn": ["coach", "medical", "front_desk", "branch_manager", "admin", "owner"]
    },
    {
      "name": "ai.drafts.confirm",
      "guard": "sanctum",
      "description": "Confirm a draft — executes the pending domain action. Author or admin only.",
      "seededOn": ["coach", "medical", "front_desk", "branch_manager", "admin", "owner"]
    },
    {
      "name": "ai.drafts.discard",
      "guard": "sanctum",
      "seededOn": ["coach", "medical", "front_desk", "branch_manager", "admin", "owner"]
    },

    {
      "name": "ai.tools.background-write",
      "guard": "sanctum",
      "description": "Marker permission — carried by system/background users only.",
      "seededOn": []
    },

    {
      "name": "ai.mcp.serve",
      "guard": "sanctum",
      "description": "Access to expose tenant AI via MCP endpoint. Enterprise entitlement.",
      "seededOn": ["admin", "owner"]
    },

    {
      "name": "platform.ai.conversations.viewAny",
      "guard": "platform_admin",
      "description": "PII-masked. Prompts + responses redacted.",
      "seededOn": ["super_admin"]
    },
    {
      "name": "platform.ai.runs.audit",
      "guard": "platform_admin",
      "description": "Token/cost reconciliation. No prompt/response bodies.",
      "seededOn": ["super_admin", "ops"]
    },
    {
      "name": "platform.ai.tool-calls.audit",
      "guard": "platform_admin",
      "description": "Tool-abuse detection. tool_name + status only.",
      "seededOn": ["super_admin", "ops"]
    },
    {
      "name": "platform.ai.tool-registry.view",
      "guard": "platform_admin",
      "description": "Read the discovered tool registry across tenants.",
      "seededOn": ["super_admin", "ops", "support"]
    }
  ]
}
