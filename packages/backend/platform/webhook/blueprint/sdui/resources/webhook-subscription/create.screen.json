{
  "id": "webhook.resources.webhook-subscription.create",
  "title": "New webhook",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/webhooks/new",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "webhook", "entity": "webhook-subscription", "action": "create" },
  "requiresPermission": "webhook.subscriptions.create",
  "dataSources": [
    {
      "name": "eventsCatalog",
      "kind": "http.get",
      "url": "/api/v1/tenant/webhook/events",
      "unwrap": "data",
      "cache": { "ttlSeconds": 300 }
    },
    {
      "name": "destinationsCatalog",
      "kind": "http.get",
      "url": "/api/v1/tenant/webhook/destinations",
      "unwrap": "data",
      "cache": { "ttlSeconds": 300 }
    },
    {
      "name": "apiVersions",
      "kind": "http.get",
      "url": "/api/v1/tenant/versioning/api-versions",
      "unwrap": "data",
      "cache": { "ttlSeconds": 300 }
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-6 p-6 max-w-3xl mx-auto" },
      "children": [
        {
          "kind": "Link",
          "props": {
            "leadingIcon": "arrow-left",
            "children": "Cancel",
            "className": "text-sm text-muted"
          },
          "actions": { "onPress": { "kind": "navigate", "to": "/tenant/webhooks" } }
        },
        {
          "kind": "Text",
          "props": { "as": "h1", "className": "text-2xl font-semibold", "children": "New webhook" }
        },
        {
          "kind": "Alert",
          "props": {
            "variant": "info",
            "children": "The signing secret will be shown ONCE on creation. Save it \u2014 you won't see it again."
          }
        },
        {
          "kind": "Form",
          "props": {
            "submitUrl": "/api/v1/tenant/webhook/subscriptions",
            "submitMethod": "POST",
            "onSuccess": [
              {
                "kind": "toast.success",
                "message": "Webhook created. Save the secret from the response body."
              },
              { "kind": "navigateExpr", "expr": "'/tenant/webhooks/' + response.data.id" }
            ]
          },
          "children": [
            {
              "kind": "TextField",
              "props": {
                "label": "Name",
                "name": "name",
                "isRequired": true,
                "placeholder": "Prod webhook \u2014 payment updates"
              }
            },
            {
              "kind": "TextArea",
              "props": {
                "label": "Description",
                "name": "description",
                "rows": 2,
                "placeholder": "Optional notes about this webhook."
              }
            },
            {
              "kind": "Select",
              "props": {
                "label": "Destination",
                "name": "destination",
                "isRequired": true,
                "defaultValue": "https"
              },
              "optionsSource": {
                "$ref": "destinationsCatalog",
                "valueField": "name",
                "labelField": "display_name"
              },
              "description": "EventBridge / PubSub / mTLS require the enterprise plan."
            },
            {
              "kind": "TextField",
              "props": {
                "label": "URL",
                "name": "destination_config.url",
                "isRequired": true,
                "type": "url",
                "placeholder": "https://api.your-app.com/webhooks/stackra"
              }
            },
            {
              "kind": "MultiSelect",
              "props": {
                "label": "Events",
                "name": "events",
                "isRequired": true,
                "placeholder": "Pick events to subscribe to"
              },
              "optionsSource": {
                "$ref": "eventsCatalog",
                "valueField": "name",
                "labelField": "name"
              },
              "description": "Wildcards supported (invitation.* matches all invitation events)."
            },
            {
              "kind": "Select",
              "props": {
                "label": "API version pin",
                "name": "api_version",
                "placeholder": "Follow current"
              },
              "optionsSource": {
                "$ref": "apiVersions",
                "valueField": "slug",
                "labelField": "slug"
              },
              "description": "Pin to a specific version. Payloads auto-transform to the pinned version. Recommended: pin during breaking API migrations, unpin otherwise."
            },
            {
              "kind": "View",
              "props": { "className": "grid grid-cols-2 gap-3" },
              "children": [
                {
                  "kind": "NumberField",
                  "props": {
                    "label": "Timeout (seconds)",
                    "name": "timeout_seconds",
                    "defaultValue": 30,
                    "min": 1,
                    "max": 300
                  }
                },
                {
                  "kind": "NumberField",
                  "props": {
                    "label": "Max attempts",
                    "name": "max_attempts",
                    "defaultValue": 5,
                    "min": 1,
                    "max": 10
                  }
                },
                {
                  "kind": "NumberField",
                  "props": {
                    "label": "Rate limit (req/min)",
                    "name": "rate_limit_per_minute",
                    "min": 1,
                    "max": 100000,
                    "description": "Empty = unlimited (per plan)."
                  }
                },
                {
                  "kind": "NumberField",
                  "props": {
                    "label": "Failure threshold",
                    "name": "consecutive_failure_threshold",
                    "defaultValue": 30,
                    "min": 1,
                    "max": 1000,
                    "description": "Auto-disable after N consecutive failures."
                  }
                }
              ]
            },
            {
              "kind": "Switch",
              "props": {
                "label": "Verify SSL",
                "name": "verify_ssl",
                "defaultValue": true,
                "description": "Off only in dev environments."
              }
            },
            {
              "kind": "Switch",
              "props": {
                "label": "Compress payload (gzip)",
                "name": "compress_payload",
                "defaultValue": false,
                "description": "Reduces bandwidth for large payloads. Team + Enterprise."
              }
            },
            {
              "kind": "Button",
              "props": {
                "variant": "primary",
                "size": "md",
                "type": "submit",
                "children": "Create webhook"
              }
            }
          ]
        }
      ]
    }
  ]
}
