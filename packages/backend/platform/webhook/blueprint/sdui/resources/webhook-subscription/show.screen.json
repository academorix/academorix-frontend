{
  "id": "webhook.resources.webhook-subscription.show",
  "title": "Webhook detail",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/webhooks/{id}",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "webhook", "entity": "webhook-subscription", "action": "show" },
  "requiresPermission": "webhook.subscriptions.view",
  "params": [{ "name": "id", "type": "string", "in": "path", "required": true }],
  "dataSources": [
    {
      "name": "subscription",
      "kind": "http.get",
      "urlExpr": "'/api/v1/tenant/webhook/subscriptions/' + params.id",
      "unwrap": "data"
    },
    {
      "name": "recentDeliveries",
      "kind": "http.get",
      "urlExpr": "'/api/v1/tenant/webhook/deliveries?filter[subscription_id]=' + params.id + '&sort=-created_at&per_page=20'",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-6 p-6 max-w-5xl mx-auto" },
      "children": [
        {
          "kind": "Link",
          "props": {
            "leadingIcon": "arrow-left",
            "children": "Back",
            "className": "text-sm text-muted"
          },
          "actions": { "onPress": { "kind": "navigate", "to": "/tenant/webhooks" } }
        },
        {
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "kind": "View",
              "props": { "className": "flex flex-col gap-1" },
              "children": [
                {
                  "kind": "Text",
                  "props": { "as": "h1", "className": "text-2xl font-semibold" },
                  "bindings": { "children": { "$ref": "subscription.name" } }
                },
                {
                  "kind": "Text",
                  "props": { "className": "text-sm text-muted font-mono" },
                  "bindings": { "children": { "$ref": "subscription.id" } }
                },
                {
                  "kind": "View",
                  "props": { "className": "flex items-center gap-2 mt-2" },
                  "children": [
                    {
                      "kind": "Chip",
                      "props": { "size": "md" },
                      "bindings": {
                        "variant": {
                          "$expr": "subscription.state === 'active' ? 'success' : (subscription.state === 'paused' ? 'warning' : 'danger')"
                        },
                        "children": { "$ref": "subscription.state" }
                      }
                    },
                    {
                      "kind": "Chip",
                      "props": { "size": "sm", "variant": "neutral" },
                      "bindings": {
                        "hidden": { "$expr": "!subscription.api_version" },
                        "children": { "$expr": "'API ' + (subscription.api_version || 'current')" }
                      }
                    },
                    {
                      "kind": "Chip",
                      "props": { "size": "sm", "variant": "info" },
                      "bindings": {
                        "hidden": { "$expr": "!subscription.has_rotation_grace" },
                        "children": "rotation grace active"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "kind": "View",
              "props": { "className": "flex items-center gap-2" },
              "children": [
                {
                  "kind": "Button",
                  "props": {
                    "variant": "outline",
                    "size": "sm",
                    "leadingIcon": "beaker",
                    "children": "Send test"
                  },
                  "bindings": {
                    "isDisabled": {
                      "$expr": "!identity.permissions.includes('webhook.subscriptions.test')"
                    }
                  },
                  "actions": {
                    "onPress": {
                      "kind": "http.post",
                      "urlExpr": "'/api/v1/tenant/webhook/subscriptions/' + params.id + '/test'",
                      "onSuccess": {
                        "kind": "toast.success",
                        "message": "Test dispatched \u2014 check deliveries below."
                      }
                    }
                  }
                },
                {
                  "kind": "Button",
                  "props": {
                    "variant": "primary",
                    "size": "sm",
                    "leadingIcon": "pencil",
                    "children": "Edit"
                  },
                  "bindings": {
                    "isDisabled": {
                      "$expr": "!identity.permissions.includes('webhook.subscriptions.update') || subscription.is_system"
                    }
                  },
                  "actions": {
                    "onPress": {
                      "kind": "navigate",
                      "toExpr": "'/tenant/webhooks/' + params.id + '/edit'"
                    }
                  }
                }
              ]
            }
          ]
        },
        {
          "kind": "Alert",
          "props": { "variant": "danger" },
          "bindings": {
            "hidden": { "$expr": "!subscription.is_disabled" },
            "children": {
              "$expr": "'This subscription was disabled: ' + subscription.disabled_reason + '. Fix the receiver and click Resume when ready.'"
            }
          },
          "children": [
            {
              "kind": "Button",
              "props": {
                "variant": "primary",
                "size": "sm",
                "children": "Resume",
                "className": "mt-2"
              },
              "actions": {
                "onPress": {
                  "kind": "http.post",
                  "urlExpr": "'/api/v1/tenant/webhook/subscriptions/' + params.id + '/resume'",
                  "onSuccess": [
                    { "kind": "toast.success", "message": "Resumed" },
                    { "kind": "data.refresh", "source": "subscription" }
                  ]
                }
              }
            }
          ]
        },
        {
          "kind": "Card",
          "props": { "className": "p-6" },
          "children": [
            {
              "kind": "Text",
              "props": {
                "as": "h2",
                "className": "text-sm font-semibold text-muted uppercase tracking-wide mb-3",
                "children": "Configuration"
              }
            },
            {
              "kind": "DescriptionList",
              "children": [
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "Destination" },
                  "bindings": { "value": { "$ref": "subscription.destination" } }
                },
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "Events" },
                  "bindings": { "value": { "$expr": "subscription.events.join(', ')" } }
                },
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "Timeout" },
                  "bindings": { "value": { "$expr": "subscription.timeout_seconds + 's'" } }
                },
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "Max attempts" },
                  "bindings": { "value": { "$ref": "subscription.max_attempts" } }
                },
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "Backoff strategy" },
                  "bindings": { "value": { "$ref": "subscription.backoff_strategy" } }
                },
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "Rate limit" },
                  "bindings": {
                    "value": {
                      "$expr": "subscription.rate_limit_per_minute ? subscription.rate_limit_per_minute + '/min' : 'Unlimited'"
                    }
                  }
                },
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "Consecutive failures" },
                  "bindings": {
                    "value": {
                      "$expr": "subscription.consecutive_failure_count + ' / ' + subscription.consecutive_failure_threshold + ' threshold'"
                    }
                  }
                }
              ]
            }
          ]
        },
        {
          "kind": "Card",
          "props": { "className": "p-6" },
          "children": [
            {
              "kind": "Text",
              "props": {
                "as": "h2",
                "className": "text-sm font-semibold text-muted uppercase tracking-wide mb-3",
                "children": "Recent deliveries"
              }
            },
            {
              "kind": "List",
              "props": {
                "emptyState": {
                  "title": "No deliveries yet",
                  "description": "Deliveries appear here as events fire."
                }
              },
              "bindings": { "items": { "$ref": "recentDeliveries" } },
              "itemRenderer": {
                "kind": "View",
                "props": {
                  "className": "flex items-center justify-between p-3 border-b last:border-b-0"
                },
                "children": [
                  {
                    "kind": "View",
                    "props": { "className": "flex items-center gap-3" },
                    "children": [
                      {
                        "kind": "Widget",
                        "widget": "webhook.webhook-delivery-status-chip",
                        "props": { "state": { "$ref": "row.state" }, "size": "sm" }
                      },
                      {
                        "kind": "View",
                        "props": { "className": "flex flex-col" },
                        "children": [
                          {
                            "kind": "Text",
                            "props": { "className": "font-mono text-sm" },
                            "bindings": { "children": { "$ref": "row.event_name" } }
                          },
                          {
                            "kind": "Text",
                            "props": { "className": "text-xs text-muted" },
                            "bindings": {
                              "children": {
                                "$expr": "formatRelative(row.created_at) + (row.response_status ? ' \u00b7 ' + row.response_status : '') + (row.duration_ms ? ' \u00b7 ' + row.duration_ms + 'ms' : '')"
                              }
                            }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "kind": "Link",
                    "props": { "size": "sm", "children": "Detail" },
                    "actions": {
                      "onPress": {
                        "kind": "navigate",
                        "toExpr": "'/tenant/webhooks/deliveries/' + row.id"
                      }
                    }
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
