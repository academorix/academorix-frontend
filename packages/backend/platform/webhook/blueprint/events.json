{
  "id": "stackra://modules/webhook/events",
  "$version": 1,
  "title": "webhook \u2014 published events",
  "description": "14 events across subscription lifecycle + delivery lifecycle + health probes + inbound receipts. All afterCommit.",
  "namespace": "Stackra\\Webhook\\Events",
  "dispatchMode": "afterCommit",
  "events": [
    {
      "name": "WebhookSubscriptionCreated",
      "class": "Stackra\\Webhook\\Events\\WebhookSubscriptionCreated",
      "trigger": "New WebhookSubscription persisted.",
      "queue": "notifications",
      "consumers": [
        "versioning::ValidateSubscriptionVersion",
        "compliance::AuditWebhookSubscriptionCreatedListener"
      ],
      "payload": {
        "subscription_id": "ULID",
        "tenant_id": "ULID",
        "name": "string",
        "destination": "string",
        "events": "string[]",
        "api_version": "string | null",
        "created_by": "ULID | null"
      }
    },
    {
      "name": "WebhookSubscriptionUpdated",
      "class": "Stackra\\Webhook\\Events\\WebhookSubscriptionUpdated",
      "trigger": "WebhookSubscription attributes changed. Fires on every save; HasVersions captures the snapshot separately.",
      "queue": "notifications",
      "consumers": ["versioning::ValidateSubscriptionVersion"],
      "payload": { "subscription_id": "ULID", "tenant_id": "ULID", "changed_fields": "string[]" }
    },
    {
      "name": "WebhookSubscriptionPaused",
      "class": "Stackra\\Webhook\\Events\\WebhookSubscriptionPaused",
      "trigger": "state \u2192 paused (manual admin action or platform-ops pause).",
      "queue": "notifications",
      "consumers": ["compliance::AuditListener"],
      "payload": {
        "subscription_id": "ULID",
        "tenant_id": "ULID",
        "reason": "string",
        "actor_id": "ULID | null"
      }
    },
    {
      "name": "WebhookSubscriptionResumed",
      "class": "Stackra\\Webhook\\Events\\WebhookSubscriptionResumed",
      "trigger": "state \u2192 active (from paused or disabled).",
      "queue": "notifications",
      "consumers": ["compliance::AuditListener"],
      "payload": {
        "subscription_id": "ULID",
        "tenant_id": "ULID",
        "previous_state": "'paused' | 'disabled'",
        "actor_id": "ULID | null"
      }
    },
    {
      "name": "WebhookSubscriptionDisabled",
      "class": "Stackra\\Webhook\\Events\\WebhookSubscriptionDisabled",
      "trigger": "state \u2192 disabled (auto: 410 Gone / consecutive_failure_threshold / api_version_sunset / tenant_suspended; or manual).",
      "queue": "notifications-critical",
      "consumers": [
        "notifications::DispatchWebhookSubscriptionDisabledNotification",
        "compliance::AuditListener"
      ],
      "payload": {
        "subscription_id": "ULID",
        "tenant_id": "ULID",
        "reason": "'gone_410' | 'failure_threshold' | 'manual' | 'api_version_sunset' | 'tenant_suspended'",
        "disabled_at": "ISO 8601",
        "consecutive_failure_count": "integer"
      }
    },
    {
      "name": "WebhookSubscriptionUpgraded",
      "class": "Stackra\\Webhook\\Events\\WebhookSubscriptionUpgraded",
      "trigger": "AutoUpgradePinnedSubscriptionsJob transitioned subscription.api_version from a sunset version to the migration_target_slug.",
      "queue": "notifications",
      "consumers": [
        "notifications::DispatchWebhookSubscriptionUpgradedNotification",
        "compliance::AuditListener"
      ],
      "payload": {
        "subscription_id": "ULID",
        "tenant_id": "ULID",
        "from_version": "string",
        "to_version": "string",
        "reason": "'sunset_migration' | 'admin_action'"
      }
    },
    {
      "name": "WebhookSecretRotated",
      "class": "Stackra\\Webhook\\Events\\WebhookSecretRotated",
      "trigger": "Admin rotated the signing secret. secret_previous set + grace window started.",
      "queue": "notifications",
      "consumers": ["compliance::AuditSecretRotationListener"],
      "payload": {
        "subscription_id": "ULID",
        "tenant_id": "ULID",
        "grace_expires_at": "ISO 8601",
        "actor_id": "ULID"
      }
    },
    {
      "name": "WebhookDeliveryDispatched",
      "class": "Stackra\\Webhook\\Events\\WebhookDeliveryDispatched",
      "trigger": "DispatchWebhookJob started \u2014 state transitions pending \u2192 inFlight. Emitted for observability.",
      "queue": "notifications",
      "consumers": ["observability::MetricsCollector"],
      "payload": {
        "delivery_id": "ULID",
        "subscription_id": "ULID",
        "event_name": "string",
        "attempt_number": "integer",
        "batch_id": "string | null"
      }
    },
    {
      "name": "WebhookDelivered",
      "class": "Stackra\\Webhook\\Events\\WebhookDelivered",
      "trigger": "Delivery succeeded (2xx response). state \u2192 delivered.",
      "queue": "notifications",
      "consumers": ["observability::MetricsCollector", "notifications::TrackDeliveryListener"],
      "payload": {
        "delivery_id": "ULID",
        "subscription_id": "ULID",
        "tenant_id": "ULID",
        "event_name": "string",
        "response_status": "integer",
        "duration_ms": "integer",
        "attempt_number": "integer"
      }
    },
    {
      "name": "WebhookDeliveryFailed",
      "class": "Stackra\\Webhook\\Events\\WebhookDeliveryFailed",
      "trigger": "Retryable failure (408/425/429/5xx or network error). state \u2192 failedRetryable + next_attempt_at scheduled.",
      "queue": "notifications",
      "consumers": ["observability::MetricsCollector"],
      "payload": {
        "delivery_id": "ULID",
        "subscription_id": "ULID",
        "event_name": "string",
        "attempt_number": "integer",
        "response_status": "integer | null",
        "error_class": "string | null",
        "next_attempt_at": "ISO 8601"
      }
    },
    {
      "name": "WebhookDeliveryFailedPermanent",
      "class": "Stackra\\Webhook\\Events\\WebhookDeliveryFailedPermanent",
      "trigger": "Non-retryable failure (410 Gone, other 4xx, max_attempts exhausted, or hard error). state \u2192 failedPermanent.",
      "queue": "notifications-critical",
      "consumers": ["observability::MetricsCollector", "compliance::AuditPermanentFailureListener"],
      "payload": {
        "delivery_id": "ULID",
        "subscription_id": "ULID",
        "tenant_id": "ULID",
        "event_name": "string",
        "attempt_number": "integer",
        "response_status": "integer | null",
        "error_class": "string | null",
        "reason": "'gone' | 'max_attempts_exhausted' | 'permanent_4xx' | 'hard_error'"
      }
    },
    {
      "name": "WebhookProbeFailed",
      "class": "Stackra\\Webhook\\Events\\WebhookProbeFailed",
      "trigger": "WebhookProbeJob observed N consecutive health probe failures for a subscription.",
      "queue": "notifications-critical",
      "consumers": [
        "notifications::DispatchWebhookProbeFailedNotification",
        "observability::AlertingListener"
      ],
      "payload": {
        "subscription_id": "ULID",
        "tenant_id": "ULID",
        "consecutive_probe_failures": "integer",
        "last_probe_response_status": "integer | null",
        "last_probe_error": "string | null"
      }
    },
    {
      "name": "InboundWebhookReceived",
      "class": "Stackra\\Webhook\\Events\\InboundWebhookReceived",
      "trigger": "Inbound receiver accepted a signature-verified request. Fanned out to downstream module listeners.",
      "queue": "notifications-webhooks",
      "consumers": [
        "notifications-mail::IngestMailProviderWebhookListener",
        "notifications-push::IngestPushProviderWebhookListener",
        "notifications-sms::IngestSmsProviderWebhookListener",
        "subscription::IngestStripeWebhookListener",
        "any module with namespace-scoped ingestion"
      ],
      "payload": {
        "receipt_id": "ULID",
        "namespace": "string \u2014 e.g. 'notifications-mail'",
        "provider": "string \u2014 e.g. 'mailgun'",
        "headers": "object \u2014 sanitised header set",
        "payload": "object \u2014 raw parsed body",
        "request_id": "string",
        "received_at": "ISO 8601"
      }
    },
    {
      "name": "InboundWebhookProcessed",
      "class": "Stackra\\Webhook\\Events\\InboundWebhookProcessed",
      "trigger": "Downstream module signalled completion of inbound webhook processing.",
      "queue": "notifications-webhooks",
      "consumers": ["observability::MetricsCollector"],
      "payload": {
        "receipt_id": "ULID",
        "namespace": "string",
        "provider": "string",
        "handler_class": "string",
        "outcome": "'success' | 'failure'",
        "duration_ms": "integer"
      }
    }
  ]
}
