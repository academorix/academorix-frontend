        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/support",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../tenancy",
      "options": {
        "symlink": true
      }
    }
  ]
}
