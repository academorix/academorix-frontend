{
  "id": "branch.resources.branch.edit",
  "title": "Edit branch",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/branches/{branch_id}/edit",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "branch", "entity": "branch", "action": "update" },
  "requiresPermission": "branches.update",
  "dataSources": [
    {
      "name": "branch",
      "kind": "http.get",
      "urlExpr": "'/api/v1/branches/' + route.branch_id + '?include=organization,region'",
      "unwrap": "data"
    },
    {
      "name": "amenityCatalog",
      "kind": "static",
      "sourceFile": "data/amenity-catalog.json",
      "unwrap": "categories"
    },
    {
      "name": "me",
      "kind": "http.get",
      "url": "/api/auth/me",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-6 p-6 max-w-3xl" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-center justify-between" },
          "children": [
            {
              "kind": "View",
              "children": [
                {
                  "kind": "Text",
                  "props": { "as": "h1", "className": "text-2xl font-semibold" },
                  "bindings": { "children": { "$expr": "'Edit ' + branch.name" } }
                },
                {
                  "kind": "Text",
                  "props": { "className": "text-sm text-muted" },
                  "bindings": {
                    "children": { "$expr": "branch.organization_name + ' · ' + branch.region_name" }
                  }
                }
              ]
            },
            {
              "kind": "Widget",
              "props": { "id": "branch.is-open-chip" },
              "bindings": {
                "props": {
                  "status": { "$ref": "branch.status" },
                  "isOpenNow": { "$ref": "branch.is_open_now" },
                  "showLabel": true
                }
              }
            }
          ]
        },
        {
          "kind": "InfoBanner",
          "props": { "variant": "warning" },
          "bindings": {
            "hidden": { "$expr": "branch.status === 'active'" },
            "children": {
              "$expr": "branch.status === 'paused' ? 'This branch is paused. Edits go through but bookings are refused.' : 'This branch is closed. Read-only.'"
            }
          }
        },
        {
          "kind": "Form",
          "props": {
            "action": "http.patch",
            "urlExpr": "'/api/v1/branches/' + route.branch_id",
            "onSuccess": { "kind": "toast", "message": "Branch updated." }
          },
          "children": [
            {
              "kind": "Fieldset",
              "props": { "legend": "Identity" },
              "children": [
                {
                  "kind": "TextField",
                  "props": { "name": "name", "label": "Name", "required": true },
                  "bindings": { "defaultValue": { "$ref": "branch.name" } }
                },
                {
                  "kind": "TextField",
                  "props": { "name": "slug", "label": "Slug" },
                  "bindings": { "defaultValue": { "$ref": "branch.slug" } }
                },
                {
                  "kind": "TextField",
                  "props": { "name": "code", "label": "Internal code" },
                  "bindings": { "defaultValue": { "$ref": "branch.code" } }
                },
                {
                  "kind": "TextArea",
                  "props": { "name": "description", "label": "Description", "rows": 3 },
                  "bindings": { "defaultValue": { "$ref": "branch.description" } }
                },
                {
                  "kind": "NumberField",
                  "props": {
                    "name": "sort_order",
                    "label": "Sort order",
                    "min": 0,
                    "helpText": "Lower runs first in list views."
                  },
                  "bindings": { "defaultValue": { "$ref": "branch.sort_order" } }
                }
              ]
            },
            {
              "kind": "Fieldset",
              "props": { "legend": "Contact" },
              "children": [
                {
                  "kind": "TextField",
                  "props": { "name": "phone", "label": "Phone (E.164)" },
                  "bindings": { "defaultValue": { "$ref": "branch.phone" } }
                },
                {
                  "kind": "TextField",
                  "props": { "name": "email", "label": "Email", "inputMode": "email" },
                  "bindings": { "defaultValue": { "$ref": "branch.email" } }
                },
                {
                  "kind": "TextField",
                  "props": { "name": "website_url", "label": "Website" },
                  "bindings": { "defaultValue": { "$ref": "branch.website_url" } }
                }
              ]
            },
            {
              "kind": "Fieldset",
              "props": { "legend": "Capacity + amenities" },
              "children": [
                {
                  "kind": "NumberField",
                  "props": {
                    "name": "capacity",
                    "label": "Maximum concurrent occupants",
                    "min": 1,
                    "helpText": "Fire-safety cap. Blank = no cap."
                  },
                  "bindings": { "defaultValue": { "$ref": "branch.capacity" } }
                },
                {
                  "kind": "Widget",
                  "props": { "id": "branch.amenity-picker" },
                  "bindings": {
                    "props": {
                      "value_field": "amenities",
                      "defaultValue": { "$ref": "branch.amenities" },
                      "catalog": { "$ref": "amenityCatalog" },
                      "allow_custom": {
                        "$expr": "me.features.indexOf('branch.custom_amenities') > -1"
                      }
                    }
                  }
                }
              ]
            },
            {
              "kind": "View",
              "props": { "className": "flex justify-between items-center pt-4 border-t" },
              "children": [
                {
                  "kind": "View",
                  "props": { "className": "flex gap-2" },
                  "children": [
                    {
                      "kind": "Button",
                      "props": {
                        "variant": "ghost",
                        "leadingIcon": "clock",
                        "children": "Edit hours"
                      },
                      "actions": {
                        "onPress": {
                          "kind": "navigate",
                          "toExpr": "'/branches/' + route.branch_id + '/hours'"
                        }
                      },
                      "requiresPermission": "branches.update_hours"
                    },
                    {
                      "kind": "Button",
                      "props": {
                        "variant": "ghost",
                        "leadingIcon": "map-pin",
                        "children": "Edit address & map"
                      },
                      "actions": {
                        "onPress": {
                          "kind": "navigate",
                          "toExpr": "'/branches/map?focus=' + route.branch_id"
                        }
                      },
                      "requiresPermission": "branches.update_address"
                    }
                  ]
                },
                {
                  "kind": "SubmitButton",
                  "props": { "variant": "primary", "children": "Save changes" }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
