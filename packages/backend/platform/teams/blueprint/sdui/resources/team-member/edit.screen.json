{
  "id": "teams.resources.team-member.edit",
  "title": "Edit team member",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/teams/:teamId/members/:memberId/edit",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "teams", "entity": "team-member", "action": "update" },
  "requiresPermission": "team_members.update",
  "requiresEntitlement": "teams",
  "dataSources": [
    {
      "name": "team",
      "kind": "http.get",
      "url": "/api/v1/teams/{teamId}",
      "unwrap": "data"
    },
    {
      "name": "member",
      "kind": "http.get",
      "url": "/api/v1/teams/{teamId}/members/{memberId}",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-2xl mx-auto" },
      "children": [
        {
          "kind": "Text",
          "props": { "as": "h1", "className": "text-2xl font-semibold" },
          "bindings": {
            "children": { "$expr": "'Edit ' + member.member.name + ' on ' + team.name" }
          }
        },
        {
          "kind": "Alert",
          "props": { "variant": "info", "className": "text-sm" },
          "children": [
            {
              "kind": "Text",
              "props": {
                "children": "Member type and identity are immutable. To swap a member out, remove them and add a new roster row."
              }
            }
          ]
        },
        {
          "kind": "Form",
          "bindings": { "initialValues": { "$ref": "member" } },
          "actions": {
            "onSubmit": {
              "kind": "http.patch",
              "url": "/api/v1/teams/{teamId}/members/{memberId}",
              "onSuccess": {
                "kind": "navigate",
                "toExpr": "'/tenant/teams/' + team.id"
              },
              "onError": { "kind": "toast.error" }
            }
          },
          "children": [
            {
              "kind": "Fieldset",
              "props": { "legend": "Role", "className": "space-y-3" },
              "children": [
                {
                  "kind": "ComboBox",
                  "props": {
                    "name": "role_on_team",
                    "label": "Role",
                    "required": true,
                    "menuTrigger": "focus"
                  },
                  "props_items": [
                    { "id": "player", "label": "Player" },
                    { "id": "captain", "label": "Captain" },
                    { "id": "vice_captain", "label": "Vice-captain" },
                    { "id": "coach", "label": "Coach" },
                    { "id": "assistant_coach", "label": "Assistant coach" },
                    { "id": "team_manager", "label": "Team manager" },
                    { "id": "medical", "label": "Medical" },
                    { "id": "analyst", "label": "Analyst" },
                    { "id": "substitute", "label": "Substitute" }
                  ]
                },
                {
                  "kind": "View",
                  "props": { "className": "grid grid-cols-2 gap-3" },
                  "children": [
                    {
                      "kind": "NumberField",
                      "props": {
                        "name": "jersey_number",
                        "label": "Jersey number",
                        "min": 0,
                        "max": 999
                      }
                    },
                    {
                      "kind": "TextField",
                      "props": { "name": "position", "label": "Position", "maxLength": 64 }
                    }
                  ]
                }
              ]
            },
            {
              "kind": "Fieldset",
              "props": { "legend": "Notes", "className": "space-y-3" },
              "children": [
                {
                  "kind": "TextArea",
                  "props": {
                    "name": "notes",
                    "label": "Coach-visible notes",
                    "rows": 3,
                    "helpText": "Staff-only. Never surfaced to the member themselves."
                  }
                }
              ]
            },
            {
              "kind": "View",
              "props": { "className": "flex justify-between gap-2 pt-2" },
              "children": [
                {
                  "kind": "Button",
                  "props": { "variant": "danger-ghost", "children": "Remove from team" },
                  "actions": {
                    "onPress": {
                      "kind": "confirm",
                      "title": "Remove from team?",
                      "message": "This preserves the historic roster row (compliance material). The person can be re-added later.",
                      "confirm": {
                        "kind": "http.delete",
                        "url": "/api/v1/teams/{teamId}/members/{memberId}",
                        "onSuccess": { "kind": "navigate", "toExpr": "'/tenant/teams/' + team.id" }
                      }
                    }
                  },
                  "requiresPermission": "team_members.delete"
                },
                {
                  "kind": "View",
                  "props": { "className": "flex gap-2" },
                  "children": [
                    {
                      "kind": "Button",
                      "props": { "variant": "ghost", "children": "Cancel" },
                      "actions": {
                        "onPress": { "kind": "navigate", "toExpr": "'/tenant/teams/' + team.id" }
                      }
                    },
                    {
                      "kind": "Button",
                      "props": {
                        "type": "submit",
                        "variant": "primary",
                        "children": "Save changes"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
