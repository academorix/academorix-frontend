{
  "id": "teams.resources.team-trial.evaluate",
  "title": "Evaluate trial",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/teams/:teamId/trials/:trialId/evaluate",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "teams", "entity": "team-trial", "action": "evaluate" },
  "requiresPermission": "trials.evaluate",
  "requiresEntitlement": "team_trials",
  "dataSources": [
    {
      "name": "team",
      "kind": "http.get",
      "url": "/api/v1/teams/{teamId}",
      "unwrap": "data"
    },
    {
      "name": "trial",
      "kind": "http.get",
      "url": "/api/v1/teams/{teamId}/trials/{trialId}",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-2xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "kind": "View",
              "children": [
                {
                  "kind": "Text",
                  "props": { "as": "h1", "className": "text-2xl font-semibold" },
                  "bindings": {
                    "children": { "$expr": "'Evaluate ' + trial.trialist_display_name" }
                  }
                },
                {
                  "kind": "Text",
                  "props": { "className": "text-sm text-muted" },
                  "bindings": { "children": { "$expr": "'Trialing for ' + team.name" } }
                }
              ]
            },
            {
              "kind": "Widget",
              "widget": "teams.trial-status-chip",
              "bindings": { "status": { "$ref": "trial.status" } }
            }
          ]
        },
        {
          "kind": "Card",
          "props": { "className": "p-4 space-y-2" },
          "children": [
            {
              "kind": "View",
              "props": { "className": "grid grid-cols-2 gap-4" },
              "children": [
                {
                  "kind": "View",
                  "children": [
                    {
                      "kind": "Text",
                      "props": { "className": "text-xs text-muted", "children": "Type" }
                    },
                    {
                      "kind": "Text",
                      "props": { "className": "font-medium" },
                      "bindings": { "children": { "$ref": "trial.trial_type" } }
                    }
                  ]
                },
                {
                  "kind": "View",
                  "children": [
                    {
                      "kind": "Text",
                      "props": { "className": "text-xs text-muted", "children": "Sessions" }
                    },
                    {
                      "kind": "Text",
                      "props": { "className": "font-medium" },
                      "bindings": { "children": { "$ref": "trial.session_count" } }
                    }
                  ]
                },
                {
                  "kind": "View",
                  "children": [
                    {
                      "kind": "Text",
                      "props": { "className": "text-xs text-muted", "children": "Starts" }
                    },
                    {
                      "kind": "Text",
                      "props": { "className": "font-medium" },
                      "bindings": { "children": { "$ref": "trial.starts_at" } }
                    }
                  ]
                },
                {
                  "kind": "View",
                  "children": [
                    {
                      "kind": "Text",
                      "props": { "className": "text-xs text-muted", "children": "Ends" }
                    },
                    {
                      "kind": "Text",
                      "props": { "className": "font-medium" },
                      "bindings": { "children": { "$ref": "trial.ends_at" } }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "kind": "Form",
          "bindings": { "initialValues": { "$ref": "trial" } },
          "actions": {
            "onSubmit": {
              "kind": "http.post",
              "url": "/api/v1/teams/{teamId}/trials/{trialId}/complete",
              "onSuccess": {
                "kind": "navigate",
                "toExpr": "'/tenant/teams/' + team.id + '/trials/' + trial.id + '/decision'"
              },
              "onError": { "kind": "toast.error" }
            }
          },
          "children": [
            {
              "kind": "Fieldset",
              "props": { "legend": "Evaluation", "className": "space-y-3" },
              "children": [
                {
                  "kind": "TextArea",
                  "props": {
                    "name": "notes",
                    "label": "Evaluation notes",
                    "rows": 8,
                    "helpText": "Coach's assessment during the trial. Confidential — never surfaced to the trialist."
                  }
                }
              ]
            },
            {
              "kind": "View",
              "props": { "className": "flex justify-end gap-2 pt-2" },
              "children": [
                {
                  "kind": "Button",
                  "props": { "variant": "ghost", "children": "Cancel" },
                  "actions": {
                    "onPress": {
                      "kind": "navigate",
                      "toExpr": "'/tenant/teams/' + team.id + '/trials'"
                    }
                  }
                },
                {
                  "kind": "Button",
                  "props": {
                    "type": "submit",
                    "variant": "primary",
                    "children": "Complete + proceed to decision"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
