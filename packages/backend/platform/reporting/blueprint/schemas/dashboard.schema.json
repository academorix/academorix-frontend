{
  "id": "stackra://modules/reporting/schemas/dashboard",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "Dashboard",
  "type": "object",
  "x-module": "reporting",
  "x-eloquent": {
    "table": "dashboards",
    "keyPrefix": "dsh_",
    "traits": [
      "HasFactory",
      "HasPrefixedUlid",
      "BelongsToTenant",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "Filterable",
      "SoftDeletes"
    ]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 30, "primary": true },
      "tenant_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "owner_user_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "users", "column": "id", "onDelete": "cascade" }
      },
      "name": { "type": "string", "length": 200, "nullable": false },
      "description": { "type": "text", "nullable": true },
      "layout": { "type": "jsonb", "nullable": false, "default": "'{}'" },
      "widgets": {
        "type": "jsonb",
        "nullable": false,
        "default": "'[]'",
        "description": "Array of {key, saved_report_id?, definition_id?, kind, config, position}."
      },
      "audience_scope": {
        "type": "string",
        "length": 16,
        "nullable": false,
        "default": "'private'"
      },
      "shared_with_role": { "type": "string", "length": 32, "nullable": true },
      "last_snapshot_at": { "type": "timestamptz", "nullable": true },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false },
      "deleted_at": { "type": "timestamptz", "nullable": true }
    },
    "indexes": [{ "columns": ["tenant_id", "owner_user_id"], "name": "dashboards_owner_idx" }]
  },
  "required": [
    "id",
    "tenant_id",
    "owner_user_id",
    "name",
    "layout",
    "widgets",
    "audience_scope",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^dsh_[0-9A-HJKMNP-TV-Z]{26}$" },
    "audience_scope": {
      "type": "string",
      "enum": ["private", "shared_with_role", "shared_with_tenant", "public"]
    }
  },
  "additionalProperties": false
}
