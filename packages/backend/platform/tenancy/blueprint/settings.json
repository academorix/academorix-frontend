{
  "id": "stackra://modules/tenancy/settings",
  "$version": 1,
  "title": "tenants \u2014 settings",
  "description": "Tenant-facing tenant settings. Canonical group/section/field taxonomy. Six #[AsSetting] classes carved by concern: tenant basics, domains, branding, contacts, notification preferences, privacy. A seventh danger-zone group ships action-typed fields (archive tenant).",
  "storedIn": "settings",
  "sduiScreen": "sdui/screens/settings-tenant.screen.json",
  "reference": { "contract": "stackra://modules/settings/attributes" },
  "groups": [
    {
      "key": "tenant",
      "class": "Stackra\\Tenancy\\Settings\\TenantSettings",
      "label": "Tenant",
      "description": "Basic tenant preferences \u2014 timezone, locale, currency, formatting.",
      "icon": "building-office-2",
      "scope": "tenant",
      "public": false,
      "sortOrder": 1,
      "permission": "tenants.manage_own_settings",
      "sections": [
        {
          "label": "Locale + region",
          "description": "Applied to every session, report, and schedule surface.",
          "icon": "globe-europe-africa",
          "sortOrder": 1,
          "fields": [
            {
              "name": "timezone",
              "controlType": "timezone",
              "label": "Timezone",
              "defaultValue": "UTC",
              "validation": ["required", "timezone"],
              "sortOrder": 1,
              "helpText": "IANA identifier. Source of truth: Tenant.provisioning.timezone."
            },
            {
              "name": "locale",
              "controlType": "locale",
              "label": "Language",
              "defaultValue": "en",
              "validation": ["required", "string", "max:8"],
              "sortOrder": 2
            },
            {
              "name": "currency",
              "controlType": "currency",
              "label": "Currency",
              "defaultValue": "USD",
              "validation": ["required", "string", "size:3"],
              "sortOrder": 3
            }
          ]
        },
        {
          "label": "Formatting",
          "icon": "calendar-days",
          "sortOrder": 2,
          "fields": [
            {
              "name": "first_day_of_week",
              "controlType": "select",
              "label": "First day of week",
              "defaultValue": "monday",
              "options": { "monday": "Monday", "sunday": "Sunday", "saturday": "Saturday" },
              "validation": ["required", "string", "in:monday,sunday,saturday"],
              "sortOrder": 1
            },
            {
              "name": "date_format",
              "controlType": "select",
              "label": "Date format",
              "defaultValue": "iso",
              "options": {
                "iso": "ISO (2026-07-14)",
                "us": "US (07/14/2026)",
                "eu": "EU (14/07/2026)",
                "long": "Long (14 July 2026)"
              },
              "validation": ["required", "string", "in:iso,us,eu,long"],
              "sortOrder": 2
            },
            {
              "name": "time_format",
              "controlType": "select",
              "label": "Time format",
              "defaultValue": "24h",
              "options": { "24h": "24-hour", "12h": "12-hour" },
              "validation": ["required", "string", "in:24h,12h"],
              "sortOrder": 3
            }
          ]
        }
      ]
    },
    {
      "key": "tenant_domains",
      "class": "Stackra\\Tenancy\\Settings\\TenantDomainSettings",
      "label": "Custom domains",
      "description": "Custom domain preferences.",
      "icon": "globe-alt",
      "scope": "tenant",
      "public": false,
      "sortOrder": 2,
      "permission": "tenants.manage_domains",
      "gates": { "requires_feature_flag": "tenants.custom-domains" },
      "sections": [
        {
          "label": "Domain policy",
          "icon": "shield-check",
          "sortOrder": 1,
          "fields": [
            {
              "name": "allow_custom_domains",
              "controlType": "toggle",
              "label": "Allow custom domains",
              "defaultValue": true,
              "validation": ["boolean"],
              "sortOrder": 1
            },
            {
              "name": "enforce_https",
              "controlType": "toggle",
              "label": "Enforce HTTPS",
              "defaultValue": true,
              "validation": ["boolean"],
              "sortOrder": 2,
              "helpText": "Redirect http:// to https:// for custom domains."
            },
            {
              "name": "auto_verify_interval_hours",
              "controlType": "number",
              "label": "Re-verify interval (hours)",
              "defaultValue": 24,
              "validation": ["required", "integer", "min:1", "max:168"],
              "min": 1,
              "max": 168,
              "sortOrder": 3
            }
          ]
        }
      ]
    },
    {
      "key": "tenant_branding",
      "class": "Stackra\\Tenancy\\Settings\\TenantBrandingSettings",
      "label": "Branding",
      "description": "Branding profile policy.",
      "icon": "swatch",
      "scope": "tenant",
      "public": false,
      "sortOrder": 3,
      "permission": "tenants.manage_branding",
      "sections": [
        {
          "label": "Profiles",
          "sortOrder": 1,
          "fields": [
            {
              "name": "allow_per_domain_profiles",
              "controlType": "toggle",
              "label": "Per-domain branding profiles",
              "defaultValue": false,
              "validation": ["boolean"],
              "sortOrder": 1,
              "helpText": "Ship distinct branding for each custom domain (v2).",
              "gates": { "requires_feature_flag": "tenants.per-domain-branding" }
            }
          ]
        },
        {
          "label": "Accessibility",
          "sortOrder": 2,
          "fields": [
            {
              "name": "enforce_contrast",
              "controlType": "toggle",
              "label": "Enforce WCAG 2.2 AA contrast",
              "defaultValue": false,
              "validation": ["boolean"],
              "sortOrder": 1,
              "helpText": "Reject brand colour combinations that fail SC 1.4.11.",
              "gates": { "requires_feature_flag": "tenants.branding.contrast-enforcement" }
            }
          ]
        }
      ]
    },
    {
      "key": "tenant_contacts",
      "class": "Stackra\\Tenancy\\Settings\\TenantContactSettings",
      "label": "Contacts",
      "description": "Named-contact + notification preferences.",
      "icon": "user-group",
      "scope": "tenant",
      "public": false,
      "sortOrder": 4,
      "permission": "tenants.manage_contacts",
      "sections": [
        {
          "label": "DPO policy",
          "description": "GDPR Art. 37 \u2014 recommended for tenants processing EU data subjects.",
          "icon": "shield-check",
          "sortOrder": 1,
          "fields": [
            {
              "name": "require_dpo_before_activation",
              "controlType": "toggle",
              "label": "Require verified DPO before activation",
              "defaultValue": false,
              "validation": ["boolean"],
              "sortOrder": 1,
              "gates": { "requires_feature_flag": "tenants.tenant-contacts.dpo-required" }
            },
            {
              "name": "notify_expiring_verifications",
              "controlType": "toggle",
              "label": "Notify me when a contact's verification expires",
              "defaultValue": true,
              "validation": ["boolean"],
              "sortOrder": 2
            }
          ]
        }
      ]
    },
    {
      "key": "tenant_notifications",
      "class": "Stackra\\Tenancy\\Settings\\TenantNotificationSettings",
      "label": "Admin notifications",
      "description": "Which notifications reach the tenant's admins.",
      "icon": "bell",
      "scope": "tenant",
      "public": false,
      "sortOrder": 5,
      "permission": "tenants.manage_own_settings",
      "sections": [
        {
          "label": "Lifecycle events",
          "sortOrder": 1,
          "fields": [
            {
              "name": "tenant_lifecycle_email",
              "controlType": "toggle",
              "label": "Email on suspend / resume / archive",
              "defaultValue": true,
              "validation": ["boolean"],
              "sortOrder": 1
            },
            {
              "name": "tenant_lifecycle_in_app",
              "controlType": "toggle",
              "label": "In-app notification on lifecycle",
              "defaultValue": true,
              "validation": ["boolean"],
              "sortOrder": 2
            }
          ]
        },
        {
          "label": "Domain + branding",
          "sortOrder": 2,
          "fields": [
            {
              "name": "domain_verification_email",
              "controlType": "toggle",
              "label": "Email on domain verification result",
              "defaultValue": true,
              "validation": ["boolean"],
              "sortOrder": 1
            },
            {
              "name": "branding_updated_in_app",
              "controlType": "toggle",
              "label": "In-app notification on branding change",
              "defaultValue": true,
              "validation": ["boolean"],
              "sortOrder": 2
            }
          ]
        },
        {
          "label": "Integrations",
          "sortOrder": 3,
          "fields": [
            {
              "name": "integration_failure_slack",
              "controlType": "toggle",
              "label": "Route integration failures to Slack",
              "defaultValue": false,
              "validation": ["boolean"],
              "sortOrder": 1,
              "gates": { "requires_feature_flag": "tenants.integrations-v2" }
            }
          ]
        }
      ]
    },
    {
      "key": "tenant_privacy",
      "class": "Stackra\\Tenancy\\Settings\\TenantPrivacySettings",
      "label": "Privacy",
      "description": "Consent + data-handling preferences.",
      "icon": "shield-check",
      "scope": "tenant",
      "public": false,
      "sortOrder": 6,
      "permission": "tenants.manage_own_settings",
      "sections": [
        {
          "label": "Consent + visibility",
          "sortOrder": 1,
          "fields": [
            {
              "name": "analytics_consent_default",
              "controlType": "select",
              "label": "Analytics consent default",
              "defaultValue": "functional",
              "options": {
                "essential": "Essential only",
                "functional": "Functional",
                "analytics": "Analytics",
                "marketing": "Marketing"
              },
              "validation": ["required", "string", "in:essential,functional,analytics,marketing"],
              "sortOrder": 1,
              "helpText": "Default consent tier applied to new users before they interact with the banner."
            },
            {
              "name": "tenant_directory_visibility",
              "controlType": "select",
              "label": "Tenant directory visibility",
              "defaultValue": "hidden",
              "options": {
                "hidden": "Hidden",
                "domain": "Visible to same-domain tenants",
                "public": "Public"
              },
              "validation": ["required", "string", "in:hidden,domain,public"],
              "sortOrder": 2,
              "helpText": "Whether this tenant appears in the Application's public tenant picker."
            },
            {
              "name": "data_residency_region",
              "controlType": "select",
              "label": "Data residency region",
              "defaultValue": "us",
              "options": { "us": "United States", "eu": "European Union", "apac": "Asia-Pacific" },
              "validation": ["required", "string", "in:us,eu,apac"],
              "sortOrder": 3,
              "readOnly": true,
              "helpText": "Read-only \u2014 resolved from the Application the tenant belongs to."
            }
          ]
        }
      ]
    },
    {
      "key": "tenant_danger_zone",
      "class": "Stackra\\Tenancy\\Settings\\TenantDangerZoneSettings",
      "label": "Danger zone",
      "description": "Irreversible actions. Every action here dispatches a lifecycle event + audit trail entry.",
      "icon": "exclamation-triangle",
      "scope": "tenant",
      "public": false,
      "sortOrder": 99,
      "permission": "tenants.manage_own_settings",
      "sections": [
        {
          "label": "Archive",
          "sortOrder": 1,
          "fields": [
            {
              "name": "archive_tenant",
              "controlType": "action",
              "label": "Archive tenant",
              "defaultValue": null,
              "sortOrder": 1,
              "action": {
                "verb": "POST",
                "route": "/api/v1/tenants/{id}/archive",
                "confirm": {
                  "title": "Archive this tenant?",
                  "description": "Marks the tenant archived and schedules hard-delete after 30 days. Data can be restored via support during the retention window.",
                  "confirmationInputMatches": "tenant.slug"
                }
              },
              "helpText": "Requires typing the tenant slug to confirm."
            }
          ]
        }
      ]
    }
  ],
  "notes": [
    "`controlType: 'action'` is an extension beyond the ControlType enum in modules/settings/control-types.json \u2014 renders as a Button instead of a form control. Registered by tenants at boot.",
    "`gates.requires_permission` / `requires_feature_flag` / `requires_entitlement` metadata is enforced at the resolver + writer layers by the settings module. Fields whose gates fail are hidden from the schema response."
  ]
}
