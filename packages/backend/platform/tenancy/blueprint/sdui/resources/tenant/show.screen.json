{
  "id": "tenants.resources.tenant.show",
  "title": "Tenant detail",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/platform/tenants/{id}",
  "host": "central_admin",
  "audience": "authenticated",
  "resource": { "module": "tenancy", "entity": "tenant", "action": "show" },
  "requiresPermission": "platform.tenants.view",
  "params": [{ "name": "id", "type": "string", "in": "path", "required": true }],
  "dataSources": [
    {
      "name": "tenant",
      "kind": "http.get",
      "urlExpr": "'/api/v1/tenants/' + params.id + '?include=application,branding,domains,contacts'",
      "unwrap": "data"
    }
  ],
  "broadcasts": [
    {
      "channel": "tenant.{id}.lifecycle",
      "on": ["TenantSuspended", "TenantResumed", "TenantArchived", "TenantErased"],
      "action": { "kind": "data.refresh", "source": "tenant" }
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-6 p-6 max-w-5xl mx-auto" },
      "children": [
        {
          "kind": "Link",
          "props": { "leadingIcon": "arrow-left", "children": "Back to tenants" },
          "actions": { "onPress": { "kind": "navigate", "to": "/platform/tenants" } }
        },
        {
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "kind": "View",
              "props": { "className": "flex items-center gap-4" },
              "children": [
                {
                  "kind": "Avatar",
                  "props": { "size": "lg" },
                  "bindings": {
                    "src": { "$expr": "tenant.branding?.logo_url" },
                    "fallback": { "$expr": "(tenant.name || 'T')[0]" }
                  }
                },
                {
                  "kind": "View",
                  "children": [
                    {
                      "kind": "Text",
                      "props": { "as": "h1", "className": "text-2xl font-semibold" },
                      "bindings": { "children": { "$ref": "tenant.name" } }
                    },
                    {
                      "kind": "Text",
                      "props": { "className": "text-sm text-muted font-mono" },
                      "bindings": { "children": { "$expr": "tenant.slug + '.stackra.app'" } }
                    },
                    {
                      "kind": "View",
                      "props": { "className": "flex items-center gap-2 mt-2" },
                      "children": [
                        {
                          "kind": "Chip",
                          "props": { "size": "sm" },
                          "bindings": {
                            "variant": {
                              "$expr": "tenant.status === 'active' ? 'success' : (tenant.status === 'suspended' ? 'warning' : 'danger')"
                            },
                            "children": { "$ref": "tenant.status" }
                          }
                        },
                        {
                          "kind": "Chip",
                          "props": { "size": "xs", "variant": "neutral" },
                          "bindings": { "children": { "$ref": "tenant.business_type" } }
                        },
                        {
                          "kind": "Chip",
                          "props": { "size": "xs", "variant": "info" },
                          "bindings": {
                            "children": { "$expr": "'plan: ' + (tenant.plan || 'free')" }
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "kind": "View",
              "props": { "className": "flex items-center gap-2" },
              "children": [
                {
                  "kind": "Button",
                  "props": {
                    "variant": "outline",
                    "size": "sm",
                    "leadingIcon": "pencil",
                    "children": "Edit"
                  },
                  "actions": {
                    "onPress": {
                      "kind": "navigate",
                      "toExpr": "'/platform/tenants/' + params.id + '/edit'"
                    }
                  }
                },
                {
                  "kind": "Menu",
                  "props": {
                    "trigger": {
                      "kind": "Button",
                      "props": {
                        "variant": "outline",
                        "size": "sm",
                        "isIconOnly": true,
                        "leadingIcon": "ellipsis-horizontal"
                      }
                    }
                  },
                  "items": [
                    {
                      "id": "suspend",
                      "label": "Suspend",
                      "leadingIcon": "pause",
                      "bindings": { "isDisabled": { "$expr": "tenant.status !== 'active'" } },
                      "action": {
                        "kind": "http.post",
                        "urlExpr": "'/api/v1/tenants/' + params.id + '/suspend'",
                        "confirm": {
                          "title": "Suspend this tenant?",
                          "confirmationInputMatches": "tenant.slug"
                        },
                        "onSuccess": [
                          { "kind": "toast.success", "message": "Suspended" },
                          { "kind": "data.refresh", "source": "tenant" }
                        ]
                      }
                    },
                    {
                      "id": "resume",
                      "label": "Resume",
                      "leadingIcon": "play",
                      "bindings": { "isDisabled": { "$expr": "tenant.status !== 'suspended'" } },
                      "action": {
                        "kind": "http.post",
                        "urlExpr": "'/api/v1/tenants/' + params.id + '/resume'",
                        "onSuccess": { "kind": "data.refresh", "source": "tenant" }
                      }
                    },
                    {
                      "id": "archive",
                      "label": "Archive",
                      "leadingIcon": "archive-box",
                      "bindings": { "isDisabled": { "$expr": "tenant.status === 'archived'" } },
                      "action": {
                        "kind": "http.post",
                        "urlExpr": "'/api/v1/tenants/' + params.id + '/archive'",
                        "confirm": {
                          "title": "Archive this tenant?",
                          "description": "Marks archived. 30-day grace before hard delete.",
                          "confirmationInputMatches": "tenant.slug"
                        },
                        "onSuccess": { "kind": "data.refresh", "source": "tenant" }
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "kind": "Card",
          "props": { "className": "p-6" },
          "children": [
            {
              "kind": "Text",
              "props": {
                "as": "h2",
                "className": "text-sm font-semibold text-muted uppercase tracking-wide mb-3",
                "children": "Details"
              }
            },
            {
              "kind": "DescriptionList",
              "children": [
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "Application" },
                  "bindings": { "value": { "$expr": "tenant.application?.name" } }
                },
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "Owner" },
                  "bindings": {
                    "value": { "$expr": "tenant.owner?.display_name || tenant.owner?.email" }
                  }
                },
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "Users" },
                  "bindings": { "value": { "$ref": "tenant.users_count" } }
                },
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "Data residency" },
                  "bindings": { "value": { "$ref": "tenant.data_residency_region" } }
                },
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "Provisioned" },
                  "bindings": { "value": { "$expr": "formatDate(tenant.created_at)" } }
                },
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "Suspended" },
                  "bindings": {
                    "hidden": { "$expr": "!tenant.suspended_at" },
                    "value": { "$expr": "formatDate(tenant.suspended_at)" }
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
