{
  "id": "tenants.resources.tenant.create",
  "title": "New tenant",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/platform/tenants/new",
  "host": "central_admin",
  "audience": "authenticated",
  "resource": { "module": "tenancy", "entity": "tenant", "action": "create" },
  "requiresPermission": "platform.tenants.create",
  "dataSources": [
    {
      "name": "applications",
      "kind": "http.get",
      "url": "/api/v1/applications?per_page=50",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-6 p-6 max-w-3xl mx-auto" },
      "children": [
        {
          "kind": "Link",
          "props": { "leadingIcon": "arrow-left", "children": "Cancel" },
          "actions": { "onPress": { "kind": "navigate", "to": "/platform/tenants" } }
        },
        {
          "kind": "Text",
          "props": {
            "as": "h1",
            "className": "text-2xl font-semibold",
            "children": "New tenant"
          }
        },
        {
          "kind": "Alert",
          "props": {
            "variant": "info",
            "children": "The tenant will be provisioned with defaults for its business type: sample organisation + branch + region + owner user seeded from BusinessType.default_config."
          }
        },
        {
          "kind": "Form",
          "props": {
            "submitUrl": "/api/v1/tenants",
            "submitMethod": "POST",
            "onSuccess": [
              {
                "kind": "toast.success",
                "message": "Tenant created \u2014 provisioning in progress"
              },
              { "kind": "navigateExpr", "expr": "'/platform/tenants/' + response.data.id" }
            ]
          },
          "children": [
            {
              "kind": "Select",
              "props": { "label": "Application", "name": "application_id", "isRequired": true },
              "optionsSource": { "$ref": "applications", "valueField": "id", "labelField": "name" }
            },
            {
              "kind": "TextField",
              "props": {
                "label": "Tenant name",
                "name": "name",
                "isRequired": true,
                "placeholder": "Acme Academy"
              }
            },
            {
              "kind": "TextField",
              "props": {
                "label": "Slug",
                "name": "slug",
                "isRequired": true,
                "placeholder": "acme",
                "description": "Becomes the primary subdomain (acme.stackra.app)."
              }
            },
            {
              "kind": "Widget",
              "widget": "tenants.widgets.business-type-select",
              "props": { "name": "business_type", "label": "Business type", "isRequired": true }
            },
            {
              "kind": "TextField",
              "props": {
                "label": "Owner email",
                "name": "owner_email",
                "isRequired": true,
                "type": "email",
                "description": "Invitation sent to this address to complete provisioning."
              }
            },
            {
              "kind": "TextField",
              "props": {
                "label": "Owner display name",
                "name": "owner_display_name",
                "isRequired": true
              }
            },
            {
              "kind": "Select",
              "props": {
                "label": "Initial plan",
                "name": "plan",
                "isRequired": true,
                "defaultValue": "free"
              },
              "options": [
                { "key": "free", "label": "Free" },
                { "key": "team", "label": "Team (14-day trial)" },
                { "key": "enterprise", "label": "Enterprise (contract)" }
              ]
            },
            {
              "kind": "Button",
              "props": {
                "variant": "primary",
                "size": "md",
                "type": "submit",
                "children": "Provision tenant"
              }
            }
          ]
        }
      ]
    }
  ]
}
