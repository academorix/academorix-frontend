{
  "id": "theme.preset-thumbnail",
  "title": "Preset thumbnail",
  "version": 1,
  "kind": "SduiWidget",
  "description": "1200×630 preset preview thumbnail generated by PreviewPresetJob. Falls back to a color-swatch placeholder derived from color.primary.500 + color.surface.default when the thumbnail is missing or still generating.",
  "props": {
    "preset": {
      "type": "object",
      "description": "ThemePreset row (preferred). Renders preview_thumbnail_url when available."
    },
    "theme": {
      "type": "object",
      "description": "Theme row (fallback). Uses the theme's selected_preset for the thumbnail source."
    },
    "compact": {
      "type": "boolean",
      "default": false,
      "description": "Compact variant renders a 60×60 swatch instead of the full thumbnail."
    },
    "large": {
      "type": "boolean",
      "default": false,
      "description": "Large variant renders 800×420."
    }
  },
  "dataSources": [],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "relative rounded-lg overflow-hidden bg-content2" },
      "bindings": {
        "className": {
          "$expr": "props.compact ? 'size-14 rounded overflow-hidden' : props.large ? 'w-full aspect-[1200/630] rounded-lg overflow-hidden' : 'w-full aspect-[1200/630] rounded overflow-hidden'"
        }
      },
      "children": [
        {
          "kind": "Image",
          "props": { "className": "w-full h-full object-cover" },
          "bindings": {
            "hidden": {
              "$expr": "!(props.preset && props.preset.preview_thumbnail_url) && !(props.theme && props.theme.selected_preset && props.theme.selected_preset.preview_thumbnail_url)"
            },
            "src": {
              "$expr": "(props.preset && props.preset.preview_thumbnail_url) || (props.theme && props.theme.selected_preset && props.theme.selected_preset.preview_thumbnail_url)"
            },
            "alt": {
              "$expr": "(props.preset && props.preset.name) || (props.theme && props.theme.name) || 'Preview'"
            }
          }
        },
        {
          "kind": "View",
          "props": { "className": "absolute inset-0 flex" },
          "bindings": {
            "hidden": {
              "$expr": "(props.preset && props.preset.preview_thumbnail_url) || (props.theme && props.theme.selected_preset && props.theme.selected_preset.preview_thumbnail_url)"
            }
          },
          "children": [
            {
              "kind": "View",
              "props": { "className": "flex-1" },
              "bindings": {
                "style": {
                  "$expr": "{ backgroundColor: (props.preset && props.preset.tokens && props.preset.tokens['color.surface.default']) || '#F9FAFB' }"
                }
              }
            },
            {
              "kind": "View",
              "props": { "className": "flex-1 flex items-center justify-center" },
              "bindings": {
                "style": {
                  "$expr": "{ backgroundColor: (props.preset && props.preset.tokens && props.preset.tokens['color.primary.500']) || '#3B82F6' }"
                }
              },
              "children": [
                {
                  "kind": "Text",
                  "props": { "className": "text-xs font-mono text-white/80" },
                  "bindings": {
                    "hidden": { "$ref": "props.compact" },
                    "children": "Aa"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
