{
  "name": "stackra/application",
  "type": "library",
  "description": "Application (product-catalogue) domain module — the global cross-tenant registry of Stackra products (Sports, Marketplace, Ticketing, Venue, Education) plus the BusinessType catalogue (academy, sports_center, school, gym, federation, club). Every Tenant belongs to exactly one Application; `application_id` cascades through the tenancy hierarchy via the `BelongsToApplication` trait (owned here). BusinessType is dual-source per .kiro/steering/enum-db-seed-dual-source.md — code-primary via `BusinessTypeEnum`, DB mirror in `business_types` for admin visibility + tenant-defined customs.",
  "license": "proprietary",
  "keywords": [
    "stackra",
    "laravel",
    "application",
    "product-catalogue",
    "business-type",
    "cross-tenant",
    "platform-registry",
    "domain-module"
  ],
  "require": {
    "php": "^8.3",
    "stackra/authorization": "@dev",
    "stackra/console": "@dev",
    "stackra/crud": "@dev",
    "stackra/database": "@dev",
    "stackra/enum": "@dev",
    "stackra/events": "@dev",
    "stackra/exceptions": "@dev",
    "stackra/foundation": "@dev",
    "stackra/retention": "@dev",
    "stackra/routing": "@dev",
    "stackra/service-provider": "@dev",
    "stackra/support": "@dev",
    "illuminate/auth": "^13.0",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/events": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "spatie/laravel-data": "^4.11"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Stackra\\Application\\": "src/",
      "Stackra\\Application\\Database\\Factories\\": "database/factories/",
      "Stackra\\Application\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Stackra\\Application\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Stackra\\Application\\Providers\\ApplicationServiceProvider"
      ],
      "aliases": {}
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "repositories": [
    {
      "type": "path",
      "url": "../../authorization",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/console",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/crud",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/database",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/enum",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/events",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/exceptions",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../foundation",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../compliance/retention",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/routing",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/service-provider",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/support",
      "options": {
        "symlink": true
      }
    }
  ],
  "scripts": {
    "test": "Stackra\\Foundation\\Scripts\\TestScripts::run",
    "test:coverage": "Stackra\\Foundation\\Scripts\\TestScripts::coverage",
    "test:parallel": "Stackra\\Foundation\\Scripts\\TestScripts::parallel",
    "test:filter": "Stackra\\Foundation\\Scripts\\TestScripts::filter",
    "analyse": "Stackra\\Foundation\\Scripts\\AnalyseScripts::run",
    "analyse:baseline": "Stackra\\Foundation\\Scripts\\AnalyseScripts::baseline",
    "lint": "Stackra\\Foundation\\Scripts\\LintScripts::check",
    "lint:fix": "Stackra\\Foundation\\Scripts\\LintScripts::fix",
    "doppler:status": "Stackra\\Foundation\\Scripts\\DopplerScripts::status",
    "doppler:setup": "Stackra\\Foundation\\Scripts\\DopplerScripts::setup"
  }
}
