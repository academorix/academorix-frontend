{
  "id": "stackra://modules/public-site/retention",
  "$version": 1,
  "title": "public-site — data retention windows",
  "policies": [
    {
      "entity": "Page",
      "hot_days": null,
      "on_purge": "keep_indefinitely",
      "conditions": ["status = 'published'"],
      "description": "Published pages retained; archived pages 90d then hard delete."
    },
    {
      "entity": "Page",
      "hot_days": 90,
      "on_purge": "hard_delete",
      "conditions": ["status IN ('draft', 'archived')"]
    },
    { "entity": "Block", "hot_days": null, "on_purge": "keep_indefinitely" },
    {
      "entity": "PublicFormSubmission",
      "hot_days": 90,
      "warm_days": 365,
      "cold_days": null,
      "on_purge": "hard_delete",
      "description": "Form submissions handed off to CRM as Lead rows; only the local audit envelope retained."
    }
  ]
}
