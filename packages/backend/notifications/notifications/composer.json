{
  "name": "academorix/notifications",
  "type": "library",
  "description": "Notification substrate core for Academorix. Owns six aggregates: `Notification` (the universal delivery record), `NotificationDelivery` (per-channel attempt audit trail), `NotificationTemplate` (versioned reusable templates), `NotificationPreference` (per-user opt-in per category per channel), `NotificationCategory` (module-fed registry with is_system+tenant-override rows) and `NotificationDigest` (batched daily/weekly delivery). Channel-agnostic: the single dispatch entry point (`DispatchGatewayInterface`) fires an event-carried state payload to the send queue; channel modules subscribe and translate to their transport. Attribute-driven consumer registration (`#[Notifiable]`, `#[HasPreferences]`) + attribute-first discovery + framework-swappable services + HTTP surface for tenant inbox, tenant preferences, tenant admin templates, RFC 8058 one-click unsubscribe, and cross-tenant platform diagnostics.",
  "license": "proprietary",
  "keywords": [
    "academorix",
    "laravel",
    "notifications",
    "delivery-log",
    "templates",
    "preferences",
    "digests",
    "category-registry",
    "event-carried-state",
    "dispatch-gateway",
    "unsubscribe",
    "audit-trail"
  ],
  "require": {
    "php": "^8.3",
    "academorix/application": "@dev",
    "academorix/authorization": "@dev",
    "academorix/console": "@dev",
    "academorix/crud": "@dev",
    "academorix/database": "@dev",
    "academorix/enum": "@dev",
    "academorix/events": "@dev",
    "academorix/exceptions": "@dev",
    "academorix/foundation": "@dev",
    "academorix/retention": "@dev",
    "academorix/routing": "@dev",
    "academorix/serializer": "@dev",
    "academorix/service-provider": "@dev",
    "academorix/support": "@dev",
    "academorix/tenancy": "@dev",
    "illuminate/bus": "^13.0",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/events": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/queue": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "spatie/laravel-data": "^4.11"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Academorix\\Notifications\\": "src/",
      "Academorix\\Notifications\\Database\\Factories\\": "database/factories/",
      "Academorix\\Notifications\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Academorix\\Notifications\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Academorix\\Notifications\\Providers\\NotificationsServiceProvider"
      ],
      "aliases": {}
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
