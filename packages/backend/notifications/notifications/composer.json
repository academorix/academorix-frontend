{
  "name": "stackra/notifications",
  "type": "library",
  "description": "Notification substrate core for Stackra. Owns six aggregates: `Notification` (the universal delivery record), `NotificationDelivery` (per-channel attempt audit trail), `NotificationTemplate` (versioned reusable templates), `NotificationPreference` (per-user opt-in per category per channel), `NotificationCategory` (module-fed registry with is_system+tenant-override rows) and `NotificationDigest` (batched daily/weekly delivery). Channel-agnostic: the single dispatch entry point (`DispatchGatewayInterface`) fires an event-carried state payload to the send queue; channel modules subscribe and translate to their transport. Attribute-driven consumer registration (`#[Notifiable]`, `#[HasPreferences]`) + attribute-first discovery + framework-swappable services + HTTP surface for tenant inbox, tenant preferences, tenant admin templates, RFC 8058 one-click unsubscribe, and cross-tenant platform diagnostics.",
  "license": "proprietary",
  "keywords": [
    "stackra",
    "laravel",
    "notifications",
    "delivery-log",
    "templates",
    "preferences",
    "digests",
    "category-registry",
    "event-carried-state",
    "dispatch-gateway",
    "unsubscribe",
    "audit-trail"
  ],
  "require": {
    "php": "^8.3",
    "stackra/application": "@dev",
    "stackra/authorization": "@dev",
    "stackra/console": "@dev",
    "stackra/crud": "@dev",
    "stackra/database": "@dev",
    "stackra/enum": "@dev",
    "stackra/events": "@dev",
    "stackra/exceptions": "@dev",
    "stackra/foundation": "@dev",
    "stackra/retention": "@dev",
    "stackra/routing": "@dev",
    "stackra/serializer": "@dev",
    "stackra/service-provider": "@dev",
    "stackra/support": "@dev",
    "stackra/tenancy": "@dev",
    "illuminate/bus": "^13.0",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/events": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/queue": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "spatie/laravel-data": "^4.11"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Stackra\\Notifications\\": "src/",
      "Stackra\\Notifications\\Database\\Factories\\": "database/factories/",
      "Stackra\\Notifications\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Stackra\\Notifications\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Stackra\\Notifications\\Providers\\NotificationsServiceProvider"
      ],
      "aliases": {}
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
