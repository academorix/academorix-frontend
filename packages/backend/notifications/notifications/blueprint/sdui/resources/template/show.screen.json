{
  "id": "notifications.resources.template.show",
  "title": "Template detail",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/notification-templates/{id}",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "notifications", "entity": "template", "action": "show" },
  "requiresPermission": "notifications.templates.view",
  "params": [{ "name": "id", "type": "string", "in": "path", "required": true }],
  "dataSources": [
    {
      "name": "template",
      "kind": "http.get",
      "urlExpr": "'/api/v1/tenant/notification-templates/' + params.id",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-6 p-6 max-w-5xl mx-auto" },
      "children": [
        {
          "kind": "Link",
          "props": {
            "leadingIcon": "arrow-left",
            "children": "Back to templates",
            "className": "text-sm text-muted"
          },
          "actions": {
            "onPress": { "kind": "navigate", "to": "/tenant/notification-templates" }
          }
        },
        {
          "id": "header",
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "kind": "View",
              "props": { "className": "flex flex-col gap-1" },
              "children": [
                {
                  "kind": "Text",
                  "props": { "as": "h1", "className": "text-2xl font-semibold" },
                  "bindings": { "children": { "$ref": "template.key" } }
                },
                {
                  "kind": "Text",
                  "props": { "className": "text-sm text-muted" },
                  "bindings": {
                    "children": {
                      "$expr": "template.channel + ' · ' + template.locale + ' · v' + template.version + ' · ' + template.state"
                    }
                  }
                }
              ]
            },
            {
              "kind": "View",
              "props": { "className": "flex items-center gap-2" },
              "children": [
                {
                  "kind": "Button",
                  "props": {
                    "variant": "outline",
                    "size": "sm",
                    "leadingIcon": "beaker",
                    "children": "Send test"
                  },
                  "bindings": {
                    "isDisabled": {
                      "$expr": "!identity.permissions.includes('notifications.templates.test')"
                    }
                  },
                  "actions": {
                    "onPress": {
                      "kind": "http.post",
                      "urlExpr": "'/api/v1/tenant/notification-templates/' + params.id + '/test'",
                      "confirm": {
                        "title": "Send a test?",
                        "description": "A rendered preview will be sent to your own email address."
                      },
                      "onSuccess": { "kind": "toast.success", "message": "Test sent" }
                    }
                  }
                },
                {
                  "kind": "Button",
                  "props": {
                    "variant": "primary",
                    "size": "sm",
                    "leadingIcon": "pencil",
                    "children": "Edit"
                  },
                  "bindings": {
                    "isDisabled": {
                      "$expr": "template.is_system && !identity.roles.includes('super_admin')"
                    }
                  },
                  "actions": {
                    "onPress": {
                      "kind": "navigate",
                      "toExpr": "'/tenant/notification-templates/' + params.id + '/edit'"
                    }
                  }
                }
              ]
            }
          ]
        },
        {
          "id": "preview",
          "kind": "Card",
          "props": { "className": "p-6" },
          "children": [
            {
              "kind": "Text",
              "props": {
                "as": "h2",
                "className": "text-sm font-semibold text-muted uppercase tracking-wide mb-3",
                "children": "Preview"
              }
            },
            {
              "kind": "HtmlContent",
              "props": { "className": "prose max-w-none border rounded-lg p-4 bg-content1" },
              "bindings": { "html": { "$ref": "template.body_rendered_html" } }
            }
          ]
        },
        {
          "id": "metadata",
          "kind": "Card",
          "props": { "className": "p-6" },
          "children": [
            {
              "kind": "Text",
              "props": {
                "as": "h2",
                "className": "text-sm font-semibold text-muted uppercase tracking-wide mb-3",
                "children": "Details"
              }
            },
            {
              "kind": "DescriptionList",
              "children": [
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "Category" },
                  "bindings": { "value": { "$ref": "template.category_slug" } }
                },
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "Subject template" },
                  "bindings": { "value": { "$ref": "template.subject_template" } }
                },
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "Provider template id" },
                  "bindings": { "value": { "$expr": "template.provider_template_id || 'None'" } }
                },
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "Published at" },
                  "bindings": {
                    "value": {
                      "$expr": "template.published_at ? formatDate(template.published_at) : 'Not published'"
                    }
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
