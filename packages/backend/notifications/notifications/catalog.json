{
  "$schema": "https://gist.githubusercontent.com/stackra-user/073a1ab687cd93ede7ae927b96a025ea/raw/catalog.v1.json",
  "name": "stackra/notifications",
  "tier": "saas",
  "surfaces": ["core"],
  "kind": "feature",
  "purpose": "Channel-agnostic notification substrate — the single DispatchGateway plus six aggregates every notification consumer and channel driver plugs into.",
  "capabilities": [
    "Notification + NotificationDelivery aggregates",
    "NotificationTemplate — versioned reusable templates",
    "NotificationPreference — per-user opt-in per (category, channel)",
    "NotificationCategory — module-fed registry",
    "NotificationDigest — batched daily/weekly delivery",
    "DispatchGateway — single sanctioned entry point",
    "#[Notifiable] / #[HasPreferences] attribute-driven registration",
    "RFC 8058 one-click unsubscribe surface"
  ],
  "when_to_use": "Every notification originates here — the channel modules (in-app, mail, push, SMS) subscribe to events and never expose their own send methods.",
  "when_not_to_use": "For editorial newsletter cadences, use stackra/newsletter which consumes this substrate.",
  "peer_deps": [
    "stackra/application",
    "stackra/authorization",
    "stackra/console",
    "stackra/crud",
    "stackra/database",
    "stackra/enum",
    "stackra/events",
    "stackra/exceptions",
    "stackra/foundation",
    "stackra/retention",
    "stackra/routing",
    "stackra/serializer",
    "stackra/service-provider",
    "stackra/support",
    "stackra/tenancy",
    "spatie/laravel-data"
  ],
  "backend_pair": null,
  "size_gzip_kb": {},
  "maturity": "alpha",
  "owning_agent": "laravel-feature-builder",
  "docs": ["packages/backend/notifications/notifications/README.md"]
}
