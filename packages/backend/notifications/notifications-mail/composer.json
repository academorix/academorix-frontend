{
  "name": "academorix/notifications-mail",
  "type": "library",
  "description": "Mail notification channel for Academorix. Registers the `mail` channel with the core NotificationChannelRegistry + subscribes to NotificationDispatched events. On dispatch: renders the template through Laravel Blade, injects CAN-SPAM + RFC 8058 List-Unsubscribe headers, hands off to Laravel Mail's MailManager, and captures the provider message id into a NotificationDelivery row. Ingests per-provider webhooks (Mailgun / SendGrid / AWS SES / Postmark / Resend) via the webhook module's InboundWebhookReceived event, normalises them into MailDelivered/Opened/Clicked/Bounced/Complaint events, and owns a MailSuppression aggregate for hard-bounced / complained / manually-blocked addresses. Priority 26 — loads after notifications core (20) and notifications-in-app (25).",
  "license": "proprietary",
  "keywords": [
    "academorix",
    "laravel",
    "notifications",
    "mail",
    "email",
    "mailgun",
    "sendgrid",
    "aws-ses",
    "postmark",
    "resend",
    "react-email",
    "can-spam",
    "casl",
    "suppression",
    "channel-driver"
  ],
  "require": {
    "php": "^8.3",
    "academorix/application": "@dev",
    "academorix/authorization": "@dev",
    "academorix/console": "@dev",
    "academorix/crud": "@dev",
    "academorix/database": "@dev",
    "academorix/enum": "@dev",
    "academorix/events": "@dev",
    "academorix/exceptions": "@dev",
    "academorix/foundation": "@dev",
    "academorix/notifications": "@dev",
    "academorix/retention": "@dev",
    "academorix/routing": "@dev",
    "academorix/service-provider": "@dev",
    "academorix/support": "@dev",
    "academorix/tenancy": "@dev",
    "illuminate/bus": "^13.0",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/events": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/mail": "^13.0",
    "illuminate/queue": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "spatie/laravel-data": "^4.11"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "suggest": {
    "symfony/mailgun-mailer": "Mailgun transport for Laravel Mail (^7.0).",
    "symfony/postmark-mailer": "Postmark transport for Laravel Mail (^7.0).",
    "aws/aws-sdk-php": "AWS SES transport + SNS webhook signature verification (^3.0).",
    "resend/resend-laravel": "Resend transport for Laravel Mail (^0.9)."
  },
  "autoload": {
    "psr-4": {
      "Academorix\\Notifications\\Mail\\": "src/",
      "Academorix\\Notifications\\Mail\\Database\\Factories\\": "database/factories/",
      "Academorix\\Notifications\\Mail\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Academorix\\Notifications\\Mail\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Academorix\\Notifications\\Mail\\Providers\\NotificationsMailServiceProvider"
      ],
      "aliases": {}
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
