{
  "id": "notifications-mail.mail-suppression-reason-chip",
  "title": "Mail suppression reason chip",
  "version": 1,
  "kind": "SduiWidget",
  "description": "Colour-coded chip for MailSuppression.reason. Mapping: hard_bounce / complaint / spam_trap = danger, unsubscribed = warning, manual = info.",
  "props": {
    "reason": { "type": "string", "description": "MailSuppression.reason enum." },
    "size": { "type": "string", "default": "sm", "enum": ["xs", "sm", "md"] },
    "showIcon": { "type": "boolean", "default": true },
    "showLabel": { "type": "boolean", "default": true }
  },
  "dataSources": [],
  "nodes": [
    {
      "id": "chip",
      "kind": "Chip",
      "bindings": {
        "variant": {
          "$expr": "['hard_bounce', 'complaint', 'spam_trap'].includes(props.reason) ? 'danger' : (props.reason === 'unsubscribed' ? 'warning' : 'info')"
        },
        "size": { "$ref": "props.size" }
      },
      "children": [
        {
          "kind": "Icon",
          "props": { "className": "size-3 mr-1" },
          "bindings": {
            "hidden": { "$expr": "!props.showIcon" },
            "icon": {
              "$expr": "props.reason === 'hard_bounce' ? 'exclamation-triangle' : (props.reason === 'complaint' ? 'flag' : (props.reason === 'spam_trap' ? 'shield-exclamation' : (props.reason === 'unsubscribed' ? 'envelope-x-mark' : 'hand-raised')))"
            }
          }
        },
        {
          "kind": "Text",
          "props": { "as": "span" },
          "bindings": {
            "hidden": { "$expr": "!props.showLabel" },
            "children": {
              "$expr": "props.reason === 'hard_bounce' ? 'Hard bounce' : (props.reason === 'complaint' ? 'Complaint' : (props.reason === 'unsubscribed' ? 'Unsubscribed' : (props.reason === 'spam_trap' ? 'Spam trap' : 'Manual')))"
            }
          }
        }
      ]
    }
  ]
}
