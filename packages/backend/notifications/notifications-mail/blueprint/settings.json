{
  "id": "stackra://modules/notifications-mail/settings",
  "$version": 1,
  "title": "notifications-mail \u2014 settings",
  "description": "Mail-specific settings on top of notifications core's sender identity. Canonical group/section/field taxonomy. Two groups: `mail` (channel routing + brand) and `mail_smtp` (enterprise custom SMTP \u2014 split into its own class to gate on entitlement).",
  "storedIn": "settings",
  "reference": { "contract": "stackra://modules/settings/attributes" },
  "groups": [
    {
      "key": "mail",
      "class": "Stackra\\Notifications\\Mail\\Settings\\MailSettings",
      "label": "Email",
      "description": "Email channel routing + brand overlays.",
      "icon": "envelope",
      "scope": "tenant",
      "public": false,
      "sortOrder": 12,
      "permission": "settings.read",
      "sections": [
        {
          "label": "Provider preference",
          "description": "Which mail provider to route sends through. Overrides platform default.",
          "icon": "arrows-right-left",
          "sortOrder": 1,
          "fields": [
            {
              "name": "default_provider",
              "controlType": "select",
              "label": "Default provider",
              "defaultValue": null,
              "options": {
                "mailgun": "Mailgun",
                "sendgrid": "SendGrid",
                "aws-ses": "AWS SES",
                "postmark": "Postmark",
                "resend": "Resend"
              },
              "validation": ["nullable", "string", "in:mailgun,sendgrid,aws-ses,postmark,resend"],
              "sortOrder": 1,
              "helpText": "Null = platform default from config."
            }
          ]
        },
        {
          "label": "Dedicated IP",
          "description": "Sends from a dedicated IP (SendGrid / SES). Requires notifications.mail.dedicated_ip entitlement.",
          "icon": "server-stack",
          "sortOrder": 2,
          "fields": [
            {
              "name": "dedicated_ip_enabled",
              "controlType": "toggle",
              "label": "Enable dedicated IP",
              "defaultValue": false,
              "validation": ["boolean"],
              "sortOrder": 1
            },
            {
              "name": "dedicated_ip_pool_name",
              "controlType": "text",
              "label": "IP pool name",
              "defaultValue": null,
              "validation": ["nullable", "string", "max:100"],
              "sortOrder": 2,
              "helpText": "Provider-side IP pool name."
            }
          ]
        },
        {
          "label": "Footer customisation",
          "description": "Overlay on top of core's brand.footer_text.",
          "icon": "document-text",
          "sortOrder": 3,
          "fields": [
            {
              "name": "footer_company_name",
              "controlType": "text",
              "label": "Company name (footer)",
              "defaultValue": null,
              "validation": ["nullable", "string", "max:200"],
              "sortOrder": 1,
              "helpText": "Overrides tenant.name in CAN-SPAM footer."
            },
            {
              "name": "footer_postal_address_override",
              "controlType": "textarea",
              "label": "Postal address override",
              "defaultValue": null,
              "validation": ["nullable", "string", "max:500"],
              "sortOrder": 2,
              "helpText": "Overrides core's sender.postal_address for mail-specific compliance edge cases."
            },
            {
              "name": "footer_unsubscribe_text",
              "controlType": "text",
              "label": "Unsubscribe link text",
              "defaultValue": "Unsubscribe from these emails",
              "validation": ["required", "string", "max:100"],
              "sortOrder": 3
            }
          ]
        }
      ]
    },
    {
      "key": "mail_smtp",
      "class": "Stackra\\Notifications\\Mail\\Settings\\MailSmtpSettings",
      "label": "Custom SMTP",
      "description": "Enterprise-only: bring-your-own SMTP endpoint. Overrides provider selection entirely.",
      "icon": "wrench-screwdriver",
      "scope": "tenant",
      "public": false,
      "sortOrder": 13,
      "permission": "settings.read",
      "sections": [
        {
          "label": "Connection",
          "description": "Requires notifications.mail.custom_smtp entitlement.",
          "icon": "signal",
          "sortOrder": 1,
          "fields": [
            {
              "name": "enabled",
              "controlType": "toggle",
              "label": "Enable custom SMTP",
              "defaultValue": false,
              "validation": ["boolean"],
              "sortOrder": 1
            },
            {
              "name": "host",
              "controlType": "text",
              "label": "Host",
              "defaultValue": null,
              "validation": ["required_if:enabled,true", "nullable", "string", "max:255"],
              "sortOrder": 2,
              "placeholder": "smtp.example.com"
            },
            {
              "name": "port",
              "controlType": "number",
              "label": "Port",
              "defaultValue": 587,
              "validation": ["integer", "min:1", "max:65535"],
              "min": 1,
              "max": 65535,
              "sortOrder": 3
            },
            {
              "name": "encryption",
              "controlType": "select",
              "label": "Encryption",
              "defaultValue": "tls",
              "options": { "tls": "TLS (StartTLS)", "ssl": "SSL", "none": "None (dev only)" },
              "validation": ["required", "string", "in:tls,ssl,none"],
              "sortOrder": 4
            },
            {
              "name": "username",
              "controlType": "text",
              "label": "Username",
              "defaultValue": null,
              "validation": ["required_if:enabled,true", "nullable", "string", "max:255"],
              "sortOrder": 5
            },
            {
              "name": "password_secret_ref",
              "controlType": "password",
              "label": "Password (Doppler secret ref)",
              "defaultValue": null,
              "validation": ["required_if:enabled,true", "nullable", "string", "max:255"],
              "sensitive": true,
              "sortOrder": 6,
              "helpText": "Doppler secret reference. Password never stored in plaintext."
            }
          ]
        }
      ]
    }
  ]
}
