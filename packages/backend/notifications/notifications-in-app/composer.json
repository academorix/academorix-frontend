{
  "name": "stackra/notifications-in-app",
  "type": "library",
  "description": "In-app notification channel for Stackra. Registers the `in_app` channel with the core NotificationChannelRegistry + subscribes to NotificationDispatched events. On dispatch: writes a NotificationDelivery row (state=delivered) synchronously and emits a Reverb broadcast on `user.{id}.notifications` for live inbox updates. Owns two aggregates: `InAppMessage` (denormalised inbox row for the user's bell UI) and `InAppMessageRead` (per-view read/dismissed state). Attribute-driven channel discovery via `#[AsNotificationChannel]` on the driver class. Priority 25 \u2014 loads after notifications core (20).",
  "license": "proprietary",
  "keywords": [
    "stackra",
    "laravel",
    "notifications",
    "in-app",
    "inbox",
    "reverb",
    "broadcast",
    "live-updates",
    "channel-driver"
  ],
  "require": {
    "php": "^8.3",
    "stackra/application": "@dev",
    "stackra/authorization": "@dev",
    "stackra/console": "@dev",
    "stackra/crud": "@dev",
    "stackra/database": "@dev",
    "stackra/enum": "@dev",
    "stackra/events": "@dev",
    "stackra/exceptions": "@dev",
    "stackra/foundation": "@dev",
    "stackra/notifications": "@dev",
    "stackra/retention": "@dev",
    "stackra/routing": "@dev",
    "stackra/service-provider": "@dev",
    "stackra/support": "@dev",
    "stackra/tenancy": "@dev",
    "illuminate/broadcasting": "^13.0",
    "illuminate/bus": "^13.0",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/events": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/queue": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "spatie/laravel-data": "^4.11"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Stackra\\Notifications\\InApp\\": "src/",
      "Stackra\\Notifications\\InApp\\Database\\Factories\\": "database/factories/",
      "Stackra\\Notifications\\InApp\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Stackra\\Notifications\\InApp\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Stackra\\Notifications\\InApp\\Providers\\NotificationsInAppServiceProvider"
      ],
      "aliases": {}
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
