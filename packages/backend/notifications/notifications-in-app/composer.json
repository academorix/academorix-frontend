{
  "name": "academorix/notifications-in-app",
  "type": "library",
  "description": "In-app notification channel for Academorix. Registers the `in_app` channel with the core NotificationChannelRegistry + subscribes to NotificationDispatched events. On dispatch: writes a NotificationDelivery row (state=delivered) synchronously and emits a Reverb broadcast on `user.{id}.notifications` for live inbox updates. Owns two aggregates: `InAppMessage` (denormalised inbox row for the user's bell UI) and `InAppMessageRead` (per-view read/dismissed state). Attribute-driven channel discovery via `#[AsNotificationChannel]` on the driver class. Priority 25 — loads after notifications core (20).",
  "license": "proprietary",
  "keywords": [
    "academorix",
    "laravel",
    "notifications",
    "in-app",
    "inbox",
    "reverb",
    "broadcast",
    "live-updates",
    "channel-driver"
  ],
  "require": {
    "php": "^8.3",
    "academorix/application": "@dev",
    "academorix/authorization": "@dev",
    "academorix/console": "@dev",
    "academorix/crud": "@dev",
    "academorix/database": "@dev",
    "academorix/enum": "@dev",
    "academorix/events": "@dev",
    "academorix/exceptions": "@dev",
    "academorix/foundation": "@dev",
    "academorix/notifications": "@dev",
    "academorix/retention": "@dev",
    "academorix/routing": "@dev",
    "academorix/service-provider": "@dev",
    "academorix/support": "@dev",
    "academorix/tenancy": "@dev",
    "illuminate/broadcasting": "^13.0",
    "illuminate/bus": "^13.0",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/events": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/queue": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "spatie/laravel-data": "^4.11"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Academorix\\Notifications\\InApp\\": "src/",
      "Academorix\\Notifications\\InApp\\Database\\Factories\\": "database/factories/",
      "Academorix\\Notifications\\InApp\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Academorix\\Notifications\\InApp\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Academorix\\Notifications\\InApp\\Providers\\NotificationsInAppServiceProvider"
      ],
      "aliases": {}
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "repositories": [
