{
  "$version": 1,
  "name": "notifications-push",
  "alias": "notifications-push",
  "namespace": "Stackra\\Notifications\\Push",
  "description": "Push notification channel. Owns the PushSubscription entity (device tokens — RESTRICTED tier, encrypted at rest via KMS) + own MultipleInstanceManager wrapping FCM (Android + Web) / APNs (iOS) / Expo (React Native) / OneSignal (enterprise). Adds provider-agnostic delivery with token validation (dry-run before persist), invalid-token cleanup, COPPA VPC gate for minors, GDPR Art. 32 encryption controls, and per-provider health probes. Consumes webhook module for inbound provider feedback (APNs Feedback Service, FCM invalid-token callbacks).",
  "keywords": [
    "notifications",
    "push",
    "mobile-push",
    "web-push",
    "fcm",
    "apns",
    "expo",
    "onesignal",
    "device-tokens",
    "coppa"
  ],
  "priority": 27,
  "providers": ["Stackra\\Notifications\\Push\\Providers\\NotificationsPushServiceProvider"],
  "files": [],
  "dependencies": ["foundation", "tenancy", "notifications", "webhook"],
  "extendedBy": [],
  "contributes": {
    "traits": [],
    "blueprints": [],
    "middleware": [],
    "events": [
      "PushSent",
      "PushDelivered",
      "PushFailed",
      "PushOpened",
      "PushInvalidToken",
      "PushSubscriptionRegistered",
      "PushSubscriptionExpired",
      "PushSubscriptionRevoked"
    ],
    "policies": ["PushSubscriptionPolicy"],
    "hooks": [],
    "commands": [
      "notifications:push:test",
      "notifications:push:prune-expired",
      "notifications:push:validate-tokens"
    ],
    "jobs": [
      "SendPushJob",
      "PruneExpiredSubscriptionsJob",
      "IngestPushProviderWebhookJob",
      "ValidatePushTokenJob"
    ],
    "notifications": [],
    "broadcasts": [],
    "observers": ["PushSubscriptionObserver"],
    "rules": ["valid_device_token", "supported_push_platform"],
    "casts": ["DeviceTokenCast", "PushPayloadCast"],
    "views": [],
    "lang": ["notifications-push"],
    "config": ["notifications-push"],
    "macros": [],
    "bindings": [
      "PushChannel",
      "PushTransportManager",
      "PushSubscriptionRegistry",
      "TokenValidator"
    ],
    "resources": ["push-subscription"]
  },
  "channelRegistration": {
    "slug": "push",
    "class": "Stackra\\Notifications\\Push\\Channels\\PushChannel",
    "kind": "external",
    "provider_kind": "provider-mediated",
    "supported_providers": ["fcm", "apns", "expo", "onesignal", "log", "array"],
    "supports_open_tracking": true,
    "supports_click_tracking": true,
    "supports_delivery_tracking": true,
    "registration": "Service provider registers `push` with core's NotificationChannelRegistry + registers PushSubscription CRUD routes."
  },
  "hosts": {
    "tenant": {
      "description": "Per-user push subscription (device token) management.",
      "routes": [
        "GET /api/v1/tenant/notification-subscriptions",
        "POST /api/v1/tenant/notification-subscriptions",
        "DELETE /api/v1/tenant/notification-subscriptions/{subscription}"
      ]
    }
  },
  "delegated": {
    "provider_webhooks": {
      "movedTo": "modules/webhook",
      "endpoint": "POST /webhooks/inbound/notifications-push/{provider}",
      "reason": "Universal webhook module owns inbound receiver + signature verification. This module ships per-provider strategies (FcmSignatureStrategy for Cloud Pub/Sub OIDC, ApnsFeedbackStrategy for APNs Feedback Service) that plug in at boot."
    }
  }
}
