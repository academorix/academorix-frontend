{
  "name": "stackra/notifications-push",
  "type": "library",
  "description": "Push notification channel. Owns the PushSubscription entity (device tokens — RESTRICTED tier, encrypted at rest) + a MultipleInstanceManager wrapping FCM (Android + Web) / APNs (iOS) / Expo (React Native) / OneSignal (enterprise). Provider-agnostic delivery with token validation, invalid-token cleanup, COPPA VPC gate for minors, GDPR Art. 32 encryption controls, per-provider health probes. Consumes webhook module for inbound provider feedback.",
  "license": "proprietary",
  "keywords": [
    "stackra",
    "laravel",
    "notifications",
    "push",
    "mobile-push",
    "web-push",
    "fcm",
    "apns",
    "expo",
    "onesignal",
    "device-tokens",
    "coppa"
  ],
  "require": {
    "php": "^8.3",
    "stackra/application": "@dev",
    "stackra/authorization": "@dev",
    "stackra/console": "@dev",
    "stackra/crud": "@dev",
    "stackra/database": "@dev",
    "stackra/enum": "@dev",
    "stackra/events": "@dev",
    "stackra/exceptions": "@dev",
    "stackra/foundation": "@dev",
    "stackra/notifications": "@dev",
    "stackra/retention": "@dev",
    "stackra/routing": "@dev",
    "stackra/service-provider": "@dev",
    "stackra/support": "@dev",
    "stackra/tenancy": "@dev",
    "stackra/webhook": "@dev",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/events": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/queue": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "spatie/laravel-data": "^4.11"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Stackra\\Notifications\\Push\\": "src/",
      "Stackra\\Notifications\\Push\\Database\\Factories\\": "database/factories/",
      "Stackra\\Notifications\\Push\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Stackra\\Notifications\\Push\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Stackra\\Notifications\\Push\\Providers\\NotificationsPushServiceProvider"
      ],
      "aliases": {}
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "repositories": [
    {
