{
  "id": "stackra://modules/notifications-sms/policies",
  "$version": 1,
  "title": "notifications-sms \u2014 authorization policies",
  "policies": [
    {
      "model": "SmsOptOut",
      "class": "Stackra\\Notifications\\Sms\\Policies\\SmsOptOutPolicy",
      "abilities": [
        {
          "action": "viewAny",
          "permission": "notifications.sms.opt-outs.viewAny",
          "scope": "tenant admin"
        },
        { "action": "view", "permission": "notifications.sms.opt-outs.view" },
        {
          "action": "create",
          "permission": "notifications.sms.opt-outs.create",
          "scope": "tenant admin (reason=manual)"
        },
        {
          "action": "delete",
          "permission": "notifications.sms.opt-outs.delete",
          "scope": "REFUSED when reason=stop_keyword unless super_admin AND re-consent evidence in body. REFUSED when is_system=true unless super_admin."
        }
      ]
    }
  ]
}
