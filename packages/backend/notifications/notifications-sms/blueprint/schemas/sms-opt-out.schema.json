{
  "id": "stackra://modules/notifications-sms/schemas/sms-opt-out",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "SmsOptOut",
  "description": "Opt-out records. Reasons: stop_keyword (customer replied STOP), manual (admin blocked), do_not_call_registry (US DNC), invalid_number (carrier reported bad), spam_trap. Retained for TCPA + CASL evidence \u2014 hard-bounce forever, stop_keyword P5Y.",
  "type": "object",
  "x-module": "notifications-sms",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "sms_opt_outs",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "sopt_",
    "incrementing": false,
    "model": "Stackra\\Notifications\\Sms\\Models\\SmsOptOut",
    "interface": "Stackra\\Notifications\\Sms\\Contracts\\Data\\SmsOptOutInterface",
    "implements": ["Stackra\\Notifications\\Sms\\Contracts\\Data\\SmsOptOutInterface"],
    "traits": [
      "HasFactory",
      "HasUlids",
      "HasSystemFlag",
      "BelongsToTenantOptional",
      "HasMetadata",
      "HasUserstamps",
      "HasAuditable",
      "Filterable",
      "Searchable",
      "SoftDeletes"
    ],
    "casts": {
      "reason": "SmsOptOutReason",
      "phone": "PhoneNumberCast",
      "is_system": "boolean",
      "metadata": "array",
      "expires_at": "datetime",
      "opted_out_at": "datetime"
    },
    "appends": ["is_permanent", "country_code"],
    "observers": ["SmsOptOutObserver"],
    "hidden": ["metadata"],
    "guarded": []
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": {
        "type": "string",
        "length": 64,
        "primary": true,
        "description": "Prefixed ULID: `sopt_<26 chars>`."
      },
      "tenant_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": {
          "table": "tenants",
          "column": "id",
          "onUpdate": "cascade",
          "onDelete": "cascade"
        },
        "description": "NULL = platform-wide."
      },
      "phone": {
        "type": "string",
        "length": 20,
        "nullable": false,
        "description": "E.164 format (+15551234567). Confidential tier."
      },
      "phone_country_code": {
        "type": "string",
        "length": 3,
        "nullable": false,
        "description": "Country dial code (denormalised). Powers per-country DNC queries."
      },
      "reason": {
        "type": "string",
        "length": 24,
        "nullable": false,
        "description": "Enum: stop_keyword, manual, do_not_call_registry, invalid_number, spam_trap, complaint."
      },
      "provider": {
        "type": "string",
        "length": 32,
        "nullable": true,
        "description": "Provider that reported (null for manual/DNC entries)."
      },
      "source_delivery_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": {
          "table": "notification_deliveries",
          "column": "id",
          "onUpdate": "cascade",
          "onDelete": "set null"
        }
      },
      "inbound_message_body": {
        "type": "text",
        "nullable": true,
        "description": "The literal STOP-keyword message body received (STOP / STOPALL / QUIT / CANCEL / UNSUBSCRIBE). Retained as evidence."
      },
      "opted_out_at": {
        "type": "timestamptz",
        "nullable": false,
        "description": "Timestamp of the opt-out. Distinct from created_at (row insertion) for edge cases where opt-out is backdated."
      },
      "is_system": {
        "type": "boolean",
        "nullable": false,
        "default": false,
        "description": "True for platform-wide DNC + spam-trap entries."
      },
      "expires_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "For invalid_number reason: 30d recheck. Others never expire."
      },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_by": { "type": "uuid", "nullable": true },
      "updated_by": { "type": "uuid", "nullable": true },
      "deleted_by": { "type": "uuid", "nullable": true },
      "deleted_at": { "type": "timestamptz", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "phone"],
        "unique": true,
        "name": "sms_opt_outs_tenant_phone_unique",
        "description": "Primary lookup on every send."
      },
      {
        "columns": ["phone"],
        "unique": false,
        "name": "sms_opt_outs_phone_index",
        "description": "Cross-tenant lookup for platform-wide DNC (tenant_id IS NULL)."
      },
      { "columns": ["phone_country_code"], "unique": false, "name": "sms_opt_outs_country_index" },
      { "columns": ["reason", "created_at"], "unique": false, "name": "sms_opt_outs_reason_index" }
    ]
  },
  "required": [
    "id",
    "phone",
    "phone_country_code",
    "reason",
    "opted_out_at",
    "is_system",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^sopt_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": ["string", "null"], "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "phone": { "type": "string", "pattern": "^\\+[1-9][0-9]{1,14}$", "maxLength": 20 },
    "phone_country_code": { "type": "string", "pattern": "^[1-9][0-9]{0,2}$", "maxLength": 3 },
    "reason": {
      "type": "string",
      "enum": [
        "stop_keyword",
        "manual",
        "do_not_call_registry",
        "invalid_number",
        "spam_trap",
        "complaint"
      ]
    },
    "provider": { "type": ["string", "null"], "maxLength": 32 },
    "source_delivery_id": { "type": ["string", "null"] },
    "inbound_message_body": { "type": ["string", "null"] },
    "opted_out_at": { "type": "string", "format": "date-time" },
    "is_system": { "type": "boolean" },
    "expires_at": { "type": ["string", "null"], "format": "date-time" },
    "is_permanent": {
      "type": "boolean",
      "description": "Computed. reason IN stop_keyword/complaint/spam_trap OR is_system."
    },
    "country_code": { "type": "string", "description": "Computed. From phone_country_code." },
    "metadata": { "type": ["object", "null"], "additionalProperties": true },
    "created_by": { "type": ["string", "null"], "format": "uuid" },
    "updated_by": { "type": ["string", "null"], "format": "uuid" },
    "deleted_by": { "type": ["string", "null"], "format": "uuid" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "deleted_at": { "type": ["string", "null"], "format": "date-time" }
  },
  "additionalProperties": false,
  "x-wire": {
    "envelope": "spatie-data",
    "wrap": "data",
    "mapper": "SnakeCaseMapper",
    "hidden": ["metadata", "created_by", "updated_by", "deleted_by"],
    "computed": ["is_permanent", "country_code"]
  }
}
