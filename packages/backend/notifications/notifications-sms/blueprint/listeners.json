{
  "id": "stackra://modules/notifications-sms/listeners",
  "$version": 1,
  "title": "notifications-sms \u2014 subscribed events",
  "listeners": [
    {
      "event": "notifications::NotificationDispatched",
      "listener": "Stackra\\Notifications\\Sms\\Listeners\\HandleSmsDispatch",
      "queue": "notifications",
      "filter": "event.channels_requested contains 'sms'",
      "purpose": "Dispatches SendSmsJob."
    },
    {
      "event": "webhook::InboundWebhookReceived",
      "listener": "Stackra\\Notifications\\Sms\\Listeners\\IngestSmsProviderWebhookListener",
      "queue": "notifications-webhooks",
      "filter": "event.namespace === 'notifications-sms'",
      "purpose": "Dispatches IngestSmsProviderWebhookJob. Handles both delivery receipts AND inbound STOP/START keywords."
    },
    {
      "event": "notifications-sms::SmsUndeliverable",
      "listener": "Stackra\\Notifications\\Sms\\Listeners\\AddOptOutListener",
      "queue": "notifications",
      "purpose": "Adds invalid_number opt-out with 30d expiry (recheck window)."
    },
    {
      "event": "notifications-sms::SmsOptedOut",
      "listener": "Stackra\\Notifications\\Sms\\Listeners\\PropagateOptOutToPreferencesListener",
      "queue": "notifications",
      "purpose": "Cross-channel: sets NotificationPreference(channel=sms, enabled=false) for the associated user (found via User.phone match)."
    },
    {
      "event": "notifications-sms::SmsOptedOut",
      "listener": "Stackra\\Notifications\\Sms\\Listeners\\SendOptOutConfirmation",
      "queue": "notifications",
      "purpose": "CTIA-required: send auto-reply confirming unsubscribe."
    },
    {
      "event": "notifications-sms::SmsSubscribedIn",
      "listener": "Stackra\\Notifications\\Sms\\Listeners\\RevokeOptOutListener",
      "queue": "notifications",
      "purpose": "Soft-deletes existing SmsOptOut when user replied START."
    },
    {
      "event": "notifications-sms::SmsSubscribedIn",
      "listener": "Stackra\\Notifications\\Sms\\Listeners\\SendSubscribeConfirmation",
      "queue": "notifications",
      "purpose": "Confirms re-subscription per CTIA."
    },
    {
      "event": "notifications-sms::SmsCostRecorded",
      "listener": "Stackra\\Notifications\\Sms\\Listeners\\UpdateCostAggregation",
      "queue": "notifications",
      "purpose": "Updates the per-tenant per-country cost aggregation (cached for dashboard)."
    },
    {
      "event": "user::UserErased",
      "listener": "Stackra\\Notifications\\Sms\\Listeners\\AnonymiseOptOutsForErasedUser",
      "queue": "notifications",
      "purpose": "GDPR Art. 17 \u2014 phone number replaced with SHA-256 hash; opt-out row retained for TCPA evidence."
    }
  ]
}
