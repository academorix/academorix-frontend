{
  "id": "stackra://modules/notifications-sms/events",
  "$version": 1,
  "title": "notifications-sms \u2014 published events",
  "namespace": "Stackra\\Notifications\\Sms\\Events",
  "dispatchMode": "afterCommit",
  "events": [
    {
      "name": "SmsSent",
      "class": "Stackra\\Notifications\\Sms\\Events\\SmsSent",
      "trigger": "Provider accepted the message + returned SID.",
      "queue": "notifications",
      "consumers": ["notifications::UpdateDeliverySentListener"],
      "payload": {
        "notification_id": "ULID",
        "delivery_id": "ULID",
        "provider": "string",
        "provider_message_id": "string",
        "phone": "string (E.164)",
        "cost_micro_units": "integer | null",
        "sent_at": "ISO 8601"
      }
    },
    {
      "name": "SmsDelivered",
      "class": "Stackra\\Notifications\\Sms\\Events\\SmsDelivered",
      "trigger": "Provider webhook confirms carrier delivery.",
      "queue": "notifications",
      "consumers": ["notifications::UpdateDeliveryDeliveredListener"],
      "payload": {
        "notification_id": "ULID",
        "delivery_id": "ULID",
        "provider": "string",
        "delivered_at": "ISO 8601"
      }
    },
    {
      "name": "SmsFailed",
      "class": "Stackra\\Notifications\\Sms\\Events\\SmsFailed",
      "trigger": "Provider or carrier reported failure (transient).",
      "queue": "notifications",
      "consumers": ["notifications::UpdateDeliveryFailedListener"],
      "payload": {
        "notification_id": "ULID",
        "delivery_id": "ULID",
        "provider": "string",
        "error_code": "string",
        "error_message": "string"
      }
    },
    {
      "name": "SmsUndeliverable",
      "class": "Stackra\\Notifications\\Sms\\Events\\SmsUndeliverable",
      "trigger": "Permanent failure (invalid number, unreachable carrier). Adds to SmsOptOut with reason=invalid_number.",
      "queue": "notifications",
      "consumers": [
        "notifications::UpdateDeliveryFailedListener",
        "notifications-sms::AddOptOutListener"
      ],
      "payload": {
        "notification_id": "ULID",
        "delivery_id": "ULID",
        "provider": "string",
        "phone": "string (E.164)",
        "error_code": "string"
      }
    },
    {
      "name": "SmsOptedOut",
      "class": "Stackra\\Notifications\\Sms\\Events\\SmsOptedOut",
      "trigger": "SmsOptOut row created (either STOP-keyword or admin manual).",
      "queue": "notifications",
      "consumers": [
        "notifications-sms::PropagateOptOutToPreferencesListener",
        "compliance::AuditListener",
        "notifications-sms::SendOptOutConfirmation"
      ],
      "payload": {
        "opt_out_id": "ULID",
        "tenant_id": "ULID | null",
        "phone": "string (E.164)",
        "reason": "string",
        "source": "'stop_keyword' | 'admin' | 'dnc' | 'invalid_number' | 'complaint'"
      }
    },
    {
      "name": "SmsSubscribedIn",
      "class": "Stackra\\Notifications\\Sms\\Events\\SmsSubscribedIn",
      "trigger": "Inbound message body matches START / SUBSCRIBE / UNSTOP \u2014 re-subscription per CTIA guidelines.",
      "queue": "notifications",
      "consumers": [
        "notifications-sms::RevokeOptOutListener",
        "notifications-sms::SendSubscribeConfirmation"
      ],
      "payload": {
        "tenant_id": "ULID",
        "phone": "string",
        "inbound_message_body": "string",
        "provider": "string"
      }
    },
    {
      "name": "SmsCostRecorded",
      "class": "Stackra\\Notifications\\Sms\\Events\\SmsCostRecorded",
      "trigger": "Provider webhook returned final cost. Emitted after SmsDelivered.",
      "queue": "notifications",
      "consumers": ["notifications-sms::UpdateCostAggregation", "billing::TrackSmsCostListener"],
      "payload": {
        "delivery_id": "ULID",
        "tenant_id": "ULID",
        "provider": "string",
        "phone_country_code": "string",
        "cost_micro_units": "integer",
        "currency": "'USD' | 'EUR' | 'GBP'"
      }
    },
    {
      "name": "SmsOptOutRevoked",
      "class": "Stackra\\Notifications\\Sms\\Events\\SmsOptOutRevoked",
      "trigger": "SmsOptOut soft-deleted (admin revoke OR SmsSubscribedIn).",
      "queue": "notifications",
      "consumers": ["compliance::AuditListener"],
      "payload": { "opt_out_id": "ULID", "phone": "string", "revoked_by_user_id": "ULID | null" }
    }
  ]
}
