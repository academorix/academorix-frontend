{
  "id": "stackra://modules/messaging/schemas/conversation-participant",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "ConversationParticipant",
  "type": "object",
  "x-module": "messaging",
  "x-eloquent": {
    "table": "conversation_participants",
    "keyPrefix": "cvp_",
    "traits": ["HasFactory", "HasPrefixedUlid", "BelongsToTenant", "HasMetadata"]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 30, "primary": true },
      "tenant_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "conversation_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "conversations", "column": "id", "onDelete": "cascade" }
      },
      "user_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "users", "column": "id", "onDelete": "cascade" }
      },
      "role": { "type": "string", "length": 16, "nullable": false, "default": "'member'" },
      "joined_at": { "type": "timestamptz", "nullable": false },
      "left_at": { "type": "timestamptz", "nullable": true },
      "muted_until": { "type": "timestamptz", "nullable": true },
      "last_read_at": { "type": "timestamptz", "nullable": true },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "conversation_id", "user_id"],
        "unique": true,
        "name": "conversation_participants_unique"
      },
      {
        "columns": ["tenant_id", "user_id", "last_read_at"],
        "name": "conversation_participants_unread_idx"
      }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "conversation_id",
    "user_id",
    "role",
    "joined_at",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^cvp_[0-9A-HJKMNP-TV-Z]{26}$" },
    "role": { "type": "string", "enum": ["member", "admin", "observer"] }
  },
  "additionalProperties": false
}
