{
  "name": "stackra/newsletter",
  "type": "library",
  "description": "Editorial publication + audience management for Stackra. Ships five aggregates: Newsletter (the publication), NewsletterIssue (an individual issue with content + schedule), NewsletterSubscription (audience membership), NewsletterCampaign (a send event), NewsletterAudience (segment definition). CONSUMES notifications-mail for outbound delivery; NOT itself a channel driver. CAN-SPAM + CASL enforcement, one-click unsubscribe via signed URL, per-issue open + click tracking, subscriber-growth analytics, sender-reputation guardrails. Priority 30 - loads after notifications-mail (26).",
  "license": "proprietary",
  "keywords": [
    "stackra",
    "laravel",
    "newsletter",
    "email-marketing",
    "publications",
    "audience",
    "campaigns",
    "can-spam",
    "casl",
    "subscribers",
    "segments"
  ],
  "require": {
    "php": "^8.3",
    "stackra/activity": "@dev",
    "stackra/application": "@dev",
    "stackra/audit": "@dev",
    "stackra/authorization": "@dev",
    "stackra/console": "@dev",
    "stackra/crud": "@dev",
    "stackra/database": "@dev",
    "stackra/enum": "@dev",
    "stackra/events": "@dev",
    "stackra/exceptions": "@dev",
    "stackra/foundation": "@dev",
    "stackra/notifications": "@dev",
    "stackra/notifications-mail": "@dev",
    "stackra/retention": "@dev",
    "stackra/routing": "@dev",
    "stackra/service-provider": "@dev",
    "stackra/settings": "@dev",
    "stackra/support": "@dev",
    "stackra/tenancy": "@dev",
    "illuminate/broadcasting": "^13.0",
    "illuminate/bus": "^13.0",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/events": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/notifications": "^13.0",
    "illuminate/queue": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "spatie/laravel-data": "^4.11"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Stackra\\Newsletter\\": "src/",
      "Stackra\\Newsletter\\Database\\Factories\\": "database/factories/",
      "Stackra\\Newsletter\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Stackra\\Newsletter\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Stackra\\Newsletter\\Providers\\NewsletterServiceProvider"
      ],
      "aliases": {}
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
