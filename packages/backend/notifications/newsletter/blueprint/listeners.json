{
  "id": "stackra://modules/newsletter/listeners",
  "$version": 1,
  "title": "newsletter \u2014 subscribed events",
  "listeners": [
    {
      "event": "newsletter::NewsletterCreated",
      "listener": "Stackra\\Newsletter\\Listeners\\CreateDefaultAudience",
      "queue": "notifications",
      "purpose": "Auto-create the 'All active subscribers' audience for every new newsletter. is_default=true."
    },
    {
      "event": "newsletter::NewsletterArchived",
      "listener": "Stackra\\Newsletter\\Listeners\\PausePendingCampaigns",
      "queue": "notifications",
      "purpose": "Cancel any pending campaigns when newsletter is archived."
    },
    {
      "event": "newsletter::NewsletterSubscriptionAdded",
      "listener": "Stackra\\Newsletter\\Listeners\\DispatchConfirmationEmail",
      "queue": "notifications",
      "filter": "event.requires_confirmation === true",
      "purpose": "Send confirmation email via notifications core with signed confirmation_token URL."
    },
    {
      "event": "newsletter::NewsletterSubscriptionConfirmed",
      "listener": "Stackra\\Newsletter\\Listeners\\UpdateAudienceCache",
      "queue": "notifications",
      "purpose": "Bust cached_subscriber_ids for audiences whose expression may match this subscription."
    },
    {
      "event": "newsletter::NewsletterSubscriptionRemoved",
      "listener": "Stackra\\Newsletter\\Listeners\\UpdateAudienceCache",
      "queue": "notifications"
    },
    {
      "event": "newsletter::NewsletterCampaignCompleted",
      "listener": "Stackra\\Newsletter\\Listeners\\EvaluateReputation",
      "queue": "notifications",
      "purpose": "Check open/click/bounce/complaint rates against thresholds; fire alerts + auto-throttle newsletter on breach."
    },
    {
      "event": "newsletter::NewsletterOpenRecorded",
      "listener": "Stackra\\Newsletter\\Listeners\\UpdateEngagementScore",
      "queue": "notifications",
      "purpose": "Increment subscription.engagement_score (opens weight lower than clicks) + update last_opened_at."
    },
    {
      "event": "newsletter::NewsletterClickRecorded",
      "listener": "Stackra\\Newsletter\\Listeners\\UpdateEngagementScore",
      "queue": "notifications",
      "purpose": "Increment engagement_score + last_clicked_at."
    },
    {
      "event": "notifications-mail::MailBounced",
      "listener": "Stackra\\Newsletter\\Listeners\\HandleMailBounce",
      "queue": "notifications",
      "filter": "event.metadata contains newsletter_id + subscription_id",
      "purpose": "Flip subscription state to bounced (hard) or increment soft_bounce_count (soft). Fires NewsletterSubscriptionBounced."
    },
    {
      "event": "notifications-mail::MailComplaint",
      "listener": "Stackra\\Newsletter\\Listeners\\HandleMailComplaint",
      "queue": "notifications",
      "filter": "event.metadata contains newsletter_id + subscription_id",
      "purpose": "Flip subscription state to complained + fire NewsletterSubscriptionRemoved. Records complaint in audit for CAN-SPAM evidence."
    },
    {
      "event": "notifications-mail::MailOpened",
      "listener": "Stackra\\Newsletter\\Listeners\\HandleMailOpened",
      "queue": "notifications",
      "filter": "event.metadata contains newsletter_id",
      "purpose": "Fires NewsletterOpenRecorded."
    },
    {
      "event": "notifications-mail::MailClicked",
      "listener": "Stackra\\Newsletter\\Listeners\\HandleMailClicked",
      "queue": "notifications",
      "filter": "event.metadata contains newsletter_id",
      "purpose": "Fires NewsletterClickRecorded."
    },
    {
      "event": "user::UserErased",
      "listener": "Stackra\\Newsletter\\Listeners\\AnonymiseSubscriptionsForErasedUser",
      "queue": "notifications",
      "purpose": "GDPR Art. 17 \u2014 replace user_id + PII fields with anonymised placeholders. Subscription row retained for audit continuity."
    }
  ]
}
