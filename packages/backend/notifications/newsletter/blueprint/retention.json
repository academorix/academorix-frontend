{
  "id": "stackra://modules/newsletter/retention",
  "$version": 1,
  "title": "newsletter \u2014 retention windows",
  "compliance_regimes_referenced": [
    "can_spam \u00a77704(a)(4) \u2014 unsubscribe records retained as evidence",
    "casl s.6 + s.11 \u2014 consent + unsubscribe evidence",
    "gdpr Art. 5 + 17 \u2014 storage limitation + erasure"
  ],
  "retention": [
    {
      "entity": "Newsletter",
      "hot": { "days": "while tenant active" },
      "purge": { "trigger": "tenant erased", "action": "hard delete via cascade" }
    },
    {
      "entity": "NewsletterIssue (state=sent)",
      "hot": {
        "days": "forever while newsletter active",
        "description": "Historical evidence of what was sent. Never editable after send."
      },
      "purge": {
        "trigger": "newsletter archived + > 5y",
        "action": "anonymise-not-delete via audit"
      }
    },
    {
      "entity": "NewsletterSubscription (state=pending_confirmation)",
      "hot": { "days": "confirmation_ttl_hours" },
      "purge": {
        "trigger": "confirmation_token_expires_at reached",
        "action": "soft delete via PruneUnengagedSubscribersJob"
      }
    },
    {
      "entity": "NewsletterSubscription (state=active)",
      "hot": { "days": "while active" },
      "purge": {
        "trigger": "admin removal OR user::UserErased",
        "action": "soft delete + anonymise on erased"
      }
    },
    {
      "entity": "NewsletterSubscription (state=unsubscribed / bounced / complained)",
      "hot": { "days": 1825, "description": "5 years \u2014 CAN-SPAM + CASL evidence." },
      "purge": {
        "trigger": "> 5y since state transition",
        "action": "anonymise email + retain row"
      }
    },
    {
      "entity": "NewsletterCampaign",
      "hot": { "days": "forever while newsletter active" },
      "purge": { "trigger": "newsletter archived + > 5y", "action": "anonymise-not-delete" }
    },
    {
      "entity": "NewsletterAudience",
      "hot": { "days": "while newsletter active" },
      "purge": { "trigger": "audience delete", "action": "soft delete + 30d grace" }
    }
  ]
}
