{
  "id": "stackra://modules/newsletter/schemas/newsletter-subscription",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "NewsletterSubscription",
  "description": "Audience membership. State machine: pending_confirmation \u2192 active \u2194 unsubscribed \u2194 bounced. CAN-SPAM + CASL evidence via HasAudit trail.",
  "type": "object",
  "x-module": "newsletter",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "newsletter_subscriptions",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "nls_",
    "incrementing": false,
    "model": "Stackra\\Newsletter\\Models\\NewsletterSubscription",
    "interface": "Stackra\\Newsletter\\Contracts\\Data\\NewsletterSubscriptionInterface",
    "implements": ["Stackra\\Newsletter\\Contracts\\Data\\NewsletterSubscriptionInterface"],
    "traits": [
      "HasFactory",
      "HasUlids",
      "BelongsToTenant",
      "HasMetadata",
      "HasUserstamps",
      "HasAuditable",
      "HasActivityLog",
      "Filterable",
      "Searchable",
      "SoftDeletes"
    ],
    "casts": {
      "state": "NewsletterSubscriptionState",
      "source": "NewsletterSubscriptionSource",
      "tags": "array",
      "confirmed_at": "datetime",
      "unsubscribed_at": "datetime",
      "engagement_score": "integer",
      "last_opened_at": "datetime",
      "last_clicked_at": "datetime",
      "metadata": "array"
    },
    "appends": ["is_engaged"],
    "observers": ["NewsletterSubscriptionObserver"],
    "hidden": ["confirmation_token", "unsubscribe_token"],
    "guarded": []
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": {
        "type": "string",
        "length": 64,
        "primary": true,
        "description": "Prefixed ULID: `nls_<26 chars>`."
      },
      "tenant_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "newsletter_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "newsletters", "column": "id", "onDelete": "cascade" }
      },
      "user_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": { "table": "users", "column": "id", "onDelete": "set null" },
        "description": "Null when the subscriber is an email-only external contact."
      },
      "email": {
        "type": "string",
        "length": 254,
        "nullable": false,
        "description": "Normalised lowercase. Confidential tier."
      },
      "first_name": { "type": "string", "length": 100, "nullable": true },
      "last_name": { "type": "string", "length": 100, "nullable": true },
      "locale": { "type": "string", "length": 8, "nullable": true },
      "state": {
        "type": "string",
        "length": 24,
        "nullable": false,
        "default": "'pending_confirmation'",
        "description": "Enum: pending_confirmation / active / unsubscribed / bounced / complained."
      },
      "source": {
        "type": "string",
        "length": 32,
        "nullable": false,
        "description": "Enum: public_form / admin_added / imported / referral / api. CAN-SPAM evidence."
      },
      "confirmation_token": {
        "type": "string",
        "length": 128,
        "nullable": true,
        "description": "Signed HMAC token. Cleared on confirmation."
      },
      "confirmation_token_expires_at": { "type": "timestamptz", "nullable": true },
      "unsubscribe_token": {
        "type": "string",
        "length": 128,
        "nullable": false,
        "description": "Signed HMAC token for one-click unsubscribe URLs. Rotated on state changes."
      },
      "confirmed_at": { "type": "timestamptz", "nullable": true },
      "unsubscribed_at": { "type": "timestamptz", "nullable": true },
      "unsubscribe_reason": { "type": "string", "length": 200, "nullable": true },
      "tags": {
        "type": "jsonb",
        "nullable": true,
        "default": "'[]'::jsonb",
        "description": "Segment tags. Array<string>."
      },
      "engagement_score": {
        "type": "integer",
        "nullable": false,
        "default": 0,
        "description": "Rolling engagement metric. Updated by TrackNewsletterEngagementJob."
      },
      "last_opened_at": { "type": "timestamptz", "nullable": true },
      "last_clicked_at": { "type": "timestamptz", "nullable": true },
      "ip_address": {
        "type": "inet",
        "nullable": true,
        "description": "Sign-up IP. Truncated to /24."
      },
      "user_agent": {
        "type": "string",
        "length": 512,
        "nullable": true,
        "description": "Sign-up user agent. CAN-SPAM evidence."
      },
      "consent_evidence": {
        "type": "jsonb",
        "nullable": true,
        "description": "{ source_url, form_id, consent_text_hash, timestamp }. Regulatory evidence."
      },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_by": { "type": "uuid", "nullable": true },
      "updated_by": { "type": "uuid", "nullable": true },
      "deleted_by": { "type": "uuid", "nullable": true },
      "deleted_at": { "type": "timestamptz", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["newsletter_id", "email"],
        "unique": true,
        "name": "newsletter_subscriptions_email_unique",
        "predicate": "deleted_at IS NULL"
      },
      {
        "columns": ["newsletter_id", "state"],
        "unique": false,
        "name": "newsletter_subscriptions_state_idx"
      },
      {
        "columns": ["newsletter_id", "engagement_score"],
        "unique": false,
        "name": "newsletter_subscriptions_engagement_idx"
      },
      {
        "columns": ["confirmation_token"],
        "unique": false,
        "name": "newsletter_subscriptions_confirmation_idx",
        "predicate": "confirmation_token IS NOT NULL"
      },
      {
        "columns": ["unsubscribe_token"],
        "unique": false,
        "name": "newsletter_subscriptions_unsubscribe_idx"
      }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "newsletter_id",
    "email",
    "state",
    "source",
    "unsubscribe_token",
    "engagement_score",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^nls_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": "string", "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "newsletter_id": { "type": "string", "pattern": "^nlp_[0-9A-HJKMNP-TV-Z]{26}$" },
    "user_id": { "type": ["string", "null"] },
    "email": { "type": "string", "format": "email", "maxLength": 254 },
    "first_name": { "type": ["string", "null"], "maxLength": 100 },
    "last_name": { "type": ["string", "null"], "maxLength": 100 },
    "locale": { "type": ["string", "null"], "pattern": "^[a-z]{2}(_[A-Z]{2})?$" },
    "state": {
      "type": "string",
      "enum": ["pending_confirmation", "active", "unsubscribed", "bounced", "complained"]
    },
    "source": {
      "type": "string",
      "enum": ["public_form", "admin_added", "imported", "referral", "api"]
    },
    "confirmed_at": { "type": ["string", "null"], "format": "date-time" },
    "unsubscribed_at": { "type": ["string", "null"], "format": "date-time" },
    "unsubscribe_reason": { "type": ["string", "null"], "maxLength": 200 },
    "tags": { "type": "array", "items": { "type": "string" } },
    "engagement_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "last_opened_at": { "type": ["string", "null"], "format": "date-time" },
    "last_clicked_at": { "type": ["string", "null"], "format": "date-time" },
    "ip_address": { "type": ["string", "null"] },
    "user_agent": { "type": ["string", "null"], "maxLength": 512 },
    "consent_evidence": { "type": ["object", "null"] },
    "is_engaged": {
      "type": "boolean",
      "description": "Computed. engagement_score > 20 AND last activity within 90d."
    },
    "metadata": { "type": ["object", "null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false,
  "x-wire": {
    "envelope": "spatie-data",
    "wrap": "data",
    "mapper": "SnakeCaseMapper",
    "hidden": ["confirmation_token", "unsubscribe_token", "ip_address"],
    "computed": ["is_engaged"]
  }
}
