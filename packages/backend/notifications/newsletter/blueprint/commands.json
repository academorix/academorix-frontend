{
  "id": "stackra://modules/newsletter/commands",
  "$version": 1,
  "title": "newsletter \u2014 Artisan commands",
  "commands": [
    {
      "signature": "newsletter:send-scheduled",
      "class": "Stackra\\Newsletter\\Console\\Commands\\SendScheduledCommand",
      "purpose": "Dispatch SendNewsletterCampaignJob for all pending campaigns due. Runs from schedule."
    },
    {
      "signature": "newsletter:refresh-audiences {--newsletter=} {--force}",
      "class": "Stackra\\Newsletter\\Console\\Commands\\RefreshAudiencesCommand",
      "purpose": "Rebuild cached_subscriber_ids. --force ignores cache age."
    },
    {
      "signature": "newsletter:import-subscribers {newsletter} {file} {--dry-run}",
      "class": "Stackra\\Newsletter\\Console\\Commands\\ImportSubscribersCommand"
    },
    {
      "signature": "newsletter:export-subscribers {newsletter} {--filter=} {--out=}",
      "class": "Stackra\\Newsletter\\Console\\Commands\\ExportSubscribersCommand"
    },
    {
      "signature": "newsletter:reputation-report {--newsletter=} {--month=previous} {--email}",
      "class": "Stackra\\Newsletter\\Console\\Commands\\ReputationReportCommand",
      "purpose": "Print or email. --email = deliver to newsletter owner."
    },
    {
      "signature": "newsletter:prune-unengaged {--newsletter=} {--dry-run}",
      "class": "Stackra\\Newsletter\\Console\\Commands\\PruneUnengagedCommand"
    },
    {
      "signature": "newsletter:test-send {issue} {--to=} {--audience=}",
      "class": "Stackra\\Newsletter\\Console\\Commands\\TestSendCommand",
      "purpose": "Preview an issue by sending to a single test address or a tiny test audience. Refused in prod without --allow-production."
    }
  ]
}
