{
  "name": "academorix/laravel-horizon",
  "description": "Laravel Horizon queue monitoring with automatic supervisor and metric discovery for Academorix applications",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Academorix Team",
      "email": "dev@academorix.com"
    }
  ],
  "homepage": "https://github.com/academorix-inc/laravel-telemetry/horizon",
  "support": {
    "issues": "https://github.com/academorix-inc/laravel-telemetry/horizon/-/issues",
    "source": "https://github.com/academorix-inc/laravel-telemetry/horizon"
  },
  "keywords": [
    "academorix",
    "telemetry",
    "horizon",
    "queue",
    "monitoring",
    "jobs",
    "redis",
    "laravel"
  ],
  "prefer-stable": true,
  "minimum-stability": "dev",
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  },
  "require": {
    "laravel/horizon": "^5.0",
    "php": "^8.4|^8.5",
    "academorix/laravel-support": "@dev"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^10.0",
    "phpunit/phpunit": "^11.0"
  },
  "suggest": {
    "academorix/laravel-telemetry-pulse": "For real-time application monitoring",
    "academorix/laravel-telemetry-telescope": "For application debugging",
    "predis/predis": "Required for Redis queue driver"
  },
  "autoload": {
    "psr-4": {
      "Academorix\\Horizon\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Academorix\\Horizon\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Academorix\\Horizon\\Providers\\HorizonServiceProvider"
      ]
    }
  }
}
