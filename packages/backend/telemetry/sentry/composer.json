{
  "name": "stackra/sentry",
  "description": "Sentry error tracking and monitoring with automatic context discovery for Stackra applications",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Stackra Team",
      "email": "dev@stackra.com"
    }
  ],
  "homepage": "https://github.com/stackra-inc/laravel-telemetry/sentry",
  "support": {
    "issues": "https://github.com/stackra-inc/laravel-telemetry/sentry/-/issues",
    "source": "https://github.com/stackra-inc/laravel-telemetry/sentry"
  },
  "keywords": [
    "stackra",
    "telemetry",
    "sentry",
    "error-tracking",
    "monitoring",
    "observability",
    "laravel"
  ],
  "prefer-stable": true,
  "minimum-stability": "dev",
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  },
  "require": {
    "php": "^8.4|^8.5",
    "sentry/sentry-laravel": "^4.0",
    "stackra/support": "@dev"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^10.0",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Stackra\\Sentry\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Stackra\\Sentry\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Stackra\\Sentry\\Providers\\SentryServiceProvider"
      ]
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "../../framework/support",
      "options": {
        "symlink": true
      }
    }
  ],
  "scripts": {
    "test": "Stackra\\Foundation\\Scripts\\TestScripts::run",
    "test:coverage": "Stackra\\Foundation\\Scripts\\TestScripts::coverage",
    "test:parallel": "Stackra\\Foundation\\Scripts\\TestScripts::parallel",
    "test:filter": "Stackra\\Foundation\\Scripts\\TestScripts::filter",
    "analyse": "Stackra\\Foundation\\Scripts\\AnalyseScripts::run",
    "analyse:baseline": "Stackra\\Foundation\\Scripts\\AnalyseScripts::baseline",
    "lint": "Stackra\\Foundation\\Scripts\\LintScripts::check",
    "lint:fix": "Stackra\\Foundation\\Scripts\\LintScripts::fix",
    "doppler:status": "Stackra\\Foundation\\Scripts\\DopplerScripts::status",
    "doppler:setup": "Stackra\\Foundation\\Scripts\\DopplerScripts::setup"
  }
}
