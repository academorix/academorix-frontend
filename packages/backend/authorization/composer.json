{
  "name": "stackra/authorization",
  "type": "library",
  "description": "Attribute-driven controller authorization layer. Ships #[RequirePermission], #[RequireAnyPermission], #[RequireRole], #[RequireAnyRole], and #[AllowGuest] \u2014 enforced by a reflection-cached middleware that fails 401/403 BEFORE the controller body runs. Zero models, zero migrations, zero coupling to a specific permission backend \u2014 every domain package can require this without dragging spatie/laravel-permission's tables in. The heavier `packages/access` builds on top with roles + permissions + admin controllers.",
  "license": "proprietary",
  "keywords": [
    "stackra",
    "laravel",
    "authorization",
    "attributes",
    "permissions",
    "roles"
  ],
  "require": {
    "php": "^8.3",
    "stackra/exceptions": "@dev",
    "stackra/foundation": "@dev",
    "stackra/service-provider": "@dev",
    "stackra/support": "@dev",
    "illuminate/auth": "^13.0",
    "illuminate/contracts": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "suggest": {
    "stackra/database": "Required by SeedsPermissionEnum \u2014 provides the underlying Enumable trait.",
    "spatie/laravel-permission": "Required by SeedsPermissionEnum \u2014 the permissions-table schema this trait writes to. Only needed by modules that project a PermissionEnum into the DB."
  },
  "autoload": {
    "psr-4": {
      "Stackra\\Authorization\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Stackra\\Authorization\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Stackra\\Authorization\\Providers\\AuthorizationServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "repositories": [
    {
      "type": "path",
      "url": "../framework/exceptions",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../foundation",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../framework/service-provider",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../framework/support",
      "options": {
        "symlink": true
      }
    }
  ],
  "scripts": {
    "test": "Stackra\\Foundation\\Scripts\\TestScripts::run",
    "test:coverage": "Stackra\\Foundation\\Scripts\\TestScripts::coverage",
    "test:parallel": "Stackra\\Foundation\\Scripts\\TestScripts::parallel",
    "test:filter": "Stackra\\Foundation\\Scripts\\TestScripts::filter",
    "analyse": "Stackra\\Foundation\\Scripts\\AnalyseScripts::run",
    "analyse:baseline": "Stackra\\Foundation\\Scripts\\AnalyseScripts::baseline",
    "lint": "Stackra\\Foundation\\Scripts\\LintScripts::check",
    "lint:fix": "Stackra\\Foundation\\Scripts\\LintScripts::fix",
    "doppler:status": "Stackra\\Foundation\\Scripts\\DopplerScripts::status",
    "doppler:setup": "Stackra\\Foundation\\Scripts\\DopplerScripts::setup"
  }
}
