{
  "name": "academorix/entitlements",
  "type": "library",
  "description": "Per-tenant quota + usage tracking substrate consumed by every metered feature (webhook, notifications, storage, newsletter, search, etc). Owns two entities — Entitlement (the resolved cap for a (tenant, key) tuple) and EntitlementUsage (audit rows for consumption events). Ships four entitlement kinds: `slot` (hard cap on concurrent count), `pool` (periodic quota with reset), `boolean` (feature toggle), `unlimited` (enterprise). Redis-backed hot-path consume() with Postgres source-of-truth. Monthly + anniversary + lifetime reset windows. Manual per-tenant overrides for enterprise negotiations. Publishes `HasEntitlements` (mixed into Tenant) + `MetersUsage` trait for models that consume metered features. Exports usage to Stripe/Paddle at billing period end for usage-based tiers.",
  "license": "proprietary",
  "keywords": [
    "academorix",
    "laravel",
    "entitlements",
    "quotas",
    "usage",
    "metering",
    "slot",
    "pool",
    "boolean",
    "enforcement",
    "billing",
    "tenant",
    "feature-flags"
  ],
  "require": {
    "php": "^8.3",
    "academorix/activity": "@dev",
    "academorix/audit": "@dev",
    "academorix/authorization": "@dev",
    "academorix/console": "@dev",
    "academorix/crud": "@dev",
    "academorix/database": "@dev",
    "academorix/enum": "@dev",
    "academorix/events": "@dev",
    "academorix/exceptions": "@dev",
    "academorix/foundation": "@dev",
    "academorix/retention": "@dev",
    "academorix/routing": "@dev",
    "academorix/service-provider": "@dev",
    "academorix/support": "@dev",
    "academorix/tenancy": "@dev",
    "illuminate/bus": "^13.0",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/events": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/queue": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "spatie/laravel-data": "^4.11"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Academorix\\Entitlements\\": "src/",
      "Academorix\\Entitlements\\Database\\Factories\\": "database/factories/",
      "Academorix\\Entitlements\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Academorix\\Entitlements\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Academorix\\Entitlements\\Providers\\EntitlementsServiceProvider"
      ],
      "aliases": {}
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
