{
  "id": "stackra://modules/entitlements/events",
  "$version": 1,
  "title": "entitlements \u2014 published events",
  "namespace": "Stackra\\Entitlements\\Events",
  "dispatchMode": "afterCommit",
  "events": [
    {
      "name": "EntitlementResolved",
      "class": "Stackra\\Entitlements\\Events\\EntitlementResolved",
      "trigger": "New Entitlement row upserted (tenant creation or plan sync).",
      "queue": "notifications",
      "consumers": ["activity::WarmActivityFeedListener"],
      "payload": {
        "entitlement_id": "ULID",
        "tenant_id": "ULID",
        "key": "string",
        "value_cap": "integer | null",
        "source_plan_id": "ULID | null"
      }
    },
    {
      "name": "EntitlementConsumed",
      "class": "Stackra\\Entitlements\\Events\\EntitlementConsumed",
      "trigger": "Enforcer::consume() succeeded. Fires afterCommit on the EntitlementUsage row.",
      "queue": "notifications",
      "wire_contract_file": "contracts/entitlement-consumed.v1.json",
      "wire_contract_version": "v1",
      "wire_event_name": "entitlements.entitlement.consumed",
      "consumers": ["telemetry::MetricsCollector"],
      "payload": {
        "entitlement_id": "ULID",
        "tenant_id": "ULID",
        "key": "string",
        "amount": "integer",
        "new_value_used": "integer",
        "correlation_id": "string | null"
      }
    },
    {
      "name": "EntitlementExceeded",
      "class": "Stackra\\Entitlements\\Events\\EntitlementExceeded",
      "trigger": "Enforcer::enforce() rejected because value_used + delta > value_cap.",
      "queue": "notifications-critical",
      "consumers": [
        "notifications::DispatchQuotaExceededNotification",
        "observability::AlertingListener"
      ],
      "payload": {
        "entitlement_id": "ULID",
        "tenant_id": "ULID",
        "key": "string",
        "value_cap": "integer",
        "value_used": "integer",
        "attempted_amount": "integer"
      }
    },
    {
      "name": "EntitlementApproachingCap",
      "class": "Stackra\\Entitlements\\Events\\EntitlementApproachingCap",
      "trigger": "value_used crossed the warn threshold (default 80% of value_cap). Fires once per period.",
      "queue": "notifications",
      "consumers": ["notifications::DispatchQuotaApproachingNotification"],
      "payload": {
        "entitlement_id": "ULID",
        "tenant_id": "ULID",
        "key": "string",
        "usage_ratio": "number"
      }
    },
    {
      "name": "EntitlementReset",
      "class": "Stackra\\Entitlements\\Events\\EntitlementReset",
      "trigger": "ResetPeriodicUsageJob or platform-admin manual reset. value_used \u2192 0.",
      "queue": "notifications",
      "consumers": ["notifications::DispatchEntitlementResetNotification"],
      "payload": {
        "entitlement_id": "ULID",
        "tenant_id": "ULID",
        "key": "string",
        "period": "'month' | 'year' | 'anniversary' | 'lifetime'",
        "previous_used": "integer",
        "next_resets_at": "ISO 8601"
      }
    },
    {
      "name": "EntitlementOverridden",
      "class": "Stackra\\Entitlements\\Events\\EntitlementOverridden",
      "trigger": "Platform admin manually set value_cap via PATCH endpoint.",
      "queue": "notifications",
      "consumers": ["compliance::AuditListener"],
      "payload": {
        "entitlement_id": "ULID",
        "tenant_id": "ULID",
        "key": "string",
        "old_value_cap": "integer | null",
        "new_value_cap": "integer | null",
        "notes": "string",
        "admin_id": "ULID"
      }
    },
    {
      "name": "EntitlementSyncStarted",
      "class": "Stackra\\Entitlements\\Events\\EntitlementSyncStarted",
      "trigger": "SyncEntitlementsFromPlanJob picked up a subscription plan change.",
      "queue": "notifications",
      "payload": { "tenant_id": "ULID", "from_plan_id": "ULID | null", "to_plan_id": "ULID" }
    },
    {
      "name": "EntitlementSyncCompleted",
      "class": "Stackra\\Entitlements\\Events\\EntitlementSyncCompleted",
      "trigger": "SyncEntitlementsFromPlanJob finished successfully.",
      "queue": "notifications",
      "consumers": ["observability::MetricsCollector"],
      "payload": { "tenant_id": "ULID", "plan_id": "ULID", "entitlements_updated": "integer" }
    },
    {
      "name": "UsageReportedToBilling",
      "class": "Stackra\\Entitlements\\Events\\UsageReportedToBilling",
      "trigger": "ExportUsageForBillingJob pushed a metered-billing entitlement's usage to Stripe/Paddle.",
      "queue": "notifications",
      "payload": {
        "entitlement_id": "ULID",
        "tenant_id": "ULID",
        "key": "string",
        "period_start": "ISO 8601",
        "period_end": "ISO 8601",
        "amount_reported": "integer",
        "provider": "'stripe' | 'paddle'",
        "provider_usage_record_id": "string"
      }
    }
  ]
}
