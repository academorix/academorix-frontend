{
  "id": "stackra://modules/entitlements/commands",
  "$version": 1,
  "title": "entitlements \u2014 Artisan commands",
  "commands": [
    {
      "signature": "entitlements:seed {tenant_id} {--plan=}",
      "class": "Stackra\\Entitlements\\Console\\Commands\\SeedCommand",
      "purpose": "Create Entitlement rows for every declared key. Values from --plan or tenant's current plan."
    },
    {
      "signature": "entitlements:describe {--key=} {--kind=}",
      "class": "Stackra\\Entitlements\\Console\\Commands\\DescribeCommand",
      "purpose": "Print EntitlementRegistry contents: all declared keys with their kind + declaring module + plan defaults."
    },
    {
      "signature": "entitlements:reset {--tenant=} {--key=} {--force}",
      "class": "Stackra\\Entitlements\\Console\\Commands\\ResetCommand",
      "purpose": "Force reset value_used for pool entitlements. --force skips the resets_at check."
    },
    {
      "signature": "entitlements:report-usage {--tenant=} {--key=} {--period=current}",
      "class": "Stackra\\Entitlements\\Console\\Commands\\ReportUsageCommand",
      "purpose": "Manually trigger ExportUsageForBillingJob for a specific entitlement + period."
    },
    {
      "signature": "entitlements:reconcile {--tenant=} {--dry-run}",
      "class": "Stackra\\Entitlements\\Console\\Commands\\ReconcileCommand",
      "purpose": "Run reconciliation now. --dry-run reports drift without correcting."
    },
    {
      "signature": "entitlements:sync-plan {tenant_id}",
      "class": "Stackra\\Entitlements\\Console\\Commands\\SyncPlanCommand",
      "purpose": "Force plan-sync for a tenant. Useful after direct DB overrides or drift."
    },
    {
      "signature": "entitlements:prune-usage {--dry-run}",
      "class": "Stackra\\Entitlements\\Console\\Commands\\PruneUsageCommand",
      "purpose": "Drop old EntitlementUsage partitions past retention."
    }
  ]
}
