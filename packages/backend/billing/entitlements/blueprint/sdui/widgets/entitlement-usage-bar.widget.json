{
  "id": "entitlements.entitlement-usage-bar",
  "title": "Entitlement usage bar",
  "version": 1,
  "kind": "SduiWidget",
  "description": "Progress bar with colour severity: green < 60%, yellow 60\u201380%, orange 80\u201395%, red 95\u2013100%. For unlimited: renders a solid neutral bar with \u221e label.",
  "props": {
    "cap": { "type": ["integer", "null"], "description": "value_cap" },
    "used": { "type": "integer", "description": "value_used" },
    "isUnlimited": { "type": "boolean", "default": false },
    "size": { "type": "string", "default": "md", "enum": ["sm", "md", "lg"] }
  },
  "dataSources": [],
  "nodes": [
    {
      "id": "wrapper",
      "kind": "View",
      "props": { "className": "flex flex-col gap-1" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-center justify-between text-xs" },
          "children": [
            {
              "kind": "Text",
              "props": { "className": "text-muted" },
              "bindings": {
                "children": {
                  "$expr": "props.isUnlimited ? 'Unlimited' : (props.used.toLocaleString() + ' / ' + (props.cap ?? 0).toLocaleString())"
                }
              }
            },
            {
              "kind": "Text",
              "props": { "className": "font-medium" },
              "bindings": {
                "hidden": { "$expr": "props.isUnlimited" },
                "children": {
                  "$expr": "Math.min(100, Math.round((props.used / Math.max(props.cap ?? 1, 1)) * 100)) + '%'"
                }
              }
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "bg-content2 rounded-full overflow-hidden" },
          "bindings": {
            "className": {
              "$expr": "'bg-content2 rounded-full overflow-hidden ' + (props.size === 'sm' ? 'h-1' : (props.size === 'lg' ? 'h-3' : 'h-2'))"
            }
          },
          "children": [
            {
              "kind": "View",
              "props": { "className": "h-full rounded-full transition-all" },
              "bindings": {
                "className": {
                  "$expr": "'h-full rounded-full transition-all ' + (props.isUnlimited ? 'bg-content3' : (() => { const r = props.used / Math.max(props.cap ?? 1, 1); return r < 0.6 ? 'bg-success' : r < 0.8 ? 'bg-warning' : r < 0.95 ? 'bg-warning-strong' : 'bg-danger'; })())"
                },
                "style": {
                  "$expr": "{ width: props.isUnlimited ? '100%' : Math.min(100, (props.used / Math.max(props.cap ?? 1, 1)) * 100) + '%' }"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
