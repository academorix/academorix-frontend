{
  "id": "stackra://modules/subscription/settings",
  "$version": 1,
  "title": "subscription \u2014 settings",
  "description": "Tenant-facing subscription preferences. One #[AsSetting] class published under group key `subscription`.",
  "storedIn": "settings",
  "reference": { "contract": "stackra://modules/settings/attributes" },
  "groups": [
    {
      "key": "subscription",
      "class": "Stackra\\Subscription\\Settings\\SubscriptionSettings",
      "label": "Billing preferences",
      "description": "How the tenant handles subscription lifecycle events.",
      "icon": "credit-card",
      "scope": "tenant",
      "public": false,
      "sortOrder": 30,
      "permission": "subscription.manage",
      "sections": [
        {
          "label": "Billing contact",
          "description": "Where billing emails + invoices are sent. Falls back to tenant owner if empty.",
          "icon": "envelope",
          "sortOrder": 1,
          "fields": [
            {
              "name": "billing_email",
              "controlType": "email",
              "label": "Billing email",
              "defaultValue": null,
              "validation": ["nullable", "email"],
              "sortOrder": 1
            },
            {
              "name": "cc_owner_on_invoices",
              "controlType": "toggle",
              "label": "CC tenant owner on invoices",
              "defaultValue": true,
              "validation": ["boolean"],
              "sortOrder": 2
            }
          ]
        },
        {
          "label": "Auto-renewal",
          "icon": "arrow-path",
          "sortOrder": 2,
          "fields": [
            {
              "name": "auto_renew_enabled",
              "controlType": "toggle",
              "label": "Auto-renew subscription",
              "defaultValue": true,
              "validation": ["boolean"],
              "sortOrder": 1,
              "helpText": "When off, cancel_at_period_end=true on the next renewal date."
            }
          ]
        },
        {
          "label": "Invoice preferences",
          "icon": "document-text",
          "sortOrder": 3,
          "fields": [
            {
              "name": "invoice_language",
              "controlType": "select",
              "label": "Invoice language",
              "defaultValue": "en",
              "options": {
                "en": "English",
                "fr": "Fran\u00e7ais",
                "es": "Espa\u00f1ol",
                "de": "Deutsch"
              },
              "validation": ["required", "in:en,fr,es,de"],
              "sortOrder": 1
            },
            {
              "name": "tax_id",
              "controlType": "text",
              "label": "Tax ID (VAT / GST / EIN)",
              "defaultValue": null,
              "validation": ["nullable", "string", "max:64"],
              "sortOrder": 2,
              "helpText": "Included on invoices for tax purposes. Format varies by jurisdiction."
            }
          ]
        }
      ]
    }
  ]
}
