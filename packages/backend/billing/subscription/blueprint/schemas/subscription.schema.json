{
  "id": "stackra://modules/subscription/schemas/subscription",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "Subscription",
  "description": "Tenant's active subscription. Wraps Cashier's subscription row via provider_subscription_id + adds our own state layer (grace period beyond provider default).",
  "type": "object",
  "x-module": "subscription",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "subscriptions",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "sub_",
    "incrementing": false,
    "model": "Stackra\\Subscription\\Models\\Subscription",
    "interface": "Stackra\\Subscription\\Contracts\\Data\\SubscriptionInterface",
    "implements": ["Stackra\\Subscription\\Contracts\\Data\\SubscriptionInterface"],
    "traits": [
      "HasFactory",
      "HasUlids",
      "BelongsToTenant",
      "HasMetadata",
      "HasUserstamps",
      "HasActivityLog",
      "HasAudit",
      "Filterable",
      "SoftDeletes"
    ],
    "casts": {
      "state": "SubscriptionState",
      "trial_ends_at": "datetime",
      "current_period_start": "datetime",
      "current_period_end": "datetime",
      "grace_ends_at": "datetime",
      "suspended_at": "datetime",
      "cancelled_at": "datetime",
      "cancel_at_period_end": "boolean",
      "reinstated_at": "datetime",
      "last_payment_at": "datetime",
      "last_payment_failed_at": "datetime",
      "consecutive_failures": "integer",
      "metadata": "array"
    },
    "appends": [
      "is_active",
      "is_on_trial",
      "is_grace",
      "is_suspended",
      "days_remaining_in_period",
      "days_past_due"
    ],
    "observers": ["SubscriptionObserver"],
    "hidden": [],
    "guarded": []
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": {
        "type": "string",
        "length": 64,
        "primary": true,
        "description": "Prefixed ULID: `sub_<26 chars>`."
      },
      "tenant_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "application_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "applications", "column": "id", "onDelete": "restrict" },
        "description": "Denormalised for Application-scoped queries."
      },
      "plan_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "plans", "column": "id", "onDelete": "restrict" }
      },
      "provider": {
        "type": "string",
        "length": 24,
        "nullable": false,
        "description": "Enum: stripe / paddle / invoice. Follows the Application's payment_provider except for enterprise invoice subscriptions."
      },
      "provider_subscription_id": {
        "type": "string",
        "length": 128,
        "nullable": true,
        "description": "Cashier's subscription id at the provider (Stripe sub_xxx / Paddle subscription id). Null for provider=invoice."
      },
      "provider_customer_id": {
        "type": "string",
        "length": 128,
        "nullable": true,
        "description": "Cashier's stripe_id / paddle_id (customer level). Denormalised from tenants."
      },
      "state": {
        "type": "string",
        "length": 24,
        "nullable": false,
        "default": "'trialing'",
        "description": "Our state. Enum: trialing / active / at_risk / grace / past_due / unpaid / suspended / cancelled / expired."
      },
      "billing_cycle": {
        "type": "string",
        "length": 16,
        "nullable": false,
        "description": "Denormalised from Plan."
      },
      "trial_ends_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "When trial ends. Null after trial ends or if no trial."
      },
      "current_period_start": {
        "type": "timestamptz",
        "nullable": true,
        "description": "Current billing period start. Synced from provider."
      },
      "current_period_end": {
        "type": "timestamptz",
        "nullable": true,
        "description": "Next renewal / expiration."
      },
      "grace_ends_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "When grace ends and tenant suspends. Set on state\u2192at_risk. Extends provider's default lifecycle."
      },
      "suspended_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "When tenant suspension kicked in. Full feature restrictions."
      },
      "cancelled_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "When user cancelled. Cancellation may be effective at_period_end or immediate."
      },
      "cancel_at_period_end": {
        "type": "boolean",
        "nullable": false,
        "default": false,
        "description": "True = cancellation deferred to period end. False = immediate."
      },
      "reinstated_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "When a cancelled subscription was reinstated (user changed mind before effective date)."
      },
      "last_payment_at": { "type": "timestamptz", "nullable": true },
      "last_payment_failed_at": { "type": "timestamptz", "nullable": true },
      "consecutive_failures": {
        "type": "integer",
        "nullable": false,
        "default": 0,
        "description": "Cashier retry attempts. Feeds DunningOrchestrator."
      },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_by": { "type": "uuid", "nullable": true },
      "updated_by": { "type": "uuid", "nullable": true },
      "deleted_by": { "type": "uuid", "nullable": true },
      "deleted_at": { "type": "timestamptz", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["tenant_id"],
        "unique": true,
        "name": "subscriptions_tenant_unique",
        "predicate": "state NOT IN ('cancelled','expired') AND deleted_at IS NULL",
        "description": "One active subscription per tenant. Historic + cancelled rows retained."
      },
      {
        "columns": ["application_id", "state"],
        "unique": false,
        "name": "subscriptions_app_state_idx"
      },
      {
        "columns": ["provider_subscription_id"],
        "unique": true,
        "name": "subscriptions_provider_unique",
        "predicate": "provider_subscription_id IS NOT NULL"
      },
      {
        "columns": ["grace_ends_at"],
        "unique": false,
        "name": "subscriptions_grace_scan_idx",
        "predicate": "state IN ('at_risk','grace','past_due')",
        "description": "AdvanceDunningStageJob scan predicate."
      },
      {
        "columns": ["trial_ends_at"],
        "unique": false,
        "name": "subscriptions_trial_scan_idx",
        "predicate": "state = 'trialing'"
      }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "application_id",
    "plan_id",
    "provider",
    "state",
    "billing_cycle",
    "consecutive_failures",
    "cancel_at_period_end",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^sub_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": "string" },
    "application_id": { "type": "string" },
    "plan_id": { "type": "string", "pattern": "^pln_[0-9A-HJKMNP-TV-Z]{26}$" },
    "provider": { "type": "string", "enum": ["stripe", "paddle", "invoice"] },
    "provider_subscription_id": { "type": ["string", "null"] },
    "provider_customer_id": { "type": ["string", "null"] },
    "state": {
      "type": "string",
      "enum": [
        "trialing",
        "active",
        "at_risk",
        "grace",
        "past_due",
        "unpaid",
        "suspended",
        "cancelled",
        "expired"
      ]
    },
    "billing_cycle": { "type": "string", "enum": ["monthly", "annual", "lifetime"] },
    "trial_ends_at": { "type": ["string", "null"], "format": "date-time" },
    "current_period_start": { "type": ["string", "null"], "format": "date-time" },
    "current_period_end": { "type": ["string", "null"], "format": "date-time" },
    "grace_ends_at": { "type": ["string", "null"], "format": "date-time" },
    "suspended_at": { "type": ["string", "null"], "format": "date-time" },
    "cancelled_at": { "type": ["string", "null"], "format": "date-time" },
    "cancel_at_period_end": { "type": "boolean" },
    "reinstated_at": { "type": ["string", "null"], "format": "date-time" },
    "last_payment_at": { "type": ["string", "null"], "format": "date-time" },
    "last_payment_failed_at": { "type": ["string", "null"], "format": "date-time" },
    "consecutive_failures": { "type": "integer", "minimum": 0 },
    "is_active": { "type": "boolean", "description": "Computed." },
    "is_on_trial": { "type": "boolean" },
    "is_grace": { "type": "boolean" },
    "is_suspended": { "type": "boolean" },
    "days_remaining_in_period": { "type": ["integer", "null"] },
    "days_past_due": { "type": ["integer", "null"] },
    "metadata": { "type": ["object", "null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false,
  "x-wire": {
    "envelope": "spatie-data",
    "wrap": "data",
    "mapper": "SnakeCaseMapper",
    "computed": [
      "is_active",
      "is_on_trial",
      "is_grace",
      "is_suspended",
      "days_remaining_in_period",
      "days_past_due"
    ]
  }
}
