{
  "name": "academorix/subscription",
  "type": "library",
  "description": "Tenant subscription lifecycle. Wraps Laravel Cashier for payment-provider-agnostic billing (Stripe + Paddle). Owns Plan (per-Application plan catalogue), Subscription (tenant's active plan with Cashier's Billable trait mixed onto Tenant), and SubscriptionEvent (audit-material lifecycle transitions retained 7 years for SOX). Consumes payment-provider webhooks via Cashier and translates to our own SubscriptionUpgraded/Downgraded/Cancelled events, which the entitlements module consumes to refresh Entitlement rows. Handles trials, grace periods beyond provider default, metered-billing usage export, and enterprise-contract offline billing.",
  "license": "proprietary",
  "keywords": [
    "academorix",
    "laravel",
    "subscription",
    "billing",
    "cashier",
    "stripe",
    "paddle",
    "plans",
    "trial",
    "usage-billing",
    "tenant",
    "sox"
  ],
  "require": {
    "php": "^8.3",
    "academorix/activity": "@dev",
    "academorix/audit": "@dev",
    "academorix/authorization": "@dev",
    "academorix/console": "@dev",
    "academorix/crud": "@dev",
    "academorix/database": "@dev",
    "academorix/entitlements": "@dev",
    "academorix/enum": "@dev",
    "academorix/events": "@dev",
    "academorix/exceptions": "@dev",
    "academorix/foundation": "@dev",
    "academorix/retention": "@dev",
    "academorix/routing": "@dev",
    "academorix/service-provider": "@dev",
    "academorix/support": "@dev",
    "academorix/tenancy": "@dev",
    "illuminate/bus": "^13.0",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/events": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/queue": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "spatie/laravel-data": "^4.11"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Academorix\\Subscription\\": "src/",
      "Academorix\\Subscription\\Database\\Factories\\": "database/factories/",
      "Academorix\\Subscription\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Academorix\\Subscription\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Academorix\\Subscription\\Providers\\SubscriptionServiceProvider"
      ],
      "aliases": {}
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
