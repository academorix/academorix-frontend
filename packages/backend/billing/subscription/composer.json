{
  "name": "stackra/subscription",
  "type": "library",
  "description": "Tenant subscription lifecycle. Wraps Laravel Cashier for payment-provider-agnostic billing (Stripe + Paddle). Owns Plan (per-Application plan catalogue), Subscription (tenant's active plan with Cashier's Billable trait mixed onto Tenant), and SubscriptionEvent (audit-material lifecycle transitions retained 7 years for SOX). Consumes payment-provider webhooks via Cashier and translates to our own SubscriptionUpgraded/Downgraded/Cancelled events, which the entitlements module consumes to refresh Entitlement rows. Handles trials, grace periods beyond provider default, metered-billing usage export, and enterprise-contract offline billing.",
  "license": "proprietary",
  "keywords": [
    "stackra",
    "laravel",
    "subscription",
    "billing",
    "cashier",
    "stripe",
    "paddle",
    "plans",
    "trial",
    "usage-billing",
    "tenant",
    "sox"
  ],
  "require": {
    "php": "^8.3",
    "stackra/activity": "@dev",
    "stackra/audit": "@dev",
    "stackra/authorization": "@dev",
    "stackra/console": "@dev",
    "stackra/crud": "@dev",
    "stackra/database": "@dev",
    "stackra/entitlements": "@dev",
    "stackra/enum": "@dev",
    "stackra/events": "@dev",
    "stackra/exceptions": "@dev",
    "stackra/foundation": "@dev",
    "stackra/retention": "@dev",
    "stackra/routing": "@dev",
    "stackra/service-provider": "@dev",
    "stackra/support": "@dev",
    "stackra/tenancy": "@dev",
    "illuminate/bus": "^13.0",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/events": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/queue": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "spatie/laravel-data": "^4.11"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Stackra\\Subscription\\": "src/",
      "Stackra\\Subscription\\Database\\Factories\\": "database/factories/",
      "Stackra\\Subscription\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Stackra\\Subscription\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Stackra\\Subscription\\Providers\\SubscriptionServiceProvider"
      ],
      "aliases": {}
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
