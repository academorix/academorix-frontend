{
    "name": "academorix/foundation",
    "type": "library",
    "description": "Shared kernel for every Academorix package: module service-provider base class, cross-cutting contracts, correlation-id middleware, guard clauses, testable clock.",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "academorix/enum": "@dev",
        "academorix/service-provider": "@dev",
        "illuminate/config": "^13.0",
        "illuminate/contracts": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/routing": "^13.0",
        "illuminate/support": "^13.0",
        "olvlvl/composer-attribute-collector": "^2.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Academorix\\Foundation\\": "src/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Academorix\\Foundation\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Academorix\\Foundation\\Providers\\FoundationServiceProvider"
            ],
            "aliases": {}
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "olvlvl/composer-attribute-collector": true,
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
