{
  "name": "stackra/compliance",
  "type": "library",
  "description": "Cross-cutting compliance substrate. Owns eight entities: ConsentCategory (config-backed catalogue), ConsentRecord (immutable subject x category x decision snapshots), Dsar (data-subject-request state machine), DsarArtefact (per-module contribution to a DSAR bundle), LegalHold (freezes retention on a subject or record set), RetentionRun (audit trail of every retention sweep), Subprocessor (versioned VPC registry), SafeguardingIncident (minor-safeguarding report inbox). Ships the HasConsent, IsRetentionAware, HasLegalHold, IsDsarContributor traits and the DsarExportable, DsarErasable, ConsentRequired, RetentionPolicy, LegalHoldable attributes.",
  "license": "proprietary",
  "keywords": [
    "stackra",
    "laravel",
    "compliance",
    "gdpr",
    "ccpa",
    "dsar",
    "consent",
    "retention",
    "legal-hold",
    "subprocessor",
    "safeguarding",
    "breach-notification"
  ],
  "require": {
    "php": "^8.3",
    "stackra/activity": "@dev",
    "stackra/audit": "@dev",
    "stackra/authorization": "@dev",
    "stackra/console": "@dev",
    "stackra/crud": "@dev",
    "stackra/database": "@dev",
    "stackra/entitlements": "@dev",
    "stackra/enum": "@dev",
    "stackra/events": "@dev",
    "stackra/exceptions": "@dev",
    "stackra/foundation": "@dev",
    "stackra/retention": "@dev",
    "stackra/routing": "@dev",
    "stackra/service-provider": "@dev",
    "stackra/support": "@dev",
    "stackra/tenancy": "@dev",
    "illuminate/bus": "^13.0",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/events": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/queue": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "spatie/laravel-data": "^4.11"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Stackra\\Compliance\\": "src/",
      "Stackra\\Compliance\\Database\\Factories\\": "database/factories/",
      "Stackra\\Compliance\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Stackra\\Compliance\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Stackra\\Compliance\\Providers\\ComplianceServiceProvider"
      ],
      "aliases": {}
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "repositories": [
