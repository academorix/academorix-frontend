{
  "name": "stackra/retention",
  "type": "library",
  "description": "Retention scanner — scans classes carrying #[AsRetentionPolicy] and applies delete / archive / anonymize actions on a scheduled cadence.",
  "license": "proprietary",
  "require": {
    "php": "^8.3",
    "stackra/console": "@dev",
    "stackra/foundation": "@dev",
    "stackra/scheduling": "@dev",
    "stackra/service-provider": "@dev",
    "illuminate/console": "^13.0",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/support": "^13.0"
  },
  "autoload": {
    "psr-4": {
      "Stackra\\Retention\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Stackra\\Retention\\Providers\\RetentionServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "repositories": [
    {
      "type": "path",
      "url": "../../framework/console",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../foundation",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/scheduling",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/service-provider",
      "options": {
        "symlink": true
      }
    }
  ]
}
