{
  "name": "stackra/architecture",
  "type": "library",
  "description": "Architectural enforcement for Stackra apps. Prevents direct model access outside Repository, Factory, Seeder, or explicitly-allowed contexts, and (optionally) forbids Controllers from bypassing Services to call Repositories. Ships marker attributes, contracts, a layer resolver, a source-file scanner, a rule engine, and an artisan command.",
  "license": "proprietary",
  "require": {
    "php": "^8.3",
    "stackra/console": "@dev",
    "stackra/foundation": "@dev",
    "stackra/exceptions": "@dev",
    "stackra/service-provider": "@dev",
    "illuminate/contracts": "^13.0",
    "illuminate/console": "^13.0",
    "illuminate/support": "^13.0",
    "symfony/finder": "^7.0"
  },
  "require-dev": {
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Stackra\\Architecture\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Stackra\\Architecture\\Tests\\": "tests/"
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "../../framework/console",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/exceptions",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../foundation",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/service-provider",
      "options": {
        "symlink": true
      }
    }
  ],
  "extra": {
    "laravel": {
      "providers": [
        "Stackra\\Architecture\\Providers\\ArchitectureServiceProvider"
      ],
      "aliases": {}
    },
    "phpstan": {
      "includes": [
        "phpstan-extension.neon"
      ]
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "phpstan/extension-installer": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "test": "Stackra\\Foundation\\Scripts\\TestScripts::run",
    "test:coverage": "Stackra\\Foundation\\Scripts\\TestScripts::coverage",
    "test:parallel": "Stackra\\Foundation\\Scripts\\TestScripts::parallel",
    "test:filter": "Stackra\\Foundation\\Scripts\\TestScripts::filter",
    "analyse": "Stackra\\Foundation\\Scripts\\AnalyseScripts::run",
    "analyse:baseline": "Stackra\\Foundation\\Scripts\\AnalyseScripts::baseline",
    "lint": "Stackra\\Foundation\\Scripts\\LintScripts::check",
    "lint:fix": "Stackra\\Foundation\\Scripts\\LintScripts::fix",
    "doppler:status": "Stackra\\Foundation\\Scripts\\DopplerScripts::status",
    "doppler:setup": "Stackra\\Foundation\\Scripts\\DopplerScripts::setup"
  }
}
