{
  "name": "academorix/architecture",
  "type": "library",
  "description": "Architectural enforcement for Academorix apps. Prevents direct model access outside Repository, Factory, Seeder, or explicitly-allowed contexts, and (optionally) forbids Controllers from bypassing Services to call Repositories. Ships marker attributes, contracts, a layer resolver, a source-file scanner, a rule engine, and an artisan command.",
  "license": "proprietary",
  "require": {
    "php": "^8.3",
    "academorix/console": "@dev",
    "academorix/foundation": "@dev",
    "academorix/exceptions": "@dev",
    "academorix/service-provider": "@dev",
    "illuminate/contracts": "^13.0",
    "illuminate/console": "^13.0",
    "illuminate/support": "^13.0",
    "symfony/finder": "^7.0"
  },
  "require-dev": {
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Academorix\\Architecture\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Academorix\\Architecture\\Tests\\": "tests/"
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "../../framework/console",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/exceptions",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../foundation",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/service-provider",
      "options": {
        "symlink": true
      }
    }
  ],
  "extra": {
    "laravel": {
      "providers": [
        "Academorix\\Architecture\\Providers\\ArchitectureServiceProvider"
      ],
      "aliases": {}
    },
    "phpstan": {
      "includes": [
        "phpstan-extension.neon"
      ]
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "phpstan/extension-installer": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
