{
  "name": "stackra/serializer",
  "description": "Data serialization and transformation utilities",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "serializer",
    "transformation",
    "data",
    "laravel",
    "stackra"
  ],
  "authors": [
    {
      "name": "Stackra Team",
      "email": "dev@stackra.com"
    }
  ],
  "require": {
    "php": "^8.4|^8.5",
    "league/fractal": "*"
  },
  "autoload": {
    "psr-4": {
      "Stackra\\Serializer\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "aliases": {
        "Serializer": "Stackra\\Serializer\\Facades\\Serializer"
      }
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^10.0"
  },
  "homepage": "https://github.com/stackra-inc/laravel-framework/serializer",
  "support": {
    "issues": "https://github.com/stackra-inc/laravel-framework/serializer/-/issues",
    "source": "https://github.com/stackra-inc/laravel-framework/serializer"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {}
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "test": "Stackra\\Foundation\\Scripts\\TestScripts::run",
    "test:coverage": "Stackra\\Foundation\\Scripts\\TestScripts::coverage",
    "test:parallel": "Stackra\\Foundation\\Scripts\\TestScripts::parallel",
    "test:filter": "Stackra\\Foundation\\Scripts\\TestScripts::filter",
    "analyse": "Stackra\\Foundation\\Scripts\\AnalyseScripts::run",
    "analyse:baseline": "Stackra\\Foundation\\Scripts\\AnalyseScripts::baseline",
    "lint": "Stackra\\Foundation\\Scripts\\LintScripts::check",
    "lint:fix": "Stackra\\Foundation\\Scripts\\LintScripts::fix",
    "doppler:status": "Stackra\\Foundation\\Scripts\\DopplerScripts::status",
    "doppler:setup": "Stackra\\Foundation\\Scripts\\DopplerScripts::setup"
  }
}
