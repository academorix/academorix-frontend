{
  "name": "academorix/scope",
  "description": "Dynamic hierarchical scope platform. Per-tenant configurable hierarchy (definitions), materialised-path node graph, namespaced cascading value store, request-context propagation, resolver chain, Eloquent auto-scoping, and cache-tag derivation. Every settings/permissions/flags/pricing consumer registers a namespace and gets uniform resolution semantics.",
  "type": "library",
  "keywords": [
    "academorix",
    "laravel",
    "scope",
    "hierarchy",
    "multitenancy",
    "cascading-resolution",
    "materialised-path"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Academorix Team",
      "email": "dev@academorix.com",
      "homepage": "https://academorix.com"
    }
  ],
  "require": {
    "php": "^8.3|^8.4|^8.5",
    "academorix/caching": "@dev",
    "academorix/database": "@dev",
    "academorix/exceptions": "@dev",
    "academorix/foundation": "@dev",
    "academorix/service-provider": "@dev",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "olvlvl/composer-attribute-collector": "^2.0"
  },
  "require-dev": {
    "laravel/pint": "^1.0",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Academorix\\Scope\\": "src/",
      "Academorix\\Scope\\Database\\Factories\\": "database/factories/",
      "Academorix\\Scope\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Academorix\\Scope\\Tests\\": "tests/"
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "../../*",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../*",
      "options": {
        "symlink": true
      }
    }
  ],
  "extra": {
    "laravel": {
      "providers": [
        "Academorix\\Scope\\Providers\\ScopeServiceProvider"
      ],
      "aliases": {
        "Scope": "Academorix\\Scope\\Facades\\Scope"
      }
    },
    "branch-alias": {
      "dev-main": "0.1.x-dev"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "olvlvl/composer-attribute-collector": true,
      "pestphp/pest-plugin": true
    }
  }
}
