{
  "name": "stackra/scope",
  "description": "Dynamic hierarchical scope platform. Per-tenant configurable hierarchy (definitions), materialised-path node graph, namespaced cascading value store, request-context propagation, resolver chain, Eloquent auto-scoping, and cache-tag derivation. Every settings/permissions/flags/pricing consumer registers a namespace and gets uniform resolution semantics.",
  "type": "library",
  "keywords": [
    "stackra",
    "laravel",
    "scope",
    "hierarchy",
    "multitenancy",
    "cascading-resolution",
    "materialised-path"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Stackra Team",
      "email": "dev@stackra.com",
      "homepage": "https://stackra.com"
    }
  ],
  "require": {
    "php": "^8.3|^8.4|^8.5",
    "stackra/caching": "@dev",
    "stackra/database": "@dev",
    "stackra/exceptions": "@dev",
    "stackra/foundation": "@dev",
    "stackra/service-provider": "@dev",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "olvlvl/composer-attribute-collector": "^2.0"
  },
  "require-dev": {
    "laravel/pint": "^1.0",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Stackra\\Scope\\": "src/",
      "Stackra\\Scope\\Database\\Factories\\": "database/factories/",
      "Stackra\\Scope\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Stackra\\Scope\\Tests\\": "tests/"
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "../caching",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../database",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../exceptions",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../foundation",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../service-provider",
      "options": {
        "symlink": true
      }
    }
  ],
  "extra": {
    "laravel": {
      "providers": [
        "Stackra\\Scope\\Providers\\ScopeServiceProvider"
      ],
      "aliases": {
        "Scope": "Stackra\\Scope\\Facades\\Scope"
      }
    },
    "branch-alias": {
      "dev-main": "0.1.x-dev"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "olvlvl/composer-attribute-collector": true,
      "pestphp/pest-plugin": true
    }
  },
  "scripts": {
    "test": "Stackra\\Foundation\\Scripts\\TestScripts::run",
    "test:coverage": "Stackra\\Foundation\\Scripts\\TestScripts::coverage",
    "test:parallel": "Stackra\\Foundation\\Scripts\\TestScripts::parallel",
    "test:filter": "Stackra\\Foundation\\Scripts\\TestScripts::filter",
    "analyse": "Stackra\\Foundation\\Scripts\\AnalyseScripts::run",
    "analyse:baseline": "Stackra\\Foundation\\Scripts\\AnalyseScripts::baseline",
    "lint": "Stackra\\Foundation\\Scripts\\LintScripts::check",
    "lint:fix": "Stackra\\Foundation\\Scripts\\LintScripts::fix",
    "doppler:status": "Stackra\\Foundation\\Scripts\\DopplerScripts::status",
    "doppler:setup": "Stackra\\Foundation\\Scripts\\DopplerScripts::setup"
  }
}
