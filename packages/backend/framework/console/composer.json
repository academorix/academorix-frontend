{
  "name": "academorix/console",
  "description": "Console framework — extended AsCommand attribute (with extension-registry support) plus a BaseCommand class that wires OmniTerm output, AOP before/after hooks, duration tracking, and per-command extension discovery. Every Academorix Artisan command extends this BaseCommand.",
  "type": "library",
  "keywords": [
    "academorix",
    "laravel",
    "console",
    "artisan",
    "commands",
    "attributes"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Academorix Team",
      "email": "dev@academorix.com",
      "homepage": "https://academorix.com"
    }
  ],
  "require": {
    "php": "^8.3|^8.4|^8.5",
    "academorix/laravel-omniterm": "@dev",
    "illuminate/console": "^13.0",
    "illuminate/contracts": "^13.0",
    "illuminate/support": "^13.0",
    "symfony/console": "^7.0"
  },
  "require-dev": {
    "laravel/pint": "^1.0",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^12.0|^13.0",
    "rector/rector": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Academorix\\Console\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Academorix\\Console\\Tests\\": "tests/"
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "../omniterm",
      "options": {
        "symlink": true
      }
    }
  ],
  "extra": {
    "branch-alias": {
      "dev-main": "0.1.x-dev"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  }
}
