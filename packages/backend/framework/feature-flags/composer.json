{
  "name": "stackra/feature-flags",
  "description": "Production-grade multi-tenant feature-flag layer on top of Laravel Pennant. Ships the KillSwitch -> Override -> Rollout -> PlanGate -> class-default resolution chain, one contract (FeatureCheckerInterface), one facade (Feature::), attribute-driven flag discovery, route gating, AI tool visibility gating, boot-payload contribution, an actions-only admin surface, and a Saloon SDK sibling.",
  "type": "library",
  "keywords": [
    "stackra",
    "laravel",
    "feature-flags",
    "pennant",
    "kill-switch",
    "rollout",
    "override",
    "plan-gate",
    "multitenancy",
    "attributes"
  ],
  "license": "proprietary",
  "authors": [
    {
      "name": "Stackra Team",
      "email": "dev@stackra.com",
      "homepage": "https://stackra.com"
    }
  ],
  "require": {
    "php": "^8.3|^8.4|^8.5",
    "stackra/authorization": "@dev",
    "stackra/caching": "@dev",
    "stackra/crud": "@dev",
    "stackra/database": "@dev",
    "stackra/enum": "@dev",
    "stackra/exceptions": "@dev",
    "stackra/foundation": "@dev",
    "stackra/routing": "@dev",
    "stackra/scope": "@dev",
    "stackra/service-provider": "@dev",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "laravel/pennant": "^1.18",
    "olvlvl/composer-attribute-collector": "^2.0",
    "owen-it/laravel-auditing": "^13.0|^14.0",
    "spatie/laravel-data": "^4.11"
  },
  "require-dev": {
    "laravel/pint": "^1.0",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Stackra\\FeatureFlags\\": "src/",
      "Stackra\\FeatureFlags\\Database\\Factories\\": "database/factories/",
      "Stackra\\FeatureFlags\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Stackra\\FeatureFlags\\Tests\\": "tests/"
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "../../authorization",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../caching",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../crud",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../database",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../enum",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../exceptions",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../foundation",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../routing",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../scope",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../service-provider",
      "options": {
        "symlink": true
      }
    }
  ],
  "extra": {
    "laravel": {
      "providers": [
        "Stackra\\FeatureFlags\\Providers\\FeatureFlagsServiceProvider"
      ],
      "aliases": {
        "Feature": "Stackra\\FeatureFlags\\Facades\\Feature"
      }
    },
    "composer-attribute-collector": {
      "include": [
        "src"
      ]
    },
    "branch-alias": {
      "dev-main": "0.1.x-dev"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "olvlvl/composer-attribute-collector": true,
      "pestphp/pest-plugin": true
    }
  },
  "scripts": {
    "test": "Stackra\\Foundation\\Scripts\\TestScripts::run",
    "test:coverage": "Stackra\\Foundation\\Scripts\\TestScripts::coverage",
    "test:parallel": "Stackra\\Foundation\\Scripts\\TestScripts::parallel",
    "test:filter": "Stackra\\Foundation\\Scripts\\TestScripts::filter",
    "analyse": "Stackra\\Foundation\\Scripts\\AnalyseScripts::run",
    "analyse:baseline": "Stackra\\Foundation\\Scripts\\AnalyseScripts::baseline",
    "lint": "Stackra\\Foundation\\Scripts\\LintScripts::check",
    "lint:fix": "Stackra\\Foundation\\Scripts\\LintScripts::fix",
    "doppler:status": "Stackra\\Foundation\\Scripts\\DopplerScripts::status",
    "doppler:setup": "Stackra\\Foundation\\Scripts\\DopplerScripts::setup"
  }
}
