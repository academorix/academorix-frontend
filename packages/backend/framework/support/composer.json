{
  "name": "academorix/support",
  "description": "Support utilities and helpers for Academorix packages: Reflection, Str, Arr, Path, CaseConverter, EmailValidator, Password. Zero-Laravel-runtime dependency where possible; ships tiny helper facades for common formatting + validation tasks.",
  "type": "library",
  "license": "proprietary",
  "keywords": [
    "support",
    "helpers",
    "utilities",
    "laravel",
    "academorix"
  ],
  "authors": [
    {
      "name": "Academorix Team",
      "email": "dev@academorix.com"
    }
  ],
  "require": {
    "php": "^8.4|^8.5"
  },
  "autoload": {
    "psr-4": {
      "Academorix\\Support\\": "src/"
    },
    "files": [
      "src/Helpers/Support.php",
      "src/Helpers/Polyfills.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Academorix\\Support\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "preferred-install": "dist",
    "optimize-autoloader": true,
    "allow-plugins": {}
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^10.0"
  },
  "homepage": "https://github.com/academorix-inc/laravel-framework/support",
  "support": {
    "issues": "https://github.com/academorix-inc/laravel-framework/support/-/issues",
    "source": "https://github.com/academorix-inc/laravel-framework/support"
  }
}
