{
  "name": "stackra/support",
  "description": "Support utilities and helpers for Stackra packages: Reflection, Str, Arr, Path, CaseConverter, EmailValidator, Password. Zero-Laravel-runtime dependency where possible; ships tiny helper facades for common formatting + validation tasks.",
  "type": "library",
  "license": "proprietary",
  "keywords": [
    "support",
    "helpers",
    "utilities",
    "laravel",
    "stackra"
  ],
  "authors": [
    {
      "name": "Stackra Team",
      "email": "dev@stackra.com"
    }
  ],
  "require": {
    "php": "^8.4|^8.5"
  },
  "autoload": {
    "psr-4": {
      "Stackra\\Support\\": "src/"
    },
    "files": [
      "src/Helpers/Support.php",
      "src/Helpers/Polyfills.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Stackra\\Support\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "preferred-install": "dist",
    "optimize-autoloader": true,
    "allow-plugins": {}
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^10.0"
  },
  "homepage": "https://github.com/stackra-inc/laravel-framework/support",
  "support": {
    "issues": "https://github.com/stackra-inc/laravel-framework/support/-/issues",
    "source": "https://github.com/stackra-inc/laravel-framework/support"
  },
  "scripts": {
    "test": "Stackra\\Foundation\\Scripts\\TestScripts::run",
    "test:coverage": "Stackra\\Foundation\\Scripts\\TestScripts::coverage",
    "test:parallel": "Stackra\\Foundation\\Scripts\\TestScripts::parallel",
    "test:filter": "Stackra\\Foundation\\Scripts\\TestScripts::filter",
    "analyse": "Stackra\\Foundation\\Scripts\\AnalyseScripts::run",
    "analyse:baseline": "Stackra\\Foundation\\Scripts\\AnalyseScripts::baseline",
    "lint": "Stackra\\Foundation\\Scripts\\LintScripts::check",
    "lint:fix": "Stackra\\Foundation\\Scripts\\LintScripts::fix",
    "doppler:status": "Stackra\\Foundation\\Scripts\\DopplerScripts::status",
    "doppler:setup": "Stackra\\Foundation\\Scripts\\DopplerScripts::setup"
  }
}
