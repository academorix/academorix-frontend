{
  "name": "stackra/container",
  "description": "Dependency injection container utilities and extensions",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "container",
    "dependency-injection",
    "ioc",
    "laravel",
    "stackra"
  ],
  "authors": [
    {
      "name": "Stackra Team",
      "email": "dev@stackra.com"
    }
  ],
  "require": {
    "php": "^8.4|^8.5",
    "illuminate/container": "^13.0|^12.0"
  },
  "autoload": {
    "psr-4": {
      "Stackra\\Container\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Stackra\\Container\\Providers\\ContainerServiceProvider"
      ]
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^10.0"
  },
  "homepage": "https://github.com/stackra/stackra-backend/tree/main/backend-packages/framework/container",
  "support": {
    "issues": "https://github.com/stackra/stackra-backend/issues",
    "source": "https://github.com/stackra/stackra-backend/tree/main/backend-packages/framework/container"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {}
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
