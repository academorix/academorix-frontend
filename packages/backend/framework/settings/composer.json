{
  "name": "stackra/settings",
  "type": "library",
  "description": "Attribute-driven settings platform for Stackra. Ships #[AsSetting] + #[SettingField] + #[SettingGroup] discovery, the SettingsRegistry + SettingsService, the settings_audit_log, and a set of non-theme system setting classes (Auth, Mail, Notifications, Preferences, Storage, ...). Theme-specific concerns live in the sibling stackra/theme package.",
  "license": "proprietary",
  "keywords": [
    "stackra",
    "settings",
    "configuration",
    "attribute-driven",
    "spatie-settings",
    "laravel"
  ],
  "require": {
    "php": "^8.4|^8.5",
    "stackra/activity": "@dev",
    "stackra/audit": "@dev",
    "stackra/crud": "@dev",
    "stackra/enum": "@dev",
    "stackra/events": "@dev",
    "stackra/foundation": "@dev",
    "stackra/routing": "@dev",
    "stackra/scope": "@dev",
    "stackra/service-provider": "@dev",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/support": "^13.0",
    "owen-it/laravel-auditing": "^13.0",
    "spatie/laravel-activitylog": "^4.10",
    "spatie/laravel-data": "^4.0",
    "spatie/laravel-settings": "^3.0"
  },
  "require-dev": {
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Stackra\\Settings\\": "src/",
      "Stackra\\Settings\\Database\\Factories\\": "database/factories/",
      "Stackra\\Settings\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Stackra\\Settings\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Stackra\\Settings\\Providers\\SettingsServiceProvider"
      ],
      "aliases": {}
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "olvlvl/composer-attribute-collector": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "repositories": [
    {
      "type": "path",
      "url": "../../shared/activity",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../shared/audit",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../crud",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../enum",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../events",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../foundation",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../routing",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../scope",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../service-provider",
      "options": {
        "symlink": true
      }
    }
  ]
}
