{
  "name": "academorix/laravel-omniterm",
  "description": "Full-fledged terminal UI toolkit — live rendering, async tasks, spinners, browser navigation, and rich HTML-to-ANSI output for Laravel Artisan commands.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "academorix",
    "terminal",
    "console",
    "cli",
    "omniterm",
    "live-rendering",
    "async",
    "spinner"
  ],
  "authors": [
    {
      "name": "Academorix Team",
      "email": "dev@academorix.com"
    }
  ],
  "require": {
    "php": "^8.4|^8.5",
    "ext-dom": "*",
    "ext-libxml": "*",
    "illuminate/contracts": "^13.0",
    "illuminate/support": "^13.0",
    "laravel/prompts": "^0.3",
    "symfony/console": "^7.0|^8.0"
  },
  "require-dev": {
    "laravel/pint": "^1.0",
    "phpunit/phpunit": "^12.0"
  },
  "autoload": {
    "psr-4": {
      "Academorix\\OmniTerm\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Academorix\\OmniTerm\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Academorix\\OmniTerm\\Providers\\OmniTermServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "olvlvl/composer-attribute-collector": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
