{
  "$version": 1,
  "title": "Base permission catalogue (RBAC-owned + framework-tier)",
  "description": "The seed permission catalogue this module ships. Domain modules (invoices, athletes, teams, sessions, ...) SHIP THEIR OWN `permissions.json` blueprints declaring permissions specific to them. `PermissionCatalogueLoader` aggregates every #[ProvidesPermissions]-decorated provider's contribution at boot + UPSERTs into the `permissions` table. This file is only the RBAC module's OWN surface (permissions ABOUT roles + permissions + principals + platform).",
  "conventions": {
    "naming": "dot-notated: `<resource>.<action>.<scope>`. Scope suffix is one of `.own` / `.tenant` / `.branch` / `.team` / `.child` / `.any` / `.organization` / `.region` per config('rbac.permissions.allowed_suffixes'). Enforced by valid_permission_name.",
    "guard": "'sanctum' for tenant plane; 'platform_admin' for platform plane. NEVER mixed.",
    "application_id": "nullable. NULL = cross-Application (framework-tier permissions). Non-null = per-Application permission (usually issued by a per-Application module).",
    "tenant_id": "always NULL for the seeded catalogue \u2014 catalogue permissions are system rows. Tenants can create CUSTOM permissions (Enterprise only) which carry tenant_id."
  },
