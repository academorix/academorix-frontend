{
  "name": "stackra/invitations",
  "type": "library",
  "description": "Agnostic invitation substrate for Stackra. Owns the `Invitation` aggregate (token-based invitations with target/inviter polymorphism, expiry, resend, bounce tracking, and a full state machine) and the `InvitationEvent` aggregate (append-only funnel audit log). Consumer modules register their `target_type` string via the `InvitationTargetRegistry` at boot; the invitations module handles delivery, bounce tracking, expiry, rate limits, and acceptance orchestration. Not coupled to any specific target or credential provider.",
  "license": "proprietary",
  "keywords": [
    "stackra",
    "laravel",
    "invitations",
    "invite",
    "onboarding",
    "acceptance",
    "polymorphic",
    "audit-funnel",
    "bounce-tracking",
    "multi-channel"
  ],
  "require": {
    "php": "^8.3",
    "stackra/authorization": "@dev",
    "stackra/console": "@dev",
    "stackra/crud": "@dev",
    "stackra/database": "@dev",
    "stackra/enum": "@dev",
    "stackra/events": "@dev",
    "stackra/exceptions": "@dev",
    "stackra/foundation": "@dev",
    "stackra/retention": "@dev",
    "stackra/routing": "@dev",
    "stackra/serializer": "@dev",
    "stackra/service-provider": "@dev",
    "stackra/support": "@dev",
    "stackra/tenancy": "@dev",
    "illuminate/bus": "^13.0",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/events": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/notifications": "^13.0",
    "illuminate/queue": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "spatie/laravel-data": "^4.11"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Stackra\\Invitations\\": "src/",
      "Stackra\\Invitations\\Database\\Factories\\": "database/factories/",
      "Stackra\\Invitations\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Stackra\\Invitations\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Stackra\\Invitations\\Providers\\InvitationsServiceProvider"
      ],
      "aliases": {}
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "repositories": [
    {
      "type": "path",
      "url": "../../authorization",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/console",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/crud",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/database",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/enum",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/events",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/exceptions",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../foundation",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../compliance/retention",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/routing",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
