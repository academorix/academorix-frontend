{
  "name": "stackra-observability/activity",
  "type": "library",
  "description": "Stackra Activity module — server-side Laravel package emitted from the module blueprint at `modules/observability/blueprints/activity/`. Tier-scoped composer name (`stackra-observability/activity`) to disambiguate from the hand-tuned `stackra/activity` under `backend-packages/shared/activity/` which owns the vendor `spatie/laravel-activitylog` wrapper + retention. This module owns the storage schema adaptation (tenant_id + application_id columns) + query surface + retention scheduling on top of it. Complements the wire SDK at `stackra-observability/activity-sdk`.",
  "license": "proprietary",
  "keywords": [
    "stackra",
    "module",
    "laravel",
    "observability",
    "activity"
  ],
  "require": {
    "php": "^8.3",
    "illuminate/support": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/container": "^13.0",
    "illuminate/contracts": "^13.0",
    "spatie/laravel-data": "^4.11",
    "stackra/foundation": "@dev",
    "stackra/crud": "@dev",
    "stackra/routing": "@dev",
    "stackra/service-provider": "@dev",
    "stackra/support": "@dev",
    "stackra-observability/activity-sdk": "@dev"
  },
  "require-dev": {
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0",
    "mockery/mockery": "^1.6"
  },
  "autoload": {
    "psr-4": {
      "Stackra\\Activity\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Stackra\\Activity\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Stackra\\Activity\\Providers\\ActivityServiceProvider"
      ],
      "aliases": {}
    }
  },
  "scripts": {
    "test": "./vendor/bin/pest",
    "test:coverage": "./vendor/bin/pest --coverage --min=80",
    "lint": "./vendor/bin/pint --test",
    "format": "./vendor/bin/pint",
    "analyse": "./vendor/bin/phpstan analyse --memory-limit=2G"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "olvlvl/composer-attribute-collector": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "repositories": [
    {
      "type": "path",
      "url": "../../framework/crud",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../foundation",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/routing",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/service-provider",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/support",
      "options": {
        "symlink": true
      }
    }
  ]
}
