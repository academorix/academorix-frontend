{
  "id": "activity.resources.activity.show",
  "title": "Activity detail",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/activities/{activity}",
  "host": "tenant",
  "audience": "authenticated",
  "resource": {
    "module": "activity",
    "entity": "activity",
    "action": "show"
  },
  "requiresPermission": "activity.viewAny",
  "dataSources": [
    {
      "name": "activity",
      "kind": "http.get",
      "urlTemplate": "/api/v1/activities/{activity}?include=subject,causer,batchSiblings",
      "params": ["activity"],
      "unwrap": "data",
      "cache": { "ttlSeconds": 60 }
    },
    {
      "name": "logNameCatalog",
      "kind": "http.get",
      "url": "/api/v1/activity/log-names",
      "unwrap": "data",
      "cache": { "ttlSeconds": 3600 }
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-6 p-6 max-w-4xl mx-auto" },
      "children": [
        {
          "id": "breadcrumbs",
          "kind": "Breadcrumbs",
          "props": {
            "items": [
              { "label": "Activity feed", "route": "/tenant/activities" },
              { "label": "Detail" }
            ]
          }
        },
        {
          "id": "header-card",
          "kind": "Card",
          "children": [
            {
              "kind": "CardHeader",
              "children": [
                {
                  "kind": "View",
                  "props": { "className": "flex items-start justify-between gap-4" },
                  "children": [
                    {
                      "kind": "View",
                      "props": { "className": "flex flex-col gap-1" },
                      "children": [
                        {
                          "kind": "Text",
                          "props": { "as": "h1", "className": "text-xl font-semibold" },
                          "bindings": {
                            "children": { "$ref": "activity.description" }
                          }
                        },
                        {
                          "kind": "Text",
                          "props": { "as": "p", "className": "text-muted text-sm" },
                          "bindings": {
                            "children": {
                              "$expr": "formatDateTime(activity.created_at) + ' • ' + activity.log_name"
                            }
                          }
                        }
                      ]
                    },
                    {
                      "kind": "Chip",
                      "props": { "variant": "neutral", "size": "sm" },
                      "bindings": {
                        "children": { "$ref": "activity.event" }
                      }
                    }
                  ]
                }
              ]
            },
            {
              "kind": "CardBody",
              "children": [
                {
                  "kind": "DescriptionList",
                  "children": [
                    {
                      "kind": "DescriptionListItem",
                      "props": { "label": "Feed" },
                      "children": [
                        {
                          "kind": "Text",
                          "bindings": {
                            "children": {
                              "$expr": "logNameCatalog.find(x => x.name === activity.log_name)?.display_label || activity.log_name"
                            }
                          }
                        }
                      ]
                    },
                    {
                      "kind": "DescriptionListItem",
                      "props": { "label": "Actor" },
                      "children": [
                        {
                          "kind": "View",
                          "props": { "className": "flex items-center gap-2" },
                          "children": [
                            {
                              "kind": "Avatar",
                              "props": { "size": "sm" },
                              "bindings": {
                                "src": { "$ref": "activity.causer.avatar_url" },
                                "label": { "$ref": "activity.causer.display_name" }
                              }
                            },
                            {
                              "kind": "Link",
                              "bindings": {
                                "children": {
                                  "$expr": "activity.causer?.display_name || 'System'"
                                },
                                "toExpr": "activity.causer_type === 'user' ? '/tenant/users/' + activity.causer_id : null"
                              }
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "kind": "DescriptionListItem",
                      "props": { "label": "Subject" },
                      "bindings": {
                        "hidden": { "$expr": "!activity.subject" }
                      },
                      "children": [
                        {
                          "kind": "Link",
                          "bindings": {
                            "children": {
                              "$expr": "activity.subject?.display_label || activity.subject_id"
                            },
                            "toExpr": "'/tenant/' + activity.subject_type + 's/' + activity.subject_id"
                          }
                        }
                      ]
                    },
                    {
                      "kind": "DescriptionListItem",
                      "props": { "label": "Application" },
                      "bindings": {
                        "hidden": { "$expr": "!activity.application_id" }
                      },
                      "children": [
                        {
                          "kind": "Chip",
                          "props": { "variant": "neutral", "size": "xs" },
                          "bindings": {
                            "children": { "$ref": "activity.application_id" }
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "id": "properties-card",
          "kind": "Card",
          "bindings": {
            "hidden": {
              "$expr": "!activity.properties || Object.keys(activity.properties).length === 0"
            }
          },
          "children": [
            {
              "kind": "CardHeader",
              "props": {
                "title": "Details",
                "description": "Structured context captured at the time of the activity."
              }
            },
            {
              "kind": "CardBody",
              "children": [
                {
                  "kind": "KeyValueList",
                  "bindings": {
                    "items": {
                      "$expr": "Object.entries(activity.properties || {}).map(([key, value]) => ({ key, value: typeof value === 'object' ? JSON.stringify(value) : String(value) }))"
                    }
                  }
                }
              ]
            }
          ]
        },
        {
          "id": "batch-siblings",
          "kind": "Card",
          "bindings": {
            "hidden": {
              "$expr": "!activity.batch_uuid || !activity.batchSiblings || activity.batchSiblings.length === 0"
            }
          },
          "children": [
            {
              "kind": "CardHeader",
              "props": {
                "title": "In the same batch",
                "description": "Other activities recorded during the same request."
              }
            },
            {
              "kind": "CardBody",
              "children": [
                {
                  "kind": "Widget",
                  "widget": "activity.timeline",
                  "bindings": {
                    "items": { "$ref": "activity.batchSiblings" }
                  },
                  "props": {
                    "groupBy": "none",
                    "collapseBatches": false,
                    "compact": true
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
