{
  "id": "monitoring.resources.health-check.edit",
  "title": "Edit health check",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/monitoring/health-checks/{check}/edit",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "monitoring", "entity": "health-check", "action": "edit" },
  "requiresPermission": "monitoring.health_checks.update",
  "requiresEntitlement": "monitoring_capture",
  "dataSources": [
    {
      "name": "check",
      "kind": "http.get",
      "url": "/api/v1/monitoring/health-checks/{check}",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "Form",
      "props": { "className": "max-w-3xl mx-auto p-6 flex flex-col gap-4" },
      "children": [
        {
          "kind": "Text",
          "props": {
            "as": "h1",
            "className": "text-2xl font-semibold",
            "children": "Edit health check"
          }
        },
        {
          "kind": "Input",
          "props": { "label": "Display name" },
          "bindings": { "defaultValue": { "$ref": "check.name" } },
          "actions": {
            "onChange": { "kind": "form.set", "field": "name", "valueExpr": "$value" }
          }
        },
        {
          "kind": "Alert",
          "props": {
            "variant": "info",
            "title": "Check type is immutable",
            "description": "To change check_type, delete this check + create a new one."
          }
        },
        {
          "kind": "Switch",
          "props": { "label": "Enabled" },
          "bindings": { "defaultValue": { "$ref": "check.is_enabled" } },
          "actions": {
            "onChange": { "kind": "form.set", "field": "is_enabled", "valueExpr": "$value" }
          }
        },
        {
          "kind": "Slider",
          "props": { "label": "Interval (seconds)", "min": 15, "max": 3600, "step": 15 },
          "bindings": { "defaultValue": { "$ref": "check.interval_seconds" } },
          "actions": {
            "onChange": { "kind": "form.set", "field": "interval_seconds", "valueExpr": "$value" }
          }
        },
        {
          "kind": "Slider",
          "props": { "label": "Timeout (seconds)", "min": 1, "max": 300, "step": 1 },
          "bindings": { "defaultValue": { "$ref": "check.timeout_seconds" } },
          "actions": {
            "onChange": { "kind": "form.set", "field": "timeout_seconds", "valueExpr": "$value" }
          }
        },
        {
          "kind": "Button",
          "props": { "variant": "primary", "children": "Save" },
          "actions": {
            "onPress": {
              "kind": "http.patch",
              "url": "/api/v1/monitoring/health-checks/{check}",
              "body": "{{form}}",
              "onSuccess": {
                "kind": "navigate",
                "toExpr": "'/tenant/monitoring/health-checks/' + $routeParams.check"
              }
            }
          }
        }
      ]
    }
  ]
}
