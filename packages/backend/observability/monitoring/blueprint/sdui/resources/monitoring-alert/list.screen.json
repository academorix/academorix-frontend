{
  "id": "monitoring.resources.monitoring-alert.list",
  "title": "Monitoring alerts",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/monitoring/alerts",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "monitoring", "entity": "monitoring-alert", "action": "list" },
  "requiresPermission": "monitoring.alerts.viewAny",
  "requiresEntitlement": "monitoring_capture",
  "dataSources": [
    {
      "name": "alerts",
      "kind": "http.get",
      "url": "/api/v1/monitoring/alerts?filter[status]=firing",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-7xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "children": [
            {
              "kind": "Text",
              "props": {
                "as": "h1",
                "className": "text-2xl font-semibold",
                "children": "Monitoring alerts"
              }
            },
            {
              "kind": "Text",
              "props": {
                "className": "text-sm text-muted",
                "children": "Fired alerts requiring ops attention."
              }
            }
          ]
        },
        {
          "kind": "FilterBar",
          "props": {
            "filters": [
              {
                "field": "status",
                "label": "Status",
                "kind": "select",
                "options": ["firing", "acknowledged", "resolved", "suppressed", "expired"]
              },
              {
                "field": "severity",
                "label": "Severity",
                "kind": "select",
                "options": ["p1", "p2", "p3", "p4"]
              },
              { "field": "from", "label": "From", "kind": "date" },
              { "field": "to", "label": "To", "kind": "date" }
            ]
          }
        },
        {
          "kind": "DataGrid",
          "bindings": { "items": { "$ref": "alerts" } },
          "props": {
            "columns": [
              {
                "field": "severity",
                "header": "Severity",
                "cellRenderer": {
                  "kind": "Widget",
                  "widget": "monitoring.severity-chip",
                  "bindings": { "severity": { "$ref": "row.severity" } }
                }
              },
              { "field": "fired_at", "header": "Fired at", "sortable": true },
              { "field": "signal_type", "header": "Signal" },
              { "field": "signal_value", "header": "Value" },
              {
                "field": "status",
                "header": "Status",
                "cellRenderer": {
                  "kind": "Widget",
                  "widget": "monitoring.status-badge",
                  "bindings": { "status": { "$ref": "row.status" } }
                }
              },
              {
                "field": "actions",
                "header": "Actions",
                "cellRenderer": {
                  "kind": "View",
                  "props": { "className": "flex gap-2" },
                  "children": [
                    {
                      "kind": "Button",
                      "props": { "variant": "secondary", "size": "sm", "children": "Acknowledge" },
                      "bindings": { "hidden": { "$expr": "row.status !== 'firing'" } },
                      "actions": {
                        "onPress": {
                          "kind": "navigate",
                          "toExpr": "'/tenant/monitoring/alerts/' + row.id + '/acknowledge'"
                        }
                      }
                    },
                    {
                      "kind": "Button",
                      "props": { "variant": "primary", "size": "sm", "children": "Resolve" },
                      "bindings": {
                        "hidden": {
                          "$expr": "row.status === 'resolved' || row.status === 'expired' || row.status === 'suppressed'"
                        }
                      },
                      "actions": {
                        "onPress": {
                          "kind": "http.post",
                          "url": "'/api/v1/monitoring/alerts/' + row.id + '/resolve'",
                          "body": { "note": "Resolved via SDUI" }
                        }
                      }
                    }
                  ]
                }
              }
            ]
          }
        }
      ]
    }
  ]
}
