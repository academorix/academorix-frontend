{
  "id": "monitoring.resources.monitoring-alert.acknowledge",
  "title": "Acknowledge alert",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/monitoring/alerts/{alert}/acknowledge",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "monitoring", "entity": "monitoring-alert", "action": "acknowledge" },
  "requiresPermission": "monitoring.alerts.acknowledge",
  "requiresEntitlement": "monitoring_capture",
  "dataSources": [
    {
      "name": "alert",
      "kind": "http.get",
      "url": "/api/v1/monitoring/alerts/{alert}",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "Form",
      "props": { "className": "max-w-2xl mx-auto p-6 flex flex-col gap-4" },
      "children": [
        {
          "kind": "Text",
          "props": {
            "as": "h1",
            "className": "text-2xl font-semibold",
            "children": "Acknowledge alert"
          }
        },
        {
          "kind": "Card",
          "props": { "className": "p-4" },
          "children": [
            {
              "kind": "View",
              "props": { "className": "flex items-center gap-3 mb-2" },
              "children": [
                {
                  "kind": "Widget",
                  "widget": "monitoring.severity-chip",
                  "bindings": { "severity": { "$ref": "alert.severity" } }
                },
                {
                  "kind": "Text",
                  "props": { "className": "font-medium" },
                  "bindings": { "children": { "$ref": "alert.signal_type" } }
                }
              ]
            },
            {
              "kind": "Text",
              "props": { "className": "text-sm text-muted" },
              "bindings": { "children": { "$expr": "'Fired at ' + alert.fired_at" } }
            },
            {
              "kind": "Text",
              "props": { "className": "text-sm mt-2" },
              "bindings": { "children": { "$expr": "'Signal value: ' + alert.signal_value" } }
            }
          ]
        },
        {
          "kind": "TextArea",
          "props": {
            "label": "Acknowledgment note (optional)",
            "placeholder": "I'm investigating. ETA on resolution: 10 min."
          },
          "actions": { "onChange": { "kind": "form.set", "field": "note", "valueExpr": "$value" } }
        },
        {
          "kind": "Button",
          "props": { "variant": "primary", "children": "Acknowledge" },
          "actions": {
            "onPress": {
              "kind": "http.post",
              "url": "/api/v1/monitoring/alerts/{alert}/acknowledge",
              "body": "{{form}}",
              "onSuccess": { "kind": "navigate", "to": "/tenant/monitoring/alerts" }
            }
          }
        }
      ]
    }
  ]
}
