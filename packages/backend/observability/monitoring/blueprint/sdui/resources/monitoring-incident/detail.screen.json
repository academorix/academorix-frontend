{
  "id": "monitoring.resources.monitoring-incident.detail",
  "title": "Incident detail",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/monitoring/incidents/{incident}",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "monitoring", "entity": "monitoring-incident", "action": "view" },
  "requiresPermission": "monitoring.incidents.view",
  "requiresEntitlement": "monitoring_capture",
  "dataSources": [
    {
      "name": "incident",
      "kind": "http.get",
      "url": "/api/v1/monitoring/incidents/{incident}",
      "unwrap": "data"
    },
    {
      "name": "alerts",
      "kind": "http.get",
      "url": "/api/v1/monitoring/alerts?filter[incident_id]={incident}",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-6 p-6 max-w-5xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "kind": "View",
              "children": [
                {
                  "kind": "Text",
                  "props": { "as": "h1", "className": "text-2xl font-semibold" },
                  "bindings": { "children": { "$ref": "incident.title" } }
                },
                {
                  "kind": "View",
                  "props": { "className": "flex items-center gap-2 mt-1" },
                  "children": [
                    {
                      "kind": "Widget",
                      "widget": "monitoring.severity-chip",
                      "bindings": { "severity": { "$ref": "incident.severity" } }
                    },
                    {
                      "kind": "Widget",
                      "widget": "monitoring.status-badge",
                      "bindings": { "status": { "$ref": "incident.status" } }
                    },
                    {
                      "kind": "Text",
                      "props": { "className": "text-sm text-muted" },
                      "bindings": { "children": { "$expr": "'Opened ' + incident.opened_at" } }
                    }
                  ]
                }
              ]
            },
            {
              "kind": "View",
              "props": { "className": "flex gap-2" },
              "children": [
                {
                  "kind": "Button",
                  "props": { "variant": "secondary", "children": "Acknowledge" },
                  "requiresPermission": "monitoring.incidents.acknowledge",
                  "bindings": { "hidden": { "$expr": "incident.status !== 'open'" } },
                  "actions": {
                    "onPress": {
                      "kind": "http.post",
                      "url": "/api/v1/monitoring/incidents/{incident}/acknowledge"
                    }
                  }
                },
                {
                  "kind": "Button",
                  "props": { "variant": "primary", "children": "Resolve" },
                  "requiresPermission": "monitoring.incidents.resolve",
                  "bindings": {
                    "hidden": {
                      "$expr": "incident.status === 'resolved' || incident.status === 'postmortem'"
                    }
                  },
                  "actions": {
                    "onPress": {
                      "kind": "navigate",
                      "toExpr": "'/tenant/monitoring/incidents/' + $routeParams.incident + '/resolve'"
                    }
                  }
                }
              ]
            }
          ]
        },
        {
          "kind": "Card",
          "props": { "className": "p-4" },
          "children": [
            {
              "kind": "Text",
              "props": {
                "as": "h2",
                "className": "text-lg font-semibold mb-2",
                "children": "Description"
              }
            },
            {
              "kind": "Text",
              "props": { "className": "text-sm" },
              "bindings": { "children": { "$ref": "incident.description" } }
            }
          ]
        },
        {
          "kind": "Card",
          "props": { "className": "p-4" },
          "children": [
            {
              "kind": "Text",
              "props": {
                "as": "h2",
                "className": "text-lg font-semibold mb-3",
                "children": "Attached alerts"
              }
            },
            {
              "kind": "DataGrid",
              "bindings": { "items": { "$ref": "alerts" } },
              "props": {
                "columns": [
                  { "field": "fired_at", "header": "Fired at" },
                  { "field": "signal_type", "header": "Signal" },
                  { "field": "signal_value", "header": "Value" },
                  {
                    "field": "status",
                    "header": "Status",
                    "cellRenderer": {
                      "kind": "Widget",
                      "widget": "monitoring.status-badge",
                      "bindings": { "status": { "$ref": "row.status" } }
                    }
                  }
                ]
              }
            }
          ]
        },
        {
          "kind": "Card",
          "props": { "className": "p-4" },
          "bindings": { "hidden": { "$expr": "!incident.postmortem_url" } },
          "children": [
            {
              "kind": "Text",
              "props": {
                "as": "h2",
                "className": "text-lg font-semibold mb-2",
                "children": "Postmortem"
              }
            },
            {
              "kind": "Link",
              "props": { "target": "_blank" },
              "bindings": {
                "href": { "$ref": "incident.postmortem_url" },
                "children": { "$ref": "incident.postmortem_url" }
              }
            }
          ]
        }
      ]
    }
  ]
}
