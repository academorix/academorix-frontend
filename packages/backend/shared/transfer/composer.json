{
  "name": "stackra/transfer",
  "type": "library",
  "description": "Enterprise-grade unified import/export engine wrapping `maatwebsite/excel`. Owns four aggregates (`XferJob`, `XferShard`, `XferArtifact`, `XferMappingProfile`), attribute-driven registration (`#[Importable]` / `#[Exportable]` / `#[SampleData]` / `#[ImportField]` / `#[ExportField]` / `#[TransferField]` / `#[ImportableWorkbook]` / `#[ExportableWorkbook]`), queue-by-default execution riding Laravel Excel's chain + `WithChunkReading`, four import modes (append / upsert / replace / delete), sharded imports for very large files, downloadable errors artifact for partial success, signed download URLs, tenant scoping via `BelongsToTenant`, per-user notifications on finish (mail / broadcast / database / push) resolved at dispatch, mapping profiles for header remap at upload time, and a preview + dry-run pipeline. Distinct from `activity` (product feed) and `audit` (compliance evidence) — transfer runs the data-movement operations both of those modules observe.",
  "license": "proprietary",
  "keywords": [
    "stackra",
    "laravel",
    "transfer",
    "import",
    "export",
    "excel",
    "csv",
    "xlsx",
    "pdf",
    "json",
    "sample-data",
    "multi-tenant",
    "maatwebsite",
    "laravel-excel",
    "queued",
    "sharded",
    "upsert"
  ],
  "require": {
    "php": "^8.3",
    "stackra/activity": "@dev",
    "stackra/application": "@dev",
    "stackra/audit": "@dev",
    "stackra/authorization": "@dev",
    "stackra/console": "@dev",
    "stackra/crud": "@dev",
    "stackra/database": "@dev",
    "stackra/enum": "@dev",
    "stackra/events": "@dev",
    "stackra/exceptions": "@dev",
    "stackra/foundation": "@dev",
    "stackra/notifications": "@dev",
    "stackra/retention": "@dev",
    "stackra/routing": "@dev",
    "stackra/serializer": "@dev",
    "stackra/service-provider": "@dev",
    "stackra/settings": "@dev",
    "stackra/support": "@dev",
    "stackra/tenancy": "@dev",
    "illuminate/bus": "^13.0",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/events": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/notifications": "^13.0",
    "illuminate/queue": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "maatwebsite/excel": "^3.1",
    "mattiverse/userstamps": "^1.0",
    "olvlvl/composer-attribute-collector": "^2.0",
    "owen-it/laravel-auditing": "^13.0",
    "spatie/laravel-activitylog": "^4.10",
    "spatie/laravel-data": "^4.11"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Stackra\\Transfer\\": "src/",
      "Stackra\\Transfer\\Database\\Factories\\": "database/factories/",
      "Stackra\\Transfer\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Stackra\\Transfer\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Stackra\\Transfer\\Providers\\TransferServiceProvider"
      ],
      "aliases": {}
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "olvlvl/composer-attribute-collector": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
