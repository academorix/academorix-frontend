{
  "id": "stackra://modules/transfer/features",
  "$version": 1,
  "title": "transfer \u2014 feature keys",
  "reference": {
    "publishedBy": "feature-flag",
    "resolvedBy": "GET /api/auth/me \u2192 data.features",
    "seededFrom": "BusinessType.default_config.features"
  },
  "features": [
    {
      "key": "transfer.enabled",
      "displayName": "Data transfer",
      "description": "Master toggle for the transfer engine. Off \u2014 all HTTP routes hidden + attributes registered but not executable.",
      "defaultEnabled": true,
      "planTiers": ["free", "team", "enterprise"]
    },
    {
      "key": "transfer.imports",
      "displayName": "Imports",
      "description": "Enable inbound data. Off \u2014 POST /transfer/imports* returns 403.",
      "defaultEnabled": true,
      "planTiers": ["free", "team", "enterprise"]
    },
    {
      "key": "transfer.exports",
      "displayName": "Exports",
      "description": "Enable outbound data. Off \u2014 POST /transfer/exports* returns 403.",
      "defaultEnabled": true,
      "planTiers": ["free", "team", "enterprise"]
    },
    {
      "key": "transfer.samples",
      "displayName": "Sample data",
      "description": "Enable factory-driven sample-data generation. Off \u2014 POST /transfer/samples returns 403.",
      "defaultEnabled": false,
      "planTiers": ["team", "enterprise"]
    },
    {
      "key": "transfer.mapping_profiles",
      "displayName": "Mapping profiles",
      "description": "Enable saved header-remap profiles. Off \u2014 mapping-profiles/* routes hidden.",
      "defaultEnabled": true,
      "planTiers": ["team", "enterprise"]
    },
    {
      "key": "transfer.workbook",
      "displayName": "Multi-sheet workbooks",
      "description": "Enable #[ImportableWorkbook] / #[ExportableWorkbook] composers.",
      "defaultEnabled": true,
      "planTiers": ["team", "enterprise"]
    },
    {
      "key": "transfer.sharded",
      "displayName": "Sharded imports / exports",
      "description": "Enable file-shard fan-out for very large operations. Enterprise-only \u2014 heavy worker cost.",
      "defaultEnabled": false,
      "planTiers": ["enterprise"]
    },
    {
      "key": "transfer.mode_replace",
      "displayName": "Replace import mode",
      "description": "Enable the destructive `replace` import mode.",
      "defaultEnabled": false,
      "planTiers": ["team", "enterprise"]
    },
    {
      "key": "transfer.mode_delete",
      "displayName": "Delete import mode",
      "description": "Enable the destructive `delete` import mode.",
      "defaultEnabled": false,
      "planTiers": ["team", "enterprise"]
    },
    {
      "key": "transfer.formats.pdf",
      "displayName": "PDF export",
      "description": "Enable PDF as an export format (backed by DomPDF / mPDF). PDF wide-table rendering is fragile \u2014 not on by default.",
      "defaultEnabled": false,
      "planTiers": ["team", "enterprise"]
    }
  ]
}
