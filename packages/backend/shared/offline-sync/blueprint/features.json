      "planTiers": ["medium", "enterprise"]
    },
    {
      "key": "offline-sync.attendance",
      "displayName": "Attendance offline capture",
      "description": "Coach records attendance in the field without connectivity; syncs later.",
      "defaultEnabled": false,
      "planTiers": ["medium", "enterprise"]
    },
    {
      "key": "offline-sync.conflict_prompts",
      "displayName": "Interactive conflict prompts",
      "description": "User chooses resolution when server + client both changed the same field. Enterprise.",
      "defaultEnabled": false,
      "planTiers": ["enterprise"]
    },
    {
      "key": "offline-sync.credentials_offline_gates",
      "displayName": "Credentials offline gate mode",
      "description": "Gate devices cache credential registry for offline operation. Requires credentials.gate_offline_mode.",
      "defaultEnabled": false,
      "planTiers": ["enterprise"]
    }
  ]
