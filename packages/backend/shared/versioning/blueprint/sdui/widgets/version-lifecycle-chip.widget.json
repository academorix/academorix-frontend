{
  "id": "versioning.version-lifecycle-chip",
  "title": "Version lifecycle chip",
  "version": 1,
  "kind": "SduiWidget",
  "description": "Colour-coded chip for ApiVersion.state. Semantic mapping: draft = neutral, released = success, deprecated = warning, sunset = danger. Consumed by versioning's own listings + downstream modules (webhook subscription rows, tenant admin dashboard). Optionally shows a tooltip with days_until_sunset when state = deprecated.",
  "props": {
    "state": { "type": "string", "description": "The ApiVersion.state enum value." },
    "size": { "type": "string", "default": "sm", "enum": ["xs", "sm", "md"] },
    "showIcon": { "type": "boolean", "default": true },
    "showLabel": { "type": "boolean", "default": true },
    "daysUntilSunset": {
      "type": "integer",
      "description": "Optional. When state=deprecated, displays a tooltip 'sunsets in Nd'."
    }
  },
  "dataSources": [],
  "nodes": [
    {
      "id": "chip",
      "kind": "Chip",
      "bindings": {
        "variant": {
          "$expr": "props.state === 'released' ? 'success' : (props.state === 'deprecated' ? 'warning' : (props.state === 'sunset' ? 'danger' : 'neutral'))"
        },
        "size": { "$ref": "props.size" },
        "tooltip": {
          "$expr": "props.state === 'deprecated' && props.daysUntilSunset != null ? ('sunsets in ' + props.daysUntilSunset + ' days') : null"
        }
      },
      "children": [
        {
          "kind": "Icon",
          "props": { "className": "size-3 mr-1" },
          "bindings": {
            "hidden": { "$expr": "!props.showIcon" },
            "icon": {
              "$expr": "props.state === 'released' ? 'check-circle' : (props.state === 'deprecated' ? 'clock' : (props.state === 'sunset' ? 'x-circle' : 'pencil-square'))"
            }
          }
        },
        {
          "kind": "Text",
          "props": { "as": "span" },
          "bindings": {
            "hidden": { "$expr": "!props.showLabel" },
            "children": {
              "$expr": "props.state === 'released' ? 'Released' : (props.state === 'deprecated' ? 'Deprecated' : (props.state === 'sunset' ? 'Sunset' : 'Draft'))"
            }
          }
        }
      ]
    }
  ]
}
