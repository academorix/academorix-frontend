{
  "id": "stackra://modules/versioning/events",
  "$version": 1,
  "title": "versioning \u2014 published events",
  "description": "5 events. All afterCommit \u2014 downstream listeners (webhook subscription auto-upgrade, notification dispatch, tenant admin dashboard broadcast) must see the committed row.",
  "namespace": "Stackra\\Versioning\\Events",
  "dispatchMode": "afterCommit",
  "events": [
    {
      "name": "ApiVersionReleased",
      "class": "Stackra\\Versioning\\Events\\ApiVersionReleased",
      "trigger": "ApiVersion state transitions draft \u2192 released. Fires once per version, ever.",
      "queue": "notifications",
      "consumers": [
        "notifications::TrackApiVersionReleasedListener",
        "compliance::AuditApiVersionReleasedListener"
      ],
      "payload": {
        "api_version_id": "ULID",
        "slug": "string",
        "name": "string",
        "scheme": "'semver' | 'calver'",
        "released_at": "ISO 8601",
        "actor_id": "ULID | null"
      }
    },
    {
      "name": "ApiVersionDeprecated",
      "class": "Stackra\\Versioning\\Events\\ApiVersionDeprecated",
      "trigger": "ApiVersion state transitions released \u2192 deprecated. Fires once per version.",
      "queue": "notifications-critical",
      "consumers": [
        "webhook::TrackVersionDeprecatedForSubscriptions",
        "notifications::PublishDeprecationNoticesListener",
        "compliance::AuditApiVersionDeprecatedListener"
      ],
      "payload": {
        "api_version_id": "ULID",
        "slug": "string",
        "deprecated_at": "ISO 8601",
        "sunset_at": "ISO 8601 | null",
        "migration_target_slug": "string | null",
        "migration_guide_url": "string | null",
        "affected_subscription_count": "integer \u2014 how many WebhookSubscriptions reference this slug at deprecation time",
        "actor_id": "ULID | null"
      }
    },
    {
      "name": "ApiVersionSunset",
      "class": "Stackra\\Versioning\\Events\\ApiVersionSunset",
      "trigger": "ApiVersion state transitions deprecated \u2192 sunset. Fired by SunsetApiVersionJob when now() > sunset_at, or manually via endpoint.",
      "queue": "notifications-critical",
      "consumers": [
        "webhook::AutoUpgradePinnedSubscriptions",
        "notifications::PublishSunsetFinalNoticesListener",
        "compliance::AuditApiVersionSunsetListener"
      ],
      "payload": {
        "api_version_id": "ULID",
        "slug": "string",
        "sunset_at": "ISO 8601",
        "migration_target_slug": "string | null",
        "auto_upgrade_performed": "boolean \u2014 true when migration_target_slug set + upgrades executed",
        "affected_subscription_count": "integer",
        "actor_id": "ULID | null | 'system' when scheduled"
      }
    },
    {
      "name": "DeprecationNoticePublished",
      "class": "Stackra\\Versioning\\Events\\DeprecationNoticePublished",
      "trigger": "DeprecationNotice state transitions draft \u2192 published.",
      "queue": "notifications",
      "consumers": [
        "notifications::DispatchDeprecationNotificationsListener",
        "compliance::AuditDeprecationNoticePublishedListener"
      ],
      "payload": {
        "notice_id": "ULID",
        "api_version_id": "ULID",
        "api_version_slug": "string",
        "notice_type": "'deprecation' | 'sunset_reminder' | 'sunset_final' | 'partial_deprecation'",
        "title": "string",
        "affected_endpoints": "string[]",
        "affected_events": "string[]",
        "notify_customers": "boolean",
        "published_at": "ISO 8601",
        "actor_id": "ULID | null"
      }
    },
    {
      "name": "PayloadTransformerRegistered",
      "class": "Stackra\\Versioning\\Events\\PayloadTransformerRegistered",
      "trigger": "Build-time compiler discovered a #[AsPayloadTransformer] class + registered it with PayloadTransformerRegistry. Fired at boot for observability, not for consumers to act on.",
      "queue": "notifications",
      "consumers": ["observability::MetricsCollector"],
      "payload": {
        "transformer_class": "string",
        "surface": "'rest' | 'webhook' | 'graphql'",
        "event": "string \u2014 event name or wildcard '*'",
        "from_version": "string",
        "to_version": "string"
      }
    }
  ]
}
