{
  "name": "stackra/versioning",
  "type": "library",
  "description": "Public interface versioning substrate. Owns the ApiVersion + DeprecationNotice aggregates, the resolver chain (URL path / content negotiation / query param / webhook subscription / GraphQL context), payload transformer registry (attribute-discovered via #[AsPayloadTransformer]), version scheme adapters (SemVer + CalVer), the RFC 8594 Sunset workflow, and the platform-admin + tenant + central-public HTTP surfaces.",
  "license": "proprietary",
  "keywords": [
    "stackra",
    "laravel",
    "versioning",
    "api-versioning",
    "payload-versioning",
    "webhook-versioning",
    "graphql-versioning",
    "deprecation",
    "sunset",
    "rfc-8594",
    "semver",
    "calver",
    "payload-transformers"
  ],
  "require": {
    "php": "^8.3",
    "stackra/authorization": "@dev",
    "stackra/console": "@dev",
    "stackra/crud": "@dev",
    "stackra/database": "@dev",
    "stackra/enum": "@dev",
    "stackra/events": "@dev",
    "stackra/exceptions": "@dev",
    "stackra/foundation": "@dev",
    "stackra/retention": "@dev",
    "stackra/routing": "@dev",
    "stackra/service-provider": "@dev",
    "stackra/support": "@dev",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/events": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/queue": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "wildside/userstamps": "^1.0",
    "olvlvl/composer-attribute-collector": "^2.0",
    "owen-it/laravel-auditing": "^13.0",
    "spatie/laravel-data": "^4.11"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "suggest": {
    "composer/semver": "For strict SemVer comparison in SemVerScheme. Falls back to native version_compare when absent."
  },
  "autoload": {
    "psr-4": {
      "Stackra\\Versioning\\": "src/",
      "Stackra\\Versioning\\Database\\Factories\\": "database/factories/",
      "Stackra\\Versioning\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Stackra\\Versioning\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Stackra\\Versioning\\Providers\\VersioningServiceProvider"
      ],
      "aliases": {}
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "olvlvl/composer-attribute-collector": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "repositories": [
    {
      "type": "path",
      "url": "../../authorization",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/console",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/crud",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/database",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/enum",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/events",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/exceptions",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../foundation",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../compliance/retention",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/routing",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/service-provider",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/support",
      "options": {
        "symlink": true
      }
    }
  ],
  "scripts": {
    "test": "Stackra\\Foundation\\Scripts\\TestScripts::run",
    "test:coverage": "Stackra\\Foundation\\Scripts\\TestScripts::coverage",
    "test:parallel": "Stackra\\Foundation\\Scripts\\TestScripts::parallel",
    "test:filter": "Stackra\\Foundation\\Scripts\\TestScripts::filter",
    "analyse": "Stackra\\Foundation\\Scripts\\AnalyseScripts::run",
    "analyse:baseline": "Stackra\\Foundation\\Scripts\\AnalyseScripts::baseline",
    "lint": "Stackra\\Foundation\\Scripts\\LintScripts::check",
    "lint:fix": "Stackra\\Foundation\\Scripts\\LintScripts::fix",
    "doppler:status": "Stackra\\Foundation\\Scripts\\DopplerScripts::status",
    "doppler:setup": "Stackra\\Foundation\\Scripts\\DopplerScripts::setup"
  }
}
