{
  "name": "academorix/versioning",
  "type": "library",
  "description": "Public interface versioning substrate. Owns the ApiVersion + DeprecationNotice aggregates, the resolver chain (URL path / content negotiation / query param / webhook subscription / GraphQL context), payload transformer registry (attribute-discovered via #[AsPayloadTransformer]), version scheme adapters (SemVer + CalVer), the RFC 8594 Sunset workflow, and the platform-admin + tenant + central-public HTTP surfaces.",
  "license": "proprietary",
  "keywords": [
    "academorix",
    "laravel",
    "versioning",
    "api-versioning",
    "payload-versioning",
    "webhook-versioning",
    "graphql-versioning",
    "deprecation",
    "sunset",
    "rfc-8594",
    "semver",
    "calver",
    "payload-transformers"
  ],
  "require": {
    "php": "^8.3",
    "academorix/authorization": "@dev",
    "academorix/console": "@dev",
    "academorix/crud": "@dev",
    "academorix/database": "@dev",
    "academorix/enum": "@dev",
    "academorix/events": "@dev",
    "academorix/exceptions": "@dev",
    "academorix/foundation": "@dev",
    "academorix/retention": "@dev",
    "academorix/routing": "@dev",
    "academorix/service-provider": "@dev",
    "academorix/support": "@dev",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/events": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/queue": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "mattiverse/userstamps": "^1.0",
    "olvlvl/composer-attribute-collector": "^2.0",
    "owen-it/laravel-auditing": "^13.0",
    "spatie/laravel-data": "^4.11"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "suggest": {
    "composer/semver": "For strict SemVer comparison in SemVerScheme. Falls back to native version_compare when absent."
  },
  "autoload": {
    "psr-4": {
      "Academorix\\Versioning\\": "src/",
      "Academorix\\Versioning\\Database\\Factories\\": "database/factories/",
      "Academorix\\Versioning\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Academorix\\Versioning\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Academorix\\Versioning\\Providers\\VersioningServiceProvider"
      ],
      "aliases": {}
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "olvlvl/composer-attribute-collector": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
