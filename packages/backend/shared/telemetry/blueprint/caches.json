{
  "id": "stackra://modules/telemetry/caches",
  "$version": 1,
  "title": "telemetry \u2014 cache keys + tags",
  "driver": "redis",
  "ownedTags": ["telemetry"],
  "keys": [
    {
      "pattern": "telemetry:otel:registry:spans",
      "description": "Compiled SpanRegistry map (class::method \u2192 SpanDescriptor). Warmed on boot; long-lived.",
      "ttlSeconds": 86400,
      "tags": ["telemetry", "platform"],
      "invalidatedBy": ["foundation::ApplicationBooted", "ConfigReloaded"]
    },
    {
      "pattern": "telemetry:otel:registry:metrics",
      "description": "Compiled MetricRegistry map for #[AsCounter] / #[AsHistogram] / #[AsGauge] / #[AsUpDownCounter].",
      "ttlSeconds": 86400,
      "tags": ["telemetry", "platform"]
    },
    {
      "pattern": "telemetry:otel:resource_attributes",
      "description": "Compiled Resource block sent with every export batch. Includes service.name, deployment.environment, k8s.*.",
      "ttlSeconds": 3600,
      "tags": ["telemetry", "platform"]
    },
    {
      "pattern": "telemetry:logs:registry:context",
      "description": "Compiled LogContextRegistry (class \u2192 [enricher method, key]).",
      "ttlSeconds": 86400,
      "tags": ["telemetry", "platform"],
      "invalidatedBy": ["foundation::ApplicationBooted", "ConfigReloaded"]
    },
    {
      "pattern": "telemetry:logs:registry:channels",
      "description": "class \u2192 channel from #[AsLogChannel].",
      "ttlSeconds": 86400,
      "tags": ["telemetry", "platform"]
    },
    {
      "pattern": "telemetry:logs:redactor:rules",
      "description": "Compiled redaction rules (keys + patterns + class-level).",
      "ttlSeconds": 3600,
      "tags": ["telemetry", "platform"]
    }
  ]
}
