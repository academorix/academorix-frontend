{
  "name": "academorix/audit",
  "type": "library",
  "description": "Compliance-grade audit trail. Thin wrapper around owen-it/laravel-auditing with our conventions: KMS-encrypted old/new values for restricted-tier fields, ULID prefix `aud_`, tenant scoping via BelongsToTenantOptional (system-level audits carry tenant_id=NULL), 365d hot + 2555d cold retention (7y), platform-admin-only HTTP surface, optional tamper-evident hash chain per row for enterprise plans. Publishes `HasAudit` trait and `#[Auditable]` attribute.",
  "license": "proprietary",
  "keywords": [
    "academorix",
    "laravel",
    "audit",
    "auditing",
    "compliance",
    "owen-it",
    "gdpr",
    "soc2",
    "iso27001",
    "immutable",
    "tamper-evident"
  ],
  "require": {
    "php": "^8.3",
    "academorix/authorization": "@dev",
    "academorix/console": "@dev",
    "academorix/crud": "@dev",
    "academorix/database": "@dev",
    "academorix/enum": "@dev",
    "academorix/events": "@dev",
    "academorix/exceptions": "@dev",
    "academorix/foundation": "@dev",
    "academorix/retention": "@dev",
    "academorix/routing": "@dev",
    "academorix/service-provider": "@dev",
    "academorix/support": "@dev",
    "academorix/tenancy": "@dev",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/events": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/queue": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "owen-it/laravel-auditing": "^13.0",
    "spatie/laravel-data": "^4.11"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Academorix\\Audit\\": "src/",
      "Academorix\\Audit\\Database\\Factories\\": "database/factories/",
      "Academorix\\Audit\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Academorix\\Audit\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Academorix\\Audit\\Providers\\AuditServiceProvider"
      ],
      "aliases": {}
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "repositories": [
    {
      "type": "path",
      "url": "../../authorization",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/console",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/crud",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/database",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/enum",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/events",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/exceptions",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../foundation",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../compliance/retention",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/routing",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/service-provider",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/support",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../platform/tenancy",
      "options": {
        "symlink": true
      }
    }
  ]
}
