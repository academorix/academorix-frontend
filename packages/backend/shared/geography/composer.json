{
  "name": "stackra/geography",
  "type": "library",
  "description": "Global reference catalog wrapping nnjeim/world. Six entities \u2014 Country, State, City, Currency, Language, Timezone \u2014 shipped as PUBLIC read-only reference data + an authenticated + rate-limited IP\u2192location resolver on top of MaxMind GeoLite2 with ip-api.com fallback. Not tenant-scoped \u2014 the catalog is global platform reference data every marketing page, signup flow, and tenant UI depends on. nnjeim/world owns the six tables + migrations + seeder (installed once via `php artisan world:install`); this module ships subclass models rebinding `config('world.models.*')` so vendor relations return our subclasses, plus the Data / Repository / Service / Controller / Policy / Provider layers.",
  "license": "proprietary",
  "keywords": [
    "stackra",
    "laravel",
    "geography",
    "iso-3166",
    "iso-4217",
    "iso-639",
    "countries",
    "states",
    "cities",
    "currencies",
    "languages",
    "timezones",
    "iana",
    "geolocation",
    "maxmind",
    "geolite2",
    "ip-api",
    "nnjeim-world",
    "reference-data"
  ],
  "require": {
    "php": "^8.3",
    "stackra/authorization": "@dev",
    "stackra/console": "@dev",
    "stackra/crud": "@dev",
    "stackra/database": "@dev",
    "stackra/enum": "@dev",
    "stackra/events": "@dev",
    "stackra/exceptions": "@dev",
    "stackra/foundation": "@dev",
    "stackra/routing": "@dev",
    "stackra/service-provider": "@dev",
    "stackra/support": "@dev",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/events": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/notifications": "^13.0",
    "illuminate/queue": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "wildside/userstamps": "^1.0",
    "nesbot/carbon": "^3.0",
    "nnjeim/world": "^1.1",
    "olvlvl/composer-attribute-collector": "^2.0",
    "owen-it/laravel-auditing": "^13.0",
    "spatie/laravel-data": "^4.11"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Stackra\\Geography\\": "src/",
      "Stackra\\Geography\\Database\\Factories\\": "database/factories/",
      "Stackra\\Geography\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Stackra\\Geography\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Stackra\\Geography\\Providers\\GeographyServiceProvider"
      ],
      "aliases": {}
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "olvlvl/composer-attribute-collector": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "repositories": [
    {
      "type": "path",
      "url": "../../authorization",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/console",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/crud",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/database",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/enum",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/events",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/exceptions",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../foundation",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/routing",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/service-provider",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../../framework/support",
      "options": {
        "symlink": true
      }
    }
  ],
  "scripts": {
    "test": "Stackra\\Foundation\\Scripts\\TestScripts::run",
    "test:coverage": "Stackra\\Foundation\\Scripts\\TestScripts::coverage",
    "test:parallel": "Stackra\\Foundation\\Scripts\\TestScripts::parallel",
    "test:filter": "Stackra\\Foundation\\Scripts\\TestScripts::filter",
    "analyse": "Stackra\\Foundation\\Scripts\\AnalyseScripts::run",
    "analyse:baseline": "Stackra\\Foundation\\Scripts\\AnalyseScripts::baseline",
    "lint": "Stackra\\Foundation\\Scripts\\LintScripts::check",
    "lint:fix": "Stackra\\Foundation\\Scripts\\LintScripts::fix",
    "doppler:status": "Stackra\\Foundation\\Scripts\\DopplerScripts::status",
    "doppler:setup": "Stackra\\Foundation\\Scripts\\DopplerScripts::setup"
  }
}
