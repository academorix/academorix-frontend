{
  "name": "stackra/localization",
  "type": "library",
  "description": "Multilingual substrate on top of Laravel's built-in localization. Owns four entities — PlatformLanguage (platform catalogue of BCP-47 locale tags with script + platform state, FK-referencing geography::Language + optionally geography::Country for regional variants), TenantLocale (per-tenant enabled locales with default + fallback + auto-translate policy), Translation (persistent DB cache of resolved key→value bindings per tenant + locale), TranslationJob (audit trail for async bulk-translation work). Resolves the caller's active locale from a 7-step precedence chain (query, header, user, tenant, Accept-Language, subdomain, app default). Decorates Laravel's Translator so `t()`, `__()`, `trans()`, `trans_choice()` transparently consult the DB cache before the filesystem. Ships #[Translatable] attribute for Eloquent property translation. Publishes 5 machine-translation drivers (OpenAI, Google, DeepL, AWS Translate, Azure) + a null driver for tests. RTL-aware. All ISO-639 + ISO-3166 metadata sourced from the geography module — no field duplication.",
  "license": "proprietary",
  "keywords": [
    "stackra",
    "laravel",
    "localization",
    "i18n",
    "translation",
    "locale",
    "language",
    "bcp47",
    "iso639",
    "rtl",
    "openai",
    "google-translate",
    "deepl",
    "aws-translate",
    "azure-translator"
  ],
  "require": {
    "php": "^8.3",
    "stackra/authorization": "@dev",
    "stackra/console": "@dev",
    "stackra/crud": "@dev",
    "stackra/database": "@dev",
    "stackra/entitlements": "@dev",
    "stackra/enum": "@dev",
    "stackra/events": "@dev",
    "stackra/exceptions": "@dev",
    "stackra/foundation": "@dev",
    "stackra/geography": "@dev",
    "stackra/retention": "@dev",
    "stackra/routing": "@dev",
    "stackra/service-provider": "@dev",
    "stackra/support": "@dev",
    "stackra/tenancy": "@dev",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/events": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/notifications": "^13.0",
    "illuminate/queue": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "illuminate/translation": "^13.0",
    "spatie/laravel-data": "^4.11"
  },
  "suggest": {
    "openai-php/laravel": "Required by OpenAITranslatorDriver when the `openai` driver is used.",
    "google/cloud-translate": "Required by GoogleTranslatorDriver when the `google` driver is used.",
    "deeplcom/deepl-php": "Required by DeepLTranslatorDriver when the `deepl` driver is used.",
    "aws/aws-sdk-php": "Required by AwsTranslateDriver when the `aws-translate` driver is used."
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Stackra\\Localization\\": "src/",
      "Stackra\\Localization\\Database\\Factories\\": "database/factories/",
      "Stackra\\Localization\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Stackra\\Localization\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Stackra\\Localization\\Providers\\LocalizationServiceProvider"
      ],
      "aliases": {}
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
