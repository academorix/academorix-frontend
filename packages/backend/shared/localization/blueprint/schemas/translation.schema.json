{
  "id": "stackra://modules/localization/schemas/translation",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "Translation",
  "description": "Persistent cache of one translated key. tenant_id nullable so the same table stores platform defaults + tenant overrides. High volume \u2014 access via the (tenant_id, language_id, namespace, key) covering index. `language_id` FKs to `platform_languages.id` (Wave 5: was formerly `languages.id` before the PlatformLanguage rename).",
  "type": "object",
  "x-module": "localization",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "translations",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "trn_",
    "incrementing": false,
    "model": "Stackra\\Localization\\Models\\Translation",
    "interface": "Stackra\\Localization\\Contracts\\Data\\TranslationInterface",
    "implements": ["Stackra\\Localization\\Contracts\\Data\\TranslationInterface"],
    "traits": ["HasFactory", "HasUlids", "HasMetadata", "Filterable"],
    "casts": {
      "value": "array",
      "source": "TranslationSource",
      "quality_score": "float",
      "is_stale": "boolean",
      "verified_at": "datetime",
      "translated_at": "datetime",
      "metadata": "array"
    },
    "appends": ["is_platform_default", "is_tenant_override"],
    "observers": ["TranslationObserver"],
    "hidden": [],
    "guarded": []
  },
  "x-database": {
    "engine": "postgres",
    "partitioning": {
      "strategy": "list",
      "column": "tenant_id_bucket",
      "note": "Optional \u2014 enable when > 100M rows. Bucket by tenant_id first 2 chars of ULID."
    },
    "columns": {
      "id": {
        "type": "string",
        "length": 64,
        "primary": true,
        "description": "Prefixed ULID: `trn_<26 chars>`."
      },
      "tenant_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" },
        "description": "Null = platform default. Non-null = tenant-specific override."
      },
      "language_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "platform_languages", "column": "id", "onDelete": "cascade" },
        "description": "FK to `PlatformLanguage.id`. Column name stays `language_id` (concept-name)."
      },
      "locale_code": {
        "type": "string",
        "length": 12,
        "nullable": false,
        "description": "Denormalised from PlatformLanguage.bcp47_code. Speeds lookup without join."
      },
      "namespace": {
        "type": "string",
        "length": 100,
        "nullable": false,
        "default": "'*'",
        "description": "Laravel translation namespace. '*' = default namespace (`lang/en.json` + `lang/en/*.php` root)."
      },
      "group": {
        "type": "string",
        "length": 100,
        "nullable": false,
        "default": "''",
        "description": "The php-file basename in Laravel terms. E.g. `validation`, `auth`, `users`. Empty string when the key is from a JSON file."
      },
      "key": {
        "type": "string",
        "length": 512,
        "nullable": false,
        "description": "The translation key. E.g. `users.title`, `validation.custom.email.required`. For JSON files this is the full English string used as key."
      },
      "value": {
        "type": "jsonb",
        "nullable": false,
        "description": "JSONB so we can store either a string, an array (Laravel array-returning keys like `validation.custom`), or a plural array `[zero, one, other]`."
      },
      "source": {
        "type": "string",
        "length": 16,
        "nullable": false,
        "default": "'file'",
        "description": "Enum: file / db / ai / human / imported. Origin of this translation."
      },
      "provider": {
        "type": "string",
        "length": 32,
        "nullable": true,
        "description": "When source=ai: openai / google / deepl / aws-translate / azure-translator."
      },
      "provider_model": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "description": "E.g. gpt-4o-mini, deepl-quality-high."
      },
      "quality_score": {
        "type": "numeric",
        "nullable": true,
        "description": "0.0\u20131.0 provider-reported. Only present for AI sources."
      },
      "source_hash": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "description": "SHA-256 of the source string that was translated. Used to detect stale translations when source strings change upstream."
      },
      "is_stale": {
        "type": "boolean",
        "nullable": false,
        "default": false,
        "description": "Set when source_hash mismatch detected. Retranslate on next resolution."
      },
      "translated_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "When the translation was produced. Used for TTL checks on auto-translated rows."
      },
      "verified_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "Human review timestamp. Non-null = passed review."
      },
      "translation_job_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": { "table": "translation_jobs", "column": "id", "onDelete": "set null" },
        "description": "Bulk job that produced this row (null when hand-authored)."
      },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "language_id", "namespace", "group", "key"],
        "unique": true,
        "name": "translations_lookup_unique",
        "description": "Primary lookup key. Covers tenant + platform (tenant_id NULL) rows."
      },
      {
        "columns": ["language_id", "namespace", "group"],
        "unique": false,
        "name": "translations_scan_by_namespace_idx"
      },
      {
        "columns": ["translation_job_id"],
        "unique": false,
        "name": "translations_by_job_idx",
        "predicate": "translation_job_id IS NOT NULL"
      },
      {
        "columns": ["is_stale", "language_id"],
        "unique": false,
        "name": "translations_stale_scan_idx",
        "predicate": "is_stale = true"
      }
    ]
  },
  "required": [
    "id",
    "language_id",
    "locale_code",
    "namespace",
    "group",
    "key",
    "value",
    "source",
    "is_stale",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^trn_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": ["string", "null"], "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "language_id": { "type": "string", "pattern": "^lng_[0-9A-HJKMNP-TV-Z]{26}$" },
    "locale_code": { "type": "string" },
    "namespace": { "type": "string" },
    "group": { "type": "string" },
    "key": { "type": "string", "maxLength": 512 },
    "value": {
      "description": "String | array | plural-form array.",
      "oneOf": [{ "type": "string" }, { "type": "array" }, { "type": "object" }]
    },
    "source": { "type": "string", "enum": ["file", "db", "ai", "human", "imported"] },
    "provider": {
      "type": ["string", "null"],
      "enum": ["openai", "google", "deepl", "aws-translate", "azure-translator", null]
    },
    "provider_model": { "type": ["string", "null"] },
    "quality_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "source_hash": { "type": ["string", "null"] },
    "is_stale": { "type": "boolean" },
    "translated_at": { "type": ["string", "null"], "format": "date-time" },
    "verified_at": { "type": ["string", "null"], "format": "date-time" },
    "translation_job_id": { "type": ["string", "null"], "pattern": "^tjb_[0-9A-HJKMNP-TV-Z]{26}$" },
    "is_platform_default": { "type": "boolean", "description": "Computed. tenant_id IS NULL." },
    "is_tenant_override": {
      "type": "boolean",
      "description": "Computed. tenant_id IS NOT NULL."
    },
    "metadata": { "type": ["object", "null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false,
  "x-wire": {
    "envelope": "spatie-data",
    "wrap": "data",
    "mapper": "SnakeCaseMapper",
    "computed": ["is_platform_default", "is_tenant_override"]
  }
}
