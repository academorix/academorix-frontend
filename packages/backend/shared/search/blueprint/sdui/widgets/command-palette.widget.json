{
  "id": "search.command-palette",
  "title": "Command palette (\u2318K)",
  "version": 1,
  "kind": "SduiWidget",
  "description": "Global command palette. Mounted once in the authenticated app shell via a portal. Opens on \u2318K / Ctrl+K + on `commandPalette.open` action. Cross-model search + recent-searches + saved-queries + quick-actions. Powers the app-wide search UX.",
  "props": {
    "quickActions": {
      "type": "array",
      "default": [],
      "description": "Static quick actions injected by the app shell (e.g. Create Athlete, Go to Settings). Rendered above search results."
    },
    "defaultIndexes": {
      "type": "array",
      "default": [],
      "description": "Default set of indexes to query when the user hasn't scoped. Configured by the host page (e.g. dashboard sets athletes+teams+coaches)."
    }
  },
  "dataSources": [
    {
      "name": "sessionId",
      "kind": "clientState",
      "initial": "generateUuid()",
      "description": "Persistent for the palette's lifetime. Passed to click-through."
    },
    {
      "name": "recentQueries",
      "kind": "http.get",
      "url": "/api/v1/search/saved-queries",
      "unwrap": "data",
      "queryParams": { "filter[is_smart_list]": "false" },
      "cache": { "ttlSeconds": 60 },
      "when": { "$expr": "state.query.length === 0" }
    },
    {
      "name": "hits",
      "kind": "http.get",
      "url": "/api/v1/search",
      "unwrap": "data",
      "queryParamsFromState": ["q", "index"],
      "when": { "$expr": "state.query.length >= 2" },
      "debounceMs": 150
    },
    {
      "name": "suggests",
      "kind": "http.get",
      "url": "/api/v1/search/suggest",
      "unwrap": "data",
      "queryParamsFromState": ["q", "index"],
      "when": { "$expr": "state.query.length >= 2" },
      "debounceMs": 80
    }
  ],
  "keybindings": [
    { "key": "cmd+k", "action": "open" },
    { "key": "ctrl+k", "action": "open" },
    { "key": "escape", "action": "close", "when": "state.isOpen" },
    { "key": "arrowdown", "action": "moveSelectionDown", "when": "state.isOpen" },
    { "key": "arrowup", "action": "moveSelectionUp", "when": "state.isOpen" },
    { "key": "enter", "action": "activateSelection", "when": "state.isOpen" }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "Modal",
      "props": {
        "className": "max-w-2xl mx-auto mt-24 rounded-xl overflow-hidden shadow-2xl bg-background"
      },
      "bindings": {
        "isOpen": { "$ref": "state.isOpen" },
        "onClose": { "kind": "action", "name": "close" }
      },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-center gap-3 px-4 py-3 border-b border-content2" },
          "children": [
            { "kind": "Icon", "props": { "name": "magnifying-glass", "className": "text-muted" } },
            {
              "kind": "Input",
              "props": {
                "placeholder": { "$expr": "t('search.palette.placeholder')" },
                "className": "flex-1 border-none focus:ring-0 text-base bg-transparent",
                "autoFocus": true
              },
              "bindings": { "value": { "$ref": "state.query" } },
              "actions": { "onChange": { "kind": "state.set", "path": "query" } }
            },
            { "kind": "Kbd", "props": { "children": "\u2318K", "className": "text-xs text-muted" } }
          ]
        },

        {
          "kind": "View",
          "props": { "className": "max-h-96 overflow-y-auto p-2" },
          "children": [
            {
              "kind": "View",
              "bindings": {
                "hidden": { "$expr": "state.query.length > 0 || !props.quickActions?.length" }
              },
              "children": [
                {
                  "kind": "Text",
                  "props": {
                    "className": "text-xs uppercase text-muted px-2 py-1",
                    "children": { "$expr": "t('search.palette.quick_actions')" }
                  }
                },
                {
                  "kind": "List",
                  "bindings": { "items": { "$ref": "props.quickActions" } },
                  "itemRenderer": {
                    "kind": "Pressable",
                    "actions": { "onPress": { "$ref": "row.action" } },
                    "props": {
                      "className": "flex items-center gap-2 px-2 py-2 rounded hover:bg-content1"
                    },
                    "children": [
                      {
                        "kind": "Icon",
                        "bindings": { "name": { "$ref": "row.icon" }, "className": "text-muted" }
                      },
                      {
                        "kind": "Text",
                        "props": { "className": "flex-1" },
                        "bindings": { "children": { "$ref": "row.label" } }
                      },
                      {
                        "kind": "Kbd",
                        "props": { "className": "text-xs text-muted" },
                        "bindings": {
                          "children": { "$ref": "row.shortcut" },
                          "hidden": { "$expr": "!row.shortcut" }
                        }
                      }
                    ]
                  }
                }
              ]
            },

            {
              "kind": "View",
              "bindings": {
                "hidden": { "$expr": "state.query.length > 0 || !recentQueries?.length" }
              },
              "children": [
                {
                  "kind": "Text",
                  "props": {
                    "className": "text-xs uppercase text-muted px-2 py-1 mt-2",
                    "children": { "$expr": "t('search.palette.recent')" }
                  }
                },
                {
                  "kind": "List",
                  "bindings": { "items": { "$ref": "recentQueries" } },
                  "itemRenderer": {
                    "kind": "Pressable",
                    "actions": {
                      "onPress": {
                        "kind": "http.post",
                        "url": { "$expr": "'/api/v1/search/saved-queries/' + row.id + '/run'" },
                        "then": {
                          "kind": "navigateExpr",
                          "expr": "'/tenant/search?saved_query=' + row.id"
                        }
                      }
                    },
                    "props": {
                      "className": "flex items-center gap-2 px-2 py-2 rounded hover:bg-content1"
                    },
                    "children": [
                      { "kind": "Icon", "props": { "name": "clock", "className": "text-muted" } },
                      {
                        "kind": "Text",
                        "props": { "className": "flex-1 truncate" },
                        "bindings": { "children": { "$ref": "row.name" } }
                      }
                    ]
                  }
                }
              ]
            },

            {
              "kind": "View",
              "bindings": { "hidden": { "$expr": "state.query.length < 2 || !hits?.length" } },
              "children": [
                {
                  "kind": "Text",
                  "props": {
                    "className": "text-xs uppercase text-muted px-2 py-1",
                    "children": { "$expr": "t('search.palette.results')" }
                  }
                },
                {
                  "kind": "List",
                  "bindings": { "items": { "$ref": "hits" } },
                  "itemRenderer": {
                    "kind": "Widget",
                    "widget": "search.search-result-row",
                    "props": { "compact": true },
                    "bindings": { "hit": { "$ref": "row" }, "sessionId": { "$ref": "sessionId" } }
                  }
                }
              ]
            },

            {
              "kind": "View",
              "bindings": { "hidden": { "$expr": "state.query.length < 2 || hits?.length > 0" } },
              "children": [
                {
                  "kind": "Text",
                  "props": { "className": "text-sm text-muted text-center py-8" },
                  "bindings": {
                    "children": { "$expr": "t('search.palette.no_results', {q: state.query})" }
                  }
                }
              ]
            }
          ]
        },

        {
          "kind": "View",
          "props": {
            "className": "flex items-center gap-4 px-4 py-2 border-t border-content2 text-xs text-muted"
          },
          "children": [
            {
              "kind": "View",
              "props": { "className": "flex items-center gap-1" },
              "children": [
                { "kind": "Kbd", "props": { "children": "\u2191\u2193" } },
                {
                  "kind": "Text",
                  "bindings": { "children": { "$expr": "t('search.palette.hint.navigate')" } }
                }
              ]
            },
            {
              "kind": "View",
              "props": { "className": "flex items-center gap-1" },
              "children": [
                { "kind": "Kbd", "props": { "children": "\u23ce" } },
                {
                  "kind": "Text",
                  "bindings": { "children": { "$expr": "t('search.palette.hint.select')" } }
                }
              ]
            },
            {
              "kind": "View",
              "props": { "className": "flex items-center gap-1" },
              "children": [
                { "kind": "Kbd", "props": { "children": "esc" } },
                {
                  "kind": "Text",
                  "bindings": { "children": { "$expr": "t('search.palette.hint.close')" } }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
