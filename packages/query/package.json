{
  "name": "@academorix/query",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "React Query primitives for the Academorix workspace: createQueryClient() factory + defineResource<T>() that generates typed useList/useOne/useCreate/useUpdate/useDelete hooks bound to @academorix/http. Landing page uses these hooks directly; dashboard reuses via Refine's data provider (built on the same transport).",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client/index.ts",
    "./resource": "./src/resource/index.ts",
    "./query-keys": "./src/query-keys/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf .turbo"
  },
  "dependencies": {
    "@academorix/core": "workspace:*",
    "@academorix/http": "workspace:*"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5",
    "react": ">=19"
  },
  "devDependencies": {
    "@academorix/eslint-config": "workspace:*",
    "@academorix/typescript-config": "workspace:*",
    "@tanstack/react-query": "catalog:",
    "@types/react": "catalog:",
    "eslint": "catalog:",
    "react": "catalog:",
    "typescript": "catalog:"
  }
}
