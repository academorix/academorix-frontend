{
  "name": "@academorix/api-types",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Typed API contracts (Zod schemas + inferred types) for every mock JSON fixture. Consumers import from the barrel: import { Athlete, InvoiceId, MatchStatus } from '@academorix/api-types'.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "generate:report": "node scripts/generate-schemas.mjs",
    "contract-check": "node scripts/contract-check.mjs",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@academorix/typescript-config": "workspace:*",
    "typescript": "catalog:"
  }
}
