    "embla-carousel-react": "catalog:",
    "marked": "catalog:",
    "motion": "catalog:",
    "react-aria-components": "catalog:",
    "react-markdown": "catalog:",
    "react-resizable-panels": "catalog:",
    "recharts": "catalog:",
    "remark-breaks": "catalog:",
