{
  "name": "academorix/activity",
  "type": "library",
  "description": "Tenant-facing activity feed. Thin wrapper around spatie/laravel-activitylog with our conventions: tenant scoping via BelongsToTenant global scope, ULID prefix `act_`, tier-based retention (30 / 90 / 365 days per plan), causer resolution from Sanctum. Publishes the `HasActivityLog` trait (aliases spatie's LogsActivity + adds our defaults) and `#[LoggableActivity]` attribute for build-time discovery of models that opt in. Distinct from the audit module — activity is product UX; audit is compliance evidence.",
  "license": "proprietary",
  "keywords": [
    "academorix",
    "laravel",
    "activity",
    "activity-log",
    "spatie",
    "product-feed",
    "tenant-facing",
    "who-did-what"
  ],
  "require": {
    "php": "^8.3",
    "academorix/authorization": "@dev",
    "academorix/console": "@dev",
    "academorix/crud": "@dev",
    "academorix/database": "@dev",
    "academorix/enum": "@dev",
    "academorix/events": "@dev",
    "academorix/exceptions": "@dev",
    "academorix/foundation": "@dev",
    "academorix/retention": "@dev",
    "academorix/routing": "@dev",
    "academorix/service-provider": "@dev",
    "academorix/support": "@dev",
    "academorix/tenancy": "@dev",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/events": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/queue": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "spatie/laravel-activitylog": "^4.10",
    "spatie/laravel-data": "^4.11"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Academorix\\Activity\\": "src/",
      "Academorix\\Activity\\Database\\Factories\\": "database/factories/",
      "Academorix\\Activity\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Academorix\\Activity\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Academorix\\Activity\\Providers\\ActivityServiceProvider"
      ],
      "aliases": {}
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
