{
  "name": "academorix/notifications-sms",
  "type": "library",
  "description": "SMS notification channel. Owns the SmsOptOut entity (TCPA + CASL evidence-grade unsubscribe records) + a MultipleInstanceManager wrapping Twilio / MessageBird / Vonage / Plivo / AWS SNS. Handles STOP-keyword inbound via the webhook module. Tracks per-message cost + destination-country pricing. Cost-cap entitlement prevents runaway spend.",
  "license": "proprietary",
  "keywords": [
    "academorix",
    "laravel",
    "notifications",
    "sms",
    "text-messaging",
    "twilio",
    "messagebird",
    "vonage",
    "plivo",
    "aws-sns",
    "tcpa",
    "casl",
    "stop-keyword",
    "cost-tracking"
  ],
  "require": {
    "php": "^8.3",
    "academorix/authorization": "@dev",
    "academorix/console": "@dev",
    "academorix/crud": "@dev",
    "academorix/database": "@dev",
    "academorix/enum": "@dev",
    "academorix/events": "@dev",
    "academorix/exceptions": "@dev",
    "academorix/foundation": "@dev",
    "academorix/notifications": "@dev",
    "academorix/retention": "@dev",
    "academorix/routing": "@dev",
    "academorix/service-provider": "@dev",
    "academorix/support": "@dev",
    "academorix/tenancy": "@dev",
    "academorix/webhook": "@dev",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/events": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/queue": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "spatie/laravel-data": "^4.11"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Academorix\\Notifications\\Sms\\": "src/",
      "Academorix\\Notifications\\Sms\\Database\\Factories\\": "database/factories/",
      "Academorix\\Notifications\\Sms\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Academorix\\Notifications\\Sms\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Academorix\\Notifications\\Sms\\Providers\\NotificationsSmsServiceProvider"
      ],
      "aliases": {}
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
