{
  "name": "@academorix/realtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Realtime transport + React hooks for the Academorix workspace. Wraps Laravel Reverb via Laravel Echo + pusher-js (lazy-loaded to keep the initial bundle small). Ships useChannel / usePrivateChannel / usePresenceChannel hooks + a Refine LiveProvider adapter for the dashboard.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client/index.ts",
    "./hooks": "./src/hooks/index.ts",
    "./refine": "./src/refine/index.ts",
    "./context": "./src/context/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf .turbo"
  },
  "dependencies": {
    "@academorix/core": "workspace:*"
  },
  "peerDependencies": {
    "laravel-echo": "catalog:",
    "pusher-js": "catalog:",
    "react": "catalog:"
  },
  "peerDependenciesMeta": {
    "laravel-echo": {
      "optional": true
    },
    "pusher-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@academorix/eslint-config": "workspace:*",
    "@academorix/typescript-config": "workspace:*",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/react": "catalog:",
    "eslint": "catalog:",
    "jsdom": "catalog:",
    "laravel-echo": "catalog:",
    "pusher-js": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
