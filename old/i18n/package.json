{
  "name": "@academorix/i18n",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Locale primitives + React runtime (LocaleProvider, useLocale, RTL detection, Intl formatters, MessageCatalog contract) for the Academorix workspace. Each app instantiates a typed kit bound to its concrete locale tuple via createLocaleContext<T>().",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./config": "./src/config/index.ts",
    "./context": "./src/context/index.ts",
    "./format": "./src/format/index.ts",
    "./messages": "./src/messages/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf .turbo"
  },
  "dependencies": {
    "@academorix/core": "workspace:*"
  },
  "peerDependencies": {
    "react": "catalog:"
  },
  "devDependencies": {
    "@academorix/eslint-config": "workspace:*",
    "@academorix/config-tsconfig": "workspace:*",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/react": "catalog:",
    "eslint": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
