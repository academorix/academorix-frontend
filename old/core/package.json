{
  "name": "@academorix/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Zero-dependency foundation for the Academorix workspace: env<T> reader, defineConfig<T> passthrough, ID brand utilities, HttpError, and other primitives shared by every @academorix/* package.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./env": "./src/env/index.ts",
    "./config": "./src/config/index.ts",
    "./errors": "./src/errors/index.ts",
    "./brand": "./src/brand/index.ts",
    "./utils": "./src/utils/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf .turbo"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@academorix/eslint-config": "workspace:*",
    "@academorix/config-tsconfig": "workspace:*",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
