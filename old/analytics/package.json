{
  "name": "@academorix/analytics",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Analytics primitives for the Academorix workspace: adapter interface, AnalyticsProvider + useAnalytics factory, defineEvents passthrough, and pluggable console/Vercel/PostHog/Sentry adapters. Event registry stays per-app; adapters and hooks stay shared.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./config": "./src/config/index.ts",
    "./context": "./src/context/index.ts",
    "./adapters": "./src/adapters/index.ts",
    "./adapters/console": "./src/adapters/console.adapter.ts",
    "./adapters/vercel": "./src/adapters/vercel.adapter.ts",
    "./adapters/posthog": "./src/adapters/posthog.adapter.ts",
    "./adapters/sentry": "./src/adapters/sentry.adapter.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf .turbo"
  },
  "dependencies": {
    "@academorix/core": "workspace:*"
  },
  "peerDependencies": {
    "react": "catalog:"
  },
  "devDependencies": {
    "@academorix/eslint-config": "workspace:*",
    "@academorix/config-tsconfig": "workspace:*",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/react": "catalog:",
    "eslint": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
