{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "stackra/api",
  "type": "project",
  "description": "Stackra headless tenant API — Laravel Octane runtime for the ~90 backend packages.",
  "keywords": [
    "stackra",
    "api",
    "laravel",
    "octane"
  ],
  "license": "proprietary",
  "require": {
    "php": "^8.3",
    "laravel/framework": "^13.8",
    "laravel/tinker": "^3.0",
    "laravel/octane": "^2.10",
    "laravel/horizon": "^5.34",
    "laravel/sanctum": "^4.0",
    "stackra-observability/activity": "@dev",
    "stackra-observability/audit": "@dev",
    "stackra-shared/foundation": "@dev",
    "stackra/admin-console": "@dev",
    "stackra/ai": "@dev",
    "stackra/announcements": "@dev",
    "stackra/application": "@dev",
    "stackra/approvals": "@dev",
    "stackra/architecture": "@dev",
    "stackra/attributes": "@dev",
    "stackra/auth": "@dev",
    "stackra/authorization": "@dev",
    "stackra/branch": "@dev",
    "stackra/branding": "@dev",
    "stackra/caching": "@dev",
    "stackra/compliance": "@dev",
    "stackra/console": "@dev",
    "stackra/container": "@dev",
    "stackra/credentials": "@dev",
    "stackra/crud": "@dev",
    "stackra/database": "@dev",
    "stackra/debugbar": "@dev",
    "stackra/delegation": "@dev",
    "stackra/domains": "@dev",
    "stackra/entitlements": "@dev",
    "stackra/enum": "@dev",
    "stackra/events": "@dev",
    "stackra/exceptions": "@dev",
    "stackra/facility": "@dev",
    "stackra/feature-flags": "@dev",
    "stackra/forms": "@dev",
    "stackra/foundation": "@dev",
    "stackra/geography": "@dev",
    "stackra/grants": "@dev",
    "stackra/health": "@dev",
    "stackra/horizon": "@dev",
    "stackra/identity": "@dev",
    "stackra/integrations": "@dev",
    "stackra/invitations": "@dev",
    "stackra/localization": "@dev",
    "stackra/messaging": "@dev",
    "stackra/mfa": "@dev",
    "stackra/monitoring": "@dev",
    "stackra/newsletter": "@dev",
    "stackra/nightwatch": "@dev",
    "stackra/notifications": "@dev",
    "stackra/notifications-in-app": "@dev",
    "stackra/notifications-mail": "@dev",
    "stackra/notifications-push": "@dev",
    "stackra/notifications-sms": "@dev",
    "stackra/offline-sync": "@dev",
    "stackra/organization": "@dev",
    "stackra/people": "@dev",
    "stackra/platform-user": "@dev",
    "stackra/public-site": "@dev",
    "stackra/rbac": "@dev",
    "stackra/realtime": "@dev",
    "stackra/reception": "@dev",
    "stackra/region": "@dev",
    "stackra/reporting": "@dev",
    "stackra/requests": "@dev",
    "stackra/retention": "@dev",
    "stackra/routing": "@dev",
    "stackra/scheduling": "@dev",
    "stackra/scope": "@dev",
    "stackra/search": "@dev",
    "stackra/sentry": "@dev",
    "stackra/serializer": "@dev",
    "stackra/service-accounts": "@dev",
    "stackra/service-provider": "@dev",
    "stackra/settings": "@dev",
    "stackra/staff": "@dev",
    "stackra/storage": "@dev",
    "stackra/subscription": "@dev",
    "stackra/support": "@dev",
    "stackra/tasks": "@dev",
    "stackra/teams": "@dev",
    "stackra/tenancy": "@dev",
    "stackra/theme": "@dev",
    "stackra/transfer": "@dev",
    "stackra/user": "@dev",
    "stackra/versioning": "@dev",
    "stackra/webhook": "@dev"
  },
  "require-dev": {
    "fakerphp/faker": "^1.23",
    "laravel/boost": "^2.2",
    "laravel/pail": "^1.2",
    "laravel/pint": "^1.27",
    "larastan/larastan": "^3.0",
    "mockery/mockery": "^1.6",
    "nunomaduro/collision": "^8.6",
    "pestphp/pest": "^4.7",
    "pestphp/pest-plugin-laravel": "^4.1",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Academorix\\Api\\": "src/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "test": "Stackra\\Foundation\\Scripts\\TestScripts::run",
    "test:coverage": "Stackra\\Foundation\\Scripts\\TestScripts::coverage",
    "test:parallel": "Stackra\\Foundation\\Scripts\\TestScripts::parallel",
    "test:filter": "Stackra\\Foundation\\Scripts\\TestScripts::filter",
    "analyse": "Stackra\\Foundation\\Scripts\\AnalyseScripts::run",
    "analyse:baseline": "Stackra\\Foundation\\Scripts\\AnalyseScripts::baseline",
    "lint": "Stackra\\Foundation\\Scripts\\LintScripts::check",
    "lint:fix": "Stackra\\Foundation\\Scripts\\LintScripts::fix",
    "cache:clear": "doppler run -- php artisan cache:flush",
    "cache:warm": "doppler run -- php artisan cache:build",
    "db:migrate": "Stackra\\Foundation\\Scripts\\DatabaseScripts::migrate",
    "db:migrate:fresh": "Stackra\\Foundation\\Scripts\\DatabaseScripts::fresh",
    "db:migrate:rollback": "Stackra\\Foundation\\Scripts\\DatabaseScripts::rollback",
    "db:migrate:status": "Stackra\\Foundation\\Scripts\\DatabaseScripts::status",
    "db:seed": "Stackra\\Foundation\\Scripts\\DatabaseScripts::seed",
    "db:reset": "Stackra\\Foundation\\Scripts\\DatabaseScripts::reset",
    "db:wipe": "Stackra\\Foundation\\Scripts\\DatabaseScripts::wipe",
    "db:show": "Stackra\\Foundation\\Scripts\\DatabaseScripts::show",
    "dev": [
      "Composer\\Config::disableProcessTimeout",
      "doppler run -- npx concurrently -c '#93c5fd,#c4b5fd,#fb7185' 'php artisan octane:start --watch' 'php artisan queue:listen --tries=1 --timeout=0' 'php artisan pail --timeout=0' --names=server,queue,logs --kill-others"
    ],
    "serve": "doppler run -- php artisan octane:start",
    "queue": "doppler run -- php artisan queue:work",
    "horizon": "doppler run -- php artisan horizon"
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "php-http/discovery": true,
      "olvlvl/composer-attribute-collector": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
