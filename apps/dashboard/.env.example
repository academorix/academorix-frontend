# -----------------------------------------------------------------------------
# refine-heroui-pro — environment variables
# -----------------------------------------------------------------------------
#
# Every VITE_* var here is exposed to the browser at build time. Real values
# live in Doppler under the `academorix-dashboard` project (configs: `dev`,
# `stg`, `prd`). Local dev pulls them via `doppler run -- pnpm dev` or
# `doppler run -- pnpm build`.
#
# Firebase's security model treats the web `apiKey` and `messagingSenderId`
# as public — they ship in every JS bundle. Access control is enforced by
# Firebase Auth + Security Rules, not by hiding these values. Still, we
# route them through Doppler for env parity + rotation.
#
# The DASHBOARD-side keys below are the *client* Firebase config. The
# backend's service account JSON (which IS a secret) lives on the
# `academorix-backend` Doppler project as `FIREBASE_CREDENTIALS`.
# -----------------------------------------------------------------------------

# --- API endpoints -----------------------------------------------------------
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=Academorix
VITE_APP_ENV=local
VITE_MARKETING_URL=http://localhost:3001
VITE_CENTRAL_HOST=localhost
VITE_PLATFORM_ADMIN_HOST=admin.localhost

# --- Laravel Reverb (WebSockets) ---------------------------------------------
VITE_REVERB_APP_KEY=academorix-local-key
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

# --- Firebase Cloud Messaging (FCM) ------------------------------------------
# Web SDK config from the Firebase Console → Project settings → Your apps →
# Web app. All values are technically public in Firebase's model; centralised
# in Doppler for env parity.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Web push VAPID public key. Generate under Cloud Messaging → Web
# configuration → Web push certificates. Required by `getToken()` on the
# JS side; passed through verbatim.
VITE_FIREBASE_VAPID_KEY=
