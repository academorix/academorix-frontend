# Copy this file to `.env` for local development:
#   cp environments/.env.example environments/.env
#
# Every variable is exposed to the browser bundle and MUST be prefixed VITE_.
# Do not put secrets here — anything here ships to the client.

# --- Application ---
VITE_APP_NAME=Academorix
VITE_APP_ENV=local

# --- Backend REST API ---
VITE_API_URL=http://localhost:8000

# --- Laravel Reverb (WebSockets) — public client credentials ---
VITE_REVERB_APP_KEY=academorix-local-key
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

# --- Web Push (VAPID public key, base64url-encoded) ---
# Optional — required only when the `WEB_PUSH` feature flag is on. The
# push flow first attempts `GET /api/v1/config/vapid` (endpoint
# currently a backend gap — see notifications module); this
# variable acts as the deploy-time fallback. Generate one with:
#   npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=
