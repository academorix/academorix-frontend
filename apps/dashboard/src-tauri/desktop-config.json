{
  "$comment": "GENERATED FILE - do not edit by hand. Run 'pnpm --filter @academorix/dashboard sync:desktop-config' to regenerate from src/config/desktop.config.ts. This snapshot is consumed by src-tauri/build.rs at compile time so the Rust shell and the SPA agree on window sizing, tray items, updater endpoint, and security posture.",
  "app": {
    "protocol": "academorix",
    "globalShortcut": "CmdOrCtrl+Shift+A"
  },
  "window": {
    "default": {
      "width": 1440,
      "height": 900,
      "minWidth": 1024,
      "minHeight": 720,
      "resizable": true,
      "transparent": false,
      "decorations": true,
      "focus": true
    },
    "restoreState": true,
    "closeBehaviour": "quit"
  },
  "tray": {
    "enabled": true,
    "items": [
      {
        "id": "tray.open",
        "labelKey": "desktop.tray.open",
        "section": "actions"
      },
      {
        "id": "tray.new_athlete",
        "labelKey": "desktop.tray.new_athlete",
        "section": "navigation"
      },
      {
        "id": "tray.new_session",
        "labelKey": "desktop.tray.new_session",
        "section": "navigation"
      },
      {
        "id": "tray.check_updates",
        "labelKey": "desktop.tray.check_updates",
        "section": "system"
      },
      {
        "id": "tray.sign_out",
        "labelKey": "desktop.tray.sign_out",
        "section": "system"
      },
      {
        "id": "tray.quit",
        "labelKey": "desktop.tray.quit",
        "section": "system"
      }
    ]
  },
  "updater": {
    "enabled": true,
    "feedUrl": "https://updates.academorix.com/dashboard/{target}/{arch}/{current-version}",
    "intervalMs": 14400000,
    "publicKey": ""
  },
  "security": {
    "allowFileDrop": false,
    "allowedShellUrls": [
      "https://academorix.com/*",
      "https://academorix.app/*",
      "https://docs.academorix.com/*",
      "mailto:*"
    ]
  },
  "logging": {
    "level": "info"
  }
}
