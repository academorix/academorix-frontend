{
  "name": "@academorix/dashboard",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "codegen": "openapi-typescript ${ACADEMORIX_OPENAPI_URL:-http://localhost:8000/api/openapi.json} --output ./src/lib/api/schema.d.ts",
    "generate-pwa-assets": "pwa-assets-generator --preset minimal-2023 public/favicon.svg",
    "sync:desktop-config": "node scripts/sync-desktop-config.mjs",
    "tauri": "tauri",
    "tauri:dev": "pnpm sync:desktop-config && tauri dev",
    "tauri:build": "pnpm sync:desktop-config && tauri build",
    "tauri:build:debug": "pnpm sync:desktop-config && tauri build --debug",
    "clean": "rm -rf dist coverage .turbo dev-dist src-tauri/target src-tauri/gen"
  },
  "dependencies": {
    "@academorix/analytics": "workspace:*",
    "@academorix/core": "workspace:*",
    "@academorix/feature-flags": "workspace:*",
    "@academorix/http": "workspace:*",
    "@academorix/i18n": "workspace:*",
    "@academorix/notifications": "workspace:*",
    "@academorix/pwa": "workspace:*",
    "@academorix/query": "workspace:*",
    "@academorix/realtime": "workspace:*",
    "@academorix/ui": "workspace:*",
    "@heroui-pro/react": "catalog:",
    "@heroui/styles": "catalog:",
    "@refinedev/core": "catalog:",
    "@refinedev/react-router": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tauri-apps/api": "catalog:",
    "laravel-echo": "catalog:",
    "openapi-fetch": "catalog:",
    "pusher-js": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-grid-layout": "catalog:",
    "react-router": "catalog:",
    "web-vitals": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@academorix/eslint-config": "workspace:*",
    "@academorix/typescript-config": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "@tauri-apps/cli": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-grid-layout": "catalog:",
    "@vite-pwa/assets-generator": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "jsdom": "catalog:",
    "openapi-typescript": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-pwa": "catalog:",
    "vitest": "catalog:",
    "workbox-window": "catalog:"
  }
}
