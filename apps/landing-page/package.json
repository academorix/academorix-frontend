{
  "name": "@academorix/landing-page",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Public marketing surface for Academorix (landing, pricing, self-serve tenant onboarding). Next.js 16 App Router + HeroUI v3 + Tailwind v4.",
  "scripts": {
    "dev": "next dev",
    "dev:fresh": "rm -rf .next .turbo && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.sw.json --noEmit",
    "generate-pwa-assets": "pwa-assets-generator",
    "clean": "rm -rf .next .turbo out"
  },
  "dependencies": {
    "@academorix/ui": "workspace:*",
    "@heroui-pro/react": "catalog:",
    "@heroui/react": "catalog:",
    "@heroui/styles": "catalog:",
    "clsx": "catalog:",
    "intl-messageformat": "catalog:",
    "next": "catalog:",
    "next-intl": "catalog:",
    "next-themes": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwind-variants": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@academorix/eslint-config": "workspace:*",
    "@academorix/typescript-config": "workspace:*",
    "@eslint/compat": "catalog:",
    "@eslint/eslintrc": "catalog:",
    "@next/bundle-analyzer": "^16.2.10",
    "@next/eslint-plugin-next": "catalog:",
    "@serwist/turbopack": "catalog:",
    "@tailwindcss/postcss": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vite-pwa/assets-generator": "catalog:",
    "esbuild": "catalog:",
    "eslint": "catalog:",
    "eslint-config-next": "catalog:",
    "postcss": "^8.5.6",
    "serwist": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  }
}
