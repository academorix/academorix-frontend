{
  "min-length": {
    "id": "min-length",
    "label": {
      "en": "At least 12 characters",
      "ar": "لا يقل عن 12 حرفاً"
    },
    "test": "min_length",
    "min": 12
  },
  "uppercase": {
    "id": "uppercase",
    "label": {
      "en": "One uppercase letter",
      "ar": "حرف كبير واحد"
    },
    "test": "[A-Z]"
  },
  "lowercase": {
    "id": "lowercase",
    "label": {
      "en": "One lowercase letter",
      "ar": "حرف صغير واحد"
    },
    "test": "[a-z]"
  },
  "digit": {
    "id": "digit",
    "label": {
      "en": "One number",
      "ar": "رقم واحد"
    },
    "test": "\\d"
  },
  "special": {
    "id": "special",
    "label": {
      "en": "One special character",
      "ar": "رمز خاص واحد"
    },
    "test": "[^A-Za-z0-9]"
  }
}
