# Marketing app — env template.
# Copy to `environments/.env` for local dev; set the real values in Vercel
# for staging/production.

# ─── Core URLs ─────────────────────────────────────────────────────

# Where the tenant SPA lives. Every "Sign in" / "Get started" CTA opens
# this. Local dev: SPA runs at 3000, marketing at 3001. Production:
# https://dashboard-academorix.vercel.app.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# The marketing app's own canonical origin. Used for OG images + sitemap.
NEXT_PUBLIC_MARKETING_URL=http://localhost:3001

# Backend API origin. Only used server-side by the future pricing catalog
# fetch (currently the catalog is static in config/plans.ts).
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ─── Observability (all env-gated; absence = subsystem off) ────────

# Sentry project DSN. When set, boots the client + server + edge
# Sentry SDKs plus the `global-error.tsx` fatal-error reporter. Empty
# in dev keeps every SDK quiet.
NEXT_PUBLIC_SENTRY_DSN=

# Sentry environment tag. Defaults to NODE_ENV when unset.
# Recommended values: production / staging / preview / development.
NEXT_PUBLIC_SENTRY_ENV=

# Sampling rates. Both accept a 0..1 decimal.
# TRACES_RATE controls transaction (span) sampling. Default 0.1.
# REPLAY_RATE controls session-replay sampling on error sessions.
# Session replay only fires on sessions that already had an error;
# healthy sessions never carry a replay.
NEXT_PUBLIC_SENTRY_TRACES_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAY_RATE=0.1

# OpenTelemetry service name. When set, boots @vercel/otel and emits
# spans across Route Handlers, Server Components, and Server Actions.
# Recommended: academorix-landing-page-production.
OTEL_SERVICE_NAME=

# pino log level for the server-side logger. Default: info in prod,
# debug in dev. Options: trace / debug / info / warn / error / fatal.
LOG_LEVEL=
