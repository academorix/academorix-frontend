{
  "id": "stackra://modules/safeguarding/policies",
  "$version": 1,
  "title": "safeguarding — authorization policies",
  "description": "TWO policies. Incidents are HIGHLY sensitive — investigator + safeguarding officer + owner only. Any other viewer requires explicit case-access grant (per-incident ACL). StaffCheck view scoped to check subject + branch_manager + admin.",
  "policies": [
    {
      "model": "Incident",
      "class": "Stackra\\Platform\\Safeguarding\\Policies\\IncidentPolicy",
      "abilities": [
        {
          "action": "viewAny",
          "permission": "safeguarding.incidents.viewAny",
          "scope": "safeguarding officer + owner only"
        },
        {
          "action": "view",
          "permission": "safeguarding.incidents.view",
          "scope": "reporter + investigator + safeguarding officer + owner + case-access grantees"
        },
        {
          "action": "report",
          "permission": "safeguarding.incidents.report",
          "scope": "any authenticated staff / parent / athlete"
        },
        {
          "action": "openInvestigation",
          "permission": "safeguarding.incidents.investigate",
          "scope": "safeguarding officer only"
        },
        {
          "action": "resolve",
          "permission": "safeguarding.incidents.resolve",
          "scope": "safeguarding officer + owner"
        },
        {
          "action": "escalate",
          "permission": "safeguarding.incidents.escalate",
          "scope": "safeguarding officer + owner. External reporting"
        },
        {
          "action": "grantCaseAccess",
          "permission": "safeguarding.incidents.grant-access",
          "scope": "safeguarding officer + owner only. Full audit chain"
        }
      ]
    },
    {
      "model": "StaffCheck",
      "class": "Stackra\\Platform\\Safeguarding\\Policies\\StaffCheckPolicy",
      "abilities": [
        {
          "action": "viewAny",
          "permission": "safeguarding.staff-checks.viewAny",
          "scope": "branch_manager + admin + owner + safeguarding officer"
        },
        {
          "action": "view",
          "permission": "safeguarding.staff-checks.view",
          "scope": "check subject (own) + branch_manager + admin + owner + safeguarding officer"
        },
        {
          "action": "create",
          "permission": "safeguarding.staff-checks.create",
          "scope": "branch_manager + admin + owner"
        },
        {
          "action": "update",
          "permission": "safeguarding.staff-checks.update",
          "scope": "admin + owner. Kind / expiry changes only"
        },
        {
          "action": "renew",
          "permission": "safeguarding.staff-checks.renew",
          "scope": "branch_manager + admin + owner"
        }
      ]
    }
  ]
}
