{
  "name": "academorix/geofencing",
  "type": "library",
  "description": "Model-agnostic point-in-polygon primitive. Any Eloquent model can carry a geofence by using the HasGeofence trait + declaring itself with the #[Geofenceable] attribute. Owns the audited GeofenceCheck log (immutable, insert-only, `gfc_` prefix). Ships the polygon + radius evaluator, override flow, mobile pre-flight endpoint, and Spatie Health probes.",
  "license": "proprietary",
  "keywords": [
    "academorix",
    "laravel",
    "geofencing",
    "geofence",
    "point-in-polygon",
    "polygon",
    "radius",
    "haversine",
    "postgis",
    "magellan",
    "spinen-geometry",
    "polymorphic",
    "model-agnostic",
    "attendance",
    "clock-in",
    "check-in",
    "spatial",
    "audit-log",
    "trait"
  ],
  "require": {
    "php": "^8.3",
    "stackra/authorization": "@dev",
    "stackra/console": "@dev",
    "stackra/crud": "@dev",
    "stackra/database": "@dev",
    "stackra/enum": "@dev",
    "stackra/events": "@dev",
    "stackra/exceptions": "@dev",
    "stackra/foundation": "@dev",
    "stackra/retention": "@dev",
    "stackra/routing": "@dev",
    "stackra/service-provider": "@dev",
    "stackra/support": "@dev",
    "stackra/tenancy": "@dev",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/events": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/queue": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "spatie/laravel-data": "^4.11"
  },
  "suggest": {
    "clickbar/laravel-magellan": "PostGIS spatial column types on Eloquent models (^0.7). Required for production polygon fences.",
    "spinen/laravel-geometry": "Runtime geometry math wrapping geoPHP (^3.0). Preferred over the hand-rolled fallback for precise polygon math.",
    "stackra/activity": "Activity feed integration — emits `geofence.evaluated` product-facing lines when installed.",
    "stackra/audit": "Compliance-grade audit trail integration."
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Academorix\\Geofencing\\": "src/",
      "Academorix\\Geofencing\\Database\\Factories\\": "database/factories/",
      "Academorix\\Geofencing\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Academorix\\Geofencing\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Stackra\\Geofencing\\Providers\\GeofencingServiceProvider"
      ],
      "aliases": {}
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "repositories": [
    {
      "type": "path",
      "url": "../../../../../../packages/backend/authorization",
      "options": {
        "symlink": true
      }
    },
    {
