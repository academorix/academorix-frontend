{
  "id": "referrals.resources.referral.list",
  "title": "Referrals",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/referrals",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "referrals", "entity": "referral", "action": "list" },
  "requiresPermission": "referrals.viewAny",
  "requiresEntitlement": "referrals_capture",
  "dataSources": [
    {
      "name": "referrals",
      "kind": "http.get",
      "url": "/api/v1/referrals",
      "unwrap": "data",
      "queryFromFilters": true
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-7xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "children": [
            {
              "kind": "Text",
              "props": {
                "as": "h1",
                "className": "text-2xl font-semibold",
                "children": "Referrals"
              }
            },
            {
              "kind": "Text",
              "props": {
                "className": "text-sm text-muted",
                "children": "Every tracked referrer × referred instance across every program."
              }
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "flex items-center gap-2 py-2 flex-wrap" },
          "children": [
            {
              "kind": "Widget",
              "widget": "referrals.program-picker",
              "props": { "label": "Program", "onlyActive": false },
              "actions": {
                "onSelectionChange": {
                  "kind": "filter.set",
                  "field": "program_id",
                  "valueExpr": "$payload.program_id"
                }
              }
            },
            {
              "kind": "ComboBox",
              "props": { "label": "Status", "menuTrigger": "focus" },
              "props_items": [
                { "id": "pending_claim", "label": "Pending claim" },
                { "id": "claimed", "label": "Claimed" },
                { "id": "signed_up", "label": "Signed up" },
                { "id": "trigger_pending", "label": "Trigger pending" },
                { "id": "vesting", "label": "Vesting" },
                { "id": "vested", "label": "Vested" },
                { "id": "rewarded", "label": "Rewarded" },
                { "id": "cancelled", "label": "Cancelled" },
                { "id": "expired", "label": "Expired" },
                { "id": "fraudulent", "label": "Fraudulent" }
              ],
              "actions": {
                "onSelectionChange": {
                  "kind": "filter.set",
                  "field": "status",
                  "valueExpr": "$selectedKey"
                }
              }
            },
            {
              "kind": "ComboBox",
              "props": { "label": "Has fraud flag?", "menuTrigger": "focus" },
              "props_items": [
                { "id": "true", "label": "Yes" },
                { "id": "false", "label": "No" }
              ],
              "actions": {
                "onSelectionChange": {
                  "kind": "filter.set",
                  "field": "has_fraud_flag",
                  "valueExpr": "$selectedKey"
                }
              }
            }
          ]
        },
        {
          "kind": "Table",
          "bindings": {
            "items": { "$ref": "referrals" },
            "isLoading": { "$ref": "referrals.isLoading" }
          },
          "columns": [
            {
              "key": "referrer",
              "label": "Referrer",
              "renderer": {
                "kind": "Text",
                "bindings": {
                  "children": { "$expr": "row.referrer?.display_name || row.referrer_id" }
                }
              }
            },
            {
              "key": "referred",
              "label": "Referred",
              "renderer": {
                "kind": "Text",
                "bindings": {
                  "children": {
                    "$expr": "row.referred?.display_name || row.referred_email || '—'"
                  }
                }
              }
            },
            {
              "key": "status",
              "label": "Status",
              "renderer": {
                "kind": "Widget",
                "widget": "referrals.referral-status-chip",
                "bindings": { "status": { "$ref": "row.status" }, "size": "xs" }
              }
            },
            {
              "key": "program",
              "label": "Program",
              "renderer": {
                "kind": "Text",
                "bindings": { "children": { "$ref": "row.program.name" } }
              }
            },
            {
              "key": "fraud_score",
              "label": "Fraud",
              "renderer": {
                "kind": "Chip",
                "bindings": {
                  "variant": {
                    "$expr": "row.fraud_score >= 90 ? 'danger' : (row.fraud_score >= 40 ? 'warning' : 'neutral')"
                  },
                  "size": "xs",
                  "children": { "$expr": "row.fraud_score + '/100'" }
                }
              }
            },
            { "key": "claimed_at", "label": "Claimed", "format": "date" }
          ],
          "rowAction": {
            "onPress": { "kind": "navigate", "toExpr": "'/tenant/referrals/' + row.id" }
          }
        }
      ]
    }
  ]
}
