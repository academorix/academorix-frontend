    "pinterest_capi": {
      "display_name": "Pinterest Conversions API",
      "requires_hashed_pii": true,
      "supports_negative_amounts": false,
      "supports": [
        "signup",
        "trial_converted",
        "subscription_started",
        "membership_purchased",
        "lead_captured",
        "cart_abandoned"
      ],
      "notes": "Focused on consumer-app conversions. Requires SHA256 email + phone."
    },
    "custom_webhook": {
      "display_name": "Custom Webhook (HMAC-signed JSON)",
      "requires_hashed_pii": false,
      "supports_negative_amounts": true,
      "supports": [
        "signup",
        "trial_started",
        "trial_ended",
        "trial_converted",
        "subscription_started",
        "subscription_upgraded",
        "subscription_downgraded",
        "subscription_cancelled",
        "membership_purchased",
        "lead_captured",
        "session_booked",
        "event_registered",
        "athlete_enrolled",
        "athlete_withdrawn",
        "cart_abandoned",
        "churn_predicted",
        "referral_completed",
        "refund_issued",
        "chargeback_filed",
        "feature_used_high_value",
        "demo_scheduled",
        "demo_attended",
        "newsletter_subscribed",
        "newsletter_unsubscribed",
        "contact_form_submitted",
        "app_install"
      ],
      "notes": "Universal support — the tenant's endpoint decides how to interpret each event. Payload is the full marketing_event row + attribution + consent snapshot as-is. HMAC-signed with hmac_secret."
    }
