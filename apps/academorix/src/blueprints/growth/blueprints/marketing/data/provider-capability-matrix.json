{
  "$version": 1,
  "title": "Provider × event type capability matrix",
  "description": "Which providers support which event_types. Read by the MarketingProviderConfigObserver's valid_enabled_event_types rule. A tenant's enabled_event_types must be a subset of this list for the chosen provider. The MarketingEventDispatcher's fan-out computation also reads this to determine eligible providers per event.",
  "providers": {
    "meta_capi": {
      "display_name": "Meta Conversions API",
      "requires_hashed_pii": true,
      "supports_negative_amounts": true,
      "supports": [
        "signup",
        "trial_started",
        "trial_ended",
        "trial_converted",
        "subscription_started",
        "subscription_upgraded",
        "subscription_cancelled",
        "membership_purchased",
        "lead_captured",
        "session_booked",
        "event_registered",
        "athlete_enrolled",
        "cart_abandoned",
        "referral_completed",
        "refund_issued",
        "demo_scheduled",
        "demo_attended",
        "newsletter_subscribed",
        "contact_form_submitted",
        "app_install"
      ],
      "notes": "Widest support in the catalogue. Requires SHA256 email + phone. Supports negative amounts for refund_issued."
    },
    "google_ads": {
      "display_name": "Google Ads Enhanced Conversions",
      "requires_hashed_pii": true,
      "supports_negative_amounts": true,
      "supports": [
        "signup",
        "trial_started",
        "trial_converted",
        "subscription_started",
        "subscription_upgraded",
        "subscription_cancelled",
        "membership_purchased",
        "lead_captured",
        "session_booked",
        "event_registered",
        "cart_abandoned",
        "referral_completed",
        "refund_issued",
        "chargeback_filed",
        "demo_scheduled",
        "demo_attended",
        "newsletter_subscribed",
        "contact_form_submitted",
        "app_install"
      ],
      "notes": "Requires gclid for click-based attribution. Enhanced Conversions Upload endpoint accepts SHA256 email."
    },
    "google_analytics_4": {
      "display_name": "GA4 Measurement Protocol",
      "requires_hashed_pii": false,
      "supports_negative_amounts": true,
      "supports": [
        "signup",
        "trial_started",
        "trial_ended",
        "trial_converted",
        "subscription_started",
        "subscription_upgraded",
        "subscription_downgraded",
        "subscription_cancelled",
        "membership_purchased",
        "lead_captured",
        "session_booked",
        "event_registered",
        "athlete_enrolled",
        "athlete_withdrawn",
        "cart_abandoned",
        "churn_predicted",
        "referral_completed",
        "refund_issued",
        "chargeback_filed",
        "feature_used_high_value",
        "demo_scheduled",
        "demo_attended",
        "newsletter_subscribed",
        "newsletter_unsubscribed",
        "contact_form_submitted",
        "app_install"
      ],
      "notes": "Universal support — GA4's event contract accepts any named event. Client_id + user_id passed raw (identifiers, not PII)."
    },
    "gtm_server": {
      "display_name": "Google Tag Manager Server-side",
      "requires_hashed_pii": false,
      "supports_negative_amounts": true,
      "supports": [
        "signup",
        "trial_started",
        "trial_ended",
        "trial_converted",
        "subscription_started",
        "subscription_upgraded",
        "subscription_downgraded",
        "subscription_cancelled",
        "membership_purchased",
        "lead_captured",
        "session_booked",
        "event_registered",
        "athlete_enrolled",
        "athlete_withdrawn",
        "cart_abandoned",
        "churn_predicted",
        "referral_completed",
        "refund_issued",
        "chargeback_filed",
        "feature_used_high_value",
        "demo_scheduled",
        "demo_attended",
        "newsletter_subscribed",
        "newsletter_unsubscribed",
        "contact_form_submitted",
        "app_install"
      ],
      "notes": "Universal support — the tenant's GTM Server container decides the downstream fan-out. Stackra delivers the canonical event shape + attribution + consent snapshot."
    },
    "tiktok_events": {
      "display_name": "TikTok Events API",
      "requires_hashed_pii": true,
      "supports_negative_amounts": false,
      "supports": [
        "signup",
        "trial_started",
        "trial_converted",
        "subscription_started",
        "membership_purchased",
        "lead_captured",
        "event_registered",
        "cart_abandoned",
        "referral_completed",
        "app_install"
      ],
      "notes": "Narrower catalogue — TikTok's Events API focuses on top + middle-funnel. Refunds and cancellations are NOT supported (does not support negative amounts)."
    },
    "linkedin_insight": {
      "display_name": "LinkedIn Insight Tag Conversions API",
      "requires_hashed_pii": true,
      "supports_negative_amounts": false,
      "supports": [
