{
  "id": "academorix://modules/analytics/routes",
  "$version": 1,
  "title": "analytics — HTTP routes",
  "description": "Two hosts: tenant (main admin surface) + platform-admin (cross-tenant support). Every route enforces analytics_capture entitlement + tenant.resolve middleware. Event + delivery routes are READ-only; provider + identity have full CRUD; funnel + experiment are report endpoints. No public endpoints \u2014 analytics ingestion is via the internal listener path, never via an HTTP verb from the browser (that's `@academorix/analytics` frontend's job).",
  "groups": [
    {
      "name": "tenant-events",
      "prefix": "/api/v1/analytics/events",
      "middleware": [
        "request.id",
        "cors.strict",
        "versioning.resolve",
        "auth:sanctum",
        "tenant.resolve",
        "entitlements.check:analytics_capture",
        "throttle:foundation-read",
        "response.envelope"
      ],
      "hosts": ["tenant"],
      "description": "Read-only inspection of analytics events.",
      "routes": [
        {
          "method": "GET",
          "path": "/",
          "controller": "Academorix\\Growth\\Analytics\\Http\\Controllers\\Tenant\\AnalyticsEventController@index",
          "permission": "analytics.events.viewAny"
        },
        {
          "method": "GET",
          "path": "/{event}",
          "controller": "Academorix\\Growth\\Analytics\\Http\\Controllers\\Tenant\\AnalyticsEventController@show",
          "permission": "analytics.events.view"
        }
      ]
    },
    {
      "name": "tenant-deliveries",
      "prefix": "/api/v1/analytics/deliveries",
      "middleware": [
        "request.id",
        "cors.strict",
        "versioning.resolve",
        "auth:sanctum",
        "tenant.resolve",
        "entitlements.check:analytics_capture",
        "throttle:foundation-read",
        "response.envelope"
      ],
      "hosts": ["tenant"],
      "description": "Read-only delivery log inspection.",
      "routes": [
        {
          "method": "GET",
          "path": "/",
          "controller": "Academorix\\Growth\\Analytics\\Http\\Controllers\\Tenant\\AnalyticsDeliveryController@index",
          "permission": "analytics.deliveries.viewAny"
        }
      ]
    },
    {
      "name": "tenant-providers",
      "prefix": "/api/v1/analytics/providers",
      "middleware": [
        "request.id",
        "cors.strict",
        "versioning.resolve",
        "auth:sanctum",
        "tenant.resolve",
        "entitlements.check:analytics_capture",
        "throttle:foundation-base",
        "response.envelope"
      ],
      "hosts": ["tenant"],
      "description": "CRUD + test + circuit-breaker reset for AnalyticsProviderConfig.",
      "routes": [
        {
          "method": "GET",
          "path": "/",
          "controller": "Academorix\\Growth\\Analytics\\Http\\Controllers\\Tenant\\AnalyticsProviderConfigController@index",
          "permission": "analytics.providers.viewAny"
        },
        {
          "method": "POST",
          "path": "/",
          "controller": "Academorix\\Growth\\Analytics\\Http\\Controllers\\Tenant\\AnalyticsProviderConfigController@store",
          "permission": "analytics.providers.create",
          "entitlements": ["analytics_provider_slot"],
          "description": "Consumes analytics_provider_slot; refused with 403 when no slot remaining."
        },
        {
          "method": "GET",
          "path": "/{provider}",
          "controller": "Academorix\\Growth\\Analytics\\Http\\Controllers\\Tenant\\AnalyticsProviderConfigController@show",
          "permission": "analytics.providers.view"
        },
        {
          "method": "PATCH",
          "path": "/{provider}",
          "controller": "Academorix\\Growth\\Analytics\\Http\\Controllers\\Tenant\\AnalyticsProviderConfigController@update",
          "permission": "analytics.providers.update"
        },
        {
          "method": "DELETE",
          "path": "/{provider}",
          "controller": "Academorix\\Growth\\Analytics\\Http\\Controllers\\Tenant\\AnalyticsProviderConfigController@destroy",
          "permission": "analytics.providers.delete",
          "description": "Soft-delete. Releases the analytics_provider_slot after the batch buffer drains."
        },
        {
          "method": "POST",
          "path": "/{provider}/test",
          "controller": "Academorix\\Growth\\Analytics\\Http\\Controllers\\Tenant\\AnalyticsProviderConfigController@test",
          "permission": "analytics.providers.test",
          "throttle": "custom:30,3600",
          "description": "Dispatches a synthetic test event. Rate-limited to 30 tests/hour."
        },
        {
          "method": "POST",
          "path": "/{provider}/reset-circuit-breaker",
          "controller": "Academorix\\Growth\\Analytics\\Http\\Controllers\\Tenant\\AnalyticsProviderConfigController@resetCircuitBreaker",
          "permission": "analytics.providers.reset_circuit_breaker",
          "description": "Manually forces circuit_breaker_state.state \u2192 closed. Emits an audit row + AnalyticsProviderCircuitBreakerClosed event."
        }
      ]
    },
    {
      "name": "tenant-identities",
      "prefix": "/api/v1/analytics/identities",
      "middleware": [
        "request.id",
        "cors.strict",
        "versioning.resolve",
        "auth:sanctum",
        "tenant.resolve",
        "entitlements.check:analytics_capture",
        "throttle:foundation-base",
        "response.envelope"
      ],
      "hosts": ["tenant"],
      "description": "Identity resolution surface. Merge is Enterprise-only.",
      "routes": [
        {
          "method": "GET",
          "path": "/",
          "controller": "Academorix\\Growth\\Analytics\\Http\\Controllers\\Tenant\\AnalyticsIdentityController@index",
          "permission": "analytics.identities.viewAny"
        },
        {
          "method": "POST",
          "path": "/{identity}/merge",
          "controller": "Academorix\\Growth\\Analytics\\Http\\Controllers\\Tenant\\AnalyticsIdentityController@merge",
          "permission": "analytics.identities.merge",
          "entitlements": ["analytics_identity_merge"],
          "description": "Merges one or more identities into this one. Enterprise-only entitlement."
        },
        {
          "method": "POST",
          "path": "/{identity}/identify",
          "controller": "Academorix\\Growth\\Analytics\\Http\\Controllers\\Tenant\\AnalyticsIdentityController@identify",
          "permission": "analytics.identities.identify",
          "description": "Server-side identify \u2014 associates an anonymous_id with a User.id."
        }
      ]
    },
    {
      "name": "tenant-funnels",
      "prefix": "/api/v1/analytics/funnels",
      "middleware": [
        "request.id",
        "cors.strict",
        "versioning.resolve",
        "auth:sanctum",
        "tenant.resolve",
        "entitlements.check:analytics_capture",
        "analytics.enforce_consent",
        "throttle:foundation-read",
        "response.envelope"
      ],
      "hosts": ["tenant"],
      "description": "Semantic funnel query surface. Reads events with category='funnel_step'.",
      "routes": [
        {
          "method": "GET",
          "path": "/{funnel_key}/report",
          "controller": "Academorix\\Growth\\Analytics\\Http\\Controllers\\Tenant\\AnalyticsFunnelController@report",
          "permission": "analytics.funnels.view"
        }
      ]
    },
    {
      "name": "tenant-experiments",
      "prefix": "/api/v1/analytics/experiments",
      "middleware": [
        "request.id",
        "cors.strict",
        "versioning.resolve",
        "auth:sanctum",
        "tenant.resolve",
        "entitlements.check:analytics_capture",
        "throttle:foundation-read",
        "response.envelope"
      ],
      "hosts": ["tenant"],
      "description": "A/B experiment results surface. Reads events with category='experiment'.",
      "routes": [
        {
          "method": "GET",
          "path": "/{experiment_key}/results",
          "controller": "Academorix\\Growth\\Analytics\\Http\\Controllers\\Tenant\\AnalyticsExperimentController@results",
          "permission": "analytics.experiments.view"
        }
      ]
    },
    {
      "name": "platform-support",
      "prefix": "/api/v1/platform/analytics",
      "middleware": [
        "request.id",
        "cors.strict",
        "versioning.resolve",
        "auth:platform_admin",
        "throttle:platform-base",
        "response.envelope"
      ],
      "hosts": ["platform-admin"],
      "description": "Cross-tenant support tooling for on-call.",
      "routes": [
        {
          "method": "GET",
          "path": "/deliveries",
          "controller": "Academorix\\Growth\\Analytics\\Http\\Controllers\\Platform\\AnalyticsDeliveryController@index",
          "permission": "analytics.deliveries.viewAny (platform_admin guard)"
        },
        {
          "method": "GET",
          "path": "/circuit-breakers",
          "controller": "Academorix\\Growth\\Analytics\\Http\\Controllers\\Platform\\AnalyticsCircuitBreakerController@index",
          "permission": "analytics.circuit_breakers.viewAny (platform_admin guard)",
          "description": "Cross-tenant view of every open + half-open circuit breaker. Sorted by opened_at desc."
        }
      ]
    }
  ]
}
