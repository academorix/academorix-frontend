{
  "id": "stackra://modules/analytics/data/providers/mixpanel",
  "$version": 1,
  "provider": "mixpanel",
  "displayName": "Mixpanel",
  "description": "Mixpanel product analytics + cohort + funnel + retention. Server-side /import endpoint.",
  "wire_protocol": {
    "endpoint_template": "https://api.mixpanel.com/import",
    "endpoint_eu": "https://api-eu.mixpanel.com/import",
    "http_method": "POST",
    "content_type": "application/json",
    "auth_scheme": "Basic (service_account_username:service_account_secret)",
    "note": "Mixpanel deprecated /track for server-side; /import is the canonical server-side endpoint."
  },
  "config_schema": {
    "type": "object",
    "required": [
      "project_token",
      "service_account_username",
      "service_account_secret",
      "project_id"
    ],
    "properties": {
      "project_token": {
        "type": "string",
        "description": "Mixpanel project token. Public identifier.",
        "minLength": 20,
        "maxLength": 128
      },
      "service_account_username": {
        "type": "string",
        "description": "Service account username for /import endpoint auth."
      },
      "service_account_secret": {
        "type": "string",
        "description": "Service account secret. Sensitive.",
        "minLength": 20
      },
      "project_id": {
        "type": "integer",
        "description": "Mixpanel project id (numeric)."
      },
      "region": {
        "type": "string",
        "enum": ["us", "eu"],
        "default": "us"
      },
      "strict_mode": {
        "type": "boolean",
        "default": true,
        "description": "Mixpanel /import strict mode \u2014 refuses events with missing $insert_id or invalid $device_id. Should be on to catch driver bugs."
      }
    },
    "additionalProperties": false
  },
  "test_event": {
    "event_kind": "track",
    "event_name": "test_event_from_stackra",
    "properties": {
      "__test": true,
      "$insert_id": "test-{ULID}",
      "source": "stackra_provider_test"
    }
  }
}
