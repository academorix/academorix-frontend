{
  "id": "analytics.analytics-sampling-indicator",
  "title": "Analytics sampling indicator",
  "version": 1,
  "kind": "SduiWidget",
  "description": "Small inline indicator showing configured sampling rate. Colour-coded: 100% green (all-through), 10-99% info, <10% warning, 0% muted. Consumed by provider list + delivery detail.",
  "props": {
    "samplingRate": { "type": "number", "description": "Sampling rate (0..1)." },
    "showLabel": { "type": "boolean", "default": true },
    "size": { "type": "string", "default": "sm", "enum": ["xs", "sm", "md"] }
  },
  "dataSources": [],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "inline-flex items-center gap-1" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "size-2 rounded-full" },
          "bindings": {
            "className": {
              "$expr": "'size-2 rounded-full ' + (props.samplingRate >= 1.0 ? 'bg-success' : (props.samplingRate >= 0.1 ? 'bg-info' : (props.samplingRate > 0 ? 'bg-warning' : 'bg-muted')))"
            },
            "title": { "$expr": "'Sampling rate: ' + Math.round(props.samplingRate * 100) + '%'" }
          }
        },
        {
          "kind": "Text",
          "props": { "className": "text-xs font-mono text-muted" },
          "bindings": {
            "hidden": { "$expr": "!props.showLabel" },
            "children": { "$expr": "Math.round(props.samplingRate * 100) + '%'" }
          }
        }
      ]
    }
  ]
}
