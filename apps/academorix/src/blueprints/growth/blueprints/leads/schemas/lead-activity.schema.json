{
  "id": "stackra://modules/leads/schemas/lead-activity",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "LeadActivity",
  "description": "Append-only timeline entry per Lead. One row per touchpoint (note, email, call, meeting, form submission, stage change, assignment, trial scheduled, trial attended). Belongs to Tenant + Lead (RESTRICT). NEVER carries application_id, region_id, organization_id, or scope_node_id.",
  "type": "object",
  "x-module": "leads",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "lead_activities",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "lea_",
    "incrementing": false,
    "model": "Stackra\\Growth\\Leads\\Models\\LeadActivity",
    "interface": "Stackra\\Growth\\Leads\\Contracts\\Data\\LeadActivityInterface",
    "implements": ["Stackra\\Growth\\Leads\\Contracts\\Data\\LeadActivityInterface"],
    "traits": [
      "HasFactory",
      "HasUlids",
      "BelongsToTenant",
      "BelongsToLead",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "Filterable"
    ],
    "casts": {
      "type": "LeadActivityType",
      "metadata": "array",
      "occurred_at": "datetime"
    },
    "observers": ["LeadActivityObserver"],
    "appends": ["is_system_generated"]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": {
        "type": "string",
        "length": 64,
        "primary": true,
        "description": "Prefixed ULID: `lea_<26>`."
      },
      "tenant_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "lead_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "leads", "column": "id", "onDelete": "cascade" }
      },
      "type": {
        "type": "string",
        "length": 32,
        "nullable": false,
        "description": "Enum: note / email / call / meeting / form_submission / stage_change / assignment / trial_scheduled / trial_attended."
      },
      "body": {
        "type": "text",
        "nullable": true,
        "description": "Free-text body. NULL for system-generated activities (stage_change, assignment) whose payload lives in metadata."
      },
      "metadata": {
        "type": "jsonb",
        "nullable": true,
        "description": "Activity-specific payload. Shape depends on type: { from_stage, to_stage } for stage_change; { from_owner_id, to_owner_id } for assignment; { email_id, subject, direction } for email; { call_id, duration_seconds, direction } for call; { meeting_id, scheduled_at, location } for meeting; { form_id, submission_id, fields } for form_submission; { trial_scheduled_at } for trial_scheduled."
      },
      "actor_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": { "table": "users", "column": "id", "onDelete": "set null" },
        "description": "The User whose action generated this activity. NULL when system-generated by a job (auto-reassignment, auto-stage-change)."
      },
      "occurred_at": {
        "type": "timestamptz",
        "nullable": false,
        "description": "When the touchpoint happened. Distinct from created_at — a coach can log a call that happened yesterday."
      },
      "created_by": { "type": "string", "length": 64, "nullable": true },
      "updated_by": { "type": "string", "length": 64, "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "lead_id", "occurred_at"],
        "name": "lead_activities_lead_time_idx"
      },
      { "columns": ["tenant_id", "type", "occurred_at"], "name": "lead_activities_type_time_idx" },
      {
        "columns": ["tenant_id", "actor_id", "occurred_at"],
        "name": "lead_activities_actor_time_idx",
        "predicate": "actor_id IS NOT NULL"
      }
    ]
  },
  "required": ["id", "tenant_id", "lead_id", "type", "occurred_at", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string", "pattern": "^lea_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": "string", "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "lead_id": { "type": "string", "pattern": "^led_[0-9A-HJKMNP-TV-Z]{26}$" },
    "type": {
      "type": "string",
      "enum": [
        "note",
        "email",
        "call",
        "meeting",
        "form_submission",
        "stage_change",
        "assignment",
        "trial_scheduled",
        "trial_attended"
      ]
    },
    "body": { "type": ["string", "null"] },
    "metadata": { "type": ["object", "null"] },
    "actor_id": { "type": ["string", "null"], "pattern": "^usr_[0-9A-HJKMNP-TV-Z]{26}$" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "x-invariants": [
    "APPEND-ONLY — updates are permitted only for body / metadata polish; type + lead_id + occurred_at IMMUTABLE post-create",
    "occurred_at <= now() (activities cannot be back-logged into the future)",
    "type='stage_change' requires metadata.from_stage AND metadata.to_stage set",
    "type='assignment' requires metadata.to_owner_id set",
    "hard-deletion is FORBIDDEN — activities cascade-delete only when the parent lead is hard-deleted"
  ]
}
