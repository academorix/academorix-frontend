{
  "id": "stackra://modules/geofencing/feature-flags",
  "$version": 1,
  "title": "geofencing \u2014 kill switches",
  "engine": "laravel/pennant",
  "flags": [
    {
      "key": "geofencing.evaluator_enabled",
      "kind": "kill-switch",
      "default": "on",
      "description": "Master evaluator switch. Off = GeofenceService::evaluate() returns ERROR result. Emergency only."
    },
    {
      "key": "geofencing.preflight_enabled",
      "kind": "kill-switch",
      "default": "on",
      "description": "Off = /preflight returns HTTP 503. Used during upstream vendor outages."
    },
    { "key": "geofencing.overrides_enabled", "kind": "kill-switch", "default": "on" },
    {
      "key": "geofencing.polygon_mode_enabled",
      "kind": "kill-switch",
      "default": "on",
      "description": "Off = evaluator falls back to radius mode even when the branch has a polygon."
    },
    {
      "key": "geofencing.metrics_recorder_enabled",
      "kind": "kill-switch",
      "default": "on",
      "description": "GeofenceMetricsRecorder listener. Off = no metric emission on GeofenceEvaluated."
    },
    {
      "key": "geofencing.retention_purge",
      "kind": "kill-switch",
      "default": "on",
      "description": "PurgeStaleGeofenceChecksJob execution."
    },
    { "key": "geofencing.immutability_reconcile", "kind": "kill-switch", "default": "on" }
  ]
}
