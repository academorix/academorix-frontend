{
  "id": "stackra://modules/medical/schemas/treatment",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "Treatment",
  "description": "Treatment record linked to an Injury — provider / date / notes (encrypted) / follow_up_at.",
  "type": "object",
  "x-module": "medical",
  "x-eloquent": {
    "table": "treatments",
    "keyPrefix": "trt_",
    "traits": [
      "HasFactory",
      "HasPrefixedUlid",
      "BelongsToTenant",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "EncryptsSensitiveFields",
      "Filterable",
      "SoftDeletes"
    ]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 30, "primary": true },
      "tenant_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "injury_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "injuries", "column": "id", "onDelete": "cascade" }
      },
      "administered_at": { "type": "timestamptz", "nullable": false },
      "provider_name_encrypted": { "type": "text", "nullable": true },
      "kind": {
        "type": "string",
        "length": 32,
        "nullable": false,
        "description": "physio / medication / rehab / consult / imaging / surgery / other."
      },
      "notes_encrypted": { "type": "text", "nullable": true },
      "follow_up_at": { "type": "timestamptz", "nullable": true },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false },
      "deleted_at": { "type": "timestamptz", "nullable": true }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "injury_id", "administered_at"],
        "name": "treatments_injury_time_idx"
      }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "injury_id",
    "administered_at",
    "kind",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^trt_[0-9A-HJKMNP-TV-Z]{26}$" }
  },
  "additionalProperties": false
}
