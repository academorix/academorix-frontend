{
  "id": "stackra://modules/medical/schemas/medical-clearance",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "MedicalClearance",
  "description": "Clearance certificate that gates match squad selection. issued_at + expires_at + scope (all_activities / limited / pending_review). Blocks squad selection when expired or an active injury exists.",
  "type": "object",
  "x-module": "medical",
  "x-eloquent": {
    "table": "medical_clearances",
    "keyPrefix": "mcl_",
    "traits": [
      "HasFactory",
      "HasPrefixedUlid",
      "BelongsToTenant",
      "BelongsToAthlete",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "HasActivityLog",
      "Filterable",
      "SoftDeletes"
    ]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 30, "primary": true },
      "tenant_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "athlete_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "athletes", "column": "id", "onDelete": "restrict" }
      },
      "issued_at": { "type": "timestamptz", "nullable": false },
      "expires_at": { "type": "timestamptz", "nullable": false },
      "issued_by_user_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "users", "column": "id", "onDelete": "restrict" }
      },
      "scope": { "type": "string", "length": 24, "nullable": false, "default": "'all_activities'" },
      "restrictions": {
        "type": "jsonb",
        "nullable": true,
        "description": "When scope=limited — array of restriction descriptors (no_contact / no_heading / no_running_more_than_20m / …)."
      },
      "document_id": {
        "type": "string",
        "length": 30,
        "nullable": true,
        "foreign": { "table": "files", "column": "id", "onDelete": "set null" }
      },
      "notes_encrypted": { "type": "text", "nullable": true },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false },
      "deleted_at": { "type": "timestamptz", "nullable": true }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "athlete_id", "expires_at"],
        "name": "clearances_athlete_expiry_idx"
      },
      {
        "columns": ["tenant_id", "expires_at"],
        "name": "clearances_expiring_idx",
        "predicate": "expires_at > NOW() - INTERVAL '90 days'"
      }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "athlete_id",
    "issued_at",
    "expires_at",
    "issued_by_user_id",
    "scope",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^mcl_[0-9A-HJKMNP-TV-Z]{26}$" },
    "scope": { "type": "string", "enum": ["all_activities", "limited", "pending_review"] }
  },
  "additionalProperties": false,
  "x-invariants": ["expires_at > issued_at.", "restrictions REQUIRED when scope = 'limited'."]
}
