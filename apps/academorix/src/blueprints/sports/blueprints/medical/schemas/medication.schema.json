{
  "id": "academorix://modules/medical/schemas/medication",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "Medication",
  "description": "Active medication — name / dosage / frequency / prescribing_provider / expires_at. Restricted to medical role + admin.",
  "type": "object",
  "x-module": "medical",
  "x-eloquent": {
    "table": "medications",
    "keyPrefix": "med_",
    "traits": [
      "HasFactory",
      "HasPrefixedUlid",
      "BelongsToTenant",
      "BelongsToAthlete",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "HasActivityLog",
      "EncryptsSensitiveFields",
      "Filterable",
      "SoftDeletes"
    ]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 30, "primary": true },
      "tenant_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "athlete_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "athletes", "column": "id", "onDelete": "cascade" }
      },
      "name_encrypted": { "type": "text", "nullable": false },
      "dosage_encrypted": { "type": "text", "nullable": true },
      "frequency": { "type": "string", "length": 64, "nullable": true },
      "prescribing_provider_encrypted": { "type": "text", "nullable": true },
      "started_at": { "type": "date", "nullable": true },
      "expires_at": { "type": "date", "nullable": true },
      "status": { "type": "string", "length": 16, "nullable": false, "default": "'active'" },
      "notes_encrypted": { "type": "text", "nullable": true },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false },
      "deleted_at": { "type": "timestamptz", "nullable": true }
    },
    "indexes": [
      { "columns": ["tenant_id", "athlete_id", "status"], "name": "medications_athlete_status_idx" }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "athlete_id",
    "name_encrypted",
    "status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^med_[0-9A-HJKMNP-TV-Z]{26}$" },
    "status": { "type": "string", "enum": ["active", "discontinued", "completed", "on_hold"] }
  },
  "additionalProperties": false
}
