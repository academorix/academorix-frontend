{
  "id": "stackra://modules/medical/schemas/allergy",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "Allergy",
  "description": "Allergen + severity + notes. Surfaced to coaches via allergy-summary read (redacted). Full detail restricted to medical role.",
  "type": "object",
  "x-module": "medical",
  "x-eloquent": {
    "table": "allergies",
    "keyPrefix": "alg_",
    "traits": [
      "HasFactory",
      "HasPrefixedUlid",
      "BelongsToTenant",
      "BelongsToAthlete",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "Filterable",
      "SoftDeletes"
    ]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 30, "primary": true },
      "tenant_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "athlete_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "athletes", "column": "id", "onDelete": "cascade" }
      },
      "allergen": { "type": "string", "length": 200, "nullable": false },
      "severity": { "type": "string", "length": 16, "nullable": false },
      "notes_encrypted": { "type": "text", "nullable": true },
      "reported_by_user_id": { "type": "string", "length": 30, "nullable": true },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false },
      "deleted_at": { "type": "timestamptz", "nullable": true }
    },
    "indexes": [{ "columns": ["tenant_id", "athlete_id"], "name": "allergies_athlete_idx" }]
  },
  "required": ["id", "tenant_id", "athlete_id", "allergen", "severity", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string", "pattern": "^alg_[0-9A-HJKMNP-TV-Z]{26}$" },
    "severity": { "type": "string", "enum": ["mild", "moderate", "severe", "life_threatening"] }
  },
  "additionalProperties": false
}
