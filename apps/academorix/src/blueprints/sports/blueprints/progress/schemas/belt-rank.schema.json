{
  "id": "stackra://modules/progress/schemas/belt-rank",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "BeltRank",
  "description": "Ordered martial-arts belt (or equivalent grading) per sport_key. Karate white → yellow → orange → … → black 1st-5th dan; judo, taekwondo similar. Feeds GradingResult.",
  "type": "object",
  "x-module": "progress",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "belt_ranks",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "blt_",
    "incrementing": false,
    "traits": [
      "HasFactory",
      "HasPrefixedUlid",
      "BelongsToTenant",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "Filterable",
      "SoftDeletes"
    ],
    "casts": { "labels": "array", "metadata": "array" }
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 30, "primary": true },
      "tenant_id": {
        "type": "string",
        "length": 30,
        "nullable": true,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" },
        "description": "Nullable — platform-default ranks (from sport registry) carry tenant_id=NULL and are visible everywhere."
      },
      "sport_key": { "type": "string", "length": 32, "nullable": false },
      "code": {
        "type": "string",
        "length": 32,
        "nullable": false,
        "description": "white / yellow / orange / green / blue / brown / black_1dan / black_2dan / …"
      },
      "labels": { "type": "jsonb", "nullable": false, "default": "'{}'" },
      "color_hex": {
        "type": "string",
        "length": 7,
        "nullable": true,
        "description": "Optional display color (#RRGGBB)."
      },
      "rank_order": {
        "type": "integer",
        "nullable": false,
        "description": "Monotonic ordering per sport_key. white=0, yellow=1, …, black_5dan=15."
      },
      "min_training_hours": { "type": "integer", "nullable": true },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_by": { "type": "string", "length": 30, "nullable": true },
      "updated_by": { "type": "string", "length": 30, "nullable": true },
      "deleted_at": { "type": "timestamptz", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "sport_key", "code"],
        "unique": true,
        "name": "belt_ranks_unique",
        "predicate": "deleted_at IS NULL"
      },
      { "columns": ["sport_key", "rank_order"], "name": "belt_ranks_order_idx" }
    ]
  },
  "required": ["id", "sport_key", "code", "labels", "rank_order", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string", "pattern": "^blt_[0-9A-HJKMNP-TV-Z]{26}$" },
    "sport_key": { "type": "string", "maxLength": 32 },
    "code": { "type": "string", "maxLength": 32 },
    "rank_order": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false,
  "x-invariants": [
    "rank_order monotonic per sport_key — enforced by application layer, no gaps expected."
  ]
}
