{
  "id": "stackra://modules/event/metrics",
  "$version": 1,
  "title": "event — OpenTelemetry metrics",
  "instrumentation": "self via telemetry",
  "namespace": "stackra.event",
  "labelConventions": {
    "always": [],
    "commonlyAvailable": ["event_type", "status", "visibility", "format", "trigger", "outcome"],
    "forbiddenAsLabels": ["event_id", "tenant_id", "primary_sport_key", "name", "slug"]
  },
  "metrics": [
    {
      "name": "stackra.event.created.total",
      "kind": "counter",
      "unit": "events",
      "labels": ["event_type", "visibility"]
    },
    {
      "name": "stackra.event.create.duration_ms",
      "kind": "histogram",
      "unit": "ms",
      "buckets": [50, 200, 1000, 5000],
      "labels": []
    },
    {
      "name": "stackra.event.status_transition.total",
      "kind": "counter",
      "unit": "transitions",
      "labels": ["from_status", "to_status", "trigger"]
    },
    {
      "name": "stackra.event.cancelled.total",
      "kind": "counter",
      "unit": "cancellations",
      "labels": ["cancellation_category"],
      "description": "cancellation_category derived from cancellation_reason (weather / low_signups / staff_shortage / venue_conflict / regulatory / other)."
    },
    {
      "name": "stackra.event.rescheduled.total",
      "kind": "counter",
      "unit": "reschedules",
      "labels": ["status"]
    },
    {
      "name": "stackra.event.venue_changed.total",
      "kind": "counter",
      "unit": "changes",
      "labels": ["status"]
    },
    {
      "name": "stackra.event.pricing_changed.total",
      "kind": "counter",
      "unit": "changes",
      "labels": ["audit_severity"]
    },
    {
      "name": "stackra.event.eligibility_narrowed.total",
      "kind": "counter",
      "unit": "changes",
      "labels": [],
      "description": "Every fire is critical — feeds regulator-facing dashboard."
    },
    {
      "name": "stackra.event.published.total",
      "kind": "counter",
      "unit": "publishes",
      "labels": []
    },
    {
      "name": "stackra.event.livestream_activated.total",
      "kind": "counter",
      "unit": "activations",
      "labels": ["is_password_protected"]
    },
    {
      "name": "stackra.event.registration_opened.total",
      "kind": "counter",
      "unit": "opens",
      "labels": ["trigger"]
    },
    {
      "name": "stackra.event.registration_closed.total",
      "kind": "counter",
      "unit": "closes",
      "labels": ["trigger"]
    },
    {
      "name": "stackra.event.active.count",
      "kind": "gauge",
      "unit": "events",
      "labels": ["status", "event_type"]
    },
    {
      "name": "stackra.event.slot_exhaustion.total",
      "kind": "counter",
      "unit": "refusals",
      "labels": []
    },
    {
      "name": "stackra.event.middleware_resolve.duration_ms",
      "kind": "histogram",
      "unit": "ms",
      "buckets": [1, 5, 20, 100],
      "labels": ["source"],
      "description": "event.resolve_active middleware latency."
    },
    {
      "name": "stackra.event.middleware_reject.total",
      "kind": "counter",
      "unit": "rejects",
      "labels": ["reason"]
    },
    {
      "name": "stackra.event.phase_roll.duration_ms",
      "kind": "histogram",
      "unit": "ms",
      "buckets": [200, 1000, 5000, 30000],
      "labels": []
    },
    {
      "name": "stackra.event.phase_roll.transitions",
      "kind": "counter",
      "unit": "transitions",
      "labels": ["to_status"]
    },
    {
      "name": "stackra.event.reminder_notification.sent",
      "kind": "counter",
      "unit": "notifications",
      "labels": ["reminder_window"]
    },
    {
      "name": "stackra.event.cancellation_broadcast.recipients",
      "kind": "histogram",
      "unit": "recipients",
      "buckets": [10, 100, 500, 2000],
      "labels": [],
      "description": "Distribution of broadcast fan-out sizes."
    },
    {
      "name": "stackra.event.facility_booking_drift.count",
      "kind": "gauge",
      "unit": "rows",
      "labels": [],
      "description": "event_facilities rows without a matching resource_booking. Populated by ReconcileEventFacilityBookingsJob. Ideally 0."
    },
    {
      "name": "stackra.event.purge_pending.count",
      "kind": "gauge",
      "unit": "events",
      "labels": []
    },
    {
      "name": "stackra.event.multi_facility.usage",
      "kind": "gauge",
      "unit": "events",
      "labels": [],
      "description": "How many active events have 2+ facilities. Feeds Enterprise-tier feature adoption dashboard."
    }
  ]
}
