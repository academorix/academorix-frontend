{
  "id": "event.event.list",
  "title": "Events",
  "version": 1,
  "kind": "SduiScreen",
  "resource": "event",
  "route": "/events",
  "description": "Filterable table of events for the active tenant. Shows all events the caller has permission to see (visibility filter applies). Row actions cascade through the lifecycle state machine (announce -> open registration -> close registration -> start -> complete).",
  "dataSources": [
    {
      "name": "events",
      "kind": "http.get",
      "urlExpr": "'/api/v1/events?' + qs({ 'filter[status]': filters.status, 'filter[event_type]': filters.event_type, 'filter[visibility]': filters.visibility, 'filter[organization_id]': filters.organization_id, 'filter[branch_id]': filters.branch_id, 'filter[season_id]': filters.season_id, 'filter[primary_sport_key]': filters.sport_key, 'filter[starts_at.gte]': filters.starts_at_gte, 'filter[starts_at.lte]': filters.starts_at_lte, 'sort': sort, 'include': 'primary_facility,season', 'page': page, 'per_page': 25, 'include_archived': filters.include_archived })",
      "unwrap": "data",
      "meta": true
    }
  ],
  "nodes": [
    {
      "kind": "PageHeader",
      "children": [
        { "kind": "PageHeader.Title", "props": { "children": "Events" } },
        {
          "kind": "PageHeader.Actions",
          "children": [
            {
              "kind": "Button",
              "props": {
                "variant": "solid",
                "leadingIcon": "plus-outline",
                "children": "New event"
              },
              "bindings": {
                "onPress": { "$action": "route.push", "url": "/events/new" },
                "hidden": { "$expr": "!caller.can('events.create')" }
              }
            }
          ]
        }
      ]
    },
    {
      "kind": "FilterBar",
      "children": [
        {
          "kind": "Widget",
          "props": { "id": "shared.status-filter" },
          "bindings": {
            "props": {
              "options": [
                "draft",
                "announced",
                "registration_open",
                "registration_closed",
                "in_progress",
                "completed",
                "cancelled",
                "archived"
              ]
            }
          }
        },
        { "kind": "Widget", "props": { "id": "shared.event-type-filter" } },
        {
          "kind": "Widget",
          "props": {
            "id": "organization.organization-picker",
            "props": { "name": "organization_id", "clearable": true }
          }
        },
        {
          "kind": "Widget",
          "props": {
            "id": "branch.branch-picker",
            "props": { "name": "branch_id", "clearable": true }
          }
        },
        {
          "kind": "Widget",
          "props": {
            "id": "season.season-picker",
            "props": { "name": "season_id", "clearable": true }
          }
        }
      ]
    },
    {
      "kind": "Table",
      "bindings": { "items": { "$ref": "events" } },
      "columns": [
        {
          "kind": "TableColumn",
          "id": "name",
          "header": "Name",
          "cellExpr": "row.name",
          "sortable": true
        },
        {
          "kind": "TableColumn",
          "id": "event_type",
          "header": "Type",
          "cellExpr": "row.event_type"
        },
        {
          "kind": "TableColumn",
          "id": "starts_at",
          "header": "Starts",
          "cellExpr": "formatDateTime(row.starts_at, row.timezone)",
          "sortable": true
        },
        {
          "kind": "TableColumn",
          "id": "status",
          "header": "Status",
          "cell": {
            "kind": "Widget",
            "props": { "id": "event.event-status-chip" },
            "bindings": { "props": { "status": { "$ref": "row.status" } } }
          }
        },
        {
          "kind": "TableColumn",
          "id": "visibility",
          "header": "Visibility",
          "cell": {
            "kind": "Widget",
            "props": { "id": "event.event-visibility-chip" },
            "bindings": { "props": { "visibility": { "$ref": "row.visibility" } } }
          }
        },
        {
          "kind": "TableColumn",
          "id": "venue",
          "header": "Venue",
          "cellExpr": "row.primary_facility?.name || '—'"
        },
        {
          "kind": "TableColumn",
          "id": "registered",
          "header": "Registered",
          "cellExpr": "row.registered_count + (row.max_participants ? ' / ' + row.max_participants : '')"
        },
        {
          "kind": "TableColumn",
          "id": "actions",
          "header": "",
          "cell": {
            "kind": "Dropdown",
            "children": [
              {
                "kind": "Dropdown.Trigger",
                "children": [
                  {
                    "kind": "Button",
                    "props": {
                      "variant": "ghost",
                      "size": "sm",
                      "isIconOnly": true,
                      "leadingIcon": "dots-vertical-outline",
                      "aria-label": "Actions"
                    }
                  }
                ]
              },
              {
                "kind": "Dropdown.Menu",
                "children": [
                  {
                    "kind": "Dropdown.Item",
                    "propsExpr": "{ children: 'View', onPress: () => route.push('/events/' + row.id) }"
                  },
                  {
                    "kind": "Dropdown.Item",
                    "propsExpr": "{ children: 'Edit', onPress: () => route.push('/events/' + row.id + '/edit'), hidden: !caller.can('events.update') }"
                  },
                  { "kind": "Dropdown.Separator" },
                  {
                    "kind": "Dropdown.Item",
                    "propsExpr": "{ children: 'Announce', onPress: () => actions.post('/api/v1/events/' + row.id + '/announce'), hidden: row.status !== 'draft' || !caller.can('events.announce') }"
                  },
                  {
                    "kind": "Dropdown.Item",
                    "propsExpr": "{ children: 'Open registration', onPress: () => actions.post('/api/v1/events/' + row.id + '/open-registration'), hidden: row.status !== 'announced' || !caller.can('events.open_registration') }"
                  },
                  {
                    "kind": "Dropdown.Item",
                    "propsExpr": "{ children: 'Close registration', onPress: () => actions.post('/api/v1/events/' + row.id + '/close-registration'), hidden: row.status !== 'registration_open' || !caller.can('events.close_registration') }"
                  },
                  {
                    "kind": "Dropdown.Item",
                    "propsExpr": "{ children: 'Start', onPress: () => actions.post('/api/v1/events/' + row.id + '/start'), hidden: !['registration_closed', 'announced'].includes(row.status) || !caller.can('events.start') }"
                  },
                  {
                    "kind": "Dropdown.Item",
                    "propsExpr": "{ children: 'Complete', onPress: () => actions.post('/api/v1/events/' + row.id + '/complete'), hidden: row.status !== 'in_progress' || !caller.can('events.complete') }"
                  },
                  {
                    "kind": "Dropdown.Item",
                    "propsExpr": "{ children: 'Cancel', danger: true, onPress: () => modal.open('event.cancel-confirm', { event: row }), hidden: ['completed', 'cancelled', 'archived'].includes(row.status) || !caller.can('events.cancel') }"
                  },
                  { "kind": "Dropdown.Separator" },
                  {
                    "kind": "Dropdown.Item",
                    "propsExpr": "{ children: 'Publish', onPress: () => actions.post('/api/v1/events/' + row.id + '/publish'), hidden: row.visibility === 'public' || !caller.can('events.publish') || !features.includes('sports_events.public_visibility') }"
                  },
                  {
                    "kind": "Dropdown.Item",
                    "propsExpr": "{ children: 'Unpublish', onPress: () => actions.post('/api/v1/events/' + row.id + '/unpublish'), hidden: row.visibility !== 'public' || !caller.can('events.unpublish') }"
                  },
                  {
                    "kind": "Dropdown.Item",
                    "propsExpr": "{ children: 'Archive', onPress: () => actions.post('/api/v1/events/' + row.id + '/archive'), hidden: !['completed', 'cancelled'].includes(row.status) || !caller.can('events.archive') }"
                  }
                ]
              }
            ]
          }
        }
      ]
    },
    {
      "kind": "Pagination",
      "bindings": { "meta": { "$ref": "events._meta" } }
    }
  ]
}
