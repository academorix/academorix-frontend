{
  "id": "attendance.resources.attendance-record.list",
  "title": "Attendance records",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/attendance",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "attendance", "entity": "attendance-record", "action": "list" },
  "requiresPermission": "attendance.viewAny",
  "dataSources": [
    {
      "name": "records",
      "kind": "http.get",
      "url": "/api/v1/attendance-records",
      "unwrap": "data",
      "queryFromFilters": true
    },
    {
      "name": "sessions",
      "kind": "http.get",
      "url": "/api/v1/sessions?filter[status]=scheduled,confirmed,in_progress,completed",
      "unwrap": "data",
      "cache": { "ttlSeconds": 300 }
    },
    {
      "name": "teams",
      "kind": "http.get",
      "url": "/api/v1/teams?filter[status]=active",
      "unwrap": "data",
      "cache": { "ttlSeconds": 300 }
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-7xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "kind": "View",
              "children": [
                {
                  "kind": "Text",
                  "props": {
                    "as": "h1",
                    "className": "text-2xl font-semibold",
                    "children": "Attendance"
                  }
                },
                {
                  "kind": "Text",
                  "props": {
                    "className": "text-sm text-muted",
                    "children": "Who showed up at which session — check-ins, late arrivals, and no-shows."
                  }
                }
              ]
            },
            {
              "kind": "Button",
              "props": {
                "variant": "primary",
                "leadingIcon": "plus",
                "children": "Record check-in"
              },
              "actions": { "onPress": { "kind": "navigate", "to": "/tenant/attendance/check-in" } },
              "requiresPermission": "attendance.create"
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "flex items-center gap-2 py-2 flex-wrap" },
          "children": [
            {
              "kind": "ComboBox",
              "props": { "label": "Team", "menuTrigger": "focus", "className": "min-w-56" },
              "bindings": { "items": { "$ref": "teams" } },
              "actions": {
                "onSelectionChange": {
                  "kind": "filter.set",
                  "field": "team_id",
                  "valueExpr": "$selectedKey"
                }
              }
            },
            {
              "kind": "ComboBox",
              "props": { "label": "Session", "menuTrigger": "focus", "className": "min-w-56" },
              "bindings": { "items": { "$ref": "sessions" } },
              "actions": {
                "onSelectionChange": {
                  "kind": "filter.set",
                  "field": "session_id",
                  "valueExpr": "$selectedKey"
                }
              }
            },
            {
              "kind": "ComboBox",
              "props": { "label": "Status", "menuTrigger": "focus", "className": "min-w-48" },
              "props_items": [
                { "id": "not_yet_checked_in", "label": "Not yet checked in" },
                { "id": "present", "label": "Present" },
                { "id": "late", "label": "Late" },
                { "id": "left_early", "label": "Left early" },
                { "id": "present_with_note", "label": "Present with note" }
              ],
              "actions": {
                "onSelectionChange": {
                  "kind": "filter.set",
                  "field": "status",
                  "valueExpr": "$selectedKey"
                }
              }
            },
            {
              "kind": "ComboBox",
              "props": { "label": "Method", "menuTrigger": "focus", "className": "min-w-48" },
              "props_items": [
                { "id": "self_kiosk", "label": "Kiosk" },
                { "id": "coach_verified", "label": "Coach verified" },
                { "id": "admin_recorded", "label": "Admin recorded" },
                { "id": "geofence", "label": "Geofence" },
                { "id": "qr_scan", "label": "QR scan" }
              ],
              "actions": {
                "onSelectionChange": {
                  "kind": "filter.set",
                  "field": "checked_in_via",
                  "valueExpr": "$selectedKey"
                }
              }
            }
          ]
        },
        {
          "kind": "Table",
          "props": { "aria-label": "Attendance records" },
          "bindings": {
            "rows": { "$ref": "records" },
            "isLoading": { "$ref": "records.isLoading" }
          },
          "emptyState": {
            "kind": "View",
            "props": { "className": "text-center py-12" },
            "children": [
              {
                "kind": "Icon",
                "props": {
                  "name": "clipboard-document-check",
                  "className": "size-12 mx-auto text-muted"
                }
              },
              {
                "kind": "Text",
                "props": {
                  "className": "mt-4 text-lg font-medium",
                  "children": "No attendance recorded yet"
                }
              }
            ]
          },
          "columns": [
            {
              "key": "athlete",
              "label": "Athlete",
              "renderer": {
                "kind": "View",
                "props": { "className": "flex items-center gap-2" },
                "children": [
                  {
                    "kind": "Text",
                    "props": { "className": "font-medium" },
                    "bindings": { "children": { "$ref": "row.athlete_display_name" } }
                  },
                  {
                    "kind": "Widget",
                    "widget": "athlete.minor-badge",
                    "bindings": { "hidden": { "$expr": "!row.athlete.is_minor" } }
                  }
                ]
              }
            },
            {
              "key": "session_id",
              "label": "Session",
              "renderer": {
                "kind": "Text",
                "bindings": { "children": { "$ref": "row.session_display_name" } }
              }
            },
            {
              "key": "checked_in_at",
              "label": "Checked in",
              "renderer": {
                "kind": "Text",
                "bindings": { "children": { "$ref": "row.checked_in_at" } },
                "formatter": "datetime-short"
              }
            },
            {
              "key": "status",
              "label": "Status",
              "renderer": {
                "kind": "Widget",
                "widget": "attendance.attendance-status-chip",
                "bindings": { "status": { "$ref": "row.status" } }
              }
            },
            {
              "key": "checked_in_via",
              "label": "Method",
              "renderer": {
                "kind": "Widget",
                "widget": "attendance.check-in-method-badge",
                "bindings": { "method": { "$ref": "row.checked_in_via" } }
              }
            },
            {
              "key": "lateness",
              "label": "Lateness",
              "renderer": {
                "kind": "Widget",
                "widget": "attendance.lateness-indicator",
                "bindings": {
                  "hidden": { "$expr": "row.status !== 'late'" },
                  "minutes_late": { "$ref": "row.minutes_late" }
                }
              }
            }
          ],
          "rowActions": {
            "onPress": { "kind": "navigate", "toExpr": "'/tenant/attendance/' + row.id" }
          }
        }
      ]
    }
  ]
}
