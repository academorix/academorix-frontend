{
  "id": "attendance.resources.attendance-record.cancel",
  "title": "Cancel attendance",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/attendance/{record}/cancel",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "attendance", "entity": "attendance-record", "action": "cancel" },
  "requiresPermission": "attendance.cancel",
  "dataSources": [
    {
      "name": "record",
      "kind": "http.get",
      "urlTemplate": "/api/v1/attendance-records/{record}",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-3xl mx-auto" },
      "children": [
        {
          "kind": "Text",
          "props": {
            "as": "h1",
            "className": "text-2xl font-semibold",
            "children": "Cancel attendance record"
          }
        },
        {
          "kind": "Alert",
          "props": { "variant": "warning" },
          "bindings": { "hidden": { "$expr": "!record.consumed_pass_id" } },
          "children": [
            {
              "kind": "Text",
              "props": { "className": "font-semibold", "children": "Pass will be refunded" }
            },
            {
              "kind": "Text",
              "propsExpr": "{ children: 'Cancelling this attendance record will refund the consumed pass ' + record.consumed_pass_id + ' back to the athlete\\'s membership.' }"
            }
          ]
        },
        {
          "kind": "Card",
          "children": [
            {
              "kind": "Card.Header",
              "children": [
                {
                  "kind": "Text",
                  "propsExpr": "{ children: 'Cancelling ' + record.athlete_display_name + ' at ' + record.session_display_name }"
                }
              ]
            },
            {
              "kind": "Card.Content",
              "props": { "className": "flex flex-col gap-3" },
              "children": [
                {
                  "kind": "TextArea",
                  "props": {
                    "label": "Cancellation reason",
                    "isRequired": true,
                    "maxLength": 256,
                    "rows": 3,
                    "placeholder": "Wrong athlete, accidental check-in, session cancelled, etc."
                  },
                  "actions": {
                    "onChange": {
                      "kind": "field.set",
                      "field": "cancellation_reason",
                      "valueExpr": "$value"
                    }
                  }
                }
              ]
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "flex justify-end gap-2" },
          "children": [
            {
              "kind": "Button",
              "props": { "variant": "secondary", "children": "Keep record" },
              "actions": { "onPress": { "kind": "navigate.back" } }
            },
            {
              "kind": "Button",
              "props": { "variant": "danger", "children": "Cancel attendance + refund pass" },
              "bindings": { "disabled": { "$expr": "!form.cancellation_reason" } },
              "actions": {
                "onPress": {
                  "kind": "http.post",
                  "urlTemplate": "/api/v1/attendance-records/{record}/cancel",
                  "bodyFromForm": true,
                  "onSuccess": { "kind": "navigate", "to": "/tenant/attendance" }
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
