{
  "id": "attendance.resources.kiosk-check-in-app",
  "title": "Kiosk check-in",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/kiosk/check-in",
  "host": "tenant",
  "audience": "kiosk",
  "layout": "fullscreen",
  "resource": { "module": "attendance", "entity": "kiosk-check-in", "action": "check-in" },
  "requiresPermission": "attendance.check-in.own",
  "requiresFeature": "attendance.self_kiosk",
  "dataSources": [
    {
      "name": "todays_sessions",
      "kind": "http.get",
      "url": "/api/v1/sessions/today?filter[venue_id]={kiosk.venue_id}",
      "unwrap": "data",
      "cache": { "ttlSeconds": 60 }
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": {
        "className": "flex flex-col items-center justify-center min-h-screen bg-primary text-primary-foreground gap-8 p-8"
      },
      "children": [
        {
          "kind": "Text",
          "props": { "as": "h1", "className": "text-5xl font-bold", "children": "Welcome" }
        },
        {
          "kind": "Text",
          "props": { "className": "text-xl", "children": "Tap to check in for today's session" }
        },
        {
          "kind": "View",
          "props": { "className": "grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl w-full" },
          "bindings": { "items": { "$ref": "todays_sessions" } },
          "childTemplate": {
            "kind": "Card",
            "props": { "className": "cursor-pointer hover:scale-105 transition-transform" },
            "actions": {
              "onPress": {
                "kind": "modal.open",
                "modal": "attendance.kiosk-athlete-picker",
                "params": { "session_id": "item.id" }
              }
            },
            "children": [
              {
                "kind": "Card.Content",
                "props": { "className": "flex flex-col items-center gap-2 p-8 text-center" },
                "children": [
                  { "kind": "Icon", "props": { "name": "sparkles", "className": "size-12" } },
                  {
                    "kind": "Text",
                    "props": { "className": "text-xl font-semibold" },
                    "bindings": { "children": { "$ref": "item.name" } }
                  },
                  {
                    "kind": "Text",
                    "props": { "className": "text-sm text-muted" },
                    "bindings": { "children": { "$ref": "item.starts_at_short" } }
                  }
                ]
              }
            ]
          }
        },
        {
          "kind": "Text",
          "props": {
            "className": "text-xs text-muted mt-4",
            "children": "Each check-in captures a device fingerprint for anti-fraud. Guardian consent required for minors."
          }
        }
      ]
    }
  ],
  "modals": [
    {
      "id": "attendance.kiosk-athlete-picker",
      "title": "Who's checking in?",
      "params": ["session_id"],
      "nodes": [
        {
          "kind": "View",
          "props": { "className": "flex flex-col gap-4 p-6" },
          "children": [
            {
              "kind": "Widget",
              "widget": "athlete.athlete-picker",
              "props": { "label": "Search by name or PIN", "autoFocus": true },
              "actions": {
                "onSelect": {
                  "kind": "modal.open",
                  "modal": "attendance.kiosk-pin-confirm",
                  "params": { "session_id": "modal.session_id", "athlete_id": "$selectedId" }
                }
              }
            }
          ]
        }
      ]
    },
    {
      "id": "attendance.kiosk-pin-confirm",
      "title": "Confirm PIN",
      "params": ["session_id", "athlete_id"],
      "nodes": [
        {
          "kind": "View",
          "props": { "className": "flex flex-col items-center gap-4 p-6" },
          "children": [
            {
              "kind": "InputOTP",
              "props": { "length": 4, "autoFocus": true, "label": "Enter 4-digit PIN" },
              "actions": {
                "onComplete": {
                  "kind": "http.post",
                  "url": "/api/v1/attendance/check-in",
                  "body": {
                    "session_id": "{modal.session_id}",
                    "athlete_id": "{modal.athlete_id}",
                    "checked_in_via": "self_kiosk",
                    "device_fingerprint_hash": "{kiosk.fingerprint}",
                    "pin_verification": "$value"
                  },
                  "onSuccess": { "kind": "modal.open", "modal": "attendance.kiosk-success" },
                  "onError": {
                    "kind": "toast",
                    "variant": "danger",
                    "messageExpr": "$error.code === 'ATTENDANCE_NO_ACTIVE_PASS' ? 'No active pass — see reception' : $error.message"
                  }
                }
              }
            }
          ]
        }
      ]
    },
    {
      "id": "attendance.kiosk-success",
      "title": "Checked in!",
      "autoDismissMs": 5000,
      "nodes": [
        {
          "kind": "View",
          "props": { "className": "flex flex-col items-center gap-4 p-8" },
          "children": [
            {
              "kind": "Icon",
              "props": { "name": "check-circle", "className": "size-24 text-success" }
            },
            {
              "kind": "Text",
              "props": {
                "as": "h2",
                "className": "text-3xl font-bold",
                "children": "You're checked in!"
              }
            },
            {
              "kind": "Text",
              "props": { "className": "text-sm text-muted", "children": "Have a great session." }
            }
          ]
        }
      ]
    }
  ]
}
