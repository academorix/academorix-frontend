{
  "id": "academorix://modules/session/schemas/session",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "Session",
  "description": "A single practice / lesson / class instance. Composes a facility::ResourceBooking (`resource_booking_id`) for the physical slot + adds sport-specific fields. Carries `tenant_id` + `branch_id` + `resource_booking_id`. Optional `team_id` (nullable for standalone/private sessions), `season_id`, `event_id`. NEVER carries `application_id` / `organization_id` (cascade through branch) / `region_id` / `scope_node_id`. State machine: scheduled -> confirmed -> in_progress -> completed / cancelled / rescheduled.",
  "type": "object",
  "x-module": "session",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "sessions",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "ses_",
    "incrementing": false,
    "model": "Academorix\\Sports\\Session\\Models\\Session",
    "interface": "Academorix\\Sports\\Session\\Contracts\\Data\\SessionInterface",
    "implements": ["Academorix\\Sports\\Session\\Contracts\\Data\\SessionInterface"],
    "traits": [
      "HasFactory",
      "HasUlids",
      "BelongsToTenant",
      "BelongsToBranch",
      "BelongsToSeason",
      "BelongsToEvent",
      "HasSessionAttendance",
      "HasSlug",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "HasActivityLog",
      "Filterable",
      "Searchable",
      "SoftDeletes"
    ],
    "casts": {
      "session_type": "SessionType",
      "status": "SessionStatus",
      "gender_category": "SessionGenderCategory",
      "attendance_capacity": "integer",
      "attendance_min": "integer",
      "checked_in_athletes_count": "integer",
      "absent_athletes_count": "integer",
      "cancellation_notice_at": "datetime",
      "session_rating": "decimal:2",
      "session_rating_count": "integer",
      "coach_rating_input": "decimal:2",
      "assistant_coach_ids": "array",
      "equipment_needed": "array",
      "metadata": "array"
    },
    "appends": [
      "current_phase",
      "starts_at",
      "ends_at",
      "duration_minutes",
      "attendance_rate",
      "is_cancellable_within_notice_window"
    ],
    "observers": ["SessionObserver"]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": {
        "type": "string",
        "length": 64,
        "primary": true,
        "description": "Prefixed ULID: `ses_<26>`."
      },
      "tenant_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "branch_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "branches", "column": "id", "onDelete": "restrict" }
      },
      "resource_booking_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "resource_bookings", "column": "id", "onDelete": "restrict" },
        "description": "The physical slot reservation (`bkg_*`). RESTRICT — cannot delete the booking while a session references it. Session inherits starts_at/ends_at from the booking."
      },
      "team_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": { "table": "teams", "column": "id", "onDelete": "restrict" },
        "description": "Nullable = standalone/private session. When set, session.tenant_id MUST equal team.tenant_id."
      },
      "season_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": { "table": "seasons", "column": "id", "onDelete": "restrict" },
        "description": "Nullable. When set, season.tenant_id MUST equal session.tenant_id."
      },
      "event_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": { "table": "events", "column": "id", "onDelete": "restrict" },
        "description": "Nullable. Set when the session is part of an Event's schedule (a session in a workshop / camp)."
      },
      "sport_key": {
        "type": "string",
        "length": 32,
        "nullable": true,
        "description": "Primary sport for this session. Wave 3c sports registry key."
      },
      "name": { "type": "string", "length": 128, "nullable": false },
      "slug": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "description": "Auto-generated by helper: `<team-slug>-<week-of-year>-<year>` for team sessions; `<session-type>-<athlete-slug>-<date>` for standalone. Unique per (tenant_id, slug) partial WHERE deleted_at IS NULL when non-null."
      },
      "description": { "type": "text", "nullable": true },
      "session_type": {
        "type": "string",
        "length": 24,
        "nullable": false,
        "description": "Enum: practice / lesson / class / private_lesson / group_lesson / drop_in / workshop / trial / assessment / game / open_gym."
      },
      "head_coach_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": { "table": "coaches", "column": "id", "onDelete": "restrict" },
        "description": "The lead coach. Nullable for open_gym / drop_in sessions with no assigned coach. Same-tenant invariant enforced."
      },
      "assistant_coach_ids": {
        "type": "jsonb",
        "nullable": true,
        "description": "Array of coach ULIDs (`coa_*`), max 3. Assistants under the head_coach. Each MUST belong to session.tenant_id."
      },
      "supervising_staff_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": { "table": "staff", "column": "id", "onDelete": "restrict" },
        "description": "For events / private lessons where the supervising person is staff (reception, admin) rather than a coach. Enforced same-tenant."
      },
      "attendance_capacity": {
        "type": "integer",
        "nullable": true,
        "description": "Max athletes at this session. Nullable = defer to team.capacity OR facility.capacity_persons."
      },
      "attendance_min": {
        "type": "integer",
        "nullable": true,
        "description": "Minimum attendance below which the session auto-cancels post-start (via CancelUnderMinimumSessionsJob). Nullable = no minimum enforcement."
      },
      "age_group_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": { "table": "age_groups", "column": "id", "onDelete": "restrict" }
      },
      "gender_category": {
        "type": "string",
        "length": 16,
        "nullable": true,
        "description": "Enum: male / female / mixed / any."
      },
      "curriculum_topic": {
        "type": "string",
        "length": 256,
        "nullable": true,
        "description": "Freeform topic label (e.g. 'Ball control drills', 'Freestyle stroke refinement')."
      },
      "lesson_plan_url": {
        "type": "string",
        "length": 512,
        "nullable": true,
        "description": "Coach's shared lesson plan document URL. Enterprise-tier feature."
      },
      "equipment_needed": {
        "type": "jsonb",
        "nullable": true,
        "description": "Array of tag strings (e.g. ['cones', 'goalkeeper-gloves', 'agility-ladder'])."
      },
      "status": {
        "type": "string",
        "length": 24,
        "nullable": false,
        "default": "'scheduled'",
        "description": "Enum: scheduled / confirmed / in_progress / completed / cancelled / rescheduled."
      },
      "checked_in_athletes_count": {
        "type": "integer",
        "nullable": false,
        "default": 0,
        "description": "Derived from session_attendance where status='checked_in' or 'late'. Recomputed nightly by ReconcileAttendanceCountsJob."
      },
      "absent_athletes_count": {
        "type": "integer",
        "nullable": false,
        "default": 0
      },
      "cancellation_reason": { "type": "text", "nullable": true },
      "cancellation_notice_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "When the cancellation was announced. 24h+ prior warrants no fee refund per policy; less-than-24h cancellation is a policy signal for financial audit."
      },
      "session_notes": {
        "type": "text",
        "nullable": true,
        "description": "Coach's post-session notes. Private-tier — only visible to coaches + admins."
      },
      "session_rating": {
        "type": "decimal",
        "precision": 3,
        "scale": 2,
        "nullable": true,
        "description": "Aggregated athlete/parent rating for THIS session. Range 0.00-5.00. NULL until at least one rating received. Aggregated nightly by AggregateSessionRatingsJob."
      },
      "session_rating_count": { "type": "integer", "nullable": false, "default": 0 },
      "coach_rating_input": {
        "type": "decimal",
        "precision": 3,
        "scale": 2,
        "nullable": true,
        "description": "Coach's self-assessment. Feeds AggregateCoachRatingsJob."
      },
      "safeguarding_incident_flag": {
        "type": "boolean",
        "nullable": false,
        "default": false,
        "description": "Set true when a safeguarding-relevant incident occurred during the session. Fires SessionMinorSafeguardingIncident (critical audit). Never rendered to non-admin surfaces."
      },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_by": { "type": "string", "length": 64, "nullable": true },
      "updated_by": { "type": "string", "length": 64, "nullable": true },
      "deleted_by": { "type": "string", "length": 64, "nullable": true },
      "deleted_at": { "type": "timestamptz", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "slug"],
        "unique": true,
        "name": "sessions_scope_slug_unique",
        "predicate": "deleted_at IS NULL AND slug IS NOT NULL",
        "description": "One live slug per tenant when set."
      },
      {
        "columns": ["tenant_id", "resource_booking_id"],
        "unique": true,
        "name": "sessions_booking_unique",
        "predicate": "deleted_at IS NULL",
        "description": "One session per resource_booking (a booking backs at most one session)."
      },
      { "columns": ["tenant_id", "status"], "name": "sessions_status_idx" },
      { "columns": ["tenant_id", "branch_id", "status"], "name": "sessions_branch_status_idx" },
      {
        "columns": ["tenant_id", "team_id"],
        "name": "sessions_team_idx",
        "predicate": "team_id IS NOT NULL"
      },
      {
        "columns": ["tenant_id", "season_id"],
        "name": "sessions_season_idx",
        "predicate": "season_id IS NOT NULL"
      },
      {
        "columns": ["tenant_id", "event_id"],
        "name": "sessions_event_idx",
        "predicate": "event_id IS NOT NULL"
      },
      {
        "columns": ["tenant_id", "head_coach_id"],
        "name": "sessions_head_coach_idx",
        "predicate": "head_coach_id IS NOT NULL"
      },
      {
        "columns": ["tenant_id", "sport_key"],
        "name": "sessions_sport_idx",
        "predicate": "sport_key IS NOT NULL"
      },
      {
        "columns": ["tenant_id", "safeguarding_incident_flag"],
        "name": "sessions_safeguarding_idx",
        "predicate": "safeguarding_incident_flag = true"
      }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "branch_id",
    "resource_booking_id",
    "name",
    "session_type",
    "status",
    "checked_in_athletes_count",
    "absent_athletes_count",
    "session_rating_count",
    "safeguarding_incident_flag",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^ses_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": "string", "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "branch_id": { "type": "string", "pattern": "^brn_[0-9A-HJKMNP-TV-Z]{26}$" },
    "resource_booking_id": { "type": "string", "pattern": "^bkg_[0-9A-HJKMNP-TV-Z]{26}$" },
    "team_id": { "type": ["string", "null"], "pattern": "^tea_[0-9A-HJKMNP-TV-Z]{26}$" },
    "season_id": { "type": ["string", "null"], "pattern": "^sea_[0-9A-HJKMNP-TV-Z]{26}$" },
    "event_id": { "type": ["string", "null"], "pattern": "^eve_[0-9A-HJKMNP-TV-Z]{26}$" },
    "sport_key": { "type": ["string", "null"], "maxLength": 32, "pattern": "^[a-z][a-z0-9_]*$" },
    "name": { "type": "string", "minLength": 2, "maxLength": 128 },
    "slug": {
      "type": ["string", "null"],
      "minLength": 2,
      "maxLength": 64,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "description": { "type": ["string", "null"] },
    "session_type": {
      "type": "string",
      "enum": [
        "practice",
        "lesson",
        "class",
        "private_lesson",
        "group_lesson",
        "drop_in",
        "workshop",
        "trial",
        "assessment",
        "game",
        "open_gym"
      ]
    },
    "head_coach_id": { "type": ["string", "null"], "pattern": "^coa_[0-9A-HJKMNP-TV-Z]{26}$" },
    "assistant_coach_ids": {
      "type": ["array", "null"],
      "maxItems": 3,
      "items": { "type": "string", "pattern": "^coa_[0-9A-HJKMNP-TV-Z]{26}$" }
    },
    "supervising_staff_id": {
      "type": ["string", "null"],
      "pattern": "^stf_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "attendance_capacity": { "type": ["integer", "null"], "minimum": 1 },
    "attendance_min": { "type": ["integer", "null"], "minimum": 1 },
    "age_group_id": { "type": ["string", "null"], "pattern": "^age_[0-9A-HJKMNP-TV-Z]{26}$" },
    "gender_category": {
      "type": ["string", "null"],
      "enum": [null, "male", "female", "mixed", "any"]
    },
    "curriculum_topic": { "type": ["string", "null"], "maxLength": 256 },
    "lesson_plan_url": { "type": ["string", "null"], "format": "uri", "maxLength": 512 },
    "equipment_needed": {
      "type": ["array", "null"],
      "items": { "type": "string", "maxLength": 64 }
    },
    "status": {
      "type": "string",
      "enum": ["scheduled", "confirmed", "in_progress", "completed", "cancelled", "rescheduled"]
    },
    "checked_in_athletes_count": { "type": "integer", "minimum": 0 },
    "absent_athletes_count": { "type": "integer", "minimum": 0 },
    "cancellation_reason": { "type": ["string", "null"] },
    "cancellation_notice_at": { "type": ["string", "null"], "format": "date-time" },
    "session_notes": { "type": ["string", "null"] },
    "session_rating": { "type": ["number", "null"], "minimum": 0, "maximum": 5 },
    "session_rating_count": { "type": "integer", "minimum": 0 },
    "coach_rating_input": { "type": ["number", "null"], "minimum": 0, "maximum": 5 },
    "safeguarding_incident_flag": { "type": "boolean" },
    "metadata": { "type": ["object", "null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false,
  "x-wire": {
    "envelope": "spatie-data",
    "wrap": "data",
    "mapper": "SnakeCaseMapper",
    "computed": [
      "current_phase",
      "starts_at",
      "ends_at",
      "duration_minutes",
      "attendance_rate",
      "is_cancellable_within_notice_window"
    ]
  },
  "x-route-binding": {
    "strategy": "resolveRouteBinding",
    "accepts": ["ULID (`ses_<26>`)", "slug (case-insensitive, resolved within active tenant)"]
  },
  "x-invariants": [
    "resource_booking.tenant_id = session.tenant_id",
    "resource_booking.facility.branch_id = session.branch_id (session's branch aligns with booking's facility)",
    "session.starts_at + session.ends_at derived from resource_booking (never stored directly)",
    "team_id IS NULL OR team.tenant_id = session.tenant_id",
    "season_id IS NULL OR season.tenant_id = session.tenant_id",
    "event_id IS NULL OR event.tenant_id = session.tenant_id",
    "head_coach_id IS NULL OR coach.tenant_id = session.tenant_id",
    "assistant_coach_ids array: every element's coach.tenant_id = session.tenant_id",
    "supervising_staff_id IS NULL OR staff.tenant_id = session.tenant_id",
    "assistant_coach_ids MUST NOT contain head_coach_id (a coach can't assist themselves)",
    "attendance_min IS NULL OR attendance_capacity IS NULL OR attendance_min <= attendance_capacity",
    "session.tenant_id + branch_id + resource_booking_id IMMUTABLE post-create",
    "session_rating range [0, 5] with 2 decimal precision",
    "safeguarding_incident_flag=true implies session_notes IS NOT NULL (an incident requires narrative)",
    "COUNT(*) FILTER (WHERE deleted_at IS NULL) unique per (tenant_id, resource_booking_id) — one session per booking"
  ]
}
