{
  "id": "stackra://modules/session/schemas/session-attendance",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "SessionAttendance",
  "description": "Pivot row attaching an Athlete to a Session with attendance state. Carries `tenant_id` + `session_id` + `athlete_id` + optional `athlete_enrollment_id` (Wave 3+). Cascades organization + region + branch through session. NEVER carries `application_id` / `organization_id` / `region_id` / `branch_id` / `scope_node_id`. State machine: registered -> checked_in / absent / late / excused.",
  "type": "object",
  "x-module": "session",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "session_attendance",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "sat_",
    "incrementing": false,
    "model": "Stackra\\Sports\\Session\\Models\\SessionAttendance",
    "interface": "Stackra\\Sports\\Session\\Contracts\\Data\\SessionAttendanceInterface",
    "implements": ["Stackra\\Sports\\Session\\Contracts\\Data\\SessionAttendanceInterface"],
    "traits": [
      "HasFactory",
      "HasUlids",
      "BelongsToTenant",
      "BelongsToSession",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "HasActivityLog",
      "Filterable",
      "SoftDeletes"
    ],
    "casts": {
      "status": "AttendanceStatus",
      "checked_in_at": "datetime",
      "checked_out_at": "datetime",
      "late_minutes": "integer",
      "metadata": "array"
    },
    "observers": ["SessionAttendanceObserver"]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": {
        "type": "string",
        "length": 64,
        "primary": true,
        "description": "Prefixed ULID: `sat_<26>`."
      },
      "tenant_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "session_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "sessions", "column": "id", "onDelete": "cascade" },
        "description": "CASCADE — pivot lifetime bounded by the session."
      },
      "athlete_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "athletes", "column": "id", "onDelete": "restrict" },
        "description": "RESTRICT — an athlete with active session attendance cannot be deleted without unwinding first."
      },
      "athlete_enrollment_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": { "table": "athlete_enrollments", "column": "id", "onDelete": "set null" },
        "description": "Nullable pointer to the specific enrollment that put this athlete in the session. SET NULL on enrollment deletion so the attendance record survives (financial + safeguarding record)."
      },
      "status": {
        "type": "string",
        "length": 16,
        "nullable": false,
        "default": "'registered'",
        "description": "Enum: registered / checked_in / absent / late / excused. registered = expected to attend but hasn't checked in yet. late = checked in past a grace window."
      },
      "checked_in_at": { "type": "timestamptz", "nullable": true },
      "checked_out_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "Optional. Some sessions track check-out for duration billing / safeguarding."
      },
      "late_minutes": {
        "type": "integer",
        "nullable": true,
        "description": "Minutes past session start when checked in. Populated automatically when status='late'."
      },
      "notes": {
        "type": "text",
        "nullable": true,
        "description": "Freeform per-attendance note (excused reason, injury flag, etc.). Private-tier — coaches + admins only."
      },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_by": { "type": "string", "length": 64, "nullable": true },
      "updated_by": { "type": "string", "length": 64, "nullable": true },
      "deleted_by": { "type": "string", "length": 64, "nullable": true },
      "deleted_at": { "type": "timestamptz", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["session_id", "athlete_id"],
        "unique": true,
        "name": "session_attendance_pair_unique",
        "predicate": "deleted_at IS NULL",
        "description": "An athlete attends a session once. Re-adding after removal requires a new row."
      },
      {
        "columns": ["tenant_id", "athlete_id", "checked_in_at"],
        "name": "session_attendance_athlete_history_idx"
      },
      { "columns": ["tenant_id", "session_id", "status"], "name": "session_attendance_status_idx" },
      {
        "columns": ["tenant_id", "athlete_enrollment_id"],
        "name": "session_attendance_enrollment_idx",
        "predicate": "athlete_enrollment_id IS NOT NULL"
      }
    ]
  },
  "required": ["id", "tenant_id", "session_id", "athlete_id", "status", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string", "pattern": "^sat_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": "string", "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "session_id": { "type": "string", "pattern": "^ses_[0-9A-HJKMNP-TV-Z]{26}$" },
    "athlete_id": { "type": "string", "pattern": "^ath_[0-9A-HJKMNP-TV-Z]{26}$" },
    "athlete_enrollment_id": {
      "type": ["string", "null"],
      "pattern": "^aen_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "status": {
      "type": "string",
      "enum": ["registered", "checked_in", "absent", "late", "excused"]
    },
    "checked_in_at": { "type": ["string", "null"], "format": "date-time" },
    "checked_out_at": { "type": ["string", "null"], "format": "date-time" },
    "late_minutes": { "type": ["integer", "null"], "minimum": 0 },
    "notes": { "type": ["string", "null"] },
    "metadata": { "type": ["object", "null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false,
  "x-invariants": [
    "session.tenant_id = attendance.tenant_id",
    "athlete.tenant_id = attendance.tenant_id",
    "athlete_enrollment_id IS NULL OR athlete_enrollment.athlete_id = attendance.athlete_id",
    "athlete_enrollment_id IS NULL OR athlete_enrollment.tenant_id = attendance.tenant_id",
    "status='checked_in' OR status='late' implies checked_in_at IS NOT NULL",
    "status='late' implies late_minutes IS NOT NULL AND late_minutes > 0",
    "checked_out_at IS NULL OR (checked_in_at IS NOT NULL AND checked_out_at >= checked_in_at)",
    "session_id + athlete_id IMMUTABLE post-create — to reassign, delete + recreate",
    "COUNT(*) FILTER (WHERE deleted_at IS NULL) unique per (session_id, athlete_id)"
  ]
}
