      "SessionAthleteMarkedAbsent",
      "SessionAthleteMarkedLate",
      "SessionAthleteRemoved",
      "SessionAttendanceBelowMinimum",
      "SessionRatingReceived",
      "SessionRatingAggregated",
      "SessionLessonPlanUpdated",
      "SessionMinorSafeguardingIncident",
      "SessionArchived",
      "SessionRestored",
      "SessionDeleted"
    ],
    "policies": ["SessionPolicy", "SessionAttendancePolicy"],
    "hooks": [
      "PreventSessionOrphansOnTenantErased",
      "CancelSessionsOnFacilityRetired",
      "ReassignCoachOnCoachDeactivated"
    ],
