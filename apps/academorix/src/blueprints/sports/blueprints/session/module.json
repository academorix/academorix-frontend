      "session:start",
      "session:complete",
      "session:check-in",
      "session:mark-absent",
      "session:mark-late",
      "session:remove-athlete",
      "session:assign-coach",
      "session:update-curriculum",
      "session:aggregate-ratings",
      "session:reconcile-attendance",
      "session:archive",
      "session:restore"
    ],
    "jobs": [
