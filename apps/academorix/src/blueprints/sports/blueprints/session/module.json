      "SessionRescheduledNotification",
      "SessionCancelledNotification",
      "SessionReminderNotification",
      "SessionCoachAssignedNotification",
      "SessionCoachReassignedNotification",
      "SessionCurriculumUpdatedNotification",
      "SessionRatingRequestNotification",
      "SessionSafeguardingIncidentNotification"
