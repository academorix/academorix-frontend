{
  "$version": 1,
  "name": "session",
  "alias": "session",
  "namespace": "Stackra\\Sports\\Session",
  "description": "A single practice / lesson / class instance. Composes a ResourceBooking (from facility module) for the physical slot + adds sport-specific fields (head_coach, session_type, attendance_capacity, curriculum_topic). Sessions are ATTACHED to Teams — recurring team practices generate one Session per week per Team. Standalone sessions (private lessons, ad-hoc training) attach directly to Athletes via a session-attendance pivot. Ships: Session model with lifecycle (scheduled -> confirmed -> in_progress -> completed -> cancelled -> rescheduled), attendance tracking via SessionAttendance pivot, coach assignment (head + up to 3 assistants), session ratings feed the Coach.rating aggregator (Wave 2b), booking-cascade on facility retirement (cascade cancels attached sessions). Downstream: Wave 3 attendance module writes to the pivot; Wave 4 finance module attributes revenue per session (private-lesson pricing).",
  "keywords": [
    "session",
    "sessions",
    "practice",
    "training",
    "lesson",
    "private-lesson",
    "group-lesson",
    "class",
    "drop-in",
    "workshop",
    "trial",
    "assessment",
    "game",
    "open-gym",
    "attendance",
    "check-in",
    "coach",
    "head-coach",
    "assistant-coach",
    "curriculum",
    "lesson-plan",
    "rating",
    "capacity",
    "team",
    "athlete",
    "season",
    "event",
    "facility",
    "resource-booking",
    "safeguarding",
    "minors",
    "wave-3b"
  ],
  "priority": 65,
  "providers": ["Stackra\\Sports\\Session\\Providers\\SessionServiceProvider"],
  "files": [],
  "dependencies": [
    "foundation",
    "tenancy",
    "application",
    "organization",
    "region",
    "branch",
    "entitlements",
    "teams",
    "athlete",
    "athlete-enrollment",
    "season",
    "age-group",
    "facility",
    "staff"
  ],
  "extendedBy": [],
  "planned_consumers": ["attendance", "finance", "notifications", "coaching", "scheduling"],
  "contributes": {
    "traits": ["BelongsToSession", "HasSessionAttendance"],
    "attributes": ["AsSessionListener"],
    "blueprints": ["sessions", "session_attendance"],
    "middleware": ["session.resolve_active"],
    "events": [
