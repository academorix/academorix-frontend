      "CompleteFinishedSessionsJob",
      "CancelUnderMinimumSessionsJob",
      "ReconcileAttendanceCountsJob",
      "AggregateSessionRatingsJob",
      "NotifySessionReminderJob",
      "PurgeCompletedSessionsJob"
    ],
    "notifications": [
