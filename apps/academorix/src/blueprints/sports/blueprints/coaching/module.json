      "NotifyCertificationExpiredJob",
      "NotifyAssignmentEndingSoonJob",
      "NotifyCoachAvailabilityConflictJob",
      "PurgeExpiredSkillRatingsJob",
      "GenerateCoachRosterReportJob"
