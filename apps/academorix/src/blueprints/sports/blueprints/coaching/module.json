  "hosts": {
    "tenant": {
      "description": "Tenant-facing coaching CRUD — admin + HR + staff-role manage coaching profiles, assignments, certifications, and skill ratings. Coaches self-serve their own profile + availability + certifications via /coaches/me/*.",
      "routes": [
        "GET /api/v1/coaching-profiles",
        "POST /api/v1/coaching-profiles",
        "GET /api/v1/coaching-profiles/{profile}",
        "PATCH /api/v1/coaching-profiles/{profile}",
        "POST /api/v1/coaching-profiles/{profile}/verify",
        "POST /api/v1/coaching-profiles/{profile}/deactivate",
        "POST /api/v1/coaching-profiles/{profile}/reactivate",
        "GET /api/v1/coach-assignments",
        "POST /api/v1/coach-assignments",
        "GET /api/v1/coach-assignments/{assignment}",
        "POST /api/v1/coach-assignments/{assignment}/end",
        "DELETE /api/v1/coach-assignments/{assignment}",
        "GET /api/v1/coach-certifications",
        "POST /api/v1/coach-certifications",
        "GET /api/v1/coach-certifications/{cert}",
        "POST /api/v1/coach-certifications/{cert}/verify",
        "GET /api/v1/coach-certifications/expiring",
        "GET /api/v1/coach-skill-ratings",
        "POST /api/v1/coach-skill-ratings",
        "GET /api/v1/coach-skill-ratings/{rating}",
        "PATCH /api/v1/coach-skill-ratings/{rating}",
        "GET /api/v1/coaches/{coach}/roster-report",
        "GET /api/v1/coaches/me",
        "PATCH /api/v1/coaches/me",
        "GET /api/v1/coaches/me/assignments",
        "GET /api/v1/coaches/me/certifications",
        "POST /api/v1/coaches/me/certifications",
        "GET /api/v1/coaches/me/ratings",
        "GET /api/v1/coaches/me/export"
      ]
    },
    "platform-admin": {
      "description": "Cross-tenant read for support tooling. Coach PII (bio + phone + photo) is redacted at the platform plane; hourly-rate is redacted on every platform read.",
      "routes": [
        "GET /api/v1/platform/coaching-profiles",
        "GET /api/v1/platform/coaching-profiles/{profile}"
      ]
    }
  }
}
