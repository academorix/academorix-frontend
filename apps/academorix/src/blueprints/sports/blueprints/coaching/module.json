      "CoachAssignmentPolicy",
      "CoachCertificationPolicy",
      "CoachSkillRatingPolicy"
    ],
    "hooks": [
      "PreventStaffOffboardingWithActiveCoachingProfile",
      "PurgeCoachingDataForErasedTenant",
      "DeactivateCoachingProfileOnStaffOffboarded",
      "CancelActiveAssignmentsOnCoachingProfileDeactivated",
      "ScheduleExpirationNoticesOnCertificationAdded"
    ],
    "commands": [
      "coaching-profile:list",
      "coaching-profile:describe",
      "coaching-profile:create",
      "coaching-profile:verify",
      "coaching-profile:deactivate",
