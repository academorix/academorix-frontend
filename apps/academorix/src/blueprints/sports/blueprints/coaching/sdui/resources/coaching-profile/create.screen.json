{
  "id": "coaching.resources.coaching-profile.create",
  "title": "Elevate staff to coach",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/coaching-profiles/create",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "coaching", "entity": "coaching-profile", "action": "create" },
  "requiresPermission": "coaching_profiles.create",
  "dataSources": [
    {
      "name": "eligibleStaff",
      "kind": "http.get",
      "url": "/api/v1/staff?filter[has_coaching_profile]=false&filter[employment_status]=active",
      "unwrap": "data"
    },
    {
      "name": "sports",
      "kind": "http.get",
      "url": "/api/v1/sports?filter[is_active]=true",
      "unwrap": "data",
      "cache": { "ttlSeconds": 300 }
    },
    {
      "name": "specializationsCatalog",
      "kind": "static",
      "value": { "$catalog": "coaching.specializations-catalog" }
    },
    {
      "name": "branches",
      "kind": "http.get",
      "url": "/api/v1/branches?filter[is_active]=true",
      "unwrap": "data"
    },
    {
      "name": "features",
      "kind": "http.get",
      "url": "/api/v1/features",
      "unwrap": "data",
      "cache": { "ttlSeconds": 60 }
    }
  ],
  "form": {
    "id": "createCoachingProfileForm",
    "submit": {
      "kind": "http.post",
      "url": "/api/v1/coaching-profiles",
      "body": "$form",
      "onSuccess": {
        "kind": "navigate",
        "toExpr": "'/tenant/coaching-profiles/' + $response.data.id"
      },
      "onError": { "kind": "toast.error", "message": "Could not create coaching profile." }
    }
  },
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-3xl mx-auto" },
      "children": [
        {
          "kind": "Text",
          "props": {
            "as": "h1",
            "className": "text-2xl font-semibold",
            "children": "Elevate staff to coach"
          }
        },
        {
          "kind": "Card",
          "children": [
            {
              "kind": "Card.Header",
              "children": [
                {
                  "kind": "Text",
                  "props": {
                    "as": "h2",
                    "className": "font-semibold",
                    "children": "Staff selection"
                  }
                }
              ]
            },
            {
              "kind": "Card.Content",
              "children": [
                {
                  "kind": "ComboBox",
                  "props": { "name": "staff_id", "menuTrigger": "focus" },
                  "children": [
                    { "kind": "Label", "propsExpr": "{ children: 'Staff' }" },
                    {
                      "kind": "ComboBox.InputGroup",
                      "children": [
                        {
                          "kind": "Input",
                          "props": { "placeholder": "Search staff by name or position..." }
                        },
                        { "kind": "ComboBox.Trigger" }
                      ]
                    },
                    {
                      "kind": "ComboBox.Popover",
                      "children": [
                        {
                          "kind": "ListBox",
                          "bindings": { "items": { "$ref": "eligibleStaff" } },
                          "children": [
                            {
                              "kind": "ListBox.Item",
                              "propsExpr": "{ id: $item.id, textValue: $item.display_name + ' — ' + $item.position }",
                              "children": [
                                {
                                  "kind": "Text",
                                  "props": { "className": "text-sm font-medium" },
                                  "bindings": { "children": { "$ref": "$item.display_name" } }
                                },
                                {
                                  "kind": "Text",
                                  "props": { "className": "text-xs text-muted" },
                                  "bindings": { "children": { "$ref": "$item.position" } }
                                },
                                { "kind": "ListBox.ItemIndicator" }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "kind": "ComboBox",
                  "props": { "name": "branch_id", "menuTrigger": "focus" },
                  "children": [
                    { "kind": "Label", "propsExpr": "{ children: 'Primary branch' }" },
                    {
                      "kind": "ComboBox.InputGroup",
                      "children": [
                        { "kind": "Input", "props": { "placeholder": "Search branch..." } },
                        { "kind": "ComboBox.Trigger" }
                      ]
                    },
                    {
                      "kind": "ComboBox.Popover",
                      "children": [
                        {
                          "kind": "ListBox",
                          "bindings": { "items": { "$ref": "branches" } },
                          "children": [
                            {
                              "kind": "ListBox.Item",
                              "propsExpr": "{ id: $item.id, textValue: $item.name }",
                              "children": [
                                {
                                  "kind": "Text",
                                  "bindings": { "children": { "$ref": "$item.name" } }
                                },
                                { "kind": "ListBox.ItemIndicator" }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "kind": "Card",
          "children": [
            {
              "kind": "Card.Header",
              "children": [
                {
                  "kind": "Text",
                  "props": {
                    "as": "h2",
                    "className": "font-semibold",
                    "children": "Sport & specialization"
                  }
                }
              ]
            },
            {
              "kind": "Card.Content",
              "children": [
                {
                  "kind": "ComboBox",
                  "props": { "name": "primary_sport_id", "menuTrigger": "focus" },
                  "children": [
                    { "kind": "Label", "propsExpr": "{ children: 'Primary sport (optional)' }" },
                    {
                      "kind": "ComboBox.InputGroup",
                      "children": [
                        { "kind": "Input", "props": { "placeholder": "Search sports..." } },
                        { "kind": "ComboBox.Trigger" }
                      ]
                    },
                    {
                      "kind": "ComboBox.Popover",
                      "children": [
                        {
                          "kind": "ListBox",
                          "bindings": { "items": { "$ref": "sports" } },
                          "children": [
                            {
                              "kind": "ListBox.Item",
                              "propsExpr": "{ id: $item.id, textValue: $item.name }",
                              "children": [
                                {
                                  "kind": "Text",
                                  "bindings": { "children": { "$ref": "$item.name" } }
                                },
                                { "kind": "ListBox.ItemIndicator" }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "kind": "NumberField",
                  "props": {
                    "name": "coaching_since_year",
                    "label": "Coaching since year",
                    "min": 1900,
                    "max": 2100,
                    "placeholder": "2015"
                  }
                },
                {
                  "kind": "MultiSelect",
                  "props": {
                    "name": "specializations",
                    "label": "Specializations",
                    "placeholder": "Select one or more..."
                  },
                  "bindings": { "options": { "$ref": "specializationsCatalog.specializations" } }
                }
              ]
            }
          ]
        },
        {
          "kind": "Card",
          "children": [
            {
              "kind": "Card.Header",
              "children": [
                {
                  "kind": "Text",
                  "props": {
                    "as": "h2",
                    "className": "font-semibold",
                    "children": "Bio & availability"
                  }
                }
              ]
            },
            {
              "kind": "Card.Content",
              "children": [
                {
                  "kind": "TextArea",
                  "props": {
                    "name": "bio",
                    "label": "Biography",
                    "rows": 4,
                    "placeholder": "Short professional bio..."
                  }
                },
                {
                  "kind": "TextField",
                  "props": {
                    "name": "photo_url_signed",
                    "label": "Photo URL (S3 signed)",
                    "placeholder": "https://..."
                  }
                },
                {
                  "kind": "Widget",
                  "widget": "coaching.availability-calendar",
                  "props": { "name": "availability", "editable": true }
                },
                {
                  "kind": "Switch",
                  "props": {
                    "name": "is_accepting_new_athletes",
                    "label": "Accepting new athletes",
                    "defaultSelected": true
                  }
                },
                {
                  "kind": "NumberField",
                  "props": {
                    "name": "max_athletes_per_session",
                    "label": "Max athletes per session (optional)",
                    "min": 1,
                    "max": 999
                  }
                },
                {
                  "kind": "TagGroup",
                  "props": {
                    "name": "languages_spoken",
                    "label": "Languages spoken (ISO 639-1)",
                    "allowsCustomValue": true,
                    "placeholder": "en, es, ar..."
                  }
                }
              ]
            }
          ]
        },
        {
          "kind": "Card",
          "requiresPermission": "coaching_profiles.update.rate",
          "children": [
            {
              "kind": "Card.Header",
              "children": [
                {
                  "kind": "Text",
                  "props": {
                    "as": "h2",
                    "className": "font-semibold",
                    "children": "Reference hourly rate (private)"
                  }
                }
              ]
            },
            {
              "kind": "Card.Content",
              "children": [
                {
                  "kind": "Alert",
                  "props": {
                    "variant": "info",
                    "children": "Reference only. Payroll is out-of-scope."
                  }
                },
                {
                  "kind": "NumberField",
                  "props": { "name": "hourly_rate_cents", "label": "Hourly rate (cents)", "min": 0 }
                },
                {
                  "kind": "TextField",
                  "props": {
                    "name": "rate_currency",
                    "label": "Currency (ISO 4217)",
                    "maxLength": 3,
                    "placeholder": "USD"
                  }
                }
              ]
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "flex justify-end gap-2" },
          "children": [
            {
              "kind": "Button",
              "props": { "variant": "flat", "children": "Cancel" },
              "actions": {
                "onPress": { "kind": "navigate", "toExpr": "'/tenant/coaching-profiles'" }
              }
            },
            {
              "kind": "Button",
              "props": { "variant": "primary", "type": "submit", "children": "Create profile" }
            }
          ]
        }
      ]
    }
  ]
}
