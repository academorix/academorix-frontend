{
  "id": "coaching.widgets.skill-rating-stars",
  "title": "Skill rating stars",
  "version": 1,
  "kind": "SduiWidget",
  "widget": "coaching.skill-rating-stars",
  "description": "Renders a CoachSkillRating value. For rating_scale='stars_1_5' displays 1-5 filled stars (★★★★☆). For rating_scale='level_5_stage' displays a level label with numeric badge ('Expert (4)'). Both scales encode integer 1-5.",
  "params": {
    "rating_scale": { "type": "string", "required": true, "enum": ["stars_1_5", "level_5_stage"] },
    "rating_value": { "type": "integer", "required": true, "minimum": 1, "maximum": 5 },
    "size": { "type": "string", "required": false, "default": "md", "enum": ["sm", "md", "lg"] }
  },
  "nodes": [
    {
      "kind": "View",
      "props": { "className": "flex items-center gap-2" },
      "bindings": { "hidden": { "$expr": "$params.rating_scale !== 'stars_1_5'" } },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-center", "role": "img" },
          "bindings": { "aria-label": { "$expr": "$params.rating_value + ' out of 5 stars'" } },
          "children": [
            {
              "kind": "Icon",
              "props": { "name": "star-solid", "className": "text-yellow-500 size-4" },
              "bindings": { "hidden": { "$expr": "$params.rating_value < 1" } }
            },
            {
              "kind": "Icon",
              "props": { "name": "star-solid", "className": "text-yellow-500 size-4" },
              "bindings": { "hidden": { "$expr": "$params.rating_value < 2" } }
            },
            {
              "kind": "Icon",
              "props": { "name": "star-solid", "className": "text-yellow-500 size-4" },
              "bindings": { "hidden": { "$expr": "$params.rating_value < 3" } }
            },
            {
              "kind": "Icon",
              "props": { "name": "star-solid", "className": "text-yellow-500 size-4" },
              "bindings": { "hidden": { "$expr": "$params.rating_value < 4" } }
            },
            {
              "kind": "Icon",
              "props": { "name": "star-solid", "className": "text-yellow-500 size-4" },
              "bindings": { "hidden": { "$expr": "$params.rating_value < 5" } }
            },
            {
              "kind": "Icon",
              "props": { "name": "star-outline", "className": "text-muted size-4" },
              "bindings": { "hidden": { "$expr": "$params.rating_value >= 1" } }
            },
            {
              "kind": "Icon",
              "props": { "name": "star-outline", "className": "text-muted size-4" },
              "bindings": { "hidden": { "$expr": "$params.rating_value >= 2" } }
            },
            {
              "kind": "Icon",
              "props": { "name": "star-outline", "className": "text-muted size-4" },
              "bindings": { "hidden": { "$expr": "$params.rating_value >= 3" } }
            },
            {
              "kind": "Icon",
              "props": { "name": "star-outline", "className": "text-muted size-4" },
              "bindings": { "hidden": { "$expr": "$params.rating_value >= 4" } }
            },
            {
              "kind": "Icon",
              "props": { "name": "star-outline", "className": "text-muted size-4" },
              "bindings": { "hidden": { "$expr": "$params.rating_value >= 5" } }
            }
          ]
        }
      ]
    },
    {
      "kind": "Chip",
      "props": { "size": "sm" },
      "bindings": {
        "hidden": { "$expr": "$params.rating_scale !== 'level_5_stage'" },
        "children": {
          "$expr": "($params.rating_value === 1 ? 'Beginner' : ($params.rating_value === 2 ? 'Intermediate' : ($params.rating_value === 3 ? 'Advanced' : ($params.rating_value === 4 ? 'Expert' : 'Master')))) + ' (' + $params.rating_value + ')'"
        },
        "variant": {
          "$expr": "$params.rating_value >= 4 ? 'success' : ($params.rating_value >= 3 ? 'primary' : 'secondary')"
        }
      }
    }
  ]
}
