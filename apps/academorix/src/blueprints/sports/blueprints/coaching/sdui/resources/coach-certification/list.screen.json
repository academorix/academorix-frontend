{
  "id": "coaching.resources.coach-certification.list",
  "title": "Coach certifications",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/coach-certifications",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "coaching", "entity": "coach-certification", "action": "list" },
  "requiresPermission": "coach_certifications.viewAny",
  "dataSources": [
    {
      "name": "certifications",
      "kind": "http.get",
      "url": "/api/v1/coach-certifications?sort=expires_at",
      "unwrap": "data",
      "queryFromFilters": true
    },
    {
      "name": "features",
      "kind": "http.get",
      "url": "/api/v1/features",
      "unwrap": "data",
      "cache": { "ttlSeconds": 60 }
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-7xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "kind": "View",
              "children": [
                {
                  "kind": "Text",
                  "props": {
                    "as": "h1",
                    "className": "text-2xl font-semibold",
                    "children": "Coach certifications"
                  }
                },
                {
                  "kind": "Text",
                  "props": {
                    "className": "text-sm text-muted",
                    "children": "Held credentials with expiration tracking."
                  }
                }
              ]
            },
            {
              "kind": "Button",
              "props": {
                "variant": "primary",
                "leadingIcon": "plus",
                "children": "Capture certification"
              },
              "actions": {
                "onPress": { "kind": "navigate", "toExpr": "'/tenant/coach-certifications/create'" }
              },
              "requiresPermission": "coach_certifications.create"
            }
          ]
        },
        {
          "kind": "Table",
          "props": { "aria-label": "Certifications table" },
          "bindings": {
            "rows": { "$ref": "certifications" },
            "isLoading": { "$ref": "certifications.isLoading" }
          },
          "columns": [
            {
              "key": "coach",
              "label": "Coach",
              "renderer": {
                "kind": "Text",
                "props": { "className": "font-medium" },
                "bindings": { "children": { "$ref": "row.coach_display_name" } }
              }
            },
            {
              "key": "issuing_body",
              "label": "Issuing body",
              "renderer": {
                "kind": "Chip",
                "props": { "size": "sm" },
                "bindings": { "children": { "$ref": "row.issuing_body" } }
              }
            },
            {
              "key": "certification_name",
              "label": "Name",
              "renderer": {
                "kind": "Text",
                "bindings": { "children": { "$ref": "row.certification_name" } }
              }
            },
            {
              "key": "level",
              "label": "Level",
              "renderer": { "kind": "Text", "bindings": { "children": { "$ref": "row.level" } } }
            },
            {
              "key": "issued_at",
              "label": "Issued",
              "renderer": {
                "kind": "Text",
                "bindings": { "children": { "$expr": "$formatDate(row.issued_at, 'MMM yyyy')" } }
              }
            },
            {
              "key": "expiration",
              "label": "Expires",
              "renderer": {
                "kind": "Widget",
                "widget": "coaching.certification-expiration-badge",
                "bindings": {
                  "expires_at": { "$ref": "row.expires_at" },
                  "days_until_expiry": { "$ref": "row.days_until_expiry" },
                  "is_expired": { "$ref": "row.is_expired" }
                }
              }
            },
            {
              "key": "verified",
              "label": "Verified",
              "renderer": {
                "kind": "Chip",
                "props": { "size": "sm" },
                "bindings": {
                  "children": { "$expr": "row.is_verified ? 'Verified' : 'Pending'" },
                  "variant": { "$expr": "row.is_verified ? 'success' : 'warning'" }
                }
              }
            },
            {
              "key": "actions",
              "label": "",
              "renderer": {
                "kind": "View",
                "props": { "className": "flex gap-2" },
                "children": [
                  {
                    "kind": "Button",
                    "props": {
                      "size": "sm",
                      "variant": "flat",
                      "leadingIcon": "check-circle",
                      "children": "Verify"
                    },
                    "actions": {
                      "onPress": {
                        "kind": "navigate",
                        "toExpr": "'/tenant/coach-certifications/' + row.id + '/verify'"
                      }
                    },
                    "bindings": {
                      "hidden": {
                        "$expr": "row.is_verified || !$ref('features.coaching.advanced_certifications')"
                      }
                    },
                    "requiresPermission": "coach_certifications.verify"
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
