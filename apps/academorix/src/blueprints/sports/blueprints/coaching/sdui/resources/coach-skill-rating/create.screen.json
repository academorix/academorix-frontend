{
  "id": "coaching.resources.coach-skill-rating.create",
  "title": "Record coach skill rating",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/coach-skill-ratings/create",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "coaching", "entity": "coach-skill-rating", "action": "create" },
  "requiresPermission": "coach_skill_ratings.create",
  "dataSources": [
    {
      "name": "coaches",
      "kind": "http.get",
      "url": "/api/v1/coaching-profiles?filter[is_active]=true&filter[verified]=true",
      "unwrap": "data"
    },
    {
      "name": "sports",
      "kind": "http.get",
      "url": "/api/v1/sports?filter[is_active]=true",
      "unwrap": "data"
    },
    {
      "name": "disciplines",
      "kind": "http.get",
      "url": "/api/v1/disciplines?filter[is_active]=true",
      "unwrap": "data"
    },
    {
      "name": "positions",
      "kind": "http.get",
      "url": "/api/v1/positions?filter[is_active]=true",
      "unwrap": "data"
    },
    {
      "name": "scaleCatalog",
      "kind": "static",
      "value": { "$catalog": "coaching.rating-scale-catalog" }
    }
  ],
  "form": {
    "id": "createCoachSkillRatingForm",
    "submit": {
      "kind": "http.post",
      "url": "/api/v1/coach-skill-ratings",
      "body": "$form",
      "onSuccess": {
        "kind": "navigate",
        "toExpr": "'/tenant/coach-skill-ratings/' + $response.data.id"
      },
      "onError": { "kind": "toast.error", "message": "Could not record rating." }
    }
  },
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-2xl mx-auto" },
      "children": [
        {
          "kind": "Text",
          "props": {
            "as": "h1",
            "className": "text-2xl font-semibold",
            "children": "Record coach skill rating"
          }
        },
        {
          "kind": "Card",
          "children": [
            {
              "kind": "Card.Content",
              "children": [
                {
                  "kind": "ComboBox",
                  "props": { "name": "coaching_profile_id", "menuTrigger": "focus" },
                  "children": [
                    { "kind": "Label", "propsExpr": "{ children: 'Coach' }" },
                    {
                      "kind": "ComboBox.InputGroup",
                      "children": [
                        { "kind": "Input", "props": { "placeholder": "Search coach..." } },
                        { "kind": "ComboBox.Trigger" }
                      ]
                    },
                    {
                      "kind": "ComboBox.Popover",
                      "children": [
                        {
                          "kind": "ListBox",
                          "bindings": { "items": { "$ref": "coaches" } },
                          "children": [
                            {
                              "kind": "ListBox.Item",
                              "propsExpr": "{ id: $item.id, textValue: $item.display_name }",
                              "children": [
                                {
                                  "kind": "Text",
                                  "bindings": { "children": { "$ref": "$item.display_name" } }
                                },
                                { "kind": "ListBox.ItemIndicator" }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "kind": "ToggleButtonGroup",
                  "props": { "name": "ratable_type", "aria-label": "Ratable type" },
                  "children": [
                    { "kind": "ToggleButton", "props": { "value": "Sport", "children": "Sport" } },
                    {
                      "kind": "ToggleButton",
                      "props": { "value": "Discipline", "children": "Discipline" }
                    },
                    {
                      "kind": "ToggleButton",
                      "props": { "value": "Position", "children": "Position" }
                    }
                  ]
                },
                {
                  "kind": "ComboBox",
                  "props": { "name": "ratable_id", "menuTrigger": "focus" },
                  "bindings": { "hidden": { "$expr": "!$form.ratable_type" } },
                  "children": [
                    { "kind": "Label", "propsExpr": "{ children: 'Ratable' }" },
                    {
                      "kind": "ComboBox.InputGroup",
                      "children": [
                        { "kind": "Input", "props": { "placeholder": "Search..." } },
                        { "kind": "ComboBox.Trigger" }
                      ]
                    },
                    {
                      "kind": "ComboBox.Popover",
                      "children": [
                        {
                          "kind": "ListBox",
                          "bindings": {
                            "items": {
                              "$expr": "$form.ratable_type === 'Sport' ? $ref('sports') : ($form.ratable_type === 'Discipline' ? $ref('disciplines') : $ref('positions'))"
                            }
                          },
                          "children": [
                            {
                              "kind": "ListBox.Item",
                              "propsExpr": "{ id: $item.id, textValue: $item.name }",
                              "children": [
                                {
                                  "kind": "Text",
                                  "bindings": { "children": { "$ref": "$item.name" } }
                                },
                                { "kind": "ListBox.ItemIndicator" }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "kind": "RadioGroup",
                  "props": { "name": "rating_scale", "label": "Rating scale" },
                  "bindings": { "items": { "$ref": "scaleCatalog.scales" } },
                  "itemRenderer": {
                    "kind": "RadioGroup.Item",
                    "propsExpr": "{ value: $item.value, children: $item.label }"
                  }
                },
                {
                  "kind": "Slider",
                  "props": {
                    "name": "rating_value",
                    "label": "Rating value (1-5)",
                    "minValue": 1,
                    "maxValue": 5,
                    "step": 1,
                    "defaultValue": 3
                  }
                },
                {
                  "kind": "TextArea",
                  "props": {
                    "name": "notes",
                    "label": "Notes (optional; admin-visible only)",
                    "rows": 3
                  }
                },
                {
                  "kind": "DateField",
                  "props": { "name": "expires_at", "label": "Expires date (default: 2 years)" }
                }
              ]
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "flex justify-end gap-2" },
          "children": [
            {
              "kind": "Button",
              "props": { "variant": "flat", "children": "Cancel" },
              "actions": {
                "onPress": { "kind": "navigate", "toExpr": "'/tenant/coach-skill-ratings'" }
              }
            },
            {
              "kind": "Button",
              "props": { "variant": "primary", "type": "submit", "children": "Record rating" }
            }
          ]
        }
      ]
    }
  ]
}
