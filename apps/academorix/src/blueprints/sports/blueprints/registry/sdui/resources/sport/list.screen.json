{
  "id": "sports-registry.resources.sport.list",
  "title": "Sports catalog",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/settings/sports",
  "host": "tenant",
  "audience": "sanctum",
  "resource": { "module": "sports-registry", "entity": "sport", "action": "list" },
  "requiresPermission": "sports.viewAny",
  "notes": [
    "Shows the MERGED catalog (platform-seeded + own tenant customs). The `is_platform_seeded` filter lets the tenant admin scope the view: platform-only for browsing the base catalog; custom-only for managing their own additions.",
    "Enterprise tenants see the 'Add sport' primary action; Small + Medium tiers see it disabled with an upgrade prompt. The `entitlements.sports_registry_custom` flag drives the rendering.",
    "The `downstream_reference_count` column is populated lazily (include=downstream_reference_count on the list request); it enables the deactivate-guardrail modal without a second roundtrip."
  ],
  "dataSources": [
    {
      "name": "sports",
      "kind": "http.get",
      "urlExpr": "'/api/v1/sports?include=downstream_reference_count,discipline_count&sort=category,sort_order,name'",
      "unwrap": "data"
    },
    {
      "name": "me",
      "kind": "http.get",
      "url": "/api/auth/me",
      "unwrap": "data",
      "cache": { "ttlSeconds": 60 }
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-center justify-between" },
          "children": [
            {
              "kind": "View",
              "children": [
                {
                  "kind": "Text",
                  "props": {
                    "as": "h1",
                    "className": "text-2xl font-semibold",
                    "children": "Sports catalog"
                  }
                },
                {
                  "kind": "Text",
                  "props": {
                    "className": "text-sm text-muted",
                    "children": "Platform-seeded sports plus any custom sports your team has added. Enterprise-only for customs."
                  }
                }
              ]
            },
            {
              "kind": "Button",
              "props": { "variant": "primary", "leadingIcon": "plus", "children": "Add sport" },
              "actions": { "onPress": { "kind": "navigate", "to": "/settings/sports/create" } },
              "bindings": {
                "props": {
                  "isDisabled": { "$expr": "!me.entitlements.sports_registry_custom" }
                }
              },
              "requiresPermission": "sports.create"
            }
          ]
        },
        {
          "kind": "Alert",
          "props": {
            "variant": "info",
            "children": "Custom sports are Enterprise-only. Upgrade your plan to add sports beyond the platform catalog."
          },
          "bindings": { "hidden": { "$expr": "!!me.entitlements.sports_registry_custom" } }
        },
        {
          "kind": "Toolbar",
          "children": [
            {
              "kind": "SearchField",
              "props": { "placeholder": "Search sport name, slug, governing body", "name": "q" }
            },
            {
              "kind": "Select",
              "props": { "name": "category", "placeholder": "All categories", "clearable": true },
              "options": [
                { "key": "team_sport", "label": "Team sports" },
                { "key": "individual_sport", "label": "Individual sports" },
                { "key": "racquet", "label": "Racquet" },
                { "key": "combat", "label": "Combat" },
                { "key": "aquatic", "label": "Aquatic" },
                { "key": "winter", "label": "Winter" },
                { "key": "cycling", "label": "Cycling" },
                { "key": "track_field", "label": "Track and field" },
                { "key": "fitness", "label": "Fitness" },
                { "key": "recreational", "label": "Recreational" }
              ]
            },
            {
              "kind": "Select",
              "props": {
                "name": "gender_typical",
                "placeholder": "All genders",
                "clearable": true
              },
              "options": [
                { "key": "any", "label": "Any" },
                { "key": "male_only", "label": "Male-only" },
                { "key": "female_only", "label": "Female-only" },
                { "key": "mixed", "label": "Mixed" }
              ]
            },
            {
              "kind": "Select",
              "props": {
                "name": "is_platform_seeded",
                "placeholder": "Platform + custom",
                "clearable": true
              },
              "options": [
                { "key": "true", "label": "Platform-seeded only" },
                { "key": "false", "label": "Custom only" }
              ]
            },
            { "kind": "Toggle", "props": { "name": "is_active", "label": "Active only" } }
          ]
        },
        {
          "kind": "Table",
          "columns": [
            {
              "key": "sport",
              "header": "Sport",
              "cell": {
                "kind": "View",
                "props": { "className": "flex items-center gap-2" },
                "children": [
                  {
                    "kind": "View",
                    "props": { "className": "size-4 rounded-full flex-shrink-0" },
                    "bindings": {
                      "props": {
                        "style": { "$expr": "{ backgroundColor: row.primary_color || '#94A3B8' }" }
                      }
                    }
                  },
                  {
                    "kind": "Link",
                    "propsExpr": "{ to: '/settings/sports/' + row.id, children: row.name, className: 'font-medium' }"
                  },
                  {
                    "kind": "Text",
                    "props": { "className": "text-xs text-muted font-mono" },
                    "bindings": { "children": { "$ref": "row.slug" } }
                  }
                ]
              }
            },
            {
              "key": "category",
              "header": "Category",
              "cell": {
                "kind": "Chip",
                "props": { "size": "xs", "variant": "neutral" },
                "bindings": { "children": { "$ref": "row.category" } }
              }
            },
            {
              "key": "governing_body",
              "header": "Governing body"
            },
            {
              "key": "flags",
              "header": "Flags",
              "cell": {
                "kind": "View",
                "props": { "className": "flex items-center gap-1" },
                "children": [
                  {
                    "kind": "Chip",
                    "props": { "size": "xs", "variant": "info", "children": "Platform" },
                    "bindings": { "hidden": { "$expr": "!row.is_platform_seeded" } }
                  },
                  {
                    "kind": "Chip",
                    "props": { "size": "xs", "variant": "accent", "children": "Custom" },
                    "bindings": { "hidden": { "$expr": "row.is_platform_seeded" } }
                  },
                  {
                    "kind": "Chip",
                    "props": { "size": "xs", "variant": "success" },
                    "bindings": {
                      "hidden": { "$expr": "!row.is_active" },
                      "children": "Active"
                    }
                  },
                  {
                    "kind": "Chip",
                    "props": { "size": "xs", "variant": "neutral", "children": "Deactivated" },
                    "bindings": { "hidden": { "$expr": "row.is_active" } }
                  }
                ]
              }
            },
            {
              "key": "counts",
              "header": "Usage",
              "cell": {
                "kind": "Text",
                "props": { "className": "text-xs text-muted" },
                "bindings": {
                  "children": {
                    "$expr": "row.discipline_count + ' disciplines · ' + row.downstream_reference_count + ' references'"
                  }
                }
              }
            }
          ],
          "bindings": { "rows": { "$ref": "sports" } }
        }
      ]
    }
  ]
}
