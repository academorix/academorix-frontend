{
  "id": "stackra://modules/athlete-guardian/errors",
  "$version": 1,
  "title": "athlete-guardian — error codes",
  "namespace": "athlete_guardian",
  "errors": [
    {
      "code": "GUARDIAN_NOT_FOUND",
      "http": 404,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "athlete_guardian.errors.guardian_not_found"
    },
    {
      "code": "GUARDIAN_ATHLETE_INACTIVE",
      "http": 422,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "athlete_guardian.errors.guardian_athlete_inactive",
      "description": "Cannot add guardian to a withdrawn/archived athlete."
    },
    {
      "code": "GUARDIAN_USER_NOT_ACTIVE",
      "http": 422,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "athlete_guardian.errors.guardian_user_not_active"
    },
    {
      "code": "GUARDIAN_DUPLICATE",
      "http": 409,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
