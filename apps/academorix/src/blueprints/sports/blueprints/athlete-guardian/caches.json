{
  "id": "stackra://modules/athlete-guardian/caches",
  "$version": 1,
  "title": "athlete-guardian — cache keys + tags",
  "driver": "redis",
  "ownedTags": [
    "athlete_guardian",
    "athlete_guardian.primary",
    "athlete_guardian.by_user",
    "athlete_guardian.pickup_list"
  ],
  "keys": [
    {
      "pattern": "agu:by_athlete:{athlete_id}",
      "description": "All active guardians for an athlete. Read hot on every athlete-detail page.",
      "ttlSeconds": 300,
      "tags": ["athlete_guardian"],
      "invalidatedBy": [
        "GuardianAdded",
        "GuardianRemoved",
        "PrimaryGuardianChanged",
        "GuardianVerified",
        "GuardianVerificationRevoked"
      ]
    },
    {
      "pattern": "agu:primary:{athlete_id}",
      "description": "The current primary guardian for an athlete. Hot key — read on every notification-routing decision + medical-authorisation resolution.",
      "ttlSeconds": 600,
      "tags": ["athlete_guardian", "athlete_guardian.primary"],
      "invalidatedBy": ["PrimaryGuardianChanged", "GuardianRemoved (when the removed was primary)"]
    },
    {
      "pattern": "agu:by_user:{user_id}",
      "description": "All active guardianships held by a User. Feeds /me/guardianships + the athlete-list `.own` scope.",
      "ttlSeconds": 300,
      "tags": ["athlete_guardian", "athlete_guardian.by_user"],
      "invalidatedBy": ["GuardianAdded", "GuardianRemoved", "GuardianVerificationRevoked"]
    },
    {
      "pattern": "agu:pickup_list:{athlete_id}",
      "description": "Guardians authorised to pick up an athlete (can_pickup=true AND is_active). Read hot by reception staff on session dismissal.",
      "ttlSeconds": 300,
      "tags": ["athlete_guardian", "athlete_guardian.pickup_list"],
      "invalidatedBy": ["GuardianCanPickupToggled", "GuardianAdded", "GuardianRemoved"]
    },
    {
      "pattern": "agu:medical_authorised:{athlete_id}",
      "description": "Guardians authorised for emergency medical decisions (can_authorise_medical_care=true AND has_legal_custody=true AND is_active). Wave 4+ Medical Clearance module reads this.",
      "ttlSeconds": 600,
      "tags": ["athlete_guardian"],
      "invalidatedBy": [
        "GuardianCanAuthoriseMedicalCareToggled",
        "GuardianCustodyChanged",
        "GuardianAdded",
        "GuardianRemoved"
      ]
    }
  ]
}
