{
  "id": "stackra://modules/development/schemas/scouting-report",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "ScoutingReport",
  "type": "object",
  "x-module": "development",
  "x-eloquent": {
    "table": "scouting_reports",
    "keyPrefix": "sct_",
    "traits": [
      "HasFactory",
      "HasPrefixedUlid",
      "BelongsToTenant",
      "BelongsToAthlete",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "HasActivityLog",
      "Filterable",
      "SoftDeletes"
    ]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 30, "primary": true },
      "tenant_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "athlete_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "athletes", "column": "id", "onDelete": "restrict" }
      },
      "scout_user_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "users", "column": "id", "onDelete": "restrict" }
      },
      "observed_at": { "type": "date", "nullable": false },
      "context": {
        "type": "string",
        "length": 32,
        "nullable": true,
        "description": "match / training / trial / tournament."
      },
      "narrative": { "type": "text", "nullable": false },
      "rating_overall": { "type": "integer", "nullable": true, "description": "1-10." },
      "strengths": { "type": "jsonb", "nullable": true },
      "areas_to_develop": { "type": "jsonb", "nullable": true },
      "recommend_promotion": { "type": "boolean", "nullable": false, "default": "false" },
      "tags": { "type": "jsonb", "nullable": true },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false },
      "deleted_at": { "type": "timestamptz", "nullable": true }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "athlete_id", "observed_at"],
        "name": "scouting_reports_athlete_time_idx"
      }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "athlete_id",
    "scout_user_id",
    "observed_at",
    "narrative",
    "created_at",
    "updated_at"
  ],
  "properties": { "id": { "type": "string", "pattern": "^sct_[0-9A-HJKMNP-TV-Z]{26}$" } },
  "additionalProperties": false
}
