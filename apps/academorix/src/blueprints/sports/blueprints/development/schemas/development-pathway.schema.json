{
  "id": "stackra://modules/development/schemas/development-pathway",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "DevelopmentPathway",
  "type": "object",
  "x-module": "development",
  "x-eloquent": {
    "table": "development_pathways",
    "keyPrefix": "dvp_",
    "traits": [
      "HasFactory",
      "HasPrefixedUlid",
      "BelongsToTenant",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "Filterable",
      "SoftDeletes"
    ]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 30, "primary": true },
      "tenant_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "sport_key": { "type": "string", "length": 32, "nullable": false },
      "name": { "type": "string", "length": 200, "nullable": false },
      "description": { "type": "text", "nullable": true },
      "is_active": { "type": "boolean", "nullable": false, "default": "true" },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false },
      "deleted_at": { "type": "timestamptz", "nullable": true }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "sport_key", "name"],
        "unique": true,
        "name": "development_pathways_unique",
        "predicate": "deleted_at IS NULL"
      }
    ]
  },
  "required": ["id", "tenant_id", "sport_key", "name", "is_active", "created_at", "updated_at"],
  "properties": { "id": { "type": "string", "pattern": "^dvp_[0-9A-HJKMNP-TV-Z]{26}$" } },
  "additionalProperties": false
}
