{
  "id": "stackra://modules/private-sessions/schemas/private-session-request",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "PrivateSessionRequest",
  "type": "object",
  "x-module": "private-sessions",
  "x-eloquent": {
    "table": "private_session_requests",
    "keyPrefix": "psq_",
    "traits": [
      "HasFactory",
      "HasPrefixedUlid",
      "BelongsToTenant",
      "BelongsToAthlete",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "HasActivityLog",
      "Filterable",
      "SoftDeletes"
    ]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 30, "primary": true },
      "tenant_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "athlete_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "athletes", "column": "id", "onDelete": "restrict" }
      },
      "requested_by_user_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "users", "column": "id", "onDelete": "restrict" }
      },
      "preferred_coach_id": {
        "type": "string",
        "length": 30,
        "nullable": true,
        "foreign": { "table": "coaching_profiles", "column": "id", "onDelete": "set null" }
      },
      "assigned_coach_id": {
        "type": "string",
        "length": 30,
        "nullable": true,
        "foreign": { "table": "coaching_profiles", "column": "id", "onDelete": "set null" }
      },
      "sport_key": { "type": "string", "length": 32, "nullable": false },
      "preferred_slots": { "type": "jsonb", "nullable": true },
      "notes": { "type": "text", "nullable": true },
      "status": { "type": "string", "length": 16, "nullable": false, "default": "'requested'" },
      "scheduled_session_id": {
        "type": "string",
        "length": 30,
        "nullable": true,
        "foreign": { "table": "sessions", "column": "id", "onDelete": "set null" }
      },
      "completed_at": { "type": "timestamptz", "nullable": true },
      "cancellation_reason": { "type": "string", "length": 500, "nullable": true },
      "invoice_id": {
        "type": "string",
        "length": 30,
        "nullable": true,
        "foreign": { "table": "invoices", "column": "id", "onDelete": "set null" }
      },
      "consumed_credit_id": {
        "type": "string",
        "length": 30,
        "nullable": true,
        "foreign": { "table": "session_credits", "column": "id", "onDelete": "set null" }
      },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false },
      "deleted_at": { "type": "timestamptz", "nullable": true }
    },
    "indexes": [
      { "columns": ["tenant_id", "athlete_id", "status"], "name": "psr_athlete_status_idx" },
      { "columns": ["tenant_id", "assigned_coach_id", "status"], "name": "psr_coach_status_idx" }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "athlete_id",
    "requested_by_user_id",
    "sport_key",
    "status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^psq_[0-9A-HJKMNP-TV-Z]{26}$" },
    "status": {
      "type": "string",
      "enum": [
        "requested",
        "approved",
        "rejected",
        "scheduled",
        "completed",
        "no_show",
        "cancelled"
      ]
    }
  },
  "additionalProperties": false
}
