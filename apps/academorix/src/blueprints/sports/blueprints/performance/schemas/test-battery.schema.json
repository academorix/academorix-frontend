{
  "id": "stackra://modules/performance/schemas/test-battery",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "TestBattery",
  "description": "Named collection of PerformanceTests bundled for a program (e.g. 'U12 Football Physical Q1'). Sport + age-band scoped. Versioned.",
  "type": "object",
  "x-module": "performance",
  "x-eloquent": {
    "table": "test_batteries",
    "keyPrefix": "ptb_",
    "traits": [
      "HasFactory",
      "HasPrefixedUlid",
      "BelongsToTenant",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "Filterable",
      "SoftDeletes"
    ]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 30, "primary": true },
      "tenant_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "sport_key": { "type": "string", "length": 32, "nullable": false },
      "code": { "type": "string", "length": 64, "nullable": false },
      "name": { "type": "string", "length": 200, "nullable": false },
      "age_band": { "type": "string", "length": 32, "nullable": true },
      "test_ids": {
        "type": "jsonb",
        "nullable": false,
        "default": "'[]'",
        "description": "Ordered array of PerformanceTest IDs."
      },
      "version_number": { "type": "integer", "nullable": false, "default": "1" },
      "is_active": { "type": "boolean", "nullable": false, "default": "true" },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false },
      "deleted_at": { "type": "timestamptz", "nullable": true }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "sport_key", "code"],
        "unique": true,
        "name": "test_batteries_unique",
        "predicate": "deleted_at IS NULL"
      }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "sport_key",
    "code",
    "name",
    "test_ids",
    "version_number",
    "is_active",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^ptb_[0-9A-HJKMNP-TV-Z]{26}$" }
  },
  "additionalProperties": false
}
