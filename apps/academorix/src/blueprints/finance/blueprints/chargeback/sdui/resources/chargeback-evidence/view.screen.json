{
  "id": "chargeback.resources.chargeback-evidence.view",
  "title": "Chargeback evidence history",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/chargebacks/{chargeback}/evidence",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "chargeback", "entity": "chargeback-evidence", "action": "viewAny" },
  "requiresPermission": "chargebacks.view-evidence",
  "requiresEntitlement": "chargeback_management",
  "dataSources": [
    {
      "name": "chargeback",
      "kind": "http.get",
      "url": "/api/v1/chargebacks/{route.chargeback}",
      "unwrap": "data"
    },
    {
      "name": "evidence",
      "kind": "http.get",
      "url": "/api/v1/chargebacks/{route.chargeback}/evidence",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-5xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "children": [
            {
              "kind": "Text",
              "props": { "as": "h1", "className": "text-2xl font-semibold" },
              "children": "Evidence submissions"
            },
            {
              "kind": "Text",
              "props": { "className": "text-sm text-muted mt-1" },
              "bindings": {
                "children": {
                  "$expr": "'For chargeback ' + chargeback.chargeback_number + '. Every submission attempt (append-only audit trail).'"
                }
              }
            }
          ]
        },
        {
          "kind": "Grid",
          "props": { "className": "grid grid-cols-1 gap-4" },
          "bindings": {
            "items": { "$ref": "evidence" }
          },
          "emptyState": {
            "kind": "View",
            "props": { "className": "text-center py-12" },
            "children": [
              {
                "kind": "Icon",
                "props": {
                  "name": "document-magnifying-glass",
                  "className": "size-12 mx-auto text-muted"
                }
              },
              {
                "kind": "Text",
                "props": {
                  "className": "mt-4 text-lg font-medium",
                  "children": "No evidence submissions"
                }
              },
              {
                "kind": "Text",
                "props": {
                  "className": "text-sm text-muted",
                  "children": "No evidence has been submitted for this chargeback yet."
                }
              }
            ]
          },
          "itemRenderer": {
            "kind": "Card",
            "props": { "className": "p-6" },
            "children": [
              {
                "kind": "View",
                "props": { "className": "flex items-start justify-between gap-2 mb-4" },
                "children": [
                  {
                    "kind": "View",
                    "children": [
                      {
                        "kind": "Text",
                        "props": { "className": "text-lg font-semibold" },
                        "bindings": {
                          "children": { "$expr": "'Submission #' + row.submission_attempt_number" }
                        }
                      },
                      {
                        "kind": "Text",
                        "props": { "className": "text-xs text-muted" },
                        "bindings": {
                          "children": {
                            "$expr": "'Submitted ' + formatDate(row.submitted_at, 'long')"
                          }
                        }
                      }
                    ]
                  },
                  {
                    "kind": "Widget",
                    "widget": "chargeback.evidence-completeness-indicator",
                    "bindings": {
                      "percent": { "$ref": "row.completeness_percent" }
                    }
                  }
                ]
              },
              {
                "kind": "View",
                "props": { "className": "grid grid-cols-2 gap-3 text-sm" },
                "children": [
                  { "kind": "Text", "props": { "children": "Invoice evidence: populated" } },
                  { "kind": "Text", "props": { "children": "Receipt evidence: populated" } },
                  { "kind": "Text", "props": { "children": "Service documentation: populated" } },
                  { "kind": "Text", "props": { "children": "Refund policy: populated" } },
                  { "kind": "Text", "props": { "children": "Communication log: populated" } },
                  { "kind": "Text", "props": { "children": "Customer signature: populated" } }
                ]
              }
            ]
          }
        }
      ]
    }
  ]
}
