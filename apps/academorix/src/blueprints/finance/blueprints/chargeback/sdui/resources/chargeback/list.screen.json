{
  "id": "chargeback.resources.chargeback.list",
  "title": "Chargebacks",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/chargebacks",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "chargeback", "entity": "chargeback", "action": "list" },
  "requiresPermission": "chargebacks.viewAny",
  "requiresEntitlement": "chargeback_management",
  "dataSources": [
    {
      "name": "chargebacks",
      "kind": "http.get",
      "url": "/api/v1/chargebacks",
      "unwrap": "data",
      "queryFromFilters": true
    },
    {
      "name": "pending_evidence_count",
      "kind": "http.get",
      "url": "/api/v1/chargebacks/pending-evidence?count_only=1",
      "unwrap": "data"
    },
    {
      "name": "rate_alert_summary",
      "kind": "http.get",
      "url": "/api/v1/reports/chargeback-rate?summary_only=1",
      "unwrap": "data"
    }
  ],
  "broadcasts": [
    { "channel": "tenant.{tenantId}.chargebacks", "onEvent": ["*"], "action": "refresh" },
    {
      "channel": "tenant.{tenantId}.chargebacks.rate-alerts",
      "onEvent": ["ChargebackRateThresholdExceeded"],
      "action": "refresh_rate_summary"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-7xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "kind": "View",
              "children": [
                {
                  "kind": "Text",
                  "props": {
                    "as": "h1",
                    "className": "text-2xl font-semibold",
                    "children": "Chargebacks"
                  }
                },
                {
                  "kind": "Text",
                  "props": {
                    "className": "text-sm text-muted",
                    "children": "Bank-forced payment reversals initiated by cardholders."
                  }
                }
              ]
            },
            {
              "kind": "View",
              "props": { "className": "flex items-center gap-3" },
              "children": [
                {
                  "kind": "Button",
                  "props": {
                    "variant": "outline",
                    "leadingIcon": "clock",
                    "children": "Pending evidence"
                  },
                  "actions": {
                    "onPress": { "kind": "navigate", "to": "/tenant/chargebacks/pending-evidence" }
                  },
                  "bindings": {
                    "badge": { "$ref": "pending_evidence_count.count" },
                    "hidden": { "$expr": "!hasPermission('chargebacks.submit-evidence')" }
                  }
                },
                {
                  "kind": "Button",
                  "props": {
                    "variant": "outline",
                    "leadingIcon": "chart-bar",
                    "children": "Rate report"
                  },
                  "actions": {
                    "onPress": { "kind": "navigate", "to": "/tenant/reports/chargeback-rate" }
                  },
                  "requiresPermission": "chargebacks.view-report"
                }
              ]
            }
          ]
        },
        {
          "kind": "Alert",
          "props": { "variant": "danger" },
          "bindings": {
            "hidden": { "$expr": "!rate_alert_summary.any_threshold_exceeded" }
          },
          "children": [
            {
              "kind": "Text",
              "props": {
                "className": "font-medium",
                "children": "Chargeback rate threshold exceeded"
              }
            },
            {
              "kind": "Text",
              "props": { "className": "text-sm" },
              "bindings": {
                "children": {
                  "$expr": "'Your rolling 60-day chargeback rate on ' + rate_alert_summary.exceeded_networks.join(', ') + ' is above the VDMP/MDMP threshold. Merchant-account termination risk if sustained. Review the rate report + take corrective action.'"
                }
              }
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "flex items-center gap-2 py-2 flex-wrap" },
          "children": [
            {
              "kind": "ComboBox",
              "props": { "label": "Status", "menuTrigger": "focus", "className": "min-w-48" },
              "props_items": [
                { "id": "pending_evidence", "label": "Pending evidence" },
                { "id": "evidence_submitted", "label": "Evidence submitted" },
                { "id": "under_bank_review", "label": "Under bank review" },
                { "id": "won", "label": "Won" },
                { "id": "lost", "label": "Lost" },
                { "id": "expired", "label": "Expired" },
                { "id": "accepted_refund", "label": "Accepted refund (RDR)" }
              ],
              "actions": {
                "onSelectionChange": {
                  "kind": "filter.set",
                  "field": "status",
                  "valueExpr": "$selectedKey"
                }
              }
            },
            {
              "kind": "ComboBox",
              "props": { "label": "Network", "menuTrigger": "focus", "className": "min-w-40" },
              "props_items": [
                { "id": "visa", "label": "Visa" },
                { "id": "mastercard", "label": "Mastercard" },
                { "id": "amex", "label": "American Express" },
                { "id": "discover", "label": "Discover" },
                { "id": "jcb", "label": "JCB" },
                { "id": "unionpay", "label": "UnionPay" },
                { "id": "diners", "label": "Diners Club" },
                { "id": "other", "label": "Other" }
              ],
              "actions": {
                "onSelectionChange": {
                  "kind": "filter.set",
                  "field": "network",
                  "valueExpr": "$selectedKey"
                }
              }
            },
            {
              "kind": "ComboBox",
              "props": {
                "label": "Reason category",
                "menuTrigger": "focus",
                "className": "min-w-52"
              },
              "props_items": [
                { "id": "fraud", "label": "Fraud" },
                { "id": "authorization", "label": "Authorization" },
                { "id": "processing_errors", "label": "Processing errors" },
                { "id": "consumer_disputes", "label": "Consumer disputes" },
                { "id": "card_recovery", "label": "Card recovery" }
              ],
              "actions": {
                "onSelectionChange": {
                  "kind": "filter.set",
                  "field": "reason_category",
                  "valueExpr": "$selectedKey"
                }
              }
            },
            {
              "kind": "ComboBox",
              "props": { "label": "Provider", "menuTrigger": "focus", "className": "min-w-40" },
              "props_items": [
                { "id": "stripe", "label": "Stripe" },
                { "id": "paddle", "label": "Paddle" },
                { "id": "adyen", "label": "Adyen" },
                { "id": "square", "label": "Square" },
                { "id": "paypal", "label": "PayPal" },
                { "id": "custom_webhook", "label": "Custom" }
              ],
              "actions": {
                "onSelectionChange": {
                  "kind": "filter.set",
                  "field": "provider",
                  "valueExpr": "$selectedKey"
                }
              }
            },
            {
              "kind": "Checkbox",
              "props": { "label": "RDR-eligible only" },
              "actions": {
                "onCheckedChange": {
                  "kind": "filter.set",
                  "field": "rdr_eligible",
                  "valueExpr": "$checked ? true : null"
                }
              }
            }
          ]
        },
        {
          "kind": "Grid",
          "props": { "className": "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" },
          "bindings": {
            "items": { "$ref": "chargebacks" },
            "isLoading": { "$ref": "chargebacks.isLoading" }
          },
          "emptyState": {
            "kind": "View",
            "props": { "className": "col-span-full text-center py-12" },
            "children": [
              {
                "kind": "Icon",
                "props": { "name": "shield-check", "className": "size-12 mx-auto text-success" }
              },
              {
                "kind": "Text",
                "props": { "className": "mt-4 text-lg font-medium", "children": "No chargebacks" }
              },
              {
                "kind": "Text",
                "props": {
                  "className": "text-sm text-muted",
                  "children": "Your merchant account is in good standing — the lower this list, the better."
                }
              }
            ]
          },
          "itemRenderer": {
            "kind": "Card",
            "props": { "className": "p-4 hover:shadow-md transition-shadow cursor-pointer" },
            "actions": {
              "onPress": { "kind": "navigate", "toExpr": "'/tenant/chargebacks/' + row.id" }
            },
            "children": [
              {
                "kind": "View",
                "props": { "className": "flex items-start justify-between gap-2 mb-2" },
                "children": [
                  {
                    "kind": "View",
                    "children": [
                      {
                        "kind": "Text",
                        "props": { "className": "font-mono text-sm font-medium" },
                        "bindings": { "children": { "$ref": "row.chargeback_number" } }
                      },
                      {
                        "kind": "Text",
                        "props": { "className": "text-xs text-muted mt-0.5" },
                        "bindings": {
                          "children": { "$ref": "row.reason_description" }
                        }
                      }
                    ]
                  },
                  {
                    "kind": "Widget",
                    "widget": "chargeback.chargeback-status-chip",
                    "bindings": {
                      "status": { "$ref": "row.status" },
                      "rdrEligible": { "$ref": "row.rdr_eligible" },
                      "ce3Eligible": { "$ref": "row.ce3_eligible" }
                    }
                  }
                ]
              },
              {
                "kind": "View",
                "props": { "className": "flex items-center gap-2 mt-2 flex-wrap" },
                "children": [
                  {
                    "kind": "Widget",
                    "widget": "chargeback.network-badge",
                    "bindings": { "network": { "$ref": "row.network" } }
                  },
                  {
                    "kind": "Chip",
                    "props": { "size": "sm", "variant": "neutral" },
                    "bindings": {
                      "children": { "$ref": "row.reason_code" }
                    }
                  },
                  {
                    "kind": "Chip",
                    "props": { "size": "sm", "variant": "neutral" },
                    "bindings": {
                      "children": {
                        "$expr": "row.reason_category.split('_').map(w => w[0].toUpperCase() + w.slice(1)).join(' ')"
                      }
                    }
                  }
                ]
              },
              {
                "kind": "View",
                "props": { "className": "flex items-center gap-3 text-xs text-muted mt-3" },
                "children": [
                  {
                    "kind": "Text",
                    "bindings": {
                      "hidden": { "$expr": "!hasPermission('chargebacks.view-financials')" },
                      "children": {
                        "$expr": "formatCurrency(row.amount_cents, row.currency)"
                      }
                    }
                  },
                  {
                    "kind": "Text",
                    "props": { "className": "ml-auto" },
                    "bindings": {
                      "children": {
                        "$expr": "row.status === 'pending_evidence' ? ('Evidence due ' + formatDate(row.evidence_due_by, 'relative')) : ('Filed ' + formatDate(row.filed_at, 'relative'))"
                      }
                    }
                  }
                ]
              }
            ]
          }
        }
      ]
    }
  ]
}
