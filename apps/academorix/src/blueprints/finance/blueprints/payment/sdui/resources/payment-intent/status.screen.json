{
  "id": "payment.resources.payment-intent.status",
  "title": "Payment status",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/payments/intents/{intent}/status",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "payment", "entity": "payment-intent", "action": "view" },
  "requiresPermission": "payment.intents.view",
  "requiresEntitlement": "payment_capture",
  "dataSources": [
    {
      "name": "intent",
      "kind": "http.get",
      "urlExpr": "'/api/v1/payments/intents/' + params.intent",
      "unwrap": "data",
      "poll": {
        "intervalMs": 3000,
        "stopWhenExpr": "intent.status in ['succeeded', 'cancelled', 'failed']"
      }
    }
  ],
  "subscriptions": [
    {
      "channel": "customer.{{auth.user.id}}.payments",
      "onEvent": "PaymentIntentSucceeded",
      "refreshDataSource": "intent"
    },
    {
      "channel": "customer.{{auth.user.id}}.payments",
      "onEvent": "PaymentIntentFailed",
      "refreshDataSource": "intent"
    },
    {
      "channel": "customer.{{auth.user.id}}.payments",
      "onEvent": "PaymentIntentRequiresAction",
      "refreshDataSource": "intent"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-6 p-6 max-w-2xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-center gap-3" },
          "children": [
            {
              "kind": "Widget",
              "widget": "payment.payment-status-chip",
              "props": { "size": "lg" },
              "bindings": { "props.status": { "$ref": "intent.status" } }
            },
            {
              "kind": "Text",
              "props": { "className": "text-lg font-medium" },
              "bindings": {
                "children": {
                  "$expr": "intent.status === 'succeeded' ? 'Payment complete' : (intent.status === 'failed' ? 'Payment failed' : (intent.status === 'requires_action' ? 'Additional verification required' : 'Processing'))"
                }
              }
            }
          ]
        },
        {
          "kind": "Card",
          "bindings": {
            "hidden": { "$expr": "intent.status !== 'requires_action' || !intent.next_action_url" }
          },
          "children": [
            {
              "kind": "CardContent",
              "props": { "className": "flex flex-col gap-4" },
              "children": [
                {
                  "kind": "Alert",
                  "props": {
                    "variant": "info",
                    "title": "Verification required",
                    "description": "Your bank has requested additional verification for this payment. Complete the challenge to continue."
                  }
                },
                {
                  "kind": "Button",
                  "props": {
                    "variant": "primary",
                    "size": "lg",
                    "children": "Complete verification"
                  },
                  "actions": {
                    "onPress": {
                      "kind": "openUrl",
                      "urlExpr": "intent.next_action_url",
                      "target": "modal"
                    }
                  }
                }
              ]
            }
          ]
        },
        {
          "kind": "Card",
          "children": [
            {
              "kind": "CardHeader",
              "children": [
                {
                  "kind": "Text",
                  "props": { "as": "h3", "className": "text-md font-medium", "children": "Amount" }
                }
              ]
            },
            {
              "kind": "CardContent",
              "children": [
                {
                  "kind": "Text",
                  "props": { "className": "text-2xl font-semibold" },
                  "bindings": {
                    "children": { "$ref": "intent.amount_cents", "formatter": "currency" }
                  }
                }
              ]
            }
          ]
        },
        {
          "kind": "Alert",
          "bindings": { "hidden": { "$expr": "intent.status !== 'failed'" } },
          "props": {
            "variant": "danger",
            "title": "Payment failed"
          },
          "bindings_2": {
            "description": { "$ref": "intent.last_error_message" }
          }
        },
        {
          "kind": "Button",
          "bindings": { "hidden": { "$expr": "intent.status !== 'succeeded'" } },
          "props": { "variant": "primary", "children": "View receipt" },
          "actions": {
            "onPress": {
              "kind": "navigate",
              "toExpr": "'/tenant/payments?filter[payment_intent_id]=' + intent.id"
            }
          }
        }
      ]
    }
  ]
}
