{
  "id": "academorix://modules/expenses/schemas/payroll-run",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "PayrollRun",
  "type": "object",
  "x-module": "expenses",
  "x-eloquent": {
    "table": "payroll_runs",
    "keyPrefix": "plr_",
    "traits": [
      "HasFactory",
      "HasPrefixedUlid",
      "BelongsToTenant",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "HasActivityLog",
      "Filterable",
      "SoftDeletes"
    ]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 30, "primary": true },
      "tenant_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "period_start": { "type": "date", "nullable": false },
      "period_end": { "type": "date", "nullable": false },
      "status": { "type": "string", "length": 16, "nullable": false, "default": "'draft'" },
      "total_amount_minor": { "type": "bigint", "nullable": false, "default": "0" },
      "currency": { "type": "string", "length": 3, "nullable": false },
      "line_count": { "type": "integer", "nullable": false, "default": "0" },
      "computed_at": { "type": "timestamptz", "nullable": true },
      "approved_at": { "type": "timestamptz", "nullable": true },
      "approved_by_user_id": {
        "type": "string",
        "length": 30,
        "nullable": true,
        "foreign": { "table": "users", "column": "id", "onDelete": "set null" }
      },
      "paid_at": { "type": "timestamptz", "nullable": true },
      "notes": { "type": "text", "nullable": true },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false },
      "deleted_at": { "type": "timestamptz", "nullable": true }
    },
    "indexes": [
      { "columns": ["tenant_id", "period_start", "period_end"], "name": "payroll_runs_period_idx" }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "period_start",
    "period_end",
    "status",
    "currency",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^plr_[0-9A-HJKMNP-TV-Z]{26}$" },
    "status": { "type": "string", "enum": ["draft", "computed", "approved", "paid", "cancelled"] }
  },
  "additionalProperties": false
}
