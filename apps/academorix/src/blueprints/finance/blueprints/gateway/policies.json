{
  "id": "stackra://modules/gateway/policies",
  "$version": 1,
  "title": "gateway — authorization policies",
  "description": "Three policies. PaymentGatewayConfig — credentials NEVER leave the server; every response redacts credentials_encrypted + webhook_secret_encrypted. PaymentMethod — guardian narrowed to own methods via owner_type/owner_id check. GatewayWebhookEvent — read-only for support role; replay requires admin.",
  "policies": [
    {
      "model": "PaymentGatewayConfig",
      "class": "Stackra\\Finance\\Gateway\\Policies\\PaymentGatewayConfigPolicy",
      "abilities": [
        { "action": "viewAny", "permission": "gateways.viewAny" },
        {
          "action": "view",
          "permission": "gateways.view",
          "scope": "credentials never returned regardless of role."
        },
        { "action": "create", "permission": "gateways.create" },
        { "action": "update", "permission": "gateways.update" },
        {
          "action": "delete",
          "permission": "gateways.delete",
          "scope": "refuses when active payment_methods reference this gateway."
        },
        { "action": "test", "permission": "gateways.test" },
        { "action": "connectOauth", "permission": "gateways.connect-oauth" },
        { "action": "platformViewAny", "permission": "platform.gateways.viewAny" }
      ]
    },
    {
      "model": "PaymentMethod",
      "class": "Stackra\\Finance\\Gateway\\Policies\\PaymentMethodPolicy",
      "abilities": [
        {
          "action": "viewAny",
          "permission": "payment-methods.viewAny",
          "scope": "guardian narrowed to own (owner_type='guardian' AND owner_id=current_user_id)."
        },
        { "action": "view", "permission": "payment-methods.view", "scope": "same narrowing." },
        { "action": "create", "permission": "payment-methods.create" },
        {
          "action": "delete",
          "permission": "payment-methods.delete",
          "scope": "guardian can delete own; admin + owner can delete any."
        },
        {
          "action": "setDefault",
          "permission": "payment-methods.set-default",
          "scope": "guardian can set own default; admin + owner + finance can set any."
        }
      ]
    },
    {
      "model": "GatewayWebhookEvent",
      "class": "Stackra\\Finance\\Gateway\\Policies\\GatewayWebhookEventPolicy",
      "abilities": [
        { "action": "viewAny", "permission": "gateway-webhooks.viewAny" },
        { "action": "view", "permission": "gateway-webhooks.view" },
        {
          "action": "replay",
          "permission": "gateway-webhooks.replay",
          "scope": "refuses when status='processed' — idempotent replays only."
        },
        { "action": "platformViewAny", "permission": "platform.gateway-webhooks.viewAny" },
        { "action": "platformReplay", "permission": "platform.gateway-webhooks.replay" }
      ]
    }
  ]
}
