{
  "id": "academorix://modules/wallet/policies",
  "$version": 1,
  "title": "wallet — authorization policies",
  "description": "Guardian narrowed to own wallets (owner_type='guardian', owner_id=current_user). WalletTransaction is read-only (never editable — ledger integrity). WalletHold.release refuses when status != 'active'.",
  "policies": [
    {
      "model": "Wallet",
      "class": "Academorix\\Finance\\Wallet\\Policies\\WalletPolicy",
      "abilities": [
        {
          "action": "viewAny",
          "permission": "wallets.viewAny",
          "scope": "guardian narrowed to own."
        },
        { "action": "view", "permission": "wallets.view", "scope": "same narrowing." },
        {
          "action": "adjust",
          "permission": "wallets.adjust",
          "scope": "refuses when wallet.closed_at IS NOT NULL."
        },
        { "action": "reconcile", "permission": "wallets.reconcile", "scope": "kind='cash' only." }
      ]
    },
    {
      "model": "WalletTransaction",
      "class": "Academorix\\Finance\\Wallet\\Policies\\WalletTransactionPolicy",
      "abilities": [
        {
          "action": "viewAny",
          "permission": "wallet-transactions.viewAny",
          "scope": "narrowed by wallet_id ownership."
        },
        { "action": "view", "permission": "wallet-transactions.view" }
      ]
    },
    {
      "model": "WalletHold",
      "class": "Academorix\\Finance\\Wallet\\Policies\\WalletHoldPolicy",
      "abilities": [
        { "action": "viewAny", "permission": "wallet-holds.viewAny" },
        { "action": "view", "permission": "wallet-holds.view" },
        {
          "action": "release",
          "permission": "wallet-holds.release",
          "scope": "refuses when status != 'active'."
        }
      ]
    }
  ]
}
