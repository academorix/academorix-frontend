{
  "id": "stackra://modules/wallet/events",
  "$version": 1,
  "title": "wallet — published events",
  "namespace": "Stackra\\Finance\\Wallet\\Events",
  "dispatchMode": "afterCommit",
  "description": "Ledger events plus hold-lifecycle plus reconciliation events. WalletReconciliationDrift alerts finance when the cash-mirror drifts from Stripe balance — an incident signal.",
  "events": [
    {
      "name": "WalletOpened",
      "class": "Stackra\\Finance\\Wallet\\Events\\WalletOpened",
      "trigger": "New wallet row committed.",
      "queue": "wallet",
      "consumers": ["audit::WriteToAuditLog"],
      "payload": {
        "wallet_id": "ULID (wal_*)",
        "tenant_id": "ULID",
        "owner_type": "string",
        "owner_id": "ULID",
        "kind": "string",
        "currency": "string",
        "at": "ISO 8601"
      }
    },
    {
      "name": "WalletClosed",
      "class": "Stackra\\Finance\\Wallet\\Events\\WalletClosed",
      "trigger": "Wallet.closed_at set.",
      "queue": "wallet",
      "consumers": ["audit::WriteToAuditLog"],
      "payload": { "wallet_id": "ULID", "tenant_id": "ULID", "at": "ISO 8601" }
    },
    {
      "name": "WalletCredited",
      "class": "Stackra\\Finance\\Wallet\\Events\\WalletCredited",
      "trigger": "wallet_transaction with positive amount committed.",
      "queue": "wallet",
      "consumers": [
        "audit::WriteToAuditLog",
        "notifications::DispatchWalletCreditedNotificationListener"
      ],
      "payload": {
        "wallet_id": "ULID",
        "transaction_id": "ULID (wtx_*)",
        "amount_minor": "integer",
        "balance_after_minor": "integer",
        "at": "ISO 8601"
      }
    },
    {
      "name": "WalletDebited",
      "class": "Stackra\\Finance\\Wallet\\Events\\WalletDebited",
      "trigger": "wallet_transaction with negative amount committed.",
      "queue": "wallet",
      "consumers": ["audit::WriteToAuditLog"],
      "payload": {
        "wallet_id": "ULID",
        "transaction_id": "ULID",
        "amount_minor": "integer",
        "balance_after_minor": "integer",
        "at": "ISO 8601"
      }
    },
    {
      "name": "WalletHoldPlaced",
      "class": "Stackra\\Finance\\Wallet\\Events\\WalletHoldPlaced",
      "trigger": "New wallet_hold row committed. Reserved balance increases.",
      "queue": "wallet",
      "consumers": [],
      "payload": {
        "hold_id": "ULID (whd_*)",
        "wallet_id": "ULID",
        "amount_minor": "integer",
        "expires_at": "ISO 8601"
      }
    },
    {
      "name": "WalletHoldReleased",
      "class": "Stackra\\Finance\\Wallet\\Events\\WalletHoldReleased",
      "trigger": "Hold status -> released or expired. Reserved balance decreases.",
      "queue": "wallet",
      "consumers": ["audit::WriteToAuditLog"],
      "payload": {
        "hold_id": "ULID",
        "wallet_id": "ULID",
        "reason": "abandoned | cancelled | ttl_expired | manual",
        "at": "ISO 8601"
      }
    },
    {
      "name": "WalletHoldCommitted",
      "class": "Stackra\\Finance\\Wallet\\Events\\WalletHoldCommitted",
      "trigger": "Hold status -> settled. Converted into a wallet_transaction.",
      "queue": "wallet",
      "consumers": ["audit::WriteToAuditLog"],
      "payload": {
        "hold_id": "ULID",
        "wallet_id": "ULID",
        "transaction_id": "ULID",
        "amount_minor": "integer",
        "at": "ISO 8601"
      }
    },
    {
      "name": "WalletReconciled",
      "class": "Stackra\\Finance\\Wallet\\Events\\WalletReconciled",
      "trigger": "Nightly reconciliation completed without drift.",
      "queue": "wallet",
      "consumers": ["audit::WriteToAuditLog"],
      "payload": { "wallet_id": "ULID", "reconciled_at": "ISO 8601" }
    },
    {
      "name": "WalletReconciliationDrift",
      "class": "Stackra\\Finance\\Wallet\\Events\\WalletReconciliationDrift",
      "trigger": "Reconciliation found a difference between local balance and upstream source. INCIDENT SIGNAL.",
      "queue": "wallet-critical",
      "consumers": [
        "audit::WriteToAuditLog",
        "notifications::DispatchWalletDriftNotificationListener",
        "monitoring::MetricsCollector"
      ],
      "payload": {
        "wallet_id": "ULID",
        "local_balance_minor": "integer",
        "upstream_balance_minor": "integer",
        "drift_minor": "integer",
        "detected_at": "ISO 8601"
      }
    },
    {
      "name": "PointsEarned",
      "class": "Stackra\\Finance\\Wallet\\Events\\PointsEarned",
      "trigger": "points_earn transaction committed. Fires from points-rule engine on OrderPaid.",
      "queue": "wallet",
      "consumers": ["notifications::DispatchPointsEarnedNotificationListener"],
      "payload": {
        "wallet_id": "ULID",
        "transaction_id": "ULID",
        "amount_minor": "integer",
        "expires_at": "ISO 8601 | null",
        "at": "ISO 8601"
      }
    },
    {
      "name": "PointsRedeemed",
      "class": "Stackra\\Finance\\Wallet\\Events\\PointsRedeemed",
      "trigger": "points_redeem transaction committed. Fires from redemption flow.",
      "queue": "wallet",
      "consumers": ["audit::WriteToAuditLog"],
      "payload": {
        "wallet_id": "ULID",
        "transaction_id": "ULID",
        "amount_minor": "integer",
        "at": "ISO 8601"
      }
    },
    {
      "name": "PointsExpired",
      "class": "Stackra\\Finance\\Wallet\\Events\\PointsExpired",
      "trigger": "points_expire transaction committed. Fires from ExpirePointsJob.",
      "queue": "wallet",
      "consumers": ["notifications::DispatchPointsExpiredNotificationListener"],
      "payload": {
        "wallet_id": "ULID",
        "transaction_id": "ULID",
        "amount_minor": "integer",
        "at": "ISO 8601"
      }
    }
  ]
}
