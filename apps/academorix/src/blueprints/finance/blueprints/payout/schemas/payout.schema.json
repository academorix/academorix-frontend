{
  "id": "stackra://modules/payout/schemas/payout",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "Payout",
  "description": "One row per gateway payout event. Mirrors provider.payouts.* (Stripe). Idempotent on (tenant_id, provider, provider_payout_id). Belongs to Tenant + PaymentGatewayConfig (restrict). NEVER carries application_id, organization_id, or scope_node_id.",
  "type": "object",
  "x-module": "payout",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "payouts",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "pyo_",
    "incrementing": false,
    "model": "Stackra\\Finance\\Payout\\Models\\Payout",
    "interface": "Stackra\\Finance\\Payout\\Contracts\\Data\\PayoutInterface",
    "implements": ["Stackra\\Finance\\Payout\\Contracts\\Data\\PayoutInterface"],
    "traits": [
      "HasFactory",
      "HasUlids",
      "BelongsToTenant",
      "HasMetadata",
      "HasUserstamps",
      "Auditable"
    ],
    "casts": {
      "status": "PayoutStatus",
      "amount_minor": "bigint",
      "fee_minor": "bigint",
      "net_minor": "bigint",
      "arrival_at": "datetime",
      "paid_at": "datetime",
      "failed_at": "datetime",
      "reconciled_at": "datetime",
      "provider_snapshot": "array",
      "metadata": "array"
    }
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": {
        "type": "string",
        "length": 64,
        "primary": true,
        "description": "Prefixed ULID: `pyo_<26>`."
      },
      "tenant_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "gateway_config_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "payment_gateway_configs", "column": "id", "onDelete": "restrict" }
      },
      "provider": {
        "type": "string",
        "length": 32,
        "nullable": false,
        "description": "Enum: stripe / paddle / checkout_com / square / razorpay."
      },
      "provider_payout_id": {
        "type": "string",
        "length": 255,
        "nullable": false,
        "description": "e.g. Stripe po_*. Unique key per (tenant_id, provider)."
      },
      "status": {
        "type": "string",
        "length": 24,
        "nullable": false,
        "description": "Enum: pending / in_transit / paid / failed / cancelled."
      },
      "currency": { "type": "string", "length": 3, "nullable": false },
      "amount_minor": {
        "type": "bigint",
        "nullable": false,
        "description": "Gross payout amount (before provider fees)."
      },
      "fee_minor": {
        "type": "bigint",
        "nullable": false,
        "default": 0,
        "description": "Provider fees deducted."
      },
      "net_minor": {
        "type": "bigint",
        "nullable": false,
        "description": "amount - fee. What lands in the tenant's bank."
      },
      "arrival_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "Provider's estimated arrival date."
      },
      "paid_at": { "type": "timestamptz", "nullable": true },
      "failed_at": { "type": "timestamptz", "nullable": true },
      "reconciled_at": { "type": "timestamptz", "nullable": true },
      "destination_type": {
        "type": "string",
        "length": 32,
        "nullable": true,
        "description": "e.g. bank_account / card / wallet."
      },
      "destination_last4": { "type": "string", "length": 4, "nullable": true },
      "provider_snapshot": { "type": "jsonb", "nullable": true },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_by": { "type": "string", "length": 64, "nullable": true },
      "updated_by": { "type": "string", "length": 64, "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "provider", "provider_payout_id"],
        "unique": true,
        "name": "payouts_provider_id_unique"
      },
      { "columns": ["tenant_id", "status", "arrival_at"], "name": "payouts_status_arrival_idx" }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "gateway_config_id",
    "provider",
    "provider_payout_id",
    "status",
    "currency",
    "amount_minor",
    "fee_minor",
    "net_minor",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^pyo_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": "string", "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "provider": {
      "type": "string",
      "enum": ["stripe", "paddle", "checkout_com", "square", "razorpay"]
    },
    "status": {
      "type": "string",
      "enum": ["pending", "in_transit", "paid", "failed", "cancelled"]
    },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "amount_minor": { "type": "integer" },
    "net_minor": { "type": "integer" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
