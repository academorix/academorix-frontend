{
  "$version": 1,
  "name": "marketplace-fee",
  "alias": "marketplace_fee",
  "namespace": "Academorix\\Finance\\MarketplaceFee",
  "description": "Academorix's take-rate on Parents -> Academy transactions. Per DL-5 in tasks.md, Stripe Connect is the default gateway and fee-splits happen at charge time via Stripe Application Fees: tenant Connect account receives charge minus platform_fee; Academorix platform account receives the fee. Owns three tables: fee_schedules (per-tenant + per-application fee configuration; multiple versions retain history — an increase applies to future transactions never retroactively), fee_applications (one row per transaction where a fee was applied, references the Stripe application_fee_id), fee_payouts (Stackra-facing payout of fees to the platform account, roll-up over fee_applications in a period). Cross-integrates with finance/payment (reads active schedule to compute application_fee for Stripe), finance/payout (fees appear on tenant payouts as payout_items of kind='fee'), finance/gateway (Stripe adapter passes calculated fee to payment_intents.create).",
  "keywords": [
    "marketplace-fee",
    "platform-fee",
    "take-rate",
    "stripe-application-fee",
    "revenue-share",
    "fee-schedule",
    "fee-tier",
    "finance"
  ],
  "priority": 44,
  "providers": ["Academorix\\Finance\\MarketplaceFee\\Providers\\MarketplaceFeeServiceProvider"],
  "dependencies": ["foundation", "tenancy", "application", "gateway"],
  "extendedBy": [],
  "contributes": {
    "traits": ["HasFeeSchedules"],
    "attributes": ["AsFeeCalculator"],
    "blueprints": ["fee_schedules", "fee_applications", "fee_payouts"],
    "middleware": [],
    "events": [
      "FeeScheduleCreated",
      "FeeScheduleActivated",
      "FeeScheduleDeactivated",
      "FeeApplied",
      "FeeReversed",
      "FeePayoutCreated",
      "FeePayoutSettled"
    ],
    "policies": ["FeeSchedulePolicy", "FeeApplicationPolicy", "FeePayoutPolicy"],
    "hooks": ["PurgeFeeSchedulesForErasedTenant"],
    "commands": [
      "marketplace-fee:list-schedules",
      "marketplace-fee:create-schedule",
      "marketplace-fee:activate-schedule",
      "marketplace-fee:list-applications",
      "marketplace-fee:list-payouts",
      "marketplace-fee:settle-payout"
    ],
    "jobs": ["CalculateAndApplyFeeJob", "SettleFeePayoutJob"],
    "notifications": ["FeeScheduleChangedNotification", "FeePayoutSettledNotification"],
    "broadcasts": ["tenant.{tenantId}.marketplace-fees", "platform.marketplace-fees"],
    "observers": ["FeeScheduleObserver", "FeeApplicationObserver", "FeePayoutObserver"],
    "rules": ["valid_fee_rate", "valid_currency", "positive_flat_fee", "valid_tier_config"],
    "casts": ["FeeScheduleStatus", "FeeApplicationStatus", "FeePayoutStatus"],
    "views": [],
    "lang": ["marketplace-fee"],
    "config": ["marketplace-fee"],
    "macros": [],
    "bindings": [
      "FeeScheduleRepository",
      "FeeApplicationRepository",
      "FeePayoutRepository",
      "FeeCalculator",
      "TieredFeeCalculator",
      "FlatFeeCalculator",
      "FeeScheduleInterface"
    ],
    "resources": ["fee-schedule", "fee-application", "fee-payout"]
  },
  "wraps": {
    "packages": ["laravel/cashier-stripe ^15"],
    "rationale": "Stripe Connect application_fee_amount is set at charge time; this module wraps the calculation + application."
  },
  "hosts": {
    "tenant": {
      "description": "Tenant view of applied fees (transparency).",
      "routes": [
        "GET /api/v1/marketplace-fees/schedules",
        "GET /api/v1/marketplace-fees/schedules/{schedule}",
        "GET /api/v1/marketplace-fees/applications",
        "GET /api/v1/marketplace-fees/applications/{application}"
      ]
    },
    "central_admin": {
      "description": "Platform-facing fee schedule management + roll-up payout view.",
      "routes": [
        "GET /api/v1/platform/marketplace-fees/schedules",
        "POST /api/v1/platform/marketplace-fees/schedules",
        "GET /api/v1/platform/marketplace-fees/schedules/{schedule}",
        "PATCH /api/v1/platform/marketplace-fees/schedules/{schedule}",
        "POST /api/v1/platform/marketplace-fees/schedules/{schedule}/activate",
        "POST /api/v1/platform/marketplace-fees/schedules/{schedule}/deactivate",
        "GET /api/v1/platform/marketplace-fees/payouts",
        "GET /api/v1/platform/marketplace-fees/payouts/{payout}",
        "POST /api/v1/platform/marketplace-fees/payouts/{payout}/settle"
      ]
    }
  }
}
