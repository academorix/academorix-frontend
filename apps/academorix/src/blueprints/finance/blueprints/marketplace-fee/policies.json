{
  "id": "stackra://modules/marketplace-fee/policies",
  "$version": 1,
  "title": "marketplace-fee — authorization policies",
  "description": "Tenant plane read-only (transparency). Platform plane write. FeeSchedule.activate refuses when effective_from is in the past (never retroactive per DL-5 note in tasks.md).",
  "policies": [
    {
      "model": "FeeSchedule",
      "class": "Stackra\\Finance\\MarketplaceFee\\Policies\\FeeSchedulePolicy",
      "abilities": [
        {
          "action": "viewAny",
          "permission": "fee-schedules.viewAny",
          "scope": "tenant narrowed to own."
        },
        { "action": "view", "permission": "fee-schedules.view", "scope": "same narrowing." },
        { "action": "platformViewAny", "permission": "platform.fee-schedules.viewAny" },
        { "action": "platformCreate", "permission": "platform.fee-schedules.create" },
        {
          "action": "platformUpdate",
          "permission": "platform.fee-schedules.update",
          "scope": "refuses when status='active' — must create a new version instead."
        },
        {
          "action": "platformActivate",
          "permission": "platform.fee-schedules.activate",
          "scope": "refuses when effective_from IS in the past (never retroactive)."
        },
        {
          "action": "platformDeactivate",
          "permission": "platform.fee-schedules.deactivate",
          "scope": "refuses when status != 'active'."
        }
      ]
    },
    {
      "model": "FeeApplication",
      "class": "Stackra\\Finance\\MarketplaceFee\\Policies\\FeeApplicationPolicy",
      "abilities": [
        {
          "action": "viewAny",
          "permission": "fee-applications.viewAny",
          "scope": "tenant narrowed to own."
        },
        { "action": "view", "permission": "fee-applications.view", "scope": "same narrowing." }
      ]
    },
    {
      "model": "FeePayout",
      "class": "Stackra\\Finance\\MarketplaceFee\\Policies\\FeePayoutPolicy",
      "abilities": [
        { "action": "platformViewAny", "permission": "platform.fee-payouts.viewAny" },
        { "action": "platformView", "permission": "platform.fee-payouts.view" },
        {
          "action": "platformSettle",
          "permission": "platform.fee-payouts.settle",
          "scope": "refuses when status != 'pending'."
        }
      ]
    }
  ]
}
