{
  "id": "stackra://modules/marketplace-fee/schemas/fee-payout",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "FeePayout",
  "description": "Stackra-facing payout of fees to the platform account. Roll-up over fee_applications in a period. Belongs to Tenant (cascade). Application cascades through tenant_id → tenants.application_id per the tenancy-columns.md §2 mandate (fee_payouts is NOT one of the 8 rows that may carry application_id directly). NEVER carries application_id, organization_id, region_id, or scope_node_id.",
  "type": "object",
  "x-module": "marketplace-fee",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "fee_payouts",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "fpo_",
    "incrementing": false,
    "model": "Stackra\\Finance\\MarketplaceFee\\Models\\FeePayout",
    "interface": "Stackra\\Finance\\MarketplaceFee\\Contracts\\Data\\FeePayoutInterface",
    "implements": ["Stackra\\Finance\\MarketplaceFee\\Contracts\\Data\\FeePayoutInterface"],
    "traits": [
      "HasFactory",
      "HasUlids",
      "BelongsToTenant",
      "HasMetadata",
      "HasUserstamps",
      "Auditable"
    ],
    "casts": {
      "status": "FeePayoutStatus",
      "period_start": "datetime",
      "period_end": "datetime",
      "total_gross_minor": "integer",
      "total_fee_minor": "integer",
      "application_count": "integer",
      "settled_at": "datetime",
      "metadata": "array"
    },
    "observers": ["FeePayoutObserver"]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 64, "primary": true },
      "tenant_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "reference_number": {
        "type": "string",
        "length": 32,
        "nullable": false,
        "description": "Human reference (e.g. FEE-2026-06-ACME)."
      },
      "status": {
        "type": "string",
        "length": 16,
        "nullable": false,
        "default": "'pending'",
        "description": "Enum: pending / settled / failed / cancelled."
      },
      "currency": { "type": "string", "length": 3, "nullable": false },
      "period_start": { "type": "timestamptz", "nullable": false },
      "period_end": { "type": "timestamptz", "nullable": false },
      "total_gross_minor": { "type": "bigint", "nullable": false, "default": 0 },
      "total_fee_minor": { "type": "bigint", "nullable": false, "default": 0 },
      "application_count": { "type": "integer", "nullable": false, "default": 0 },
      "settled_at": { "type": "timestamptz", "nullable": true },
      "settlement_transfer_id": {
        "type": "string",
        "length": 255,
        "nullable": true,
        "description": "Stripe tr_* for the settlement transfer."
      },
      "notes": { "type": "text", "nullable": true },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_by": { "type": "string", "length": 64, "nullable": true },
      "updated_by": { "type": "string", "length": 64, "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "reference_number"],
        "unique": true,
        "name": "fee_payouts_reference_unique"
      },
      { "columns": ["tenant_id", "status", "period_end"], "name": "fee_payouts_period_idx" }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "reference_number",
    "status",
    "currency",
    "period_start",
    "period_end",
    "total_gross_minor",
    "total_fee_minor",
    "application_count",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^fpo_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": "string", "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "status": { "type": "string", "enum": ["pending", "settled", "failed", "cancelled"] },
    "total_fee_minor": { "type": "integer" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
