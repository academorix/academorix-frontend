{
  "id": "stackra://modules/membership/metrics",
  "$version": 1,
  "title": "membership — OpenTelemetry metrics",
  "instrumentation": "self via telemetry",
  "namespace": "stackra.membership",
  "labelConventions": {
    "always": [],
    "commonlyAvailable": ["status", "cancellation_kind", "billing_interval", "pass_type"],
    "forbiddenAsLabels": [
      "tenant_id",
      "membership_id",
      "athlete_id",
      "plan_id",
      "user_id",
      "price_snapshot_cents",
      "amount_cents"
    ]
  },
  "metrics": [
    {
      "name": "stackra.membership.count",
      "kind": "gauge",
      "unit": "memberships",
      "labels": ["status", "billing_interval"]
    },
    {
      "name": "stackra.membership.mrr_cents",
      "kind": "gauge",
      "unit": "cents",
      "labels": ["currency"],
      "description": "Monthly recurring revenue at this instant — sum of price_snapshot_cents normalized to monthly for all active memberships."
    },
    {
      "name": "stackra.membership.created_total",
      "kind": "counter",
      "unit": "memberships",
      "labels": ["billing_interval", "used_trial"]
    },
    {
      "name": "stackra.membership.activated_total",
      "kind": "counter",
      "unit": "memberships",
      "labels": ["billing_interval"]
    },
    {
      "name": "stackra.membership.renewed_total",
      "kind": "counter",
      "unit": "memberships",
      "labels": ["was_recovered"]
    },
    {
      "name": "stackra.membership.renewal_failed_total",
      "kind": "counter",
      "unit": "renewals",
      "labels": ["attempt_number", "failure_reason_category"]
    },
    {
      "name": "stackra.membership.renewal_recovered_total",
      "kind": "counter",
      "unit": "renewals",
      "labels": ["recovered_on_attempt"],
      "description": "Dunning-effectiveness signal."
    },
    {
      "name": "stackra.membership.lapsed_total",
      "kind": "counter",
      "unit": "memberships",
      "labels": []
    },
    {
      "name": "stackra.membership.cancelled_total",
      "kind": "counter",
      "unit": "memberships",
      "labels": ["cancellation_kind"]
    },
    {
      "name": "stackra.membership.refunded_total",
      "kind": "counter",
      "unit": "memberships",
      "labels": ["refund_reason_category"]
    },
    {
      "name": "stackra.membership.chargedback_total",
      "kind": "counter",
      "unit": "memberships",
      "labels": ["reason_code"]
    },
    {
      "name": "stackra.membership.trial_converted_total",
      "kind": "counter",
      "unit": "memberships",
      "labels": []
    },
    {
      "name": "stackra.membership.trial_expired_total",
      "kind": "counter",
      "unit": "memberships",
      "labels": []
    },
    {
      "name": "stackra.membership.churn_rate_percent",
      "kind": "gauge",
      "unit": "percent",
      "labels": [],
      "description": "Last-30d churn (cancelled + lapsed) / active-at-start. Recomputed hourly."
    },
    {
      "name": "stackra.membership.invoice_create_duration_ms",
      "kind": "histogram",
      "unit": "ms",
      "buckets": [50, 200, 1000, 5000],
      "labels": [],
      "description": "Atomic invoice creation duration. P99 target < 1000ms."
    },
    {
      "name": "stackra.membership.atomic_invoice_failed_total",
      "kind": "counter",
      "unit": "failures",
      "labels": [],
      "description": "CRITICAL. Every increment is P1. Atomic invoice creation rolled back."
    },
    {
      "name": "stackra.membership.entitlement.gate_refusals_total",
      "kind": "counter",
      "unit": "refusals",
      "labels": ["entitlement_key"]
    },
    {
      "name": "stackra.membership.plan.count",
      "kind": "gauge",
      "unit": "plans",
      "labels": ["is_active"]
    },
    {
      "name": "stackra.membership.plan.capacity_reached_total",
      "kind": "counter",
      "unit": "events",
      "labels": []
    },
    {
      "name": "stackra.membership.pass.issued_total",
      "kind": "counter",
      "unit": "passes",
      "labels": ["pass_type"]
    },
    {
      "name": "stackra.membership.pass.consumed_total",
      "kind": "counter",
      "unit": "passes",
      "labels": ["pass_type"]
    },
    {
      "name": "stackra.membership.pass.expired_total",
      "kind": "counter",
      "unit": "passes",
      "labels": ["pass_type"]
    },
    {
      "name": "stackra.membership.pass.refunded_total",
      "kind": "counter",
      "unit": "passes",
      "labels": []
    },
    {
      "name": "stackra.membership.pass.consumption_within_valid_window",
      "kind": "counter",
      "unit": "attempts",
      "labels": [
        "outcome: succeeded|refused_already_consumed|refused_outside_window|refused_membership_paused"
      ]
    }
  ]
}
