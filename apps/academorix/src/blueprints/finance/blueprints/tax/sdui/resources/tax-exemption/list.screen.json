{
  "id": "tax.resources.tax-exemption.list",
  "title": "Tax exemptions",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/tax/exemptions",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "tax", "entity": "tax-exemption", "action": "list" },
  "requiresPermission": "tax.exemptions.viewAny",
  "requiresEntitlement": "tax_capture",
  "dataSources": [
    {
      "name": "exemptions",
      "kind": "http.get",
      "url": "/api/v1/tax/exemptions",
      "unwrap": "data",
      "queryFromFilters": true,
      "initialFilters": { "verification_status": "pending" }
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-7xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "kind": "View",
              "children": [
                {
                  "kind": "Text",
                  "props": {
                    "as": "h1",
                    "className": "text-2xl font-semibold",
                    "children": "Tax exemptions"
                  }
                },
                {
                  "kind": "Text",
                  "props": {
                    "className": "text-sm text-muted",
                    "children": "Reseller / non-profit / diplomatic / educational exemption certificates."
                  }
                }
              ]
            },
            {
              "kind": "Button",
              "props": {
                "variant": "primary",
                "leadingIcon": "plus",
                "children": "Submit exemption"
              },
              "requiresPermission": "tax.exemptions.create",
              "actions": {
                "onPress": { "kind": "navigate", "to": "/tenant/tax/exemptions/new" }
              }
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "flex items-center gap-2 py-2 flex-wrap" },
          "children": [
            {
              "kind": "ComboBox",
              "props": {
                "label": "Verification status",
                "menuTrigger": "focus",
                "className": "min-w-56"
              },
              "props_items": [
                { "id": "pending", "label": "Pending" },
                { "id": "verified", "label": "Verified" },
                { "id": "rejected", "label": "Rejected" },
                { "id": "expired", "label": "Expired" }
              ],
              "actions": {
                "onSelectionChange": {
                  "kind": "filter.set",
                  "field": "verification_status",
                  "valueExpr": "$selectedKey"
                }
              }
            },
            {
              "kind": "ComboBox",
              "props": {
                "label": "Exemption type",
                "menuTrigger": "focus",
                "className": "min-w-56"
              },
              "props_items_source": "tax.exemption-type-catalog",
              "actions": {
                "onSelectionChange": {
                  "kind": "filter.set",
                  "field": "exemption_type",
                  "valueExpr": "$selectedKey"
                }
              }
            },
            {
              "kind": "NumberField",
              "props": {
                "label": "Expiring within days",
                "placeholder": "60",
                "className": "min-w-48"
              },
              "actions": {
                "onChange": {
                  "kind": "filter.set",
                  "field": "expiring_within_days",
                  "valueExpr": "$value"
                }
              }
            }
          ]
        },
        {
          "kind": "DataGrid",
          "bindings": {
            "items": { "$ref": "exemptions" },
            "isLoading": { "$ref": "exemptions.isLoading" }
          },
          "props": {
            "columns": [
              { "field": "exemption_type", "label": "Type", "sortable": true, "width": 160 },
              { "field": "customer_type", "label": "Customer type", "width": 140 },
              { "field": "issuing_jurisdiction_id", "label": "Jurisdiction", "width": 140 },
              {
                "field": "verification_status",
                "label": "Status",
                "sortable": true,
                "width": 160,
                "renderer": { "widget": "tax.exemption-status-chip" }
              },
              {
                "field": "valid_from",
                "label": "Valid from",
                "sortable": true,
                "width": 130,
                "formatter": "date"
              },
              {
                "field": "valid_until",
                "label": "Valid until",
                "sortable": true,
                "width": 130,
                "formatter": "date"
              },
              {
                "field": "verified_at",
                "label": "Verified at",
                "width": 160,
                "formatter": "datetime-relative"
              }
            ],
            "onRowPress": {
              "kind": "navigate",
              "toExpr": "'/tenant/tax/exemptions/' + row.id"
            }
          },
          "emptyState": {
            "kind": "View",
            "props": { "className": "text-center py-12" },
            "children": [
              {
                "kind": "Icon",
                "props": { "name": "shield-check", "className": "size-12 mx-auto text-muted" }
              },
              {
                "kind": "Text",
                "props": {
                  "className": "mt-4 text-lg font-medium",
                  "children": "No exemptions found"
                }
              },
              {
                "kind": "Text",
                "props": {
                  "className": "text-sm text-muted",
                  "children": "Customers with reseller, non-profit, diplomatic, or educational status can submit exemption certificates here."
                }
              }
            ]
          }
        }
      ]
    }
  ]
}
