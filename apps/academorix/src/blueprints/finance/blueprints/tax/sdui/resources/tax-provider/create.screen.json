{
  "id": "tax.resources.tax-provider.create",
  "title": "Add tax provider",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/tax/providers/new",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "tax", "entity": "tax-provider", "action": "create" },
  "requiresPermission": "tax.providers.create",
  "requiresEntitlement": "tax_capture",
  "dataSources": [
    {
      "name": "provider_capabilities",
      "kind": "http.get",
      "url": "/api/v1/tax/providers/capabilities",
      "unwrap": "data",
      "cache": { "ttlSeconds": 3600 }
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "MultiStepForm",
      "props": { "className": "max-w-3xl mx-auto p-6" },
      "children": [
        {
          "kind": "Step",
          "props": {
            "title": "Choose provider",
            "description": "Pick the tax computation provider."
          },
          "children": [
            {
              "kind": "RadioGroup",
              "props": { "className": "grid grid-cols-1 gap-3" },
              "bindings": {
                "items": {
                  "$expr": "[{ id: 'native_calculator', label: 'Native Calculator (built-in)', description: 'Reads tax_rates directly. Zero external cost. Best for single-country tenants.' }, { id: 'taxjar', label: 'TaxJar', description: 'US-focused sales tax + international VAT.', requiresEntitlement: 'tax_advanced_providers' }, { id: 'avalara', label: 'Avalara AvaTax', description: 'Enterprise-grade global tax with per-SKU nexus.', requiresEntitlement: 'tax_advanced_providers' }, { id: 'stripe_tax', label: 'Stripe Tax', description: 'Integrated with Stripe billing.', requiresEntitlement: 'tax_advanced_providers' }, { id: 'custom_webhook', label: 'Custom Webhook', description: 'HMAC-signed JSON to your own tax engine.', requiresEntitlement: 'tax_advanced_providers' }]"
                }
              },
              "actions": {
                "onSelectionChange": {
                  "kind": "form.set",
                  "field": "provider",
                  "valueExpr": "$selectedKey"
                }
              }
            }
          ]
        },
        {
          "kind": "Step",
          "props": {
            "title": "Credentials",
            "description": "Enter your provider credentials. Encrypted at rest."
          },
          "children": [
            {
              "kind": "DynamicForm",
              "bindings": {
                "schema": { "$expr": "provider_capabilities[form.provider].config_schema" }
              }
            }
          ]
        },
        {
          "kind": "Step",
          "props": {
            "title": "Jurisdictions",
            "description": "Which jurisdictions should this provider handle?"
          },
          "children": [
            {
              "kind": "Widget",
              "widget": "tax.jurisdiction-picker",
              "props": { "multiSelect": true },
              "actions": {
                "onSelectionChange": {
                  "kind": "form.set",
                  "field": "enabled_jurisdictions",
                  "valueExpr": "$selectedKeys"
                }
              }
            }
          ]
        },
        {
          "kind": "Step",
          "props": { "title": "Confirm", "description": "Review + create." },
          "children": [
            {
              "kind": "DescriptionList",
              "bindings": {
                "items": {
                  "$expr": "[{label: 'Provider', value: form.provider}, {label: 'Jurisdictions', value: (form.enabled_jurisdictions?.length || 0) + ' selected'}]"
                }
              }
            },
            {
              "kind": "Alert",
              "props": {
                "variant": "warning",
                "title": "Data processing agreement",
                "description": "Adding this provider means Stackra will forward customer address data to the provider. Please confirm you have accepted the provider's DPA."
              },
              "bindings": { "hidden": { "$expr": "form.provider === 'native_calculator'" } }
            },
            {
              "kind": "Button",
              "props": { "variant": "primary", "size": "lg", "children": "Create provider" },
              "actions": {
                "onPress": {
                  "kind": "http.post",
                  "url": "/api/v1/tax/providers",
                  "body": {
                    "provider": "{{form.provider}}",
                    "config": "{{form.config}}",
                    "enabled_jurisdictions": "{{form.enabled_jurisdictions}}"
                  },
                  "onSuccess": {
                    "kind": "navigate",
                    "toExpr": "'/tenant/tax/providers/' + response.data.id"
                  }
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
