{
  "id": "tax.resources.tax-calculation.list",
  "title": "Tax calculations",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/tax/calculations",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "tax", "entity": "tax-calculation", "action": "list" },
  "requiresPermission": "tax.calculations.viewAny",
  "requiresEntitlement": "tax_capture",
  "dataSources": [
    {
      "name": "calculations",
      "kind": "http.get",
      "url": "/api/v1/tax/calculations",
      "unwrap": "data",
      "queryFromFilters": true
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-7xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "children": [
            {
              "kind": "Text",
              "props": {
                "as": "h1",
                "className": "text-2xl font-semibold",
                "children": "Tax calculations"
              }
            },
            {
              "kind": "Text",
              "props": {
                "className": "text-sm text-muted",
                "children": "Read-only calculation ledger. Every row is IMMUTABLE — regulator audit trail."
              }
            }
          ]
        },
        {
          "kind": "Alert",
          "props": {
            "variant": "info",
            "title": "Calculation-freeze pattern",
            "description": "Tax calculations are IMMUTABLE after commit. Rate changes AFTER invoice issuance never retroactively re-tax historical invoices. Regulators receive the exact rate that applied at issuance."
          }
        },
        {
          "kind": "View",
          "props": { "className": "flex items-center gap-2 py-2 flex-wrap" },
          "children": [
            {
              "kind": "ComboBox",
              "props": { "label": "Provider", "menuTrigger": "focus", "className": "min-w-48" },
              "props_items": [
                { "id": "taxjar", "label": "TaxJar" },
                { "id": "avalara", "label": "Avalara AvaTax" },
                { "id": "stripe_tax", "label": "Stripe Tax" },
                { "id": "native_calculator", "label": "Native Calculator" },
                { "id": "custom_webhook", "label": "Custom Webhook" }
              ],
              "actions": {
                "onSelectionChange": {
                  "kind": "filter.set",
                  "field": "provider",
                  "valueExpr": "$selectedKey"
                }
              }
            },
            {
              "kind": "DateRangePicker",
              "props": { "label": "Date range", "className": "min-w-64" },
              "actions": {
                "onChange": {
                  "kind": "filter.setMany",
                  "fields": { "from": "$value.start", "to": "$value.end" }
                }
              }
            }
          ]
        },
        {
          "kind": "DataGrid",
          "bindings": {
            "items": { "$ref": "calculations" },
            "isLoading": { "$ref": "calculations.isLoading" }
          },
          "props": {
            "columns": [
              {
                "field": "invoice_line_id",
                "label": "Invoice line",
                "width": 200,
                "formatter": "ulid-short"
              },
              { "field": "provider", "label": "Provider", "sortable": true, "width": 160 },
              {
                "field": "source_amount_cents",
                "label": "Pre-tax",
                "sortable": true,
                "width": 130,
                "renderer": { "kind": "Text", "formatter": "currency" },
                "currencyField": "source_currency"
              },
              {
                "field": "tax_amount_cents",
                "label": "Tax",
                "sortable": true,
                "width": 130,
                "renderer": { "kind": "Text", "formatter": "currency" },
                "currencyField": "source_currency"
              },
              {
                "field": "tax_rate_snapshot.percentage",
                "label": "Rate",
                "width": 90,
                "renderer": { "widget": "tax.rate-badge" }
              },
              {
                "field": "exemption_applied",
                "label": "Exemption",
                "width": 130,
                "formatter": "boolean-yes-no"
              },
              {
                "field": "calculated_at",
                "label": "Calculated",
                "sortable": true,
                "defaultSort": "desc",
                "width": 160,
                "formatter": "datetime-relative"
              }
            ],
            "onRowPress": {
              "kind": "navigate",
              "toExpr": "'/tenant/tax/calculations/' + row.id"
            }
          }
        }
      ]
    }
  ]
}
