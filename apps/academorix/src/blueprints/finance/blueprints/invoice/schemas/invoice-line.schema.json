{
  "id": "stackra://modules/invoice/schemas/invoice-line",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "InvoiceLine",
  "description": "Per-invoice line item. Belongs to `Invoice` (RESTRICT) + `Tenant`. Draft-only mutation — post-finalize, lines are immutable + credit notes replace them. NEVER carries `application_id`, `region_id`, `organization_id`, `branch_id`, or `scope_node_id`.",
  "type": "object",
  "x-module": "invoice",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "invoice_lines",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "ivl_",
    "incrementing": false,
    "model": "Stackra\\Finance\\Invoice\\Models\\InvoiceLine",
    "interface": "Stackra\\Finance\\Invoice\\Contracts\\Data\\InvoiceLineInterface",
    "implements": ["Stackra\\Finance\\Invoice\\Contracts\\Data\\InvoiceLineInterface"],
    "traits": [
      "HasFactory",
      "HasUlids",
      "BelongsToTenant",
      "BelongsToInvoice",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "Filterable",
      "SoftDeletes"
    ],
    "casts": {
      "item_type": "InvoiceLineItemType",
      "quantity": "decimal:4",
      "unit_price_cents": "integer",
      "subtotal_cents": "integer",
      "discount_amount_cents": "integer",
      "tax_amount_cents": "integer",
      "total_cents": "integer",
      "metadata": "array"
    },
    "observers": ["InvoiceLineObserver"],
    "appends": ["counts_toward_revenue"]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": {
        "type": "string",
        "length": 64,
        "primary": true,
        "description": "Prefixed ULID: `ivl_<26>`."
      },
      "tenant_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "invoice_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "invoices", "column": "id", "onDelete": "restrict" },
        "description": "Parent invoice. RESTRICT — lines outlive purge attempts on the parent."
      },
      "line_number": {
        "type": "integer",
        "nullable": false,
        "description": "1-indexed order within the invoice. Assigned by observer. Immutable after create. Renumbered on line delete."
      },
      "item_type": {
        "type": "string",
        "length": 48,
        "nullable": false,
        "description": "Enum: membership_charge / addon / setup_fee / late_fee / adjustment / one_time_service / tax_line / discount_line. See data/item-type-catalog.json."
      },
      "description": {
        "type": "string",
        "length": 512,
        "nullable": false,
        "description": "Customer-visible description appearing on the PDF."
      },
      "quantity": {
        "type": "decimal",
        "precision": 10,
        "scale": 4,
        "nullable": false,
        "description": "Line quantity. > 0. Fractional supported (0.5 for half-hour, 1.25 for weight-based)."
      },
      "unit_price_cents": {
        "type": "bigint",
        "nullable": false,
        "description": ">= 0 for most item types; may be negative for item_type IN ('discount_line', 'adjustment')."
      },
      "unit_currency": {
        "type": "string",
        "length": 3,
        "nullable": false,
        "description": "ISO 4217. Must match parent invoice.currency (validated by observer)."
      },
      "subtotal_cents": {
        "type": "bigint",
        "nullable": false,
        "description": "ROUND(quantity × unit_price_cents) with bankers' rounding. Frozen after parent invoice finalize."
      },
      "discount_amount_cents": { "type": "bigint", "nullable": false, "default": 0 },
      "tax_amount_cents": {
        "type": "bigint",
        "nullable": false,
        "default": 0,
        "description": "Populated by CalculateInvoiceTaxJob."
      },
      "total_cents": {
        "type": "bigint",
        "nullable": false,
        "description": "subtotal - discount + tax."
      },
      "tax_calculation_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": { "table": "tax_calculations", "column": "id", "onDelete": "restrict" },
        "description": "Frozen snapshot of the tax computation. RESTRICT — TaxCalculation cannot be deleted while referenced."
      },
      "coupon_redemption_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": { "table": "coupon_redemptions", "column": "id", "onDelete": "restrict" },
        "description": "Set on discount_line items when a coupon is applied. RESTRICT."
      },
      "reference_type": {
        "type": "string",
        "length": 96,
        "nullable": true,
        "description": "Optional polymorphic back-reference to source (Membership, Session, Event, Facility)."
      },
      "reference_id": { "type": "string", "length": 64, "nullable": true },
      "metadata": {
        "type": "jsonb",
        "nullable": true,
        "description": "Free-form line-level metadata (session date, ticket number, apparel size)."
      },
      "created_by": { "type": "string", "length": 64, "nullable": true },
      "updated_by": { "type": "string", "length": 64, "nullable": true },
      "deleted_by": { "type": "string", "length": 64, "nullable": true },
      "deleted_at": { "type": "timestamptz", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "invoice_id", "line_number"],
        "unique": true,
        "name": "invoice_lines_invoice_line_number_unique",
        "predicate": "deleted_at IS NULL"
      },
      { "columns": ["tenant_id", "item_type"], "name": "invoice_lines_item_type_idx" },
      {
        "columns": ["tax_calculation_id"],
        "name": "invoice_lines_tax_calc_idx",
        "predicate": "tax_calculation_id IS NOT NULL"
      },
      {
        "columns": ["reference_type", "reference_id"],
        "name": "invoice_lines_reference_idx",
        "predicate": "reference_id IS NOT NULL"
      }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "invoice_id",
    "line_number",
    "item_type",
    "description",
    "quantity",
    "unit_price_cents",
    "unit_currency",
    "subtotal_cents",
    "discount_amount_cents",
    "tax_amount_cents",
    "total_cents",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^ivl_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": "string", "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "invoice_id": { "type": "string", "pattern": "^ivc_[0-9A-HJKMNP-TV-Z]{26}$" },
    "line_number": { "type": "integer", "minimum": 1 },
    "item_type": {
      "type": "string",
      "enum": [
        "membership_charge",
        "addon",
        "setup_fee",
        "late_fee",
        "adjustment",
        "one_time_service",
        "tax_line",
        "discount_line"
      ]
    },
    "description": { "type": "string", "minLength": 1, "maxLength": 512 },
    "quantity": {
      "type": "string",
      "pattern": "^-?[0-9]+(?:\\.[0-9]{1,4})?$",
      "description": "Decimal string (Postgres decimal type). Precision 10,4."
    },
    "unit_price_cents": { "type": "integer" },
    "unit_currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "subtotal_cents": { "type": "integer" },
    "discount_amount_cents": { "type": "integer", "minimum": 0 },
    "tax_amount_cents": { "type": "integer", "minimum": 0 },
    "total_cents": { "type": "integer" },
    "tax_calculation_id": { "type": ["string", "null"], "pattern": "^txc_[0-9A-HJKMNP-TV-Z]{26}$" },
    "coupon_redemption_id": { "type": ["string", "null"] },
    "reference_type": { "type": ["string", "null"] },
    "reference_id": { "type": ["string", "null"] },
    "metadata": { "type": ["object", "null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "x-invariants": [
    "quantity > 0 (strict)",
    "unit_price_cents >= 0 EXCEPT when item_type IN ('discount_line', 'adjustment')",
    "unit_currency == parent invoice.currency (currency mismatch refused)",
    "subtotal_cents = ROUND(quantity × unit_price_cents) with bankers' rounding",
    "total_cents = subtotal_cents - discount_amount_cents + tax_amount_cents",
    "line_number is unique per invoice AND contiguous 1..N",
    "line_number + item_type are immutable after create",
    "line CRUD only permitted while parent invoice.status='draft'",
    "tax_calculation_id is required when item_type IN ('membership_charge', 'addon', 'setup_fee', 'one_time_service') AND parent status='open' (frozen at finalize)"
  ]
}
