{
  "id": "stackra://modules/dunning/policies",
  "$version": 1,
  "title": "dunning — authorization policies",
  "description": "DunningPlan.delete refuses when active runs reference it. DunningRun state-gated: pause/resume/cancel/retry-now valid only when status='active' (pause) or 'paused' (resume). DunningEvent is read-only (never editable — timeline integrity).",
  "policies": [
    {
      "model": "DunningPlan",
      "class": "Stackra\\Finance\\Dunning\\Policies\\DunningPlanPolicy",
      "abilities": [
        { "action": "viewAny", "permission": "dunning-plans.viewAny" },
        { "action": "view", "permission": "dunning-plans.view" },
        { "action": "create", "permission": "dunning-plans.create" },
        { "action": "update", "permission": "dunning-plans.update" },
        {
          "action": "delete",
          "permission": "dunning-plans.delete",
          "scope": "refuses when plan is referenced by active dunning_runs (WHERE status='active')."
        }
      ]
    },
    {
      "model": "DunningRun",
      "class": "Stackra\\Finance\\Dunning\\Policies\\DunningRunPolicy",
      "abilities": [
        {
          "action": "viewAny",
          "permission": "dunning-runs.viewAny",
          "scope": "guardian narrowed to own (subject resolves to a membership/subscription owned by current guardian)."
        },
        { "action": "view", "permission": "dunning-runs.view", "scope": "same narrowing." },
        {
          "action": "pause",
          "permission": "dunning-runs.pause",
          "scope": "refuses when status != 'active'."
        },
        {
          "action": "resume",
          "permission": "dunning-runs.resume",
          "scope": "refuses when status != 'paused'."
        },
        {
          "action": "cancel",
          "permission": "dunning-runs.cancel",
          "scope": "refuses when status IN ('resolved', 'exhausted', 'cancelled')."
        },
        {
          "action": "retryNow",
          "permission": "dunning-runs.retry-now",
          "scope": "refuses when status != 'active'."
        }
      ]
    },
    {
      "model": "DunningEvent",
      "class": "Stackra\\Finance\\Dunning\\Policies\\DunningEventPolicy",
      "abilities": [
        {
          "action": "viewAny",
          "permission": "dunning-events.viewAny",
          "scope": "narrowed by parent run's ownership."
        },
        { "action": "view", "permission": "dunning-events.view" }
      ]
    }
  ]
}
