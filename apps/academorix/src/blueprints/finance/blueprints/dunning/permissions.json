{
  "id": "stackra://modules/dunning/permissions",
  "$version": 1,
  "title": "dunning — permissions",
  "seeder": "Stackra\\Finance\\Dunning\\Database\\Seeders\\DunningPermissionSeeder",
  "isSystem": true,
  "description": "Finance role manages plans + runs. Support role reads runs. Guardian reads own runs (transparency: 'why did my card get charged three times?').",
  "permissions": [
    {
      "name": "dunning-plans.viewAny",
      "guard": "sanctum",
      "seededOn": ["admin", "owner", "finance"]
    },
    { "name": "dunning-plans.view", "guard": "sanctum", "seededOn": ["admin", "owner", "finance"] },
    {
      "name": "dunning-plans.create",
      "guard": "sanctum",
      "seededOn": ["admin", "owner", "finance"]
    },
    {
      "name": "dunning-plans.update",
      "guard": "sanctum",
      "seededOn": ["admin", "owner", "finance"]
    },
    {
      "name": "dunning-plans.delete",
      "guard": "sanctum",
      "description": "Refuses when plan is referenced by active runs.",
      "seededOn": ["admin", "owner", "finance"]
    },
    {
      "name": "dunning-runs.viewAny",
      "guard": "sanctum",
      "description": "Guardian narrowed to own subject.",
      "seededOn": ["admin", "owner", "finance", "support", "guardian"]
    },
    {
      "name": "dunning-runs.view",
      "guard": "sanctum",
      "seededOn": ["admin", "owner", "finance", "support", "guardian"]
    },
    {
      "name": "dunning-runs.pause",
      "guard": "sanctum",
      "description": "Manually pause an active run (support case).",
      "seededOn": ["admin", "owner", "finance", "support"]
    },
    {
      "name": "dunning-runs.resume",
      "guard": "sanctum",
      "seededOn": ["admin", "owner", "finance", "support"]
    },
    {
      "name": "dunning-runs.cancel",
      "guard": "sanctum",
      "description": "Cancel a run without exhausting (e.g. refund issued).",
      "seededOn": ["admin", "owner", "finance"]
    },
    {
      "name": "dunning-runs.retry-now",
      "guard": "sanctum",
      "description": "Force-fire the next retry ahead of schedule.",
      "seededOn": ["admin", "owner", "finance"]
    },
    {
      "name": "dunning-events.viewAny",
      "guard": "sanctum",
      "seededOn": ["admin", "owner", "finance", "support", "guardian"]
    },
    {
      "name": "dunning-events.view",
      "guard": "sanctum",
      "seededOn": ["admin", "owner", "finance", "support", "guardian"]
    }
  ]
}
