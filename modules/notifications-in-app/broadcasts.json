{
  "id": "academorix://modules/notifications-in-app/broadcasts",
  "$version": 1,
  "title": "notifications-in-app \u2014 broadcast channel bindings",
  "description": "This module WRITES to channels declared by core (user.{id}.notifications + workspace.{id}.notifications). It does not declare new channels. The channel authorization rules live in core's broadcasts.json. This file documents the broadcast events fired by this module.",
  "driver": "reverb",
  "broadcastsInto": [
    {
      "channel": "user.{id}.notifications",
      "kind": "private",
      "declaredBy": "notifications (core)",
      "events": [
        {
          "event": "notifications.created",
          "class": "Academorix\\Notifications\\InApp\\Broadcasting\\NotificationCreatedBroadcast",
          "trigger": "BroadcastInAppNotificationJob succeeded",
          "payload": {
            "notification_id": "ULID",
            "category_slug": "string",
            "subject": "string",
            "seen": false,
            "created_at": "ISO 8601"
          }
        },
        {
          "event": "notifications.seen",
          "class": "Academorix\\Notifications\\InApp\\Broadcasting\\NotificationSeenBroadcast",
          "trigger": "RelayNotificationSeen listener",
          "payload": {
            "notification_id": "ULID",
            "seen_at": "ISO 8601"
          }
        },
        {
          "event": "notifications.archived",
          "class": "Academorix\\Notifications\\InApp\\Broadcasting\\NotificationArchivedBroadcast",
          "trigger": "RelayNotificationArchived listener",
          "payload": {
            "notification_id": "ULID",
            "archived_at": "ISO 8601"
          }
        }
      ]
    }
  ]
}
