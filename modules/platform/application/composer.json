{
  "name": "academorix/application",
  "type": "library",
  "description": "Application (product-catalogue) domain module — the global cross-tenant registry of Academorix products (Sports, Marketplace, Ticketing, Venue, Education) plus the BusinessType catalogue (academy, sports_center, school, gym, federation, club). Every Tenant belongs to exactly one Application; `application_id` cascades through the tenancy hierarchy via the `BelongsToApplication` trait (owned here). BusinessType is dual-source per .kiro/steering/enum-db-seed-dual-source.md — code-primary via `BusinessTypeEnum`, DB mirror in `business_types` for admin visibility + tenant-defined customs.",
  "license": "proprietary",
  "keywords": [
    "academorix",
    "laravel",
    "application",
    "product-catalogue",
    "business-type",
    "cross-tenant",
    "platform-registry",
    "domain-module"
  ],
  "require": {
    "php": "^8.3",
    "academorix-platform/application-sdk": "@dev",
    "academorix/authorization": "@dev",
    "academorix/console": "@dev",
    "academorix/crud": "@dev",
    "academorix/database": "@dev",
    "academorix/enum": "@dev",
    "academorix/events": "@dev",
    "academorix/exceptions": "@dev",
    "academorix/foundation": "@dev",
    "academorix/retention": "@dev",
    "academorix/routing": "@dev",
    "academorix/service-provider": "@dev",
    "academorix/support": "@dev",
    "illuminate/auth": "^13.0",
    "illuminate/contracts": "^13.0",
    "illuminate/database": "^13.0",
    "illuminate/events": "^13.0",
    "illuminate/http": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/support": "^13.0",
    "spatie/laravel-data": "^4.11"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Academorix\\Application\\": "src/",
      "Academorix\\Application\\Database\\Factories\\": "database/factories/",
      "Academorix\\Application\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Academorix\\Application\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Academorix\\Application\\Providers\\ApplicationServiceProvider"
      ],
      "aliases": {}
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
