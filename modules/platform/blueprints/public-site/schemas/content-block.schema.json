{
  "id": "academorix://modules/public-site/schemas/content-block",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "ContentBlock",
  "type": "object",
  "x-module": "public-site",
  "x-eloquent": {
    "table": "content_blocks",
    "keyPrefix": "cnb_",
    "traits": [
      "HasFactory",
      "HasPrefixedUlid",
      "BelongsToTenant",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "Filterable",
      "SoftDeletes"
    ]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 30, "primary": true },
      "tenant_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "public_page_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "public_pages", "column": "id", "onDelete": "cascade" }
      },
      "kind": {
        "type": "string",
        "length": 24,
        "nullable": false,
        "description": "hero / text / gallery / cta / testimonials / results_widget / roster_widget / registration_form."
      },
      "payload": { "type": "jsonb", "nullable": false, "default": "'{}'" },
      "sort_order": { "type": "integer", "nullable": false, "default": "0" },
      "is_active": { "type": "boolean", "nullable": false, "default": "true" },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false },
      "deleted_at": { "type": "timestamptz", "nullable": true }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "public_page_id", "sort_order"],
        "name": "content_blocks_page_order_idx"
      }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "public_page_id",
    "kind",
    "payload",
    "sort_order",
    "is_active",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^cnb_[0-9A-HJKMNP-TV-Z]{26}$" },
    "kind": {
      "type": "string",
      "enum": [
        "hero",
        "text",
        "gallery",
        "cta",
        "testimonials",
        "results_widget",
        "roster_widget",
        "registration_form"
      ]
    }
  },
  "additionalProperties": false
}
