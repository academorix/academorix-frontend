{
  "id": "academorix://modules/public-site/policies",
  "$version": 1,
  "title": "public-site — authorization policies",
  "policies": [
    {
      "model": "Page",
      "class": "Academorix\\Platform\\PublicSite\\Policies\\PagePolicy",
      "abilities": [
        {
          "action": "viewAny",
          "permission": "public-site.pages.viewAny",
          "scope": "admin + owner + content_editor role"
        },
        { "action": "view", "permission": "public-site.pages.view" },
        { "action": "create", "permission": "public-site.pages.create" },
        { "action": "update", "permission": "public-site.pages.update" },
        { "action": "publish", "permission": "public-site.pages.publish" },
        { "action": "archive", "permission": "public-site.pages.archive" }
      ]
    },
    {
      "model": "Block",
      "class": "Academorix\\Platform\\PublicSite\\Policies\\BlockPolicy",
      "abilities": [
        { "action": "viewAny", "permission": "public-site.blocks.viewAny" },
        { "action": "view", "permission": "public-site.blocks.view" },
        { "action": "create", "permission": "public-site.blocks.create" },
        { "action": "update", "permission": "public-site.blocks.update" }
      ]
    },
    {
      "model": "SiteSettings",
      "class": "Academorix\\Platform\\PublicSite\\Policies\\SiteSettingsPolicy",
      "abilities": [
        { "action": "view", "permission": "public-site.settings.view", "scope": "admin + owner" },
        {
          "action": "update",
          "permission": "public-site.settings.update",
          "scope": "admin + owner. Domain changes owner-only"
        }
      ]
    }
  ]
}
