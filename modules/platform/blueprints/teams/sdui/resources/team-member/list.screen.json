{
  "id": "teams.resources.team-member.list",
  "title": "Team members",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/teams/:teamId/members",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "teams", "entity": "team-member", "action": "list" },
  "requiresPermission": "team_members.viewAny",
  "requiresEntitlement": "teams",
  "realtime": {
    "channel": "team.{teamId}.members",
    "events": ["TeamMemberJoined", "TeamMemberLeft", "TeamMemberRoleChanged", "TeamMemberStatusChanged"],
    "onEvent": { "kind": "refetch", "sources": ["members"] }
  },
  "dataSources": [
    {
      "name": "team",
      "kind": "http.get",
      "url": "/api/v1/teams/{teamId}",
      "unwrap": "data"
    },
    {
      "name": "members",
      "kind": "http.get",
      "url": "/api/v1/teams/{teamId}/members",
      "unwrap": "data",
      "queryFromFilters": true
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-7xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "kind": "View",
              "children": [
                {
                  "kind": "Text",
                  "props": { "as": "h1", "className": "text-2xl font-semibold" },
                  "bindings": { "children": { "$expr": "team.name + ' — Roster'" } }
                },
                {
                  "kind": "Widget",
                  "widget": "teams.capacity-usage-bar",
                  "props": { "size": "sm" },
                  "bindings": {
                    "active_count": { "$ref": "team.active_roster_count" },
                    "capacity": { "$ref": "team.capacity" },
                    "waitlist_size": { "$ref": "team.capacity_waitlist" }
                  }
                }
              ]
            },
            {
              "kind": "Button",
              "props": { "variant": "primary", "leadingIcon": "plus", "children": "Add member" },
              "actions": { "onPress": { "kind": "navigate", "toExpr": "'/tenant/teams/' + team.id + '/members/new'" } },
              "requiresPermission": "team_members.create"
            }
          ]
        },
        {
          "kind": "Table",
          "props": { "className": "w-full" },
          "bindings": {
            "items": { "$ref": "members" },
            "isLoading": { "$ref": "members.isLoading" }
          },
          "columns": [
            { "field": "member.name", "label": "Member", "sortable": true },
            { "field": "member_type", "label": "Type" },
            { "field": "role_on_team", "label": "Role", "renderer": { "kind": "Widget", "widget": "teams.member-role-chip", "bindings": { "role": { "$ref": "row.role_on_team" } } } },
            { "field": "jersey_number", "label": "#", "align": "right" },
            { "field": "position", "label": "Position" },
            { "field": "joined_at", "label": "Joined", "format": "date" },
            { "field": "status", "label": "Status", "renderer": { "kind": "Chip", "bindings": { "variant": { "$expr": "row.status === 'active' ? 'success' : (row.status === 'injured' ? 'warning' : (row.status === 'suspended' ? 'danger' : 'neutral'))" }, "children": { "$ref": "row.status" } } } },
            {
              "field": "actions",
              "label": "",
              "renderer": {
                "kind": "Dropdown",
                "children": [
                  { "kind": "Dropdown.Item", "props": { "children": "View" }, "actions": { "onPress": { "kind": "navigate", "toExpr": "'/tenant/teams/' + team.id + '/members/' + row.id" } } },
                  { "kind": "Dropdown.Item", "props": { "children": "Change role" }, "actions": { "onPress": { "kind": "modal.open", "modal": "change-role", "context": { "member_id": "row.id" } } }, "requiresPermission": "team_members.change-role" },
                  { "kind": "Dropdown.Item", "props": { "children": "Mark injured" }, "actions": { "onPress": { "kind": "http.post", "url": "/api/v1/teams/{teamId}/members/{row.id}/mark-injured" } }, "requiresPermission": "team_members.mark-injured" },
                  { "kind": "Dropdown.Item", "props": { "children": "Mark graduated" }, "actions": { "onPress": { "kind": "http.post", "url": "/api/v1/teams/{teamId}/members/{row.id}/mark-graduated" } }, "requiresPermission": "team_members.mark-graduated" }
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
