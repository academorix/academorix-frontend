{
  "id": "academorix://modules/webhook/errors",
  "$version": 1,
  "title": "webhook \u2014 error codes",
  "namespace": "webhook",
  "errors": [
    {
      "code": "WEBHOOK_SIGNATURE_INVALID",
      "http": 401,
      "retryable": false,
      "user_facing": false,
      "audit_severity": "warn",
      "i18n_key": "webhook.errors.signature_invalid",
      "description": "Inbound signature failed verification against both primary and previous secrets. Logged."
    },
    {
      "code": "WEBHOOK_SIGNATURE_TIMESTAMP_EXPIRED",
      "http": 401,
      "retryable": false,
      "user_facing": false,
      "audit_severity": "warn",
      "i18n_key": "webhook.errors.timestamp_expired",
      "description": "X-Webhook-Timestamp older than replay_window_seconds (default 300s). Rejected to prevent replay."
    },
    {
      "code": "WEBHOOK_DELIVERY_FAILED_PERMANENT",
      "http": 200,
      "retryable": false,
      "user_facing": false,
      "audit_severity": "info",
      "i18n_key": "webhook.errors.delivery_failed_permanent",
      "description": "Not surfaced as error to callers \u2014 delivery marked failedPermanent + admin notified. Reason: 410 Gone, other 4xx, max_attempts exhausted, or hard error."
    },
    {
      "code": "WEBHOOK_SUBSCRIPTION_DISABLED",
      "http": 409,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "webhook.errors.subscription_disabled",
      "description": "Attempted operation on a disabled subscription. Admin must resume via /subscriptions/{id}/resume."
    },
    {
      "code": "WEBHOOK_SUBSCRIPTION_QUOTA_EXCEEDED",
      "http": 402,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "webhook.errors.subscription_quota_exceeded",
      "description": "Tenant reached webhook.subscriptions.count cap. Upgrade path in response."
    },
    {
      "code": "WEBHOOK_DELIVERY_QUOTA_EXCEEDED",
      "http": 402,
      "retryable": false,
      "user_facing": false,
      "audit_severity": "warn",
      "i18n_key": "webhook.errors.delivery_quota_exceeded",
      "description": "Tenant reached webhook.deliveries.month cap. Deliveries deferred until next period + admin warned."
    },
    {
      "code": "WEBHOOK_SECRET_MISSING",
      "http": 500,
      "retryable": false,
      "user_facing": false,
      "audit_severity": "alert",
      "i18n_key": "webhook.errors.secret_missing",
      "description": "Subscription has no secret column value. Data integrity issue \u2014 pages ops."
    },
    {
      "code": "WEBHOOK_DESTINATION_NOT_REGISTERED",
      "http": 422,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "warn",
      "i18n_key": "webhook.errors.destination_not_registered",
      "description": "Requested destination driver name isn't in WebhookDestinationRegistry. Typically a config drift issue."
    },
    {
      "code": "WEBHOOK_DESTINATION_CONFIG_INVALID",
      "http": 422,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "webhook.errors.destination_config_invalid",
      "description": "destination_config fails driver's schema validation on create/update."
    },
    {
      "code": "WEBHOOK_RATE_LIMIT_EXCEEDED",
      "http": 429,
      "retryable": true,
      "user_facing": false,
      "audit_severity": "info",
      "i18n_key": "webhook.errors.rate_limit_exceeded",
      "description": "Per-subscription rate_limit_per_minute reached. Delivery deferred to next minute."
    },
    {
      "code": "WEBHOOK_PAYLOAD_TOO_LARGE",
      "http": 413,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "warn",
      "i18n_key": "webhook.errors.payload_too_large",
      "description": "Payload exceeds webhook.payload_max_bytes entitlement. Publisher fix required."
    },
    {
      "code": "WEBHOOK_PROBE_FAILED",
      "http": 502,
      "retryable": true,
      "user_facing": false,
      "audit_severity": "warn",
      "i18n_key": "webhook.errors.probe_failed",
      "description": "Health probe failed. Not surfaced to callers directly; fires WebhookProbeFailed event."
    },
    {
      "code": "WEBHOOK_API_VERSION_INVALID",
      "http": 422,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "warn",
      "i18n_key": "webhook.errors.api_version_invalid",
      "description": "Referenced api_version doesn't exist OR is in state=sunset."
    },
    {
      "code": "WEBHOOK_KILL_SWITCHED",
      "http": 503,
      "retryable": true,
      "user_facing": false,
      "audit_severity": "alert",
      "i18n_key": "webhook.errors.kill_switched",
      "description": "webhook.dispatch kill switch off. Emergency ops state."
    }
  ]
}
