{
  "id": "tenants.resources.domain-record.show",
  "title": "DNS record detail",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/platform/domain-records/{id}",
  "host": "central_admin",
  "audience": "authenticated",
  "resource": { "module": "tenancy", "entity": "domain-record", "action": "show" },
  "requiresPermission": "platform.domain-records.view",
  "params": [{ "name": "id", "type": "string", "in": "path", "required": true }],
  "dataSources": [
    {
      "name": "record",
      "kind": "http.get",
      "urlExpr": "'/api/v1/domain-records/' + params.id",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-6 p-6 max-w-3xl mx-auto" },
      "children": [
        {
          "kind": "Link",
          "props": { "leadingIcon": "arrow-left", "children": "Back" },
          "actions": { "onPress": { "kind": "navigate", "to": "/platform/domain-records" } }
        },
        {
          "kind": "View",
          "props": { "className": "flex items-center gap-2" },
          "children": [
            {
              "kind": "Chip",
              "props": { "size": "sm" },
              "bindings": { "children": { "$ref": "record.kind" } }
            },
            {
              "kind": "Text",
              "props": { "as": "h1", "className": "text-2xl font-semibold font-mono" },
              "bindings": { "children": { "$ref": "record.name" } }
            }
          ]
        },
        {
          "kind": "Card",
          "props": { "className": "p-6" },
          "children": [
            {
              "kind": "DescriptionList",
              "children": [
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "Domain" },
                  "bindings": { "value": { "$ref": "record.domain.host" } }
                },
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "Expected value" },
                  "bindings": { "value": { "$ref": "record.value" } }
                },
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "Observed value" },
                  "bindings": {
                    "value": { "$expr": "record.observed_value || 'Not observed yet'" }
                  }
                },
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "Observed at" },
                  "bindings": {
                    "value": {
                      "$expr": "record.observed_at ? formatDate(record.observed_at) : 'Never'"
                    }
                  }
                },
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "Priority (MX only)" },
                  "bindings": {
                    "hidden": { "$expr": "record.kind !== 'MX'" },
                    "value": { "$ref": "record.priority" }
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
