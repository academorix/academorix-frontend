  "title": "staff — error codes",
  "namespace": "staff",
  "errors": [
    { "code": "STAFF_NOT_FOUND", "http": 404, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.staff_not_found" },
    { "code": "STAFF_BRANCH_NOT_ACTIVE", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.staff_branch_not_active", "description": "Attempted to hire into a branch that is closed or archived." },
    { "code": "STAFF_USER_ALREADY_HAS_ACTIVE_ROW", "http": 409, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.staff_user_already_has_active_row", "description": "The user already has an active Staff row in this tenant. Offboard the existing row before creating a new one." },
    { "code": "STAFF_EMPLOYEE_NUMBER_TAKEN", "http": 409, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.staff_employee_number_taken" },
    { "code": "STAFF_QUOTA_EXCEEDED", "http": 402, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.staff_quota_exceeded", "description": "Reached staff_slot cap. Small: 5, Medium: 50. Response includes upgrade path." },
    { "code": "STAFF_USER_ID_IMMUTABLE", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "warn", "i18n_key": "staff.errors.staff_user_id_immutable", "description": "You cannot repoint a Staff row at a different User. Offboard the old + hire the new." },
    { "code": "STAFF_STARTED_AT_LOCKED", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.staff_started_at_locked", "description": "started_at can only be edited during the pre_hire window; after activation it's the audit-of-record." },
    { "code": "STAFF_BRANCH_IMMUTABLE_WAVE_2B", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.staff_branch_immutable_wave_2b", "description": "Branch transfer lands in Wave 3+. Offboard + rehire at the new branch for now." },
    { "code": "STAFF_TERMINATION_REASON_REQUIRED", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.staff_termination_reason_required", "description": "Offboarding requires a documented termination_reason (resigned / terminated / retired / contract_ended / seasonal_end / other)." },
    { "code": "STAFF_SUSPENSION_REASON_REQUIRED", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.staff_suspension_reason_required" },
    { "code": "STAFF_HAS_TEAM_MEMBERSHIPS", "http": 409, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.staff_has_team_memberships", "description": "The staff still has active team memberships. Remove them (or pass cascade=true when calling /offboard)." },
    { "code": "STAFF_HAS_ACTIVE_COACH_PROFILE", "http": 409, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.staff_has_active_coach_profile", "description": "The staff has an active Coach row. Archive the coach first (or pass cascade=true)." },
    { "code": "STAFF_MUST_BE_OFFBOARDED_BEFORE_DELETE", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.staff_must_be_offboarded_before_delete" },
    { "code": "STAFF_ORG_CHART_NOT_ENTITLED", "http": 402, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.staff_org_chart_not_entitled", "description": "reports_to_staff_id feature is Enterprise-only." },
    { "code": "STAFF_ORG_CHART_CYCLE", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "warn", "i18n_key": "staff.errors.staff_org_chart_cycle", "description": "The submitted reports_to_staff_id would create a cycle in the org chart." },
    { "code": "STAFF_MANAGER_NOT_ACTIVE", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.staff_manager_not_active", "description": "reports_to_staff_id target is offboarded or suspended." },
    { "code": "STAFF_COMPENSATION_PERMISSION_REQUIRED", "http": 403, "retryable": false, "user_facing": true, "audit_severity": "warn", "i18n_key": "staff.errors.staff_compensation_permission_required", "description": "Compensation writes require `staff.manage.compensation` — distinct from `staff.update`." },
    { "code": "STAFF_COMPENSATION_TRACKING_NOT_ENABLED", "http": 402, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.staff_compensation_tracking_not_enabled", "description": "Tenant has not opted in to compensation tracking. Turn on the staff_compensation_tracking entitlement in HR settings first." },
    { "code": "STAFF_COMPENSATION_DELTA_TOO_LARGE", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "warn", "i18n_key": "staff.errors.staff_compensation_delta_too_large", "description": "The compensation delta exceeds config.staff.compensation.max_delta_percent (default 50%). Requires `staff.manage.compensation.large-delta` to bypass. Safeguard against payroll fat-finger errors." },
    { "code": "STAFF_EMERGENCY_CONTACT_PERMISSION_REQUIRED", "http": 403, "retryable": false, "user_facing": true, "audit_severity": "warn", "i18n_key": "staff.errors.staff_emergency_contact_permission_required" },
    { "code": "STAFF_TAX_ID_INVALID_FORMAT", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.staff_tax_id_invalid_format", "description": "tax_id_last4 must be exactly 4 digits." },
    { "code": "BRANCH_ALREADY_HAS_MANAGER", "http": 409, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.branch_already_has_manager", "description": "Another active Staff for this branch already has is_branch_manager=true. Use /promote-to-manager for the atomic swap, or /demote the existing first." },
    { "code": "BRANCH_MANAGER_MUST_BE_ACTIVE", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.branch_manager_must_be_active", "description": "A pre_hire / on_leave / suspended / offboarded Staff cannot be a branch manager." },
    { "code": "BRANCH_WOULD_HAVE_NO_MANAGER", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "warn", "i18n_key": "staff.errors.branch_would_have_no_manager", "description": "Demoting this staff would leave the branch without a manager. Confirm the leaderless state explicitly (`acknowledge_leaderless=true` in the body) or promote a replacement first." },
    { "code": "STAFF_HAS_ACTIVE_DIRECT_REPORTS", "http": 409, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.staff_has_active_direct_reports", "description": "Offboarding a manager: direct reports must be reassigned (they'll be set to reports_to_staff_id=null via SET NULL FK). Confirm via `orphan_direct_reports=true` in the body." },
    { "code": "BRANCH_HAS_ACTIVE_STAFF", "http": 409, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.branch_has_active_staff", "description": "Branch archive refused because active Staff exist. Offboard them first." },
    { "code": "USER_HAS_ACTIVE_STAFF", "http": 409, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.user_has_active_staff", "description": "User archive refused because the user has an active Staff row. Offboard first." },

    { "code": "COACH_NOT_FOUND", "http": 404, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.coach_not_found" },
    { "code": "COACH_STAFF_NOT_ACTIVE", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.coach_staff_not_active", "description": "Cannot create a Coach row for a Staff whose employment_status != 'active'." },
    { "code": "COACH_STAFF_ALREADY_HAS_COACH_ROW", "http": 409, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.coach_staff_already_has_coach_row", "description": "This Staff already has a live Coach row." },
    { "code": "COACH_QUOTA_EXCEEDED", "http": 402, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.coach_quota_exceeded", "description": "Reached coach_slot cap. Small: 1, Medium: 10." },
    { "code": "COACH_STAFF_ID_IMMUTABLE", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "warn", "i18n_key": "staff.errors.coach_staff_id_immutable" },
    { "code": "COACH_STARTED_BEFORE_STAFF", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.coach_started_before_staff", "description": "coach_started_at cannot be earlier than the parent Staff.started_at." },
    { "code": "COACH_INVALID_CERTIFICATION_SHAPE", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.coach_invalid_certification_shape", "description": "A certification entry violates the required shape (organization + certification + certified_at required)." },
    { "code": "COACH_CERTIFICATION_EXPIRES_BEFORE_CERTIFIED", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.coach_certification_expires_before_certified" },
    { "code": "COACH_CERTIFICATION_VERIFICATION_NOT_ENTITLED", "http": 402, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.coach_certification_verification_not_entitled", "description": "coach_certifications_verified is Enterprise-only." },
    { "code": "COACH_RATING_WRITE_FORBIDDEN", "http": 403, "retryable": false, "user_facing": false, "audit_severity": "warn", "i18n_key": "staff.errors.coach_rating_write_forbidden", "description": "rating field is written exclusively by AggregateCoachRatingsJob. Every manual write attempt is a P2 signal." },
    { "code": "COACH_INVALID_AVAILABILITY_PATTERN", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.coach_invalid_availability_pattern" },
    { "code": "COACH_INVALID_SPORT_KEY", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.coach_invalid_sport_key", "description": "sport_key not in the sports registry (soft-warn in Wave 2b, hard-fail in Wave 3)." },
    { "code": "COACH_HAS_TEAM_MEMBERSHIPS", "http": 409, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.coach_has_team_memberships", "description": "Archive refused: the coach still has active team memberships. Remove them first." },
    { "code": "COACH_MUST_BE_ARCHIVED_BEFORE_DELETE", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "staff.errors.coach_must_be_archived_before_delete" }
