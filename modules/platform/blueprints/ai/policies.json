{
  "id": "academorix://modules/ai/policies",
  "$version": 1,
  "title": "ai — authorization policies",
  "description": "Three policies with STRICT persona-role binding. Every AiRun + AiToolCall re-checks the caller's role against the persona's allowed roles — an LLM promise means nothing without a runtime policy gate.",
  "policies": [
    {
      "model": "AiConversation",
      "class": "Academorix\\Ai\\Policies\\AiConversationPolicy",
      "abilities": [
        {
          "action": "viewAny",
          "permission": "ai.conversations.viewAny",
          "scope": "user sees .own conversations; admin sees all"
        },
        {
          "action": "view",
          "permission": "ai.conversations.view",
          "scope": "conversation user + admin"
        },
        {
          "action": "start",
          "permission": "ai.conversations.start",
          "scope": "any authenticated user with persona-appropriate role. Gated by ai.persona-role middleware"
        },
        {
          "action": "archive",
          "permission": "ai.conversations.archive",
          "scope": "conversation user + admin"
        },
        {
          "action": "delete",
          "permission": "ai.conversations.delete",
          "scope": "conversation user (soft-delete) + admin (hard-delete via retention)"
        },
        {
          "action": "flag",
          "permission": "ai.conversations.flag",
          "scope": "user can flag their own conversation for review; admin flags any"
        },
        {
          "action": "platformViewAny",
          "permission": "platform.ai.conversations.viewAny",
          "guard": "platform_admin",
          "scope": "PII-masked. Prompts + responses redacted; only tokens + cost + persona visible"
        }
      ]
    },
    {
      "model": "AiRun",
      "class": "Academorix\\Ai\\Policies\\AiRunPolicy",
      "abilities": [
        {
          "action": "viewAny",
          "permission": "ai.runs.viewAny",
          "scope": "conversation user sees own runs; admin sees tenant-wide"
        },
        { "action": "view", "permission": "ai.runs.view" },
        {
          "action": "cancel",
          "permission": "ai.runs.cancel",
          "scope": "conversation user + admin. In-flight only"
        },
        {
          "action": "platformAudit",
          "permission": "platform.ai.runs.audit",
          "guard": "platform_admin",
          "scope": "audit run-cost reconciliation. Prompt + response bodies never exposed"
        }
      ]
    },
    {
      "model": "AiToolCall",
      "class": "Academorix\\Ai\\Policies\\AiToolCallPolicy",
      "abilities": [
        {
          "action": "viewAny",
          "permission": "ai.tool-calls.viewAny",
          "scope": "conversation user + admin"
        },
        {
          "action": "view",
          "permission": "ai.tool-calls.view",
          "scope": "conversation user + admin. args_hash never decrypts back to args"
        },
        {
          "action": "platformAudit",
          "permission": "platform.ai.tool-calls.audit",
          "guard": "platform_admin",
          "scope": "cross-tenant tool-abuse detection. tool_name + status only"
        }
      ]
    }
  ]
}
