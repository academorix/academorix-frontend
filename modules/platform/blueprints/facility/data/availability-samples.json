{
  "$version": 1,
  "title": "Facility availability_json — canonical samples",
  "description": "Concrete examples of the availability_json blob shape. Consumed by test fixtures + the SDUI create-facility screen's defaults. Every sample validates against schemas/availability.schema.json.",
  "shape_definition": {
    "type": "object",
    "keys_by_day": ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"],
    "value_per_day": "array of { starts: 'HH:MM' 24h, ends: 'HH:MM' 24h } windows",
    "invariants": [
      "ends > starts within each window",
      "windows within a day do not overlap",
      "windows within a day are sorted ascending by starts",
      "every window is entirely within the parent branch.opening_hours for that day"
    ]
  },
  "samples": [
