{
  "id": "settings.setting-field-renderer",
  "title": "Setting field renderer",
  "version": 1,
  "kind": "SduiWidget",
  "description": "Renders the correct HeroUI control for a FieldDescriptor. Handles all 25+ ControlType cases. Sensitive fields render masked with a reveal toggle when caller has settings.view-sensitive.",
  "props": {
    "field": { "type": "object", "description": "FieldDescriptor from the settings schema." },
    "currentValueExpr": {
      "type": "string",
      "description": "Expression that resolves to the current value from the values source."
    }
  },
  "dataSources": [],
  "nodes": [
    {
      "id": "field",
      "kind": "View",
      "props": { "className": "flex flex-col gap-1" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-center justify-between" },
          "children": [
            {
              "kind": "Text",
              "props": { "as": "label", "className": "text-sm font-medium" },
              "bindings": { "children": { "$ref": "props.field.label" } }
            },
            {
              "kind": "Chip",
              "props": { "size": "xs", "variant": "warning", "leadingIcon": "lock-closed" },
              "bindings": {
                "hidden": { "$expr": "!props.field.sensitive" },
                "children": "Sensitive"
              }
            }
          ]
        },
        {
          "kind": "Switch",
          "props": { "name": "props.field.name" },
          "bindings": {
            "hidden": { "$expr": "props.field.controlType !== 'toggle'" },
            "defaultValue": { "$expr": "props.currentValueExpr" }
          }
        },
        {
          "kind": "TextField",
          "props": { "name": "props.field.name" },
          "bindings": {
            "hidden": { "$expr": "!['text', 'email', 'url'].includes(props.field.controlType)" },
            "type": { "$ref": "props.field.controlType" },
            "defaultValue": { "$expr": "props.currentValueExpr" },
            "placeholder": { "$ref": "props.field.placeholder" }
          }
        },
        {
          "kind": "TextField",
          "props": { "name": "props.field.name", "type": "password" },
          "bindings": {
            "hidden": { "$expr": "props.field.controlType !== 'password'" },
            "defaultValue": { "$expr": "props.currentValueExpr" }
          }
        },
        {
          "kind": "TextArea",
          "props": { "name": "props.field.name" },
          "bindings": {
            "hidden": { "$expr": "props.field.controlType !== 'textarea'" },
            "defaultValue": { "$expr": "props.currentValueExpr" }
          }
        },
        {
          "kind": "NumberField",
          "props": { "name": "props.field.name" },
          "bindings": {
            "hidden": { "$expr": "props.field.controlType !== 'number'" },
            "defaultValue": { "$expr": "props.currentValueExpr" },
            "min": { "$ref": "props.field.min" },
            "max": { "$ref": "props.field.max" },
            "step": { "$ref": "props.field.step" }
          }
        },
        {
          "kind": "Select",
          "props": { "name": "props.field.name" },
          "bindings": {
            "hidden": {
              "$expr": "!['select', 'timezone', 'locale', 'country', 'currency'].includes(props.field.controlType)"
            },
            "defaultValue": { "$expr": "props.currentValueExpr" },
            "options": {
              "$expr": "Object.entries(props.field.options).map(([value, label]) => ({ key: value, label }))"
            }
          }
        },
        {
          "kind": "MultiSelect",
          "props": { "name": "props.field.name" },
          "bindings": {
            "hidden": { "$expr": "props.field.controlType !== 'multiselect'" },
            "defaultValue": { "$expr": "props.currentValueExpr" },
            "options": {
              "$expr": "Object.entries(props.field.options).map(([value, label]) => ({ key: value, label }))"
            }
          }
        },
        {
          "kind": "RadioGroup",
          "props": { "name": "props.field.name" },
          "bindings": {
            "hidden": { "$expr": "props.field.controlType !== 'radio'" },
            "defaultValue": { "$expr": "props.currentValueExpr" },
            "options": {
              "$expr": "Object.entries(props.field.options).map(([value, label]) => ({ key: value, label }))"
            }
          }
        },
        {
          "kind": "Checkbox",
          "props": { "name": "props.field.name" },
          "bindings": {
            "hidden": { "$expr": "props.field.controlType !== 'checkbox'" },
            "defaultValue": { "$expr": "props.currentValueExpr" }
          }
        },
        {
          "kind": "Slider",
          "props": { "name": "props.field.name" },
          "bindings": {
            "hidden": { "$expr": "props.field.controlType !== 'slider'" },
            "defaultValue": { "$expr": "props.currentValueExpr" },
            "min": { "$ref": "props.field.min" },
            "max": { "$ref": "props.field.max" },
            "step": { "$ref": "props.field.step" }
          }
        },
        {
          "kind": "ColorPicker",
          "props": { "name": "props.field.name" },
          "bindings": {
            "hidden": { "$expr": "props.field.controlType !== 'color'" },
            "defaultValue": { "$expr": "props.currentValueExpr" }
          }
        },
        {
          "kind": "DateField",
          "props": { "name": "props.field.name" },
          "bindings": {
            "hidden": { "$expr": "props.field.controlType !== 'date'" },
            "defaultValue": { "$expr": "props.currentValueExpr" }
          }
        },
        {
          "kind": "TimeField",
          "props": { "name": "props.field.name" },
          "bindings": {
            "hidden": { "$expr": "props.field.controlType !== 'time'" },
            "defaultValue": { "$expr": "props.currentValueExpr" }
          }
        },
        {
          "kind": "DatePicker",
          "props": { "name": "props.field.name" },
          "bindings": {
            "hidden": { "$expr": "props.field.controlType !== 'datetime'" },
            "defaultValue": { "$expr": "props.currentValueExpr" }
          }
        },
        {
          "kind": "Text",
          "props": { "className": "text-xs text-muted" },
          "bindings": {
            "hidden": { "$expr": "!props.field.helpText" },
            "children": { "$ref": "props.field.helpText" }
          }
        }
      ]
    }
  ]
}
