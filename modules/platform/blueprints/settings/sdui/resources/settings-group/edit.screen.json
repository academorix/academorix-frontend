{
  "id": "settings.resources.settings-group.edit",
  "title": "Edit settings group",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/settings/{group}",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "settings", "entity": "settings-group", "action": "edit" },
  "requiresPermission": "settings.read",
  "params": [{ "name": "group", "type": "string", "in": "path", "required": true }],
  "dataSources": [
    {
      "name": "schema",
      "kind": "http.get",
      "urlExpr": "'/api/v1/settings/' + params.group + '/schema'",
      "unwrap": "data"
    },
    {
      "name": "values",
      "kind": "http.get",
      "urlExpr": "'/api/v1/settings/' + params.group",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-6 p-6 max-w-3xl mx-auto" },
      "children": [
        {
          "kind": "Link",
          "props": {
            "leadingIcon": "arrow-left",
            "children": "All settings",
            "className": "text-sm text-muted"
          },
          "actions": { "onPress": { "kind": "navigate", "to": "/tenant/settings" } }
        },
        {
          "kind": "View",
          "props": { "className": "flex items-center gap-3" },
          "children": [
            {
              "kind": "Icon",
              "props": { "className": "size-6" },
              "bindings": { "icon": { "$ref": "schema.icon" } }
            },
            {
              "kind": "View",
              "props": { "className": "flex flex-col" },
              "children": [
                {
                  "kind": "Text",
                  "props": { "as": "h1", "className": "text-2xl font-semibold" },
                  "bindings": { "children": { "$ref": "schema.label" } }
                },
                {
                  "kind": "Text",
                  "props": { "className": "text-sm text-muted" },
                  "bindings": { "children": { "$ref": "schema.description" } }
                }
              ]
            }
          ]
        },
        {
          "kind": "Form",
          "props": {
            "submitUrlExpr": "'/api/v1/settings/' + params.group",
            "submitMethod": "PUT",
            "onSuccess": [
              { "kind": "toast.success", "message": "Saved" },
              { "kind": "data.refresh", "source": "values" }
            ]
          },
          "bindings": { "initialValues": { "$ref": "values" } },
          "children": [
            {
              "kind": "List",
              "props": { "className": "flex flex-col gap-6" },
              "bindings": { "items": { "$ref": "schema.sections" } },
              "itemRenderer": {
                "kind": "Card",
                "props": { "className": "p-6" },
                "children": [
                  {
                    "kind": "View",
                    "props": { "className": "flex items-center gap-2 mb-4" },
                    "children": [
                      {
                        "kind": "Icon",
                        "props": { "className": "size-5" },
                        "bindings": { "icon": { "$ref": "row.icon" } }
                      },
                      {
                        "kind": "View",
                        "props": { "className": "flex flex-col" },
                        "children": [
                          {
                            "kind": "Text",
                            "props": {
                              "as": "h2",
                              "className": "text-sm font-semibold uppercase tracking-wide text-muted"
                            },
                            "bindings": { "children": { "$ref": "row.label" } }
                          },
                          {
                            "kind": "Text",
                            "props": { "className": "text-xs text-muted" },
                            "bindings": {
                              "hidden": { "$expr": "!row.description" },
                              "children": { "$ref": "row.description" }
                            }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "kind": "List",
                    "props": { "className": "flex flex-col gap-4" },
                    "bindings": { "items": { "$ref": "row.fields" } },
                    "itemRenderer": {
                      "kind": "Widget",
                      "widget": "settings.setting-field-renderer",
                      "props": {
                        "field": { "$ref": "row" },
                        "currentValueExpr": "values[row.name]"
                      }
                    }
                  }
                ]
              }
            },
            {
              "kind": "View",
              "props": { "className": "flex items-center justify-end gap-2" },
              "children": [
                {
                  "kind": "Button",
                  "props": {
                    "variant": "primary",
                    "size": "md",
                    "type": "submit",
                    "children": "Save changes"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
