{
  "id": "tenants.resources.tenant-contact.create",
  "title": "Add contact",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/contacts/new",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "tenancy", "entity": "tenant-contact", "action": "create" },
  "requiresPermission": "tenants.manage_contacts",
  "dataSources": [],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-6 p-6 max-w-2xl mx-auto" },
      "children": [
        {
          "kind": "Link",
          "props": { "leadingIcon": "arrow-left", "children": "Cancel" },
          "actions": { "onPress": { "kind": "navigate", "to": "/tenant/contacts" } }
        },
        {
          "kind": "Text",
          "props": { "as": "h1", "className": "text-2xl font-semibold", "children": "Add contact" }
        },
        {
          "kind": "Form",
          "props": {
            "submitUrl": "/api/v1/tenant/contacts",
            "submitMethod": "POST",
            "onSuccess": [
              { "kind": "toast.success", "message": "Contact added. Verification email sent." },
              { "kind": "navigate", "to": "/tenant/contacts" }
            ]
          },
          "children": [
            {
              "kind": "Select",
              "props": { "label": "Kind", "name": "kind", "isRequired": true },
              "options": [
                { "key": "billing", "label": "Billing \u2014 invoices + payment failures" },
                { "key": "legal", "label": "Legal \u2014 DPA + terms updates" },
                { "key": "technical", "label": "Technical \u2014 incident + integration alerts" },
                { "key": "dpo", "label": "DPO \u2014 GDPR Art. 30 named contact" },
                { "key": "security", "label": "Security \u2014 vuln + breach notifications" }
              ]
            },
            {
              "kind": "TextField",
              "props": { "label": "Name", "name": "name", "isRequired": true }
            },
            {
              "kind": "TextField",
              "props": { "label": "Email", "name": "email", "isRequired": true, "type": "email" }
            },
            {
              "kind": "TextField",
              "props": { "label": "Phone", "name": "phone", "placeholder": "+15551234567" }
            },
            {
              "kind": "TextField",
              "props": {
                "label": "Title / role",
                "name": "title",
                "placeholder": "Head of Compliance"
              }
            },
            {
              "kind": "Alert",
              "props": {
                "variant": "info",
                "children": "A verification email is sent immediately. Contact is unverified until they click the link."
              }
            },
            {
              "kind": "Button",
              "props": {
                "variant": "primary",
                "size": "md",
                "type": "submit",
                "children": "Add contact"
              }
            }
          ]
        }
      ]
    }
  ]
}
