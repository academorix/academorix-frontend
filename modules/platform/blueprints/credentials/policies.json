{
  "id": "academorix://modules/credentials/policies",
  "$version": 1,
  "title": "credentials — authorization policies",
  "description": "Three policies. Gate device authentication is separate from user authorization — devices carry their own service account credentials + JWT signed by tenant. User-side policies govern the ADMIN surface for issuing + revoking + reading scans.",
  "policies": [
    {
      "model": "Credential",
      "class": "Academorix\\Platform\\Credentials\\Policies\\CredentialPolicy",
      "abilities": [
        {
          "action": "viewAny",
          "permission": "credentials.viewAny",
          "scope": "front_desk + branch_manager + admin + owner. Users see own credentials only."
        },
        { "action": "view", "permission": "credentials.view" },
        {
          "action": "issue",
          "permission": "credentials.issue",
          "scope": "front_desk + branch_manager + admin + owner"
        },
        {
          "action": "revoke",
          "permission": "credentials.revoke",
          "scope": "front_desk (reason=lost only) + branch_manager + admin + owner"
        },
        {
          "action": "reportLost",
          "permission": "credentials.report-lost",
          "scope": "holder self OR guardian OR staff"
        }
      ]
    },
    {
      "model": "Gate",
      "class": "Academorix\\Platform\\Credentials\\Policies\\GatePolicy",
      "abilities": [
        {
          "action": "viewAny",
          "permission": "gates.viewAny",
          "scope": "front_desk + branch_manager + admin + owner"
        },
        { "action": "view", "permission": "gates.view" },
        {
          "action": "create",
          "permission": "gates.create",
          "scope": "branch_manager + admin + owner"
        },
        {
          "action": "update",
          "permission": "gates.update",
          "scope": "branch_manager + admin + owner"
        },
        {
          "action": "configure",
          "permission": "gates.configure",
          "scope": "admin + owner. Changes entry rules — high impact"
        },
        { "action": "delete", "permission": "gates.delete", "scope": "admin + owner" }
      ]
    },
    {
      "model": "GateScan",
      "class": "Academorix\\Platform\\Credentials\\Policies\\GateScanPolicy",
      "abilities": [
        {
          "action": "viewAny",
          "permission": "gate-scans.viewAny",
          "scope": "branch_manager + admin + owner. Front desk sees current day only."
        },
        { "action": "view", "permission": "gate-scans.view" },
        {
          "action": "platformAudit",
          "permission": "platform.gate-scans.audit",
          "guard": "platform_admin"
        }
      ]
    }
  ]
}
