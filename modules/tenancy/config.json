{
  "id": "academorix://modules/tenancy/config",
  "$version": 1,
  "title": "tenancy — developer configuration",
  "description": "Developer / operator configuration for this module. Mirrors `config/tenancy.php` in the Laravel app. Values are STATIC per deploy — mutating them requires a redeploy or a `php artisan config:cache` refresh. Distinct from `settings.json` (which is user-facing and tenant-editable via the dashboard). Every key documented with type, default, env var (when overridable), and secret flag (when the value must be stored in an ENV or Vault, never checked into git).",
  "configFile": "config/tenancy.php",
  "envPrefix": "TENANCY_",
  "cli": {
    "syncCommand": "tenancy:sync-catalogue",
    "clearCommand": "config:clear",
    "cacheCommand": "config:cache"
  },
  "sections": {
    "hosts": {
      "description": "Reserved slugs and host-resolution behaviour.",
      "keys": [
        {
          "path": "tenancy.hosts.reserved_slugs",
          "type": "array<string>",
          "default": ["www", "api", "admin", "mail", "blog", "platform", "app", "static", "cdn", "help", "support", "status"],
          "description": "Slugs a tenant cannot pick during self-serve registration. Enforced by the `reserved_slug` validation rule."
        },
        {
          "path": "tenancy.hosts.cache_ttl_seconds",
          "type": "integer",
          "default": 60,
          "env": "TENANCY_HOST_CACHE_TTL",
          "description": "TTL for `domain:{host}:tenant` and `application:host:{host}` cache entries. Short by design so DNS + custom-domain edits reflect quickly."
        },
        {
          "path": "tenancy.hosts.resolver_class",
          "type": "string",
          "default": "Academorix\\Tenancy\\Hosts\\HostResolver",
          "description": "FQCN of the class that maps a request Host header to (Application, Tenant | null). Swappable for testing."
        }
      ]
    },
    "provisioning": {
      "description": "Tenant provisioning defaults.",
      "keys": [
        {
          "path": "tenancy.provisioning.default_trial_days",
          "type": "integer",
          "default": 14,
          "env": "TENANCY_DEFAULT_TRIAL_DAYS"
        },
        {
          "path": "tenancy.provisioning.grace_days_after_payment_failure",
          "type": "integer",
          "default": 7,
          "env": "TENANCY_GRACE_DAYS"
        },
        {
          "path": "tenancy.provisioning.default_locale",
          "type": "string",
          "default": "en"
        },
        {
          "path": "tenancy.provisioning.default_timezone",
          "type": "string",
          "default": "UTC"
        },
        {
          "path": "tenancy.provisioning.default_currency",
          "type": "string",
          "default": "USD"
        },
        {
          "path": "tenancy.provisioning.transaction_isolation",
          "type": "string",
          "default": "REPEATABLE READ",
          "enum": ["REPEATABLE READ", "SERIALIZABLE"],
          "description": "SQL isolation level for the tenant-provisioning transaction."
        }
      ]
    },
    "domain_verification": {
      "description": "Domain DNS verification behaviour.",
      "keys": [
        {"path": "tenancy.domain_verification.max_attempts", "type": "integer", "default": 100},
        {"path": "tenancy.domain_verification.recheck_hours", "type": "integer", "default": 24, "description": "Verified domains are re-checked every N hours via `tenancy:reverify-domains`."},
        {"path": "tenancy.domain_verification.dns_resolver", "type": "string", "default": "system", "enum": ["system", "cloudflare", "google", "quad9"]},
        {"path": "tenancy.domain_verification.ssl_renewal_days", "type": "integer", "default": 30, "description": "Days before ssl_expires_at that we trigger renewal."},
        {"path": "tenancy.domain_verification.verification_token_bytes", "type": "integer", "default": 32, "description": "Random bytes of entropy in `Domain.verification_token`. Base64-encoded → 43 chars."}
      ]
    },
    "cache": {
      "description": "Cache TTLs (seconds). Aligned with `caches.json`.",
      "keys": [
        {"path": "tenancy.cache.branding_ttl", "type": "integer", "default": 3600},
        {"path": "tenancy.cache.features_ttl", "type": "integer", "default": 300},
        {"path": "tenancy.cache.provisioning_ttl", "type": "integer", "default": 3600},
        {"path": "tenancy.cache.domain_lookup_ttl", "type": "integer", "default": 60},
        {"path": "tenancy.cache.application_lookup_ttl", "type": "integer", "default": 3600},
        {"path": "tenancy.cache.business_types_ttl", "type": "integer", "default": 86400},
        {"path": "tenancy.cache.my_workspaces_ttl", "type": "integer", "default": 60}
      ]
    },
    "retention": {
      "description": "Data retention windows (ISO-8601 durations). Aligned with `retention.json`.",
      "keys": [
        {"path": "tenancy.retention.tenant_hard_delete", "type": "iso8601-duration", "default": "P30D"},
        {"path": "tenancy.retention.domain_hard_delete", "type": "iso8601-duration", "default": "P7D"},
        {"path": "tenancy.retention.branding_hard_delete", "type": "iso8601-duration", "default": "P30D"},
        {"path": "tenancy.retention.contact_hard_delete", "type": "iso8601-duration", "default": "P30D"},
        {"path": "tenancy.retention.dpo_legal_contact_hold", "type": "iso8601-duration", "default": "P7Y", "description": "GDPR Art. 30 retention hold on DPO + legal contacts."},
        {"path": "tenancy.retention.integration_hard_delete", "type": "iso8601-duration", "default": "P30D"},
        {"path": "tenancy.retention.identity_erasure_grace", "type": "iso8601-duration", "default": "P30D", "description": "Grace period between anonymisation and hard-delete for erased Identities."}
      ]
    },
    "integrations": {
      "description": "External provider settings for TenantIntegration (v2).",
      "keys": [
        {"path": "tenancy.integrations.kms_key_id", "type": "string", "nullable": true, "env": "TENANCY_KMS_KEY_ID", "secret": true, "description": "AWS KMS key used to encrypt TenantIntegration.config. Required in production; nullable in dev where the SecretStub cast is used."},
        {"path": "tenancy.integrations.default_sync_interval_minutes", "type": "integer", "default": 15},
        {"path": "tenancy.integrations.sync_timeout_seconds", "type": "integer", "default": 300},
        {"path": "tenancy.integrations.max_consecutive_failures", "type": "integer", "default": 10, "description": "After N consecutive sync failures, is_active is auto-toggled off + IntegrationSyncFailedNotification fires."}
      ]
    },
    "notifications": {
      "description": "Notification transport defaults.",
      "keys": [
        {"path": "tenancy.notifications.from_address", "type": "email", "default": "no-reply@academorix.app", "env": "TENANCY_MAIL_FROM"},
        {"path": "tenancy.notifications.support_address", "type": "email", "default": "support@academorix.app", "env": "TENANCY_SUPPORT_ADDR"},
        {"path": "tenancy.notifications.mail_queue", "type": "string", "default": "notifications"}
      ]
    },
    "audit": {
      "description": "Audit + monitoring settings.",
      "keys": [
        {"path": "tenancy.audit.cross_tenant_alert_channel", "type": "string", "default": "security", "description": "Log channel that TenantException::crossTenantAccess() routes to. Pages on-call."},
        {"path": "tenancy.audit.persist_denied_requests", "type": "boolean", "default": true, "description": "Persist an audit row for every denied cross-tenant attempt."}
      ]
    }
  }
}
