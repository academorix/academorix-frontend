{
  "id": "tenancy.resources.tenant.settings",
  "title": "Workspace settings",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/workspace",
  "host": "tenant",
  "audience": "authenticated",
  "resource": {"module": "tenancy", "entity": "tenant", "action": "settings"},
  "requiresPermission": "tenants.manage_own_settings",
  "description": "Tenant self-edit surface. Renders workspace_*, workspace_domains, workspace_branding, workspace_contacts, workspace_notifications, workspace_privacy, workspace_danger_zone groups from the settings registry (see tenancy/settings.json).",
  "dataSources": [
    {"name": "tenant", "kind": "http.get", "url": "/api/current-tenant", "unwrap": "data"},
    {"name": "schema", "kind": "http.get", "url": "/api/v1/settings/schema?filter[group.starts_with]=workspace", "unwrap": "data", "cache": {"ttlSeconds": 300}},
    {"name": "brandings", "kind": "http.get", "url": "/api/v1/tenant/brandings?per_page=10", "unwrap": "data"}
  ],
  "broadcasts": [
    {"channel": "tenant.{id}.branding", "on": ["TenantBrandingUpdated"], "action": {"kind": "data.refresh", "source": "tenant"}}
  ],
  "nodes": [
    {"id": "root", "kind": "View", "props": {"className": "flex flex-col gap-6 p-6 max-w-4xl mx-auto"}, "children": [
      {"kind": "View", "props": {"className": "flex items-center gap-3"}, "children": [
        {"kind": "Avatar", "props": {"size": "md"}, "bindings": {"src": {"$expr": "tenant.branding?.logo_url"}, "fallback": {"$expr": "(tenant.name || 'W')[0]"}}},
        {"kind": "View", "children": [
          {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold"}, "bindings": {"children": {"$ref": "tenant.name"}}},
          {"kind": "Text", "props": {"className": "text-sm text-muted font-mono"}, "bindings": {"children": {"$expr": "tenant.slug + '.academorix.app'"}}}
        ]}
      ]},
      {"kind": "Tabs", "props": {"defaultValue": "workspace"}, "children": [
        {"kind": "TabList", "children": [
          {"kind": "Tab", "props": {"value": "workspace", "children": "Workspace"}},
          {"kind": "Tab", "props": {"value": "branding", "children": "Branding"}},
          {"kind": "Tab", "props": {"value": "domains", "children": "Domains"}},
          {"kind": "Tab", "props": {"value": "contacts", "children": "Contacts"}},
          {"kind": "Tab", "props": {"value": "notifications", "children": "Notifications"}},
          {"kind": "Tab", "props": {"value": "privacy", "children": "Privacy"}},
          {"kind": "Tab", "props": {"value": "danger", "children": "Danger zone", "className": "text-danger"}}
        ]},
        {"kind": "TabPanel", "props": {"value": "workspace"}, "children": [
          {"kind": "Widget", "widget": "settings.setting-field-renderer.batch", "props": {"groupExpr": "'workspace'"}}
        ]},
        {"kind": "TabPanel", "props": {"value": "branding"}, "children": [
          {"kind": "View", "props": {"className": "flex flex-col gap-4"}, "children": [
            {"kind": "Text", "props": {"as": "h2", "className": "text-sm font-semibold uppercase tracking-wide text-muted", "children": "Branding profiles"}},
            {"kind": "List", "bindings": {"items": {"$ref": "brandings"}}, "itemRenderer": {"kind": "View", "props": {"className": "flex items-center justify-between p-3 border rounded"}, "children": [
              {"kind": "View", "props": {"className": "flex items-center gap-3"}, "children": [
                {"kind": "View", "props": {"className": "size-8 rounded"}, "bindings": {"style": {"$expr": "{ backgroundColor: row.primary_color }"}}},
                {"kind": "Text", "props": {"className": "font-medium"}, "bindings": {"children": {"$ref": "row.name"}}},
                {"kind": "Chip", "props": {"size": "xs", "variant": "info"}, "bindings": {"hidden": {"$expr": "!row.is_primary"}, "children": "Primary"}}
              ]},
              {"kind": "Link", "props": {"size": "sm", "children": "Edit"}, "actions": {"onPress": {"kind": "openDialog", "dialog": "tenancy.dialogs.edit-branding", "propsExpr": "{ brandingId: row.id }"}}}
            ]}}
          ]}
        ]},
        {"kind": "TabPanel", "props": {"value": "domains"}, "children": [
          {"kind": "Link", "props": {"children": "Manage domains \u2192"}, "actions": {"onPress": {"kind": "navigate", "to": "/tenant/domains"}}}
        ]},
        {"kind": "TabPanel", "props": {"value": "contacts"}, "children": [
          {"kind": "Link", "props": {"children": "Manage contacts \u2192"}, "actions": {"onPress": {"kind": "navigate", "to": "/tenant/contacts"}}}
        ]},
        {"kind": "TabPanel", "props": {"value": "notifications"}, "children": [
          {"kind": "Widget", "widget": "settings.setting-field-renderer.batch", "props": {"groupExpr": "'workspace_notifications'"}}
        ]},
        {"kind": "TabPanel", "props": {"value": "privacy"}, "children": [
          {"kind": "Widget", "widget": "settings.setting-field-renderer.batch", "props": {"groupExpr": "'workspace_privacy'"}}
        ]},
        {"kind": "TabPanel", "props": {"value": "danger"}, "children": [
          {"kind": "Card", "props": {"className": "p-6 border-danger"}, "children": [
            {"kind": "Text", "props": {"as": "h3", "className": "text-lg font-semibold text-danger mb-2", "children": "Archive workspace"}},
            {"kind": "Text", "props": {"className": "text-sm text-muted mb-4", "children": "Marks the workspace archived and schedules hard-delete after 30 days. Data can be restored via support during the retention window."}},
            {"kind": "Button", "props": {"variant": "danger", "size": "md", "children": "Archive workspace\u2026"}, "actions": {"onPress": {"kind": "http.post", "urlExpr": "'/api/v1/tenants/' + tenant.id + '/archive'", "confirm": {"title": "Archive this workspace?", "description": "Requires typing the workspace slug to confirm.", "confirmationInputMatches": "tenant.slug"}, "onSuccess": {"kind": "navigate", "to": "/"}}}}
          ]}
        ]}
      ]}
    ]}
  ]
}
