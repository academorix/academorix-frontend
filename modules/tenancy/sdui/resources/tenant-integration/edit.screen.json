{
  "id": "tenancy.resources.tenant-integration.edit",
  "title": "Configure integration",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/integrations/{id}/edit",
  "host": "tenant",
  "audience": "authenticated",
  "resource": {"module": "tenancy", "entity": "tenant-integration", "action": "edit"},
  "requiresPermission": "tenants.manage_integrations",
  "requiresFeature": "tenancy.integrations-v2",
  "params": [{"name": "id", "type": "string", "in": "path", "required": true}],
  "dataSources": [
    {"name": "integration", "kind": "http.get", "urlExpr": "'/api/v1/tenant/integrations/' + params.id", "unwrap": "data"}
  ],
  "nodes": [
    {"id": "root", "kind": "View", "props": {"className": "flex flex-col gap-6 p-6 max-w-2xl mx-auto"}, "children": [
      {"kind": "Link", "props": {"leadingIcon": "arrow-left", "children": "Back to integrations"}, "actions": {"onPress": {"kind": "navigate", "to": "/tenant/integrations"}}},
      {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold"}, "bindings": {"children": {"$expr": "'Configure ' + integration.name"}}},
      {"kind": "Form", "props": {"submitUrlExpr": "'/api/v1/tenant/integrations/' + params.id", "submitMethod": "PATCH", "onSuccess": [{"kind": "toast.success", "message": "Saved"}, {"kind": "data.refresh", "source": "integration"}]}, "bindings": {"initialValues": {"$ref": "integration"}}, "children": [
        {"kind": "TextField", "props": {"label": "Name", "name": "name"}, "bindings": {"defaultValue": {"$ref": "integration.name"}}},
        {"kind": "Switch", "props": {"label": "Active", "name": "is_active", "description": "When off, provider is not consulted at sign-in / sync."}, "bindings": {"defaultValue": {"$ref": "integration.is_active"}}},
        {"kind": "Text", "props": {"as": "h2", "className": "text-sm font-semibold text-muted uppercase tracking-wide mt-4", "children": "Provider configuration"}},
        {"kind": "TextField", "props": {"label": "Metadata URL", "name": "data.metadata_url", "type": "url", "description": "SAML/OIDC IdP metadata URL."}, "bindings": {"defaultValue": {"$expr": "integration.data?.metadata_url"}}},
        {"kind": "TextArea", "props": {"label": "Metadata XML", "name": "data.metadata_xml", "rows": 6, "description": "Alternative: paste the metadata XML directly."}, "bindings": {"defaultValue": {"$expr": "integration.data?.metadata_xml"}}},
        {"kind": "TextField", "props": {"label": "Client ID (OIDC)", "name": "data.client_id"}, "bindings": {"defaultValue": {"$expr": "integration.data?.client_id"}}},
        {"kind": "TextField", "props": {"label": "Client secret (OIDC)", "name": "data.client_secret", "type": "password"}, "bindings": {"defaultValue": {"$expr": "integration.data?.client_secret"}}},
        {"kind": "TextField", "props": {"label": "SCIM bearer token", "name": "data.scim_token", "type": "password"}, "bindings": {"defaultValue": {"$expr": "integration.data?.scim_token"}}},
        {"kind": "View", "props": {"className": "flex items-center gap-2 mt-4"}, "children": [
          {"kind": "Button", "props": {"variant": "primary", "size": "md", "type": "submit", "children": "Save"}},
          {"kind": "Button", "props": {"variant": "outline", "size": "md", "children": "Test sync"}, "actions": {"onPress": {"kind": "http.post", "urlExpr": "'/api/v1/tenant/integrations/' + params.id + '/test-sync'", "onSuccess": {"kind": "toast.success", "message": "Test dispatched"}}}}
        ]}
      ]}
    ]}
  ]
}
