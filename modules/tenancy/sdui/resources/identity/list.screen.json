{
  "id": "tenancy.resources.identity.list",
  "title": "Identities",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/platform/identities",
  "host": "central_admin",
  "audience": "authenticated",
  "resource": {"module": "tenancy", "entity": "identity", "action": "list"},
  "requiresPermission": "platform.identities.viewAny",
  "description": "Cross-tenant person records. Read-only from this module \u2014 lifecycle owned by user + auth modules.",
  "dataSources": [
    {"name": "identities", "kind": "http.get", "url": "/api/v1/identities", "unwrap": "data", "paginated": true, "queryParamsFromState": ["filter[application_id]", "filter[email]", "sort", "page"]}
  ],
  "nodes": [
    {"id": "root", "kind": "View", "props": {"className": "flex flex-col gap-4 p-6"}, "children": [
      {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold", "children": "Identities"}},
      {"kind": "Text", "props": {"className": "text-sm text-muted", "children": "One Identity per email per Application. A single Identity can link to many Users across tenants."}},
      {"kind": "TextField", "props": {"label": "Search email", "name": "filter[email]", "placeholder": "user@example.com"}, "actions": {"onChange": {"kind": "data.applyFilter", "source": "identities"}}},
      {"kind": "DataGrid", "bindings": {"items": {"$ref": "identities"}}, "columns": [
        {"id": "email", "header": "Email", "cell": {"kind": "Text", "props": {"className": "font-mono text-sm"}, "bindings": {"children": {"$ref": "row.email"}}}},
        {"id": "application", "header": "Application", "cell": {"kind": "Chip", "props": {"size": "xs", "variant": "neutral"}, "bindings": {"children": {"$expr": "row.application?.name"}}}},
        {"id": "users_count", "header": "Linked users", "cell": {"kind": "Text", "props": {"className": "text-sm"}, "bindings": {"children": {"$ref": "row.users_count"}}}},
        {"id": "created", "header": "Created", "cell": {"kind": "Text", "props": {"className": "text-sm"}, "bindings": {"children": {"$expr": "formatRelative(row.created_at)"}}}},
        {"id": "actions", "header": "", "align": "end", "cell": {"kind": "Button", "props": {"variant": "ghost", "size": "sm", "children": "View"}, "actions": {"onPress": {"kind": "navigate", "toExpr": "'/platform/identities/' + row.id"}}}}
      ]}
    ]}
  ]
}
