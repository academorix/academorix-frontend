{
  "id": "tenancy.resources.tenant-contact.edit",
  "title": "Edit contact",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/contacts/{id}/edit",
  "host": "tenant",
  "audience": "authenticated",
  "resource": {"module": "tenancy", "entity": "tenant-contact", "action": "edit"},
  "requiresPermission": "tenants.manage_contacts",
  "params": [{"name": "id", "type": "string", "in": "path", "required": true}],
  "dataSources": [
    {"name": "contact", "kind": "http.get", "urlExpr": "'/api/v1/tenant/contacts/' + params.id", "unwrap": "data"}
  ],
  "nodes": [
    {"id": "root", "kind": "View", "props": {"className": "flex flex-col gap-6 p-6 max-w-2xl mx-auto"}, "children": [
      {"kind": "Link", "props": {"leadingIcon": "arrow-left", "children": "Cancel"}, "actions": {"onPress": {"kind": "navigate", "to": "/tenant/contacts"}}},
      {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold"}, "bindings": {"children": {"$expr": "'Edit ' + contact.name"}}},
      {"kind": "Form", "props": {"submitUrlExpr": "'/api/v1/tenant/contacts/' + params.id", "submitMethod": "PATCH", "onSuccess": [{"kind": "toast.success", "message": "Saved"}, {"kind": "navigate", "to": "/tenant/contacts"}]}, "bindings": {"initialValues": {"$ref": "contact"}}, "children": [
        {"kind": "TextField", "props": {"label": "Name", "name": "name"}, "bindings": {"defaultValue": {"$ref": "contact.name"}}},
        {"kind": "TextField", "props": {"label": "Email", "name": "email", "type": "email"}, "bindings": {"defaultValue": {"$ref": "contact.email"}}},
        {"kind": "TextField", "props": {"label": "Phone", "name": "phone"}, "bindings": {"defaultValue": {"$ref": "contact.phone"}}},
        {"kind": "TextField", "props": {"label": "Title", "name": "title"}, "bindings": {"defaultValue": {"$ref": "contact.title"}}},
        {"kind": "Alert", "props": {"variant": "info"}, "bindings": {"hidden": {"$expr": "!!contact.verified_at"}, "children": "Contact is unverified. Verification email was sent on create."}},
        {"kind": "View", "props": {"className": "flex items-center gap-2"}, "children": [
          {"kind": "Button", "props": {"variant": "primary", "size": "md", "type": "submit", "children": "Save"}},
          {"kind": "Button", "props": {"variant": "outline", "size": "md", "children": "Resend verification"}, "bindings": {"hidden": {"$expr": "!!contact.verified_at"}}, "actions": {"onPress": {"kind": "http.post", "urlExpr": "'/api/v1/tenant/contacts/' + params.id + '/resend-verification'", "onSuccess": {"kind": "toast.success", "message": "Verification email sent"}}}}
        ]}
      ]}
    ]}
  ]
}
