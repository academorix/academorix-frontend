{
  "id": "tenancy.resources.branding.edit",
  "title": "Edit branding",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/brandings/{id}/edit",
  "host": "tenant",
  "audience": "authenticated",
  "resource": {"module": "tenancy", "entity": "branding", "action": "edit"},
  "requiresPermission": "tenants.manage_branding",
  "params": [{"name": "id", "type": "string", "in": "path", "required": true}],
  "dataSources": [],
  "nodes": [
    {"id": "root", "kind": "View", "props": {"className": "flex flex-col gap-6 p-6 max-w-5xl mx-auto"}, "children": [
      {"kind": "Link", "props": {"leadingIcon": "arrow-left", "children": "Back to profiles"}, "actions": {"onPress": {"kind": "navigate", "to": "/tenant/brandings"}}},
      {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold", "children": "Edit branding profile"}},
      {"kind": "Widget", "widget": "tenancy.forms.tenant-branding", "props": {"brandingIdExpr": "params.id", "submitUrlExpr": "'/api/v1/tenant/brandings/' + params.id", "submitMethod": "PATCH", "onSuccess": [{"kind": "toast.success", "message": "Branding saved"}, {"kind": "navigate", "to": "/tenant/brandings"}]}}
    ]}
  ]
}
