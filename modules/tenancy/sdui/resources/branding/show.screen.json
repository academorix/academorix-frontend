{
  "id": "tenancy.resources.branding.show",
  "title": "Branding profile",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/brandings/{id}",
  "host": "tenant",
  "audience": "authenticated",
  "resource": {"module": "tenancy", "entity": "branding", "action": "show"},
  "requiresPermission": "tenants.manage_branding",
  "params": [{"name": "id", "type": "string", "in": "path", "required": true}],
  "dataSources": [
    {"name": "branding", "kind": "http.get", "urlExpr": "'/api/v1/tenant/brandings/' + params.id", "unwrap": "data"}
  ],
  "nodes": [
    {"id": "root", "kind": "View", "props": {"className": "flex flex-col gap-6 p-6 max-w-4xl mx-auto"}, "children": [
      {"kind": "Link", "props": {"leadingIcon": "arrow-left", "children": "Back to profiles"}, "actions": {"onPress": {"kind": "navigate", "to": "/tenant/brandings"}}},
      {"kind": "View", "props": {"className": "flex items-start justify-between"}, "children": [
        {"kind": "View", "props": {"className": "flex items-center gap-3"}, "children": [
          {"kind": "View", "props": {"className": "size-12 rounded"}, "bindings": {"style": {"$expr": "{ backgroundColor: branding.primary_color }"}}},
          {"kind": "View", "children": [
            {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold"}, "bindings": {"children": {"$ref": "branding.name"}}},
            {"kind": "Chip", "props": {"size": "xs", "variant": "info"}, "bindings": {"hidden": {"$expr": "!branding.is_primary"}, "children": "Primary"}}
          ]}
        ]},
        {"kind": "Button", "props": {"variant": "primary", "size": "sm", "leadingIcon": "pencil", "children": "Edit"}, "actions": {"onPress": {"kind": "navigate", "toExpr": "'/tenant/brandings/' + params.id + '/edit'"}}}
      ]},
      {"kind": "Card", "props": {"className": "p-6"}, "bindings": {"style": {"$expr": "{ backgroundColor: branding.background_color, color: branding.foreground_color }"}}, "children": [
        {"kind": "Text", "props": {"as": "h2", "className": "text-lg font-semibold mb-3", "children": "Preview"}},
        {"kind": "Button", "props": {"size": "md", "className": "mr-2"}, "bindings": {"style": {"$expr": "{ backgroundColor: branding.primary_color }"}}, "children": {"kind": "Text", "props": {"children": "Primary action"}}},
        {"kind": "Link", "props": {"className": "text-sm"}, "bindings": {"style": {"$expr": "{ color: branding.accent_color }"}}, "children": {"kind": "Text", "props": {"children": "Accent link"}}}
      ]}
    ]}
  ]
}
