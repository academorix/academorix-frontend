{
  "id": "tenancy.screens.workspace-picker",
  "title": "Choose your workspace",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/",
  "host": "central",
  "audience": "authenticated",
  "requiresPermission": null,
  "dataSources": [
    {"name": "workspaces", "kind": "http.get", "url": "/api/v1/me/workspaces", "unwrap": "data", "cache": {"ttlSeconds": 30}},
    {"name": "identity", "kind": "http.get", "url": "/api/auth/me", "unwrap": "data", "cache": {"ttlSeconds": 60}}
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": {"className": "min-h-screen flex items-center justify-center p-6 bg-content1"},
      "children": [
        {
          "id": "shell",
          "kind": "View",
          "props": {"className": "w-full max-w-lg flex flex-col gap-6"},
          "children": [
            {"kind": "View", "props": {"className": "flex flex-col items-center gap-2"}, "children": [
              {"kind": "Image", "props": {"src": "/brand/mark.svg", "alt": "Academorix", "className": "size-10"}},
              {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold", "children": "Choose your workspace"}},
              {"kind": "Text", "props": {"className": "text-sm text-muted text-center"}, "bindings": {"children": {"$expr": "'Signed in as ' + (identity.email || 'user')"}}}
            ]},
            {"kind": "List", "props": {"className": "flex flex-col gap-2", "emptyState": {"title": "No workspaces yet", "description": "Create your first workspace to get started.", "icon": "building-office-2"}}, "bindings": {"items": {"$ref": "workspaces"}, "isLoading": {"$ref": "workspaces.isLoading"}}, "itemRenderer": {
              "kind": "Button",
              "props": {"variant": "outline", "className": "flex items-center gap-3 p-4 h-auto w-full text-left justify-start"},
              "actions": {"onPress": {"kind": "navigateExpr", "expr": "row.public_url", "external": true}},
              "children": [
                {"kind": "Avatar", "props": {"size": "md"}, "bindings": {"src": {"$expr": "row.branding?.logo_url"}, "fallback": {"$expr": "(row.name || 'W')[0]"}}},
                {"kind": "View", "props": {"className": "flex flex-col flex-1 min-w-0"}, "children": [
                  {"kind": "Text", "props": {"className": "font-medium truncate"}, "bindings": {"children": {"$ref": "row.name"}}},
                  {"kind": "Text", "props": {"className": "text-xs text-muted truncate"}, "bindings": {"children": {"$expr": "row.slug + '.academorix.app'"}}}
                ]},
                {"kind": "Chip", "props": {"size": "xs", "variant": "neutral"}, "bindings": {"hidden": {"$expr": "!row.role"}, "children": {"$ref": "row.role"}}},
                {"kind": "Icon", "props": {"icon": "chevron-right", "className": "size-4 text-muted"}}
              ]
            }},
            {"kind": "Separator", "props": {"className": "my-2"}},
            {"kind": "Button", "props": {"variant": "primary", "size": "md", "leadingIcon": "plus", "children": "Create new workspace"}, "actions": {"onPress": {"kind": "navigate", "to": "/register"}}},
            {"kind": "View", "props": {"className": "flex items-center justify-center gap-4 text-xs text-muted mt-4"}, "children": [
              {"kind": "Link", "props": {"size": "xs", "children": "Can't find your workspace?"}, "actions": {"onPress": {"kind": "navigate", "to": "/find-workspace"}}},
              {"kind": "Separator", "props": {"orientation": "vertical", "className": "h-4"}},
              {"kind": "Link", "props": {"size": "xs", "children": "Sign out"}, "actions": {"onPress": {"kind": "http.post", "url": "/api/auth/logout", "onSuccess": {"kind": "reload"}}}}
            ]}
          ]
        }
      ]
    }
  ]
}
