{
  "id": "academorix://modules/tenancy/relations",
  "$version": 1,
  "title": "tenancy — cross-module relations",
  "description": "All Eloquent relations rooted at models owned by this module. Cross-module edges declare `target.module` as a lowercase folder name; CI resolves it to the target's `schemas/*.schema.json` and validates the FK columns match. Reverse relations reconcile: if X has HasMany Y here, Y's schema must declare the corresponding BelongsTo FK. Cross-tenant FKs are FORBIDDEN — every FK is either same-tenant, application-scoped, or crosses no tenancy boundary at all.",
  "anchors": [
    {
      "model": {
        "name": "Application",
        "class": "Academorix\\Tenancy\\Models\\Application",
        "schemaRef": "academorix://modules/tenancy/schemas/application"
      },
      "relations": [
        {
          "name": "tenants",
          "type": "HasMany",
          "target": {
            "module": "tenancy",
            "model": "Tenant",
            "class": "Academorix\\Tenancy\\Models\\Tenant"
          },
          "foreignKey": "application_id",
          "description": "Every tenant belongs to exactly one Application."
        },
        {
          "name": "identities",
          "type": "HasMany",
          "target": {
            "module": "tenancy",
            "model": "Identity",
            "class": "Academorix\\Tenancy\\Models\\Identity"
          },
          "foreignKey": "application_id",
          "description": "Cross-tenant person records live at the Application layer."
        },
        {
          "name": "domains",
          "type": "HasMany",
          "target": {
            "module": "tenancy",
            "model": "Domain",
            "class": "Academorix\\Tenancy\\Models\\Domain"
          },
          "foreignKey": "application_id",
          "description": "Domains carry application_id so central-host lookup can resolve them before a tenant is known."
        }
      ]
    },
    {
      "model": {
        "name": "Tenant",
        "class": "Academorix\\Tenancy\\Models\\Tenant",
        "schemaRef": "academorix://modules/tenancy/schemas/tenant"
      },
      "relations": [
        {
          "name": "application",
          "type": "BelongsTo",
          "target": {
            "module": "tenancy",
            "model": "Application",
            "class": "Academorix\\Tenancy\\Models\\Application"
          },
          "foreignKey": "application_id",
          "ownerKey": "id",
          "description": "Owned via BelongsToApplication trait."
        },
        {
          "name": "primaryBranding",
          "type": "BelongsTo",
          "target": {
            "module": "tenancy",
            "model": "Branding",
            "class": "Academorix\\Tenancy\\Models\\Branding"
          },
          "foreignKey": "primary_branding_id",
          "ownerKey": "id",
          "description": "Nullable. Materialises the active Branding row and drives the denormalised `branding` JSONB."
        },
        {
          "name": "brandings",
          "type": "HasMany",
          "target": {
            "module": "tenancy",
            "model": "Branding",
            "class": "Academorix\\Tenancy\\Models\\Branding"
          },
          "foreignKey": "tenant_id"
        },
        {
          "name": "domains",
          "type": "HasMany",
          "target": {
            "module": "tenancy",
            "model": "Domain",
            "class": "Academorix\\Tenancy\\Models\\Domain"
          },
          "foreignKey": "tenant_id",
          "cascade": {
            "onDelete": "cascade",
            "description": "Archiving a Tenant archives its Domains via the cascade FK on the domains table."
          }
        },
        {
          "name": "contacts",
          "type": "HasMany",
          "target": {
            "module": "tenancy",
            "model": "TenantContact",
            "class": "Academorix\\Tenancy\\Models\\TenantContact"
          },
          "foreignKey": "tenant_id"
        },
        {
          "name": "integrations",
          "type": "HasMany",
          "target": {
            "module": "tenancy",
            "model": "TenantIntegration",
            "class": "Academorix\\Tenancy\\Models\\TenantIntegration"
          },
          "foreignKey": "tenant_id"
        },
        {
          "name": "organizations",
          "type": "HasMany",
          "target": {
            "module": "organization",
            "model": "Organization",
            "class": "Academorix\\Organization\\Models\\Organization"
          },
          "foreignKey": "tenant_id",
          "cascade": {
            "onDelete": "cascade",
            "description": "Archiving a Tenant archives every Organization under it (soft-delete cascade)."
          },
          "description": "Every tenant carries at least one Organization (auto-provisioned with is_default=true). Multi-brand tenants add more."
        },
        {
          "name": "regions",
          "type": "HasMany",
          "target": {
            "module": "region",
            "model": "Region",
            "class": "Academorix\\Region\\Models\\Region"
          },
          "foreignKey": "tenant_id",
          "description": "Every tenant provisions one default Region on create."
        },
        {
          "name": "branches",
          "type": "HasMany",
          "target": {
            "module": "branch",
            "model": "Branch",
            "class": "Academorix\\Branch\\Models\\Branch"
          },
          "foreignKey": "tenant_id",
          "description": "Direct shortcut; also reachable via organizations.branches and regions.branches."
        },
        {
          "name": "users",
          "type": "HasMany",
          "target": {
            "module": "user",
            "model": "User",
            "class": "Academorix\\User\\Models\\User"
          },
          "foreignKey": "tenant_id",
          "description": "Every user belongs to exactly one tenant. A person invited to two workspaces has one User row per tenant, all pointing at the same application-scoped Identity."
        },
        {
          "name": "roles",
          "type": "HasMany",
          "target": {
            "module": "access",
            "model": "Role",
            "class": "Academorix\\Access\\Models\\Role"
          },
          "foreignKey": "tenant_id",
          "description": "Tenant-scoped roles on the sanctum guard. Platform roles (platform_admin guard) have tenant_id = null and are NOT part of this relation."
        },
        {
          "name": "subscription",
          "type": "HasOne",
          "target": {
            "module": "subscription",
            "model": "TenantSubscription",
            "class": "Academorix\\Subscription\\Models\\TenantSubscription"
          },
          "foreignKey": "tenant_id",
          "description": "Exactly one subscription per (application_id, tenant_id) tuple."
        },
        {
          "name": "entitlementLicenses",
          "type": "HasMany",
          "target": {
            "module": "entitlements",
            "model": "EntitlementLicense",
            "class": "Academorix\\Entitlements\\Models\\EntitlementLicense"
          },
          "foreignKey": "tenant_id",
          "description": "Full entitlement matrix for this tenant. quota_summary on /api/auth/me returns the top 3-5; the whole set is behind GET /api/v1/entitlements."
        },
        {
          "name": "audits",
          "type": "HasMany",
          "target": {
            "module": "audit",
            "model": "Audit",
            "class": "Academorix\\Audit\\Models\\Audit"
          },
          "foreignKey": "tenant_id",
          "description": "Every mutation on any tenant-scoped model writes here. Depends on the Audit-adds-tenant_id migration (gap register)."
        }
      ],
      "morphs": [
        {
          "name": "scopeNode",
          "type": "MorphOne",
          "target": {
            "module": "scope",
            "model": "ScopeNode",
            "class": "Academorix\\Scope\\Models\\ScopeNode"
          },
          "morphType": "entity_type",
          "morphId": "entity_id",
          "description": "Every Tenant projects into the scope substrate as a root node."
        }
      ]
    },
    {
      "model": {
        "name": "Domain",
        "class": "Academorix\\Tenancy\\Models\\Domain",
        "schemaRef": "academorix://modules/tenancy/schemas/domain"
      },
      "relations": [
        {
          "name": "application",
          "type": "BelongsTo",
          "target": {"module": "tenancy", "model": "Application", "class": "Academorix\\Tenancy\\Models\\Application"},
          "foreignKey": "application_id",
          "ownerKey": "id"
        },
        {
          "name": "tenant",
          "type": "BelongsTo",
          "target": {"module": "tenancy", "model": "Tenant", "class": "Academorix\\Tenancy\\Models\\Tenant"},
          "foreignKey": "tenant_id",
          "ownerKey": "id"
        },
        {
          "name": "records",
          "type": "HasMany",
          "target": {"module": "tenancy", "model": "DomainRecord", "class": "Academorix\\Tenancy\\Models\\DomainRecord"},
          "foreignKey": "domain_id"
        },
        {
          "name": "brandings",
          "type": "HasMany",
          "target": {"module": "tenancy", "model": "Branding", "class": "Academorix\\Tenancy\\Models\\Branding"},
          "foreignKey": "domain_id",
          "description": "Per-domain branding profiles."
        }
      ]
    },
    {
      "model": {
        "name": "DomainRecord",
        "class": "Academorix\\Tenancy\\Models\\DomainRecord",
        "schemaRef": "academorix://modules/tenancy/schemas/domain-record"
      },
      "relations": [
        {
          "name": "tenant",
          "type": "BelongsTo",
          "target": {"module": "tenancy", "model": "Tenant", "class": "Academorix\\Tenancy\\Models\\Tenant"},
          "foreignKey": "tenant_id"
        },
        {
          "name": "domain",
          "type": "BelongsTo",
          "target": {"module": "tenancy", "model": "Domain", "class": "Academorix\\Tenancy\\Models\\Domain"},
          "foreignKey": "domain_id"
        }
      ]
    },
    {
      "model": {
        "name": "Branding",
        "class": "Academorix\\Tenancy\\Models\\Branding",
        "schemaRef": "academorix://modules/tenancy/schemas/branding"
      },
      "relations": [
        {
          "name": "tenant",
          "type": "BelongsTo",
          "target": {"module": "tenancy", "model": "Tenant", "class": "Academorix\\Tenancy\\Models\\Tenant"},
          "foreignKey": "tenant_id"
        },
        {
          "name": "domain",
          "type": "BelongsTo",
          "target": {"module": "tenancy", "model": "Domain", "class": "Academorix\\Tenancy\\Models\\Domain"},
          "foreignKey": "domain_id",
          "description": "Nullable — null means tenant-wide profile."
        }
      ]
    },
    {
      "model": {
        "name": "Identity",
        "class": "Academorix\\Tenancy\\Models\\Identity",
        "schemaRef": "academorix://modules/tenancy/schemas/identity"
      },
      "relations": [
        {
          "name": "application",
          "type": "BelongsTo",
          "target": {"module": "tenancy", "model": "Application", "class": "Academorix\\Tenancy\\Models\\Application"},
          "foreignKey": "application_id"
        },
        {
          "name": "users",
          "type": "HasMany",
          "target": {"module": "user", "model": "User", "class": "Academorix\\User\\Models\\User"},
          "foreignKey": "identity_id",
          "description": "One Identity → many Users across tenants under the same Application. The User model in the `user` module must declare the identity_id FK column."
        }
      ]
    },
    {
      "model": {
        "name": "TenantContact",
        "class": "Academorix\\Tenancy\\Models\\TenantContact",
        "schemaRef": "academorix://modules/tenancy/schemas/tenant-contact"
      },
      "relations": [
        {
          "name": "tenant",
          "type": "BelongsTo",
          "target": {"module": "tenancy", "model": "Tenant", "class": "Academorix\\Tenancy\\Models\\Tenant"},
          "foreignKey": "tenant_id"
        }
      ]
    },
    {
      "model": {
        "name": "TenantIntegration",
        "class": "Academorix\\Tenancy\\Models\\TenantIntegration",
        "schemaRef": "academorix://modules/tenancy/schemas/tenant-integration"
      },
      "relations": [
        {
          "name": "tenant",
          "type": "BelongsTo",
          "target": {"module": "tenancy", "model": "Tenant", "class": "Academorix\\Tenancy\\Models\\Tenant"},
          "foreignKey": "tenant_id"
        }
      ]
    }
  ],
  "notes": [
    "Cross-tenant FKs are FORBIDDEN. Every FK on every relation above is same-tenant (BelongsToTenant), application-scoped (BelongsToApplication), or crosses no tenancy boundary at all (scopeNode morph).",
    "BusinessType is a config catalogue, not an Eloquent model — no relations declared here. Referenced by Tenant.business_type as a string enum.",
    "Cascade semantics: archiving a Tenant soft-deletes its Domain / Branding / Contact / Integration rows via the cascade FKs on those tables. Downstream domain modules (Organization, Branch, etc.) wire their own on-delete behaviour."
  ]
}
