{
  "id": "academorix://modules/tenancy/schemas/identity",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "Identity",
  "description": "Cross-tenant person record. Application-scoped (BelongsToApplication, NOT BelongsToTenant) so a single Identity can back many `User` rows across different Tenants under the same Application. Solves the 'invited to two workspaces with the same email' problem. Every tenant-scoped `User` (owned by the `user` module) references this via `user.identity_id`.",
  "type": "object",
  "x-module": "tenancy",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "identities",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "ident_",
    "incrementing": false,
    "model": "Academorix\\Tenancy\\Models\\Identity",
    "interface": "Academorix\\Tenancy\\Contracts\\Data\\IdentityInterface",
    "implements": ["Academorix\\Tenancy\\Contracts\\Data\\IdentityInterface"],
    "traits": [
      "HasFactory",
      "HasUlids",
      "BelongsToApplication",
      "HasMetadata",
      "HasUserstamps",
      "HasAuditable",
      "SoftDeletes"
    ],
    "casts": {
      "email_verified_at": "datetime",
      "last_seen_at": "datetime",
      "metadata": "array"
    },
    "appends": ["display_name_or_email"],
    "observers": [],
    "hidden": ["metadata"],
    "guarded": []
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": {
        "type": "string",
        "length": 64,
        "primary": true,
        "description": "Prefixed ULID: `ident_<26 chars>`."
      },
      "application_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": {
          "table": "applications",
          "column": "id",
          "onUpdate": "cascade",
          "onDelete": "restrict"
        }
      },
      "email": {
        "type": "string",
        "length": 320,
        "nullable": false,
        "description": "Canonical email address. Unique per application (RFC 5321 max 320 chars)."
      },
      "email_verified_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "First-verified timestamp. Not re-issued if the email is changed on a per-tenant User."
      },
      "given_name": { "type": "string", "length": 100, "nullable": true },
      "family_name": { "type": "string", "length": 100, "nullable": true },
      "display_name": {
        "type": "string",
        "length": 200,
        "nullable": true,
        "description": "Explicit display name override. If null, User surfaces fall back to `given_name family_name` or `email`."
      },
      "avatar_url": { "type": "string", "length": 2048, "nullable": true },
      "locale": {
        "type": "string",
        "length": 10,
        "nullable": true,
        "description": "BCP-47 locale preference. Null = fall back to tenant / application default."
      },
      "timezone": {
        "type": "string",
        "length": 64,
        "nullable": true
      },
      "last_seen_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "Any successful auth against any of this Identity's User rows updates this timestamp."
      },
      "metadata": {
        "type": "jsonb",
        "nullable": true,
        "description": "Free-form platform notes."
      },
      "created_by": { "type": "uuid", "nullable": true },
      "updated_by": { "type": "uuid", "nullable": true },
      "deleted_by": { "type": "uuid", "nullable": true },
      "deleted_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "SoftDeletes. GDPR Art. 17 right-to-erasure hard-deletes via a job after the retention window."
      },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["application_id", "email"],
        "unique": true,
        "name": "identities_application_email_unique"
      },
      {
        "columns": ["email"],
        "unique": false,
        "name": "identities_email_index",
        "description": "Non-unique across applications (dev + prod may share the same identity email)."
      },
      {
        "columns": ["last_seen_at"],
        "unique": false,
        "name": "identities_last_seen_at_index"
      }
    ]
  },
  "required": ["id", "application_id", "email", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string", "pattern": "^ident_[0-9A-HJKMNP-TV-Z]{26}$" },
    "application_id": { "type": "string", "pattern": "^app_[0-9A-HJKMNP-TV-Z]{26}$" },
    "email": { "type": "string", "format": "email", "maxLength": 320 },
    "email_verified_at": { "type": ["string", "null"], "format": "date-time" },
    "given_name": { "type": ["string", "null"], "maxLength": 100 },
    "family_name": { "type": ["string", "null"], "maxLength": 100 },
    "display_name": { "type": ["string", "null"], "maxLength": 200 },
    "display_name_or_email": {
      "type": "string",
      "description": "Computed. Prefers display_name, then given+family, then email."
    },
    "avatar_url": { "type": ["string", "null"], "format": "uri" },
    "locale": { "type": ["string", "null"], "pattern": "^[a-z]{2,3}(-[A-Z]{2})?$" },
    "timezone": { "type": ["string", "null"] },
    "last_seen_at": { "type": ["string", "null"], "format": "date-time" },
    "metadata": { "type": ["object", "null"], "additionalProperties": true },
    "created_by": { "type": ["string", "null"], "format": "uuid" },
    "updated_by": { "type": ["string", "null"], "format": "uuid" },
    "deleted_by": { "type": ["string", "null"], "format": "uuid" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "deleted_at": { "type": ["string", "null"], "format": "date-time" }
  },
  "additionalProperties": false,
  "x-wire": {
    "envelope": "spatie-data",
    "wrap": "data",
    "mapper": "SnakeCaseMapper",
    "hidden": ["metadata", "created_by", "updated_by", "deleted_by"],
    "computed": ["display_name_or_email"]
  }
}
