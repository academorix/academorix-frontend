{
  "id": "academorix://modules/tenancy/schemas/tenant-integration",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "TenantIntegration",
  "description": "External identity / directory / HRIS / LMS integration configured for a Tenant. Reserved in v1 (no controllers ship), fully filled in v2 when SSO + SCIM go GA. Landed now to avoid a one-way-door migration when downstream modules start assuming the linkage exists. Config payload is encrypted at rest via a KMS reference — the `config` column stores a pointer, not the secret.",
  "type": "object",
  "x-module": "tenancy",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "tenant_integrations",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "intg_",
    "incrementing": false,
    "model": "Academorix\\Tenancy\\Models\\TenantIntegration",
    "interface": "Academorix\\Tenancy\\Contracts\\Data\\TenantIntegrationInterface",
    "implements": ["Academorix\\Tenancy\\Contracts\\Data\\TenantIntegrationInterface"],
    "traits": [
      "HasFactory",
      "HasUlids",
      "BelongsToTenant",
      "HasMetadata",
      "HasUserstamps",
      "HasAuditable",
      "SoftDeletes"
    ],
    "casts": {
      "config": "IntegrationConfig",
      "is_active": "boolean",
      "last_sync_at": "datetime",
      "next_sync_at": "datetime",
      "metadata": "array"
    },
    "appends": [],
    "observers": ["TenantIntegrationObserver"],
    "hidden": ["config", "metadata"],
    "guarded": []
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 64, "primary": true },
      "tenant_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": {
          "table": "tenants",
          "column": "id",
          "onUpdate": "cascade",
          "onDelete": "cascade"
        }
      },
      "kind": {
        "type": "string",
        "length": 16,
        "nullable": false,
        "description": "Enum: `sso_saml`, `sso_oidc`, `scim`, `hris`, `lms`, `webhook`, `sms`, `email`."
      },
      "provider": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "description": "Provider key: `okta`, `azure_ad`, `google_workspace`, `onelogin`, `workday`, `rippling`, `bamboohr`, `canvas`, `powerschool`, `custom_saml`, `custom_oidc`."
      },
      "name": {
        "type": "string",
        "length": 200,
        "nullable": false,
        "description": "Human label ('Okta production', 'Workday HRIS')."
      },
      "config": {
        "type": "jsonb",
        "nullable": false,
        "description": "Encrypted-at-rest configuration blob. Contains a `kms_key_id` pointer + non-secret metadata. Never accepts secrets in plaintext at the API layer — controllers write via IntegrationConfigCast which encrypts on save."
      },
      "is_active": {
        "type": "boolean",
        "nullable": false,
        "default": false
      },
      "last_sync_at": { "type": "timestamptz", "nullable": true },
      "last_sync_status": {
        "type": "string",
        "length": 16,
        "nullable": false,
        "default": "unknown",
        "description": "Enum: `unknown`, `success`, `partial`, `failed`."
      },
      "last_sync_error": { "type": "text", "nullable": true },
      "next_sync_at": { "type": "timestamptz", "nullable": true },
      "sync_cursor": {
        "type": "text",
        "nullable": true,
        "description": "Provider-specific pagination cursor for incremental sync (e.g. SCIM lastChange, Workday transactionId)."
      },
      "metadata": {
        "type": "jsonb",
        "nullable": true,
        "description": "Free-form NON-SECRET platform notes on this integration — pilot flags, tenant-side context. From HasMetadata. Distinct from `config` which holds the encrypted credential material."
      },
      "created_by": { "type": "uuid", "nullable": true },
      "updated_by": { "type": "uuid", "nullable": true },
      "deleted_by": { "type": "uuid", "nullable": true },
      "deleted_at": { "type": "timestamptz", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "kind", "is_active"],
        "unique": true,
        "name": "tenant_integrations_active_unique",
        "predicate": "is_active = TRUE AND deleted_at IS NULL"
      },
      {
        "columns": ["tenant_id", "kind"],
        "unique": false,
        "name": "tenant_integrations_tenant_kind_index"
      },
      {
        "columns": ["next_sync_at"],
        "unique": false,
        "name": "tenant_integrations_next_sync_at_index",
        "predicate": "is_active = TRUE"
      }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "kind",
    "provider",
    "name",
    "config",
    "is_active",
    "last_sync_status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^intg_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": "string", "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "kind": {
      "type": "string",
      "enum": ["sso_saml", "sso_oidc", "scim", "hris", "lms", "webhook", "sms", "email"]
    },
    "provider": { "type": "string", "minLength": 1, "maxLength": 64 },
    "name": { "type": "string", "minLength": 1, "maxLength": 200 },
    "config": {
      "type": "object",
      "description": "Redacted on read; only the non-secret metadata subset surfaces. Full config never leaves the server.",
      "additionalProperties": true
    },
    "is_active": { "type": "boolean", "default": false },
    "last_sync_at": { "type": ["string", "null"], "format": "date-time" },
    "last_sync_status": {
      "type": "string",
      "enum": ["unknown", "success", "partial", "failed"]
    },
    "last_sync_error": { "type": ["string", "null"] },
    "next_sync_at": { "type": ["string", "null"], "format": "date-time" },
    "sync_cursor": { "type": ["string", "null"] },
    "metadata": { "type": ["object", "null"], "additionalProperties": true },
    "created_by": { "type": ["string", "null"], "format": "uuid" },
    "updated_by": { "type": ["string", "null"], "format": "uuid" },
    "deleted_by": { "type": ["string", "null"], "format": "uuid" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "deleted_at": { "type": ["string", "null"], "format": "date-time" }
  },
  "additionalProperties": false,
  "x-wire": {
    "envelope": "spatie-data",
    "wrap": "data",
    "mapper": "SnakeCaseMapper",
    "hidden": ["config", "metadata", "sync_cursor", "created_by", "updated_by", "deleted_by"],
    "computed": []
  }
}
