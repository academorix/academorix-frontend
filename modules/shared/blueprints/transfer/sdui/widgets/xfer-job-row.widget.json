{
  "id": "transfer.xfer-job-row",
  "title": "Xfer job row",
  "version": 1,
  "kind": "SduiWidget",
  "description": "One row in a jobs list: kind + entity + status chip + counters + relative timestamp + row actions (view, cancel, download). Consumed by the jobs list screen and dashboard 'Recent transfers' panel.",
  "props": {
    "job": { "type": "object", "description": "XferJob DTO." },
    "showCauser": {
      "type": "boolean",
      "default": false,
      "description": "Show initiator's display name. Enabled on tenant-wide + platform views."
    },
    "compact": { "type": "boolean", "default": false }
  },
  "dataSources": [],
  "nodes": [
    {
      "id": "row",
      "kind": "View",
      "props": {
        "className": "flex items-center gap-3 py-3 border-b border-content2 last:border-b-0"
      },
      "children": [
        {
          "kind": "Icon",
          "bindings": {
            "name": {
              "$expr": "({import:'arrow-down-tray',export:'arrow-up-tray',sample:'sparkles'})[props.job.kind]"
            },
            "className": "text-muted"
          }
        },
        {
          "kind": "View",
          "props": { "className": "flex flex-col min-w-0 flex-1" },
          "children": [
            {
              "kind": "View",
              "props": { "className": "flex items-center gap-2" },
              "children": [
                {
                  "kind": "Text",
                  "props": { "className": "text-sm font-medium truncate" },
                  "bindings": {
                    "children": {
                      "$expr": "t('transfer.entity.' + props.job.entity, {fallback: props.job.entity})"
                    }
                  }
                },
                {
                  "kind": "Widget",
                  "widget": "transfer.xfer-job-status-chip",
                  "props": { "size": "xs" },
                  "bindings": { "status": { "$ref": "props.job.status" } }
                },
                {
                  "kind": "Chip",
                  "props": { "size": "xs", "variant": "neutral" },
                  "bindings": {
                    "children": { "$ref": "props.job.format" },
                    "hidden": { "$expr": "!props.job.format" }
                  }
                }
              ]
            },
            {
              "kind": "View",
              "props": { "className": "flex items-center gap-3 mt-1 text-xs text-muted" },
              "children": [
                {
                  "kind": "Text",
                  "bindings": { "children": { "$expr": "formatRelative(props.job.created_at)" } }
                },
                {
                  "kind": "Text",
                  "bindings": {
                    "children": {
                      "$expr": "props.job.causer ? props.job.causer.display_name : ''"
                    },
                    "hidden": { "$expr": "!props.showCauser" }
                  }
                },
                {
                  "kind": "Text",
                  "bindings": {
                    "children": {
                      "$expr": "props.job.counters.total ? t('transfer.rows.summary', {total: props.job.counters.total, failed: props.job.counters.failed}) : ''"
                    }
                  }
                }
              ]
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "flex items-center gap-2" },
          "children": [
            {
              "kind": "Widget",
              "widget": "transfer.xfer-job-progress",
              "props": { "compact": true, "subscribeBroadcast": true },
              "bindings": {
                "job": { "$ref": "props.job" },
                "hidden": {
                  "$expr": "['succeeded','partially_succeeded','failed','cancelled'].includes(props.job.status)"
                }
              },
              "props_extra": { "className": "w-32" }
            },
            {
              "kind": "Menu",
              "props": {
                "trigger": {
                  "kind": "IconButton",
                  "props": { "icon": "ellipsis-vertical", "aria-label": "Row actions" }
                }
              },
              "children": [
                {
                  "kind": "MenuItem",
                  "props": { "children": { "$expr": "t('transfer.actions.view')" } },
                  "actions": {
                    "onPress": {
                      "kind": "navigateExpr",
                      "expr": "'/tenant/transfer/jobs/' + props.job.id"
                    }
                  }
                },
                {
                  "kind": "MenuItem",
                  "props": {
                    "children": { "$expr": "t('transfer.actions.download')" },
                    "hidden": { "$expr": "!props.job.has_result_artifact" }
                  },
                  "actions": {
                    "onPress": {
                      "kind": "http.get",
                      "url": { "$expr": "'/api/v1/transfer/jobs/' + props.job.id + '/download'" },
                      "responseKind": "download"
                    }
                  }
                },
                {
                  "kind": "MenuItem",
                  "props": {
                    "children": { "$expr": "t('transfer.actions.download_errors')" },
                    "hidden": { "$expr": "!props.job.has_errors_artifact" },
                    "className": "text-danger"
                  },
                  "actions": {
                    "onPress": {
                      "kind": "http.get",
                      "url": { "$expr": "'/api/v1/transfer/jobs/' + props.job.id + '/errors'" },
                      "responseKind": "download"
                    }
                  }
                },
                {
                  "kind": "MenuItem",
                  "props": {
                    "children": { "$expr": "t('transfer.actions.cancel')" },
                    "hidden": { "$expr": "!['queued','running'].includes(props.job.status)" }
                  },
                  "actions": {
                    "onPress": {
                      "kind": "http.post",
                      "url": { "$expr": "'/api/v1/transfer/jobs/' + props.job.id + '/cancel'" },
                      "confirm": {
                        "title": { "$expr": "t('transfer.confirm.cancel.title')" },
                        "message": { "$expr": "t('transfer.confirm.cancel.message')" }
                      }
                    }
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
