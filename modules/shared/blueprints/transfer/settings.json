{
  "id": "academorix://modules/transfer/settings",
  "$version": 1,
  "title": "transfer \u2014 settings",
  "description": "Two settings groups: tenant-scoped defaults (`transfer`) and per-user preferences (`transfer_user`). Discovered by the settings module at boot via #[AsSetting] on the two classes.",
  "storedIn": "settings",
  "reference": { "contract": "academorix://modules/settings/attributes" },
  "groups": [
    {
      "key": "transfer",
      "class": "Academorix\\Transfer\\Settings\\TransferSettings",
      "label": "Data transfer",
      "description": "Tenant-wide defaults for the import / export engine.",
      "icon": "arrow-path",
      "scope": "tenant",
      "public": false,
      "sortOrder": 60,
      "permission": "settings.read",
      "sections": [
        {
          "label": "Notifications",
          "description": "Default channels for job-completion notifications when the initiator hasn't set a preference.",
          "icon": "bell",
          "sortOrder": 1,
          "fields": [
            {
              "name": "default_notify_channels",
              "controlType": "checkbox-group",
              "label": "Default channels",
              "defaultValue": ["database", "broadcast"],
              "options": {
                "mail": "Email",
                "broadcast": "Real-time (in-app toast)",
                "database": "In-app inbox",
                "push": "Mobile push",
                "sms": "SMS"
              },
              "validation": ["required", "array", "min:1"],
              "sortOrder": 1
            }
          ]
        },
        {
          "label": "Import defaults",
          "description": "Fallback behaviour when a request omits the parameter.",
          "icon": "arrow-down-tray",
          "sortOrder": 2,
          "fields": [
            {
              "name": "default_mode",
              "controlType": "select",
              "label": "Default mode",
              "defaultValue": "upsert",
              "options": {
                "append": "Append (insert new only)",
                "upsert": "Upsert (insert or update)",
                "replace": "Replace (destructive)",
                "delete": "Delete matched rows"
              },
              "validation": ["required", "in:append,upsert,upsert,replace,delete"],
              "sortOrder": 1
            },
            {
              "name": "stop_on_error",
              "controlType": "switch",
              "label": "Stop on first error",
              "defaultValue": false,
              "sortOrder": 2
            },
            {
              "name": "max_errors",
              "controlType": "number",
              "label": "Max errors before halt",
              "defaultValue": 0,
              "validation": ["integer", "min:0"],
              "helpText": "0 = unlimited.",
              "sortOrder": 3
            },
            {
              "name": "auto_delete_source",
              "controlType": "switch",
              "label": "Auto-delete uploaded file after success",
              "defaultValue": true,
              "sortOrder": 4
            }
          ]
        },
        {
          "label": "Export defaults",
          "icon": "arrow-up-tray",
          "sortOrder": 3,
          "fields": [
            {
              "name": "default_format",
              "controlType": "select",
              "label": "Default format",
              "defaultValue": "xlsx",
              "options": { "csv": "CSV", "xlsx": "Excel (XLSX)", "json": "JSON", "pdf": "PDF" },
              "validation": ["required", "in:csv,xlsx,json,pdf"],
              "sortOrder": 1
            },
            {
              "name": "auto_size_xlsx",
              "controlType": "switch",
              "label": "Auto-size columns (XLSX)",
              "defaultValue": true,
              "sortOrder": 2
            }
          ]
        }
      ]
    },
    {
      "key": "transfer_user",
      "class": "Academorix\\Transfer\\Settings\\TransferUserSettings",
      "label": "Data transfer \u2014 my preferences",
      "description": "Per-user override of the tenant defaults.",
      "icon": "user-circle",
      "scope": "user",
      "public": false,
      "sortOrder": 20,
      "permission": "settings.read",
      "sections": [
        {
          "label": "My notification channels",
          "icon": "bell",
          "sortOrder": 1,
          "fields": [
            {
              "name": "notify_channels",
              "controlType": "checkbox-group",
              "label": "How I want to be notified",
              "defaultValue": null,
              "options": {
                "mail": "Email",
                "broadcast": "Real-time (in-app toast)",
                "database": "In-app inbox",
                "push": "Mobile push",
                "sms": "SMS"
              },
              "validation": ["nullable", "array", "min:1"],
              "helpText": "Empty = follow tenant default.",
              "sortOrder": 1
            }
          ]
        }
      ]
    }
  ]
}
