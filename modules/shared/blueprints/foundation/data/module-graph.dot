// Academorix module dependency graph.
//
// Nodes: every module folder under `modules/<tier>/<name>/`.
// Edges: A -> B means A depends on B (A's module.json.dependencies contains B).
//
// Tiers correspond to the deployable services in
// `.kiro/specs/platform-architecture/DECISION.md` §2.1 + §4:
//   shared/         — consumed by every service (foundation, telemetry, ...).
//   platform/       — the platform-service (tenancy + config + storage + …).
//   access/         — the access-service (RBAC vocabulary + invitations).
//   billing/        — the billing-service (subscription + entitlements).
//   notifications/  — the notifications-service (fan-out + transports + newsletter).
//   compliance/     — the compliance-service (DSAR, retention, legal hold, …).
//   products/       — product-scoped modules (geofencing, future sports/…).
//   identity/       — the identity-service (empty until identity/auth land).
//
// Regenerated by `modules/shared/foundation/scripts/validate-module-graph.py`
// when `module.json.dependencies` changes. This file is the source of truth
// for the docs surface + the diagram in `.kiro/steering/module-graph.md`.
//
// Priority ordering: lower priority boots first. Priorities in parentheses
// after the label. See `.kiro/steering/priority-ordering.md`.
//
// Render locally:
//   dot -Tsvg modules/shared/foundation/data/module-graph.dot -o module-graph.svg
//   dot -Tpng modules/shared/foundation/data/module-graph.dot -o module-graph.png

digraph AcademorixModules {
  rankdir = TB;
  compound = true;
  splines = ortho;
  concentrate = true;
  nodesep = 0.4;
  ranksep = 0.6;
  fontname = "Helvetica";

  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, margin=0.15];
  edge [fontname="Helvetica", fontsize=8, arrowsize=0.7];

  // ==========================================================================
  // Service clusters — one per deployable service (DECISION.md §4).
  // Node colours encode boot-wave rather than tier so the graph stays readable
  // when zoomed out.
  // ==========================================================================

  // ---- shared/ — consumed by every service ---------------------------------
  subgraph cluster_shared {
    label = "shared/  (consumed by every service)";
    style = "rounded,dashed";
    fontsize = 11;
    color = "#90A4AE";

    foundation   [label="foundation\n(0)",   fillcolor="#E3F2FD", style="rounded,filled,bold"];
    versioning   [label="versioning\n(12)",  fillcolor="#E8F5E9"];
    telemetry    [label="telemetry\n(12)",   fillcolor="#E8F5E9"];
    audit        [label="audit\n(20)",       fillcolor="#FFF8E1"];
    activity     [label="activity\n(20)",    fillcolor="#FFF8E1"];
    transfer     [label="transfer\n(23)",    fillcolor="#FCE4EC"];
    search       [label="search\n(30)",      fillcolor="#EDE7F6"];
    geography    [label="geography\n(30)",   fillcolor="#EDE7F6"];
    localization [label="localization\n(30)", fillcolor="#EDE7F6"];
  }

  // ---- platform/ — the platform-service ------------------------------------
  subgraph cluster_platform {
    label = "platform/  (platform-service)";
    style = "rounded,dashed";
    fontsize = 11;
    color = "#66BB6A";

    tenancy [label="tenancy\n(10)", fillcolor="#E8F5E9"];
    settings   [label="settings\n(22)",   fillcolor="#FFF8E1"];
    webhook    [label="webhook\n(22)",    fillcolor="#FCE4EC"];
    storage    [label="storage\n(24)",    fillcolor="#FCE4EC"];
  }

  // ---- access/ — the access-service ----------------------------------------
  subgraph cluster_access {
    label = "access/  (access-service)";
    style = "rounded,dashed";
    fontsize = 11;
    color = "#5C6BC0";

    invitations [label="invitations\n(25)", fillcolor="#FCE4EC"];
  }

  // ---- billing/ — the billing-service --------------------------------------
  subgraph cluster_billing {
    label = "billing/  (billing-service)";
    style = "rounded,dashed";
    fontsize = 11;
    color = "#AB47BC";

    entitlements [label="entitlements\n(22)", fillcolor="#FCE4EC"];
    subscription [label="subscription\n(29)", fillcolor="#FCE4EC"];
  }

  // ---- notifications/ — the notifications-service --------------------------
  subgraph cluster_notifications {
    label = "notifications/  (notifications-service)";
    style = "rounded,dashed";
    fontsize = 11;
    color = "#7E57C2";

    notifications          [label="notifications\n(20)",          fillcolor="#F3E5F5"];
    "notifications-mail"   [label="notifications-mail\n(26)",     fillcolor="#F3E5F5"];
    "notifications-push"   [label="notifications-push\n(26)",     fillcolor="#F3E5F5"];
    "notifications-sms"    [label="notifications-sms\n(26)",      fillcolor="#F3E5F5"];
    "notifications-in-app" [label="notifications-in-app\n(26)",   fillcolor="#F3E5F5"];
    newsletter             [label="newsletter\n(35)",             fillcolor="#FFEBEE"];
  }

  // ---- compliance/ — the compliance-service --------------------------------
  subgraph cluster_compliance {
    label = "compliance/  (compliance-service)";
    style = "rounded,dashed";
    fontsize = 11;
    color = "#EF6C00";

    compliance [label="compliance\n(30)", fillcolor="#EDE7F6"];
  }

  // ---- products/ — product-scoped modules ----------------------------------
  subgraph cluster_products {
    label = "products/  (per-product)";
    style = "rounded,dashed";
    fontsize = 11;
    color = "#8D6E63";

    geofencing [label="geofencing\n(30)", fillcolor="#EDE7F6"];
  }

  // (identity/ tier is empty until identity + auth modules land.)

  // ==========================================================================
  // Dependency edges (verbatim from each module.json.dependencies).
  // ==========================================================================

  // Everything depends on foundation.
  tenancy             -> foundation;
  versioning             -> foundation;
  telemetry              -> foundation;
  audit                  -> foundation;
  activity               -> foundation;
  settings               -> foundation;
  entitlements           -> foundation;
  webhook                -> foundation;
  transfer               -> foundation;
  storage                -> foundation;
  invitations            -> foundation;
  subscription           -> foundation;
  notifications          -> foundation;
  "notifications-mail"   -> foundation;
  "notifications-push"   -> foundation;
  "notifications-sms"    -> foundation;
  "notifications-in-app" -> foundation;
  newsletter             -> foundation;
  compliance             -> foundation;
  search                 -> foundation;
  geography              -> foundation;
  geofencing             -> foundation;
  localization           -> foundation;

  // Substrate dependencies (cross-tier — the DAG is thickest here).
  entitlements  -> tenancy;
  entitlements  -> activity;
  entitlements  -> audit;
  webhook       -> tenancy;
  webhook       -> versioning;
  storage       -> tenancy;
  storage       -> entitlements;
  storage       -> activity;
  storage       -> audit;
  subscription  -> tenancy;
  subscription  -> entitlements;
  subscription  -> "notifications-mail";
  invitations   -> tenancy;
  notifications -> tenancy;

  // Compliance is a cross-service orchestrator — depends on almost every
  // substrate module because DSAR/retention/legal-hold coordinate across all
  // of them.
  compliance -> tenancy;
  compliance -> audit;
  compliance -> activity;
  compliance -> storage;
  compliance -> entitlements;
  compliance -> notifications;
  compliance -> "notifications-mail";

  // Notification transport bindings.
  "notifications-mail"   -> notifications;
  "notifications-push"   -> notifications;
  "notifications-sms"    -> notifications;
  "notifications-in-app" -> notifications;

  // Cross-domain uses (leaves).
  geofencing   -> geography;
  localization -> tenancy;
  newsletter   -> tenancy;
  newsletter   -> notifications;

  // ==========================================================================
  // Legend — colours encode boot wave, not service tier.
  // ==========================================================================
  subgraph cluster_legend {
    label = "Wave / colour legend";
    style = "rounded,dashed";
    fontsize = 10;
    node [shape=box, style=filled, fontsize=9];
    l0 [label="Wave 0: foundation",                                fillcolor="#E3F2FD"];
    l1 [label="Wave 1: substrate + versioning",                    fillcolor="#E8F5E9"];
    l2 [label="Wave 2: audit / activity / settings",               fillcolor="#FFF8E1"];
    l3 [label="Wave 3: entitlements + subscription + storage",     fillcolor="#FCE4EC"];
    l4 [label="Wave 4: notifications core + transports",           fillcolor="#F3E5F5"];
    l5 [label="Wave 5: search / geo / localization / compliance",  fillcolor="#EDE7F6"];
    l6 [label="Wave 6: domain-shaped surfaces (newsletter, ...)",  fillcolor="#FFEBEE"];
    l0 -> l1 -> l2 -> l3 -> l4 -> l5 -> l6 [style=invis];
  }
}
