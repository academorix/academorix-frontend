{
  "id": "audit.resources.audit.show",
  "title": "Audit detail",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/audits/{id}",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "audit", "entity": "audit", "action": "show" },
  "requiresPermission": "audit.view",
  "params": [{ "name": "id", "type": "string", "in": "path", "required": true }],
  "dataSources": [
    {
      "name": "audit",
      "kind": "http.get",
      "urlExpr": "'/api/v1/audits/' + params.id",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-6 p-6 max-w-5xl mx-auto" },
      "children": [
        {
          "kind": "Link",
          "props": {
            "leadingIcon": "arrow-left",
            "children": "Back to audit trail",
            "className": "text-sm text-muted"
          },
          "actions": { "onPress": { "kind": "navigate", "to": "/tenant/audits" } }
        },
        {
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "kind": "View",
              "props": { "className": "flex flex-col gap-1" },
              "children": [
                {
                  "kind": "Text",
                  "props": { "as": "h1", "className": "text-2xl font-semibold font-mono" },
                  "bindings": {
                    "children": { "$expr": "audit.event + ' \u00b7 ' + audit.auditable_type" }
                  }
                },
                {
                  "kind": "Text",
                  "props": { "className": "text-sm text-muted font-mono" },
                  "bindings": { "children": { "$ref": "audit.id" } }
                }
              ]
            },
            {
              "kind": "Chip",
              "props": { "size": "sm", "variant": "warning", "leadingIcon": "lock-closed" },
              "bindings": { "hidden": { "$expr": "!audit.is_encrypted" }, "children": "Encrypted" }
            }
          ]
        },
        {
          "kind": "Card",
          "props": { "className": "p-6" },
          "children": [
            {
              "kind": "Text",
              "props": {
                "as": "h2",
                "className": "text-sm font-semibold text-muted uppercase tracking-wide mb-3",
                "children": "Metadata"
              }
            },
            {
              "kind": "DescriptionList",
              "children": [
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "When" },
                  "bindings": { "value": { "$expr": "formatDate(audit.created_at)" } }
                },
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "Actor" },
                  "bindings": { "value": { "$expr": "audit.user?.display_name || 'System'" } }
                },
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "Model" },
                  "bindings": {
                    "value": { "$expr": "audit.auditable_type + ' ' + audit.auditable_id" }
                  }
                },
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "IP address (masked)" },
                  "bindings": { "value": { "$expr": "audit.ip_address || 'Not recorded'" } }
                },
                {
                  "kind": "DescriptionListItem",
                  "props": { "label": "Chain hash" },
                  "bindings": {
                    "hidden": { "$expr": "!audit.row_hash" },
                    "value": { "$expr": "audit.row_hash.substring(0, 16) + '\u2026'" }
                  }
                }
              ]
            }
          ]
        },
        {
          "kind": "Card",
          "props": { "className": "p-6" },
          "children": [
            {
              "kind": "Text",
              "props": {
                "as": "h2",
                "className": "text-sm font-semibold text-muted uppercase tracking-wide mb-3",
                "children": "Changes"
              }
            },
            {
              "kind": "Widget",
              "widget": "audit.audit-diff-viewer",
              "props": {
                "oldValues": { "$ref": "audit.old_values" },
                "newValues": { "$ref": "audit.new_values" },
                "canViewRestricted": {
                  "$expr": "identity.permissions.includes('audit.view-restricted')"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
