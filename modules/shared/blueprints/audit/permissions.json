{
  "id": "academorix://modules/audit/permissions",
  "$version": 1,
  "title": "audit \u2014 permissions",
  "seeder": "Academorix\\Audit\\Database\\Seeders\\AuditPermissionSeeder",
  "isSystem": true,
  "permissions": [
    {
      "name": "audit.viewAny",
      "guard": "sanctum",
      "description": "Tenant DPO can list audit rows for own tenant.",
      "seededOn": ["owner", "dpo"]
    },
    { "name": "audit.view", "guard": "sanctum", "seededOn": ["owner", "dpo"] },
    {
      "name": "audit.view-restricted",
      "guard": "sanctum",
      "description": "See un-masked restricted-tier field values in audit rows. Every use logged as a new audit row (meta-audit).",
      "seededOn": ["dpo"]
    },
    {
      "name": "platform.audit.viewAny",
      "guard": "platform_admin",
      "seededOn": ["super_admin", "dpo", "compliance"]
    },
    {
      "name": "platform.audit.view",
      "guard": "platform_admin",
      "seededOn": ["super_admin", "dpo", "compliance"]
    },
    {
      "name": "platform.audit.verify-chain",
      "guard": "platform_admin",
      "description": "Trigger chain verification jobs.",
      "seededOn": ["super_admin", "compliance"]
    },
    {
      "name": "platform.audit.export-dsar",
      "guard": "platform_admin",
      "description": "Export audit rows for DSAR compliance requests. Highest sensitivity.",
      "seededOn": ["dpo", "compliance"]
    }
  ]
}
