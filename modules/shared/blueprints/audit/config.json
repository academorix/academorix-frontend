{
  "id": "academorix://modules/audit/config",
  "$version": 1,
  "title": "audit \u2014 developer configuration",
  "configFile": "config/audit.php",
  "envPrefix": "AUDIT_",
  "sections": {
    "auditing_bridge": {
      "description": "Overrides on top of owen-it's config/audit.php.",
      "keys": [
        {
          "path": "audit.database.connection",
          "type": "string",
          "env": "AUDIT_DB_CONNECTION",
          "default": null
        },
        { "path": "audit.table_name", "type": "string", "default": "audits" }
      ]
    },
    "kms": {
      "keys": [
        {
          "path": "audit.kms.driver",
          "type": "enum<aws-kms,vault,local>",
          "env": "AUDIT_KMS_DRIVER",
          "default": "aws-kms"
        },
        {
          "path": "audit.kms.key_alias",
          "type": "string",
          "env": "AUDIT_KMS_KEY_ALIAS",
          "default": "alias/academorix-audit"
        },
        {
          "path": "audit.kms.region",
          "type": "string",
          "env": "AUDIT_KMS_REGION",
          "default": "us-east-1"
        },
        {
          "path": "audit.kms.encrypt_timeout_ms",
          "type": "int",
          "env": "AUDIT_KMS_ENCRYPT_TIMEOUT_MS",
          "default": 3000
        },
        {
          "path": "audit.kms.async_threshold_bytes",
          "type": "int",
          "default": 32768,
          "description": "Payloads larger than this defer to KmsEncryptAuditFieldsJob to avoid blocking the write path."
        }
      ]
    },
    "chain": {
      "keys": [
        {
          "path": "audit.chain.enabled_default",
          "type": "bool",
          "default": false,
          "description": "Fallback for entitlement resolution. Enterprise tenants override to true via entitlement."
        },
        { "path": "audit.chain.algorithm", "type": "string", "default": "sha256" },
        {
          "path": "audit.chain.verify_sample_per_run",
          "type": "int",
          "default": 10000,
          "description": "Max rows verified per VerifyAuditChainJob invocation. Larger = more thorough; smaller = less DB load."
        }
      ]
    },
    "cold": {
      "keys": [
        {
          "path": "audit.cold.driver",
          "type": "enum<s3,gcs,azure-blob,local>",
          "env": "AUDIT_COLD_DRIVER",
          "default": "s3"
        },
        {
          "path": "audit.cold.bucket",
          "type": "string",
          "env": "AUDIT_COLD_BUCKET",
          "default": "academorix-audit-cold"
        },
        {
          "path": "audit.cold.hot_days",
          "type": "int",
          "default": 365,
          "description": "Days before rotation. Fallback when entitlement resolution fails."
        },
        { "path": "audit.cold.rotate_batch_size", "type": "int", "default": 1000 },
        {
          "path": "audit.cold.object_lock_mode",
          "type": "enum<GOVERNANCE,COMPLIANCE>",
          "default": "COMPLIANCE",
          "description": "S3 Object Lock mode. COMPLIANCE = even root user cannot delete during retention."
        }
      ]
    },
    "ip_masking": {
      "keys": [
        { "path": "audit.ip_masking.enabled", "type": "bool", "default": true },
        {
          "path": "audit.ip_masking.v4_prefix",
          "type": "int",
          "default": 24,
          "description": "IPv4 mask bits."
        },
        { "path": "audit.ip_masking.v6_prefix", "type": "int", "default": 48 }
      ]
    }
  }
}
