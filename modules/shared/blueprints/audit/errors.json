{
  "id": "academorix://modules/audit/errors",
  "$version": 1,
  "title": "audit \u2014 error codes",
  "namespace": "audit",
  "errors": [
    {
      "code": "AUDIT_KILL_SWITCHED",
      "http": 503,
      "retryable": false,
      "user_facing": false,
      "audit_severity": "alert",
      "i18n_key": "audit.errors.kill_switched",
      "description": "audit.recording kill switch off. NEVER should happen in production."
    },
    {
      "code": "AUDIT_KMS_UNREACHABLE",
      "http": 503,
      "retryable": true,
      "user_facing": false,
      "audit_severity": "alert",
      "i18n_key": "audit.errors.kms_unreachable",
      "description": "KMS Encrypt call failed. Row queued as unencrypted + KmsEncryptAuditFieldsJob dispatched. Read paths refuse decryption until KMS returns."
    },
    {
      "code": "AUDIT_CHAIN_BROKEN",
      "http": 500,
      "retryable": false,
      "user_facing": false,
      "audit_severity": "critical",
      "i18n_key": "audit.errors.chain_broken",
      "description": "VerifyAuditChainJob detected tampering. Immediate compliance page."
    },
    {
      "code": "AUDIT_COLD_KEY_MISSING",
      "http": 500,
      "retryable": false,
      "user_facing": false,
      "audit_severity": "alert",
      "i18n_key": "audit.errors.cold_key_missing",
      "description": "Row has cold_key populated but S3 object missing. Data loss investigation."
    },
    {
      "code": "AUDIT_DSAR_EXPORT_REFUSED",
      "http": 403,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "audit.errors.dsar_export_refused",
      "description": "Caller lacks platform.audit.export-dsar permission."
    },
    {
      "code": "AUDIT_ENCRYPTION_FAILED_PERMANENT",
      "http": 500,
      "retryable": false,
      "user_facing": false,
      "audit_severity": "critical",
      "i18n_key": "audit.errors.encryption_failed_permanent",
      "description": "KmsEncryptAuditFieldsJob exhausted retries. Row remains in is_encrypted=false state. Compliance follow-up required."
    }
  ]
}
