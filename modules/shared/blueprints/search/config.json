{
  "id": "academorix://modules/search/config",
  "$version": 1,
  "title": "search \u2014 developer configuration",
  "configFile": "config/search.php",
  "envPrefix": "SEARCH_",
  "sections": {
    "engines": {
      "description": "Per-engine adapter configuration. Meilisearch is built into laravel/scout; pgvector + PG FTS come from third-party Scout drivers we depend on.",
      "keys": [
        {
          "path": "search.engines.default",
          "type": "enum<meilisearch,postgres-fts,pgvector,elasticsearch>",
          "env": "SEARCH_DEFAULT_ENGINE",
          "default": "meilisearch",
          "description": "Fallback engine when a #[Searchable(engine:)] attribute doesn't specify one."
        },
        {
          "path": "search.engines.meilisearch.host",
          "type": "string",
          "env": "SEARCH_MEILISEARCH_HOST",
          "default": "http://meilisearch:7700"
        },
        {
          "path": "search.engines.meilisearch.api_key",
          "type": "string",
          "env": "SEARCH_MEILISEARCH_API_KEY",
          "secret": true
        },
        {
          "path": "search.engines.meilisearch.index_prefix",
          "type": "string",
          "default": "academorix_",
          "description": "Prefix on every physical Meilisearch index name to isolate multi-tenant deployments sharing a cluster."
        },
        {
          "path": "search.engines.postgres_fts.driver",
          "type": "string",
          "default": "devnoise/pgsql-tsvector",
          "description": "Scout driver from devnoiseconsulting/laravel-scout-postgres-tsvector."
        },
        {
          "path": "search.engines.postgres_fts.tsvector_col",
          "type": "string",
          "default": "searchable",
          "description": "Column name for the tsvector column on searchable tables."
        },
        {
          "path": "search.engines.postgres_fts.language",
          "type": "string",
          "default": "english",
          "description": "Default text-search-config for the tsvector build. Overridable per-attribute via #[Searchable(language:)]."
        },
        {
          "path": "search.engines.pgvector.driver",
          "type": "string",
          "default": "benbjurstrom/pgvector-scout",
          "description": "Scout driver from benbjurstrom/pgvector-scout."
        },
        {
          "path": "search.engines.pgvector.dimension",
          "type": "integer",
          "default": 1536,
          "description": "Vector dimension. 1536 matches OpenAI text-embedding-3-small; configurable per-model via #[Searchable(vectorDimension:)]."
        },
        {
          "path": "search.engines.pgvector.distance",
          "type": "enum<cosine,l2,inner_product>",
          "default": "cosine"
        },
        {
          "path": "search.engines.pgvector.embedder",
          "type": "string",
          "env": "SEARCH_PGVECTOR_EMBEDDER",
          "default": "openai",
          "description": "Which embedder generates the vectors. External integration \u2014 not part of this module."
        },
        {
          "path": "search.engines.elasticsearch.enabled",
          "type": "boolean",
          "default": false,
          "description": "v2 stub. When implemented, will route via a future Scout driver."
        }
      ]
    },
    "queue": {
      "keys": [
        {
          "path": "search.queue.connection",
          "type": "string",
          "env": "SEARCH_QUEUE_CONNECTION",
          "default": null
        },
        {
          "path": "search.queue.name",
          "type": "string",
          "env": "SEARCH_QUEUE_NAME",
          "default": "search"
        },
        {
          "path": "search.queue.analytics_name",
          "type": "string",
          "default": "search-analytics",
          "description": "Dedicated queue for RecordSearchAnalyticsEventJob so query bursts don't back up sync work."
        }
      ]
    },
    "query": {
      "keys": [
        {
          "path": "search.query.max_length",
          "type": "integer",
          "default": 512,
          "description": "Max characters in a raw query. Prevents abuse."
        },
        {
          "path": "search.query.timeout_ms",
          "type": "integer",
          "default": 5000,
          "description": "Per-engine query timeout. Beyond this the engine returns SEARCH_ENGINE_TIMEOUT."
        },
        { "path": "search.query.default_page_size", "type": "integer", "default": 20 },
        { "path": "search.query.max_page_size", "type": "integer", "default": 100 },
        {
          "path": "search.query.default_language",
          "type": "string",
          "default": "auto",
          "description": "Auto = detect from Accept-Language + tenant setting + user setting fallthrough."
        }
      ]
    },
    "suggest": {
      "keys": [
        { "path": "search.suggest.enabled", "type": "boolean", "default": true },
        {
          "path": "search.suggest.min_prefix_length",
          "type": "integer",
          "default": 2,
          "description": "Below this length, suggest returns empty."
        },
        { "path": "search.suggest.max_results", "type": "integer", "default": 10 },
        {
          "path": "search.suggest.ttl_seconds",
          "type": "integer",
          "default": 60,
          "description": "Per-(tenant, index, query-prefix) cache TTL. Kept short so freshly-indexed content shows up in autocomplete quickly."
        }
      ]
    },
    "analytics": {
      "keys": [
        {
          "path": "search.analytics.record",
          "type": "boolean",
          "default": true,
          "description": "Master toggle for RecordSearchAnalyticsEventJob dispatch."
        },
        {
          "path": "search.analytics.session_ttl",
          "type": "integer",
          "default": 1800,
          "description": "Seconds a search_session_id stays valid on the client (30-min session)."
        },
        {
          "path": "search.analytics.click_tracking",
          "type": "boolean",
          "default": true,
          "description": "POST /search/click endpoint on/off."
        },
        {
          "path": "search.analytics.top_queries_cache_seconds",
          "type": "integer",
          "default": 300,
          "description": "Cache TTL for the top-queries dashboard tile."
        }
      ]
    },
    "synonyms": {
      "keys": [
        { "path": "search.synonyms.enabled", "type": "boolean", "default": true },
        {
          "path": "search.synonyms.cache_ttl_seconds",
          "type": "integer",
          "default": 3600,
          "description": "search:synonyms:{tenant}:{lang} cache TTL. WarmSynonymCacheJob invalidates on mutation \u2014 this is the belt-and-braces upper bound."
        }
      ]
    },
    "shards": {
      "keys": [
        {
          "path": "search.shards.enabled",
          "type": "boolean",
          "default": true,
          "description": "Fan-out large reindexes into shards. Also gated by search.can_use_sharded entitlement."
        },
        { "path": "search.shards.min_rows_per_shard", "type": "integer", "default": 25000 },
        { "path": "search.shards.max_shards", "type": "integer", "default": 100 }
      ]
    },
    "progress": {
      "keys": [
        {
          "path": "search.progress.every_rows",
          "type": "integer",
          "default": 1000,
          "description": "Emit SearchSyncJobProgress every N rows in a shard."
        },
        { "path": "search.progress.every_percent", "type": "integer", "default": 5 }
      ]
    },
    "notifications": {
      "keys": [
        {
          "path": "search.notifications.default_channels",
          "type": "array<string>",
          "default": ["database", "broadcast"]
        },
        { "path": "search.notifications.completed_channels_max", "type": "integer", "default": 5 },
        { "path": "search.notifications.async", "type": "boolean", "default": true }
      ]
    },
    "retention": {
      "keys": [
        { "path": "search.retention.sync_job_tier_days.short", "type": "integer", "default": 90 },
        { "path": "search.retention.sync_job_tier_days.medium", "type": "integer", "default": 180 },
        { "path": "search.retention.sync_job_tier_days.long", "type": "integer", "default": 365 },
        {
          "path": "search.retention.analytics_tier_days.short",
          "type": "integer",
          "default": 30,
          "description": "High-cardinality \u2014 aggressive short-plan purge."
        },
        { "path": "search.retention.analytics_tier_days.medium", "type": "integer", "default": 90 },
        { "path": "search.retention.analytics_tier_days.long", "type": "integer", "default": 365 },
        {
          "path": "search.retention.query_text_days",
          "type": "integer",
          "default": 7,
          "description": "NULL out SearchAnalyticsEvent.query after this many days independent of row TTL. GDPR guardrail."
        },
        {
          "path": "search.retention.swap_grace_days",
          "type": "integer",
          "default": 7,
          "description": "Retain the previous physical index version this many days after alias swap. Enables one-command rollback."
        },
        {
          "path": "search.retention.stale_hours",
          "type": "integer",
          "default": 24,
          "description": "queued/running SyncJob with no progress > stale_hours \u2192 auto-cancel."
        },
        { "path": "search.retention.prune_chunk_size", "type": "integer", "default": 1000 },
        { "path": "search.retention.synonym_grace_days", "type": "integer", "default": 365 },
        { "path": "search.retention.saved_query_grace_days", "type": "integer", "default": 365 },
        { "path": "search.retention.index_grace_days", "type": "integer", "default": 30 }
      ]
    },
    "concurrency": {
      "keys": [
        {
          "path": "search.concurrency.enforced_at_dispatch",
          "type": "boolean",
          "default": true,
          "description": "Refuse dispatch when tenant already has search.max_reindex_concurrency in flight."
        }
      ]
    },
    "temporary_files": {
      "description": "Reindex intermediate state (Scout's chunked backfill scratch). Multi-server-safe when remote_disk is set.",
      "keys": [
        {
          "path": "search.temporary_files.remote_disk",
          "type": "string",
          "env": "SEARCH_TEMP_REMOTE_DISK",
          "default": null
        },
        { "path": "search.temporary_files.force_resync_remote", "type": "boolean", "default": true }
      ]
    }
  }
}
