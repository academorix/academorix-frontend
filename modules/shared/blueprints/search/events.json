{
  "id": "academorix://modules/search/events",
  "$version": 1,
  "title": "search \u2014 published events",
  "namespace": "Academorix\\Search\\Events",
  "dispatchMode": "afterCommit",
  "events": [
    {
      "name": "SearchIndexRegistered",
      "class": "Academorix\\Search\\Events\\SearchIndexRegistered",
      "trigger": "New SearchIndex row inserted. Fires from SearchIndexObserver.created (afterCommit).",
      "queue": "search",
      "broadcastable": false,
      "consumers": [
        "activity::HasActivityLog observer on SearchIndex \u2192 activity_log row",
        "audit::HasAudit observer on SearchIndex \u2192 audits row",
        "observability::MetricsCollector \u2014 index_count gauge bump"
      ],
      "payload": {
        "search_index_id": "ULID (sidx_)",
        "tenant_id": "ULID (ten_) | null",
        "model_class": "string",
        "engine": "'meilisearch' | 'postgres-fts' | 'pgvector' | 'elasticsearch'",
        "index_name": "string",
        "language": "string | null"
      }
    },
    {
      "name": "SearchIndexUnregistered",
      "class": "Academorix\\Search\\Events\\SearchIndexUnregistered",
      "trigger": "SearchIndex soft-deleted. Fires from SearchIndexObserver.deleting.",
      "queue": "search",
      "broadcastable": false,
      "consumers": [
        "activity::HasActivityLog",
        "audit::HasAudit",
        "PurgeIndexModelJob dispatch (after swap_grace_days)"
      ],
      "payload": {
        "search_index_id": "ULID",
        "engine": "string",
        "index_name": "string",
        "final_document_count": "integer"
      }
    },
    {
      "name": "SearchSyncJobQueued",
      "class": "Academorix\\Search\\Events\\SearchSyncJobQueued",
      "trigger": "SearchSyncJob row inserted (status=queued). Fires from SearchSyncJobObserver.created.",
      "queue": "search",
      "broadcastable": true,
      "consumers": [
        "activity::HasActivityLog",
        "audit::HasAudit",
        "SPA subscribes to user.{userId}.search + tenant.{tenantId}.search channels"
      ],
      "payload": {
        "search_sync_job_id": "ULID (ssync_)",
        "search_index_id": "ULID (sidx_)",
        "tenant_id": "ULID | null",
        "causer_type": "string",
        "causer_id": "string",
        "kind": "'reindex' | 'backfill' | 'flush' | 'alias_swap' | 'single_document'",
        "source": "'live' | 'xfer_artifact'"
      }
    },
    {
      "name": "SearchSyncJobStarted",
      "class": "Academorix\\Search\\Events\\SearchSyncJobStarted",
      "trigger": "SearchSyncJob transitioned from queued \u2192 running. Fires from SearchSyncJobObserver.updating.",
      "queue": "search",
      "broadcastable": true,
      "consumers": ["SPA progress bar", "activity::HasActivityLog"],
      "payload": {
        "search_sync_job_id": "ULID",
        "started_at": "ISO 8601"
      }
    },
    {
      "name": "SearchSyncJobProgress",
      "class": "Academorix\\Search\\Events\\SearchSyncJobProgress",
      "trigger": "Fires every `config('search.progress.every_rows')` rows during a chunk. NOT audit-worthy \u2014 broadcast only.",
      "queue": null,
      "broadcastable": true,
      "afterCommit": false,
      "consumers": ["SPA progress bar"],
      "payload": {
        "search_sync_job_id": "ULID",
        "progress_percent": "integer 0\u2013100",
        "counters": "{ total, indexed, updated, skipped, failed, deleted }"
      }
    },
    {
      "name": "SearchSyncJobShardCompleted",
      "class": "Academorix\\Search\\Events\\SearchSyncJobShardCompleted",
      "trigger": "One shard of a sharded reindex transitioned to succeeded or failed. Fires from ReindexModelShardJob handle().",
      "queue": "search",
      "broadcastable": true,
      "consumers": [
        "ReindexCoordinatorJob \u2014 aggregates + updates parent progress",
        "SPA detailed progress"
      ],
      "payload": {
        "search_sync_job_id": "ULID",
        "shard_index": "integer",
        "shard_status": "'succeeded' | 'failed'",
        "shard_counters": "counters object"
      }
    },
    {
      "name": "SearchSyncJobCompleted",
      "class": "Academorix\\Search\\Events\\SearchSyncJobCompleted",
      "trigger": "SearchSyncJob transitioned to succeeded OR partially_succeeded. Fires from ReindexCoordinatorJob after final aggregation. Consumers filter on status for the partial variant.",
      "queue": "search",
      "broadcastable": true,
      "consumers": [
        "activity::HasActivityLog",
        "audit::HasAudit",
        "SwapIndexAliasJob (chained; only for kind=reindex with status=succeeded)",
        "SendSearchSyncNotificationJob"
      ],
      "payload": {
        "search_sync_job_id": "ULID",
        "kind": "string",
        "status": "'succeeded' | 'partially_succeeded'",
        "counters": "counters object",
        "target_version": "integer",
        "finished_at": "ISO 8601"
      }
    },
    {
      "name": "SearchSyncJobFailed",
      "class": "Academorix\\Search\\Events\\SearchSyncJobFailed",
      "trigger": "SearchSyncJob transitioned to failed. Fires from ReindexModelShardJob::failed(Throwable).",
      "queue": "search",
      "broadcastable": true,
      "consumers": [
        "activity::HasActivityLog",
        "audit::HasAudit",
        "SendSearchSyncNotificationJob \u2014 SearchSyncFailedNotification",
        "observability::MetricsCollector"
      ],
      "payload": {
        "search_sync_job_id": "ULID",
        "error_code": "string",
        "error_message": "string (redacted of PII)",
        "finished_at": "ISO 8601"
      }
    },
    {
      "name": "SearchSyncJobCancelled",
      "class": "Academorix\\Search\\Events\\SearchSyncJobCancelled",
      "trigger": "SearchSyncJob transitioned to cancelled by user request OR stale sweep. Fires from SearchSyncJobObserver.updating.",
      "queue": "search",
      "broadcastable": true,
      "consumers": ["activity::HasActivityLog", "audit::HasAudit"],
      "payload": {
        "search_sync_job_id": "ULID",
        "cancelled_by_type": "string | null",
        "cancelled_by_id": "string | null",
        "cancel_reason": "string | null",
        "finished_at": "ISO 8601"
      }
    },
    {
      "name": "SearchIndexAliasSwapped",
      "class": "Academorix\\Search\\Events\\SearchIndexAliasSwapped",
      "trigger": "SwapIndexAliasJob successfully repointed the live alias. Fires afterCommit on the SearchIndex.current_version + live_alias update.",
      "queue": "search",
      "broadcastable": true,
      "consumers": [
        "activity::HasActivityLog",
        "audit::HasAudit",
        "PurgeIndexModelJob dispatched with swap_grace_days delay for the old version"
      ],
      "payload": {
        "search_index_id": "ULID",
        "from_version": "integer",
        "to_version": "integer",
        "engine": "string",
        "index_name": "string",
        "swapped_at": "ISO 8601"
      }
    },
    {
      "name": "SearchSynonymCreated",
      "class": "Academorix\\Search\\Events\\SearchSynonymCreated",
      "trigger": "SearchSynonym row inserted. Fires from SearchSynonymObserver.created.",
      "queue": "search",
      "broadcastable": false,
      "consumers": ["activity::HasActivityLog", "WarmSynonymCacheJob dispatch"],
      "payload": {
        "search_synonym_id": "ULID (syn_)",
        "tenant_id": "ULID | null",
        "language": "string",
        "kind": "'equivalent' | 'one_way' | 'expansion'",
        "term_count": "integer"
      }
    },
    {
      "name": "SearchSynonymUpdated",
      "class": "Academorix\\Search\\Events\\SearchSynonymUpdated",
      "trigger": "SearchSynonym row updated. Fires from SearchSynonymObserver.updated.",
      "queue": "search",
      "broadcastable": false,
      "consumers": ["activity::HasActivityLog", "WarmSynonymCacheJob dispatch"],
      "payload": {
        "search_synonym_id": "ULID",
        "changed_fields": "array<string>"
      }
    },
    {
      "name": "SearchSynonymDeleted",
      "class": "Academorix\\Search\\Events\\SearchSynonymDeleted",
      "trigger": "SearchSynonym soft-deleted. Fires from SearchSynonymObserver.deleted.",
      "queue": "search",
      "broadcastable": false,
      "consumers": ["activity::HasActivityLog", "WarmSynonymCacheJob dispatch"],
      "payload": {
        "search_synonym_id": "ULID",
        "tenant_id": "ULID | null",
        "language": "string"
      }
    },
    {
      "name": "SearchQueryRecorded",
      "class": "Academorix\\Search\\Events\\SearchQueryRecorded",
      "trigger": "One kind=query analytics event was persisted. Fires from RecordSearchAnalyticsEventJob (fire-and-forget \u2014 not afterCommit).",
      "queue": null,
      "broadcastable": false,
      "afterCommit": false,
      "consumers": ["observability::MetricsCollector \u2014 query counter increment"],
      "payload": {
        "search_analytics_event_id": "ULID (sae_)",
        "tenant_id": "ULID | null",
        "engine": "string",
        "index_names": "array<string>",
        "result_count": "integer",
        "took_ms": "integer"
      }
    },
    {
      "name": "SearchNoResultsRecorded",
      "class": "Academorix\\Search\\Events\\SearchNoResultsRecorded",
      "trigger": "One kind=no_results analytics event was persisted. Zero-result queries indicate index gaps, synonym gaps, or user typos beyond the tolerance threshold \u2014 admin dashboards watch this.",
      "queue": null,
      "broadcastable": false,
      "afterCommit": false,
      "consumers": ["observability::MetricsCollector \u2014 no_results counter increment"],
      "payload": {
        "search_analytics_event_id": "ULID",
        "tenant_id": "ULID | null",
        "engine": "string",
        "index_names": "array<string>",
        "query_hash": "SHA-256"
      }
    },
    {
      "name": "SearchClickThroughRecorded",
      "class": "Academorix\\Search\\Events\\SearchClickThroughRecorded",
      "trigger": "One kind=click_through analytics event was persisted via POST /api/v1/search/click. Position is 1-based.",
      "queue": null,
      "broadcastable": false,
      "afterCommit": false,
      "consumers": [
        "observability::MetricsCollector \u2014 click_through counter + position histogram"
      ],
      "payload": {
        "search_analytics_event_id": "ULID",
        "tenant_id": "ULID | null",
        "clicked_result_type": "string",
        "clicked_result_id": "string",
        "clicked_position": "integer"
      }
    },
    {
      "name": "SearchSavedQueryCreated",
      "class": "Academorix\\Search\\Events\\SearchSavedQueryCreated",
      "trigger": "New SearchSavedQuery row inserted. Fires from SearchSavedQuery model observer.created.",
      "queue": "search",
      "broadcastable": false,
      "consumers": ["activity::HasActivityLog"],
      "payload": {
        "search_saved_query_id": "ULID (sq_)",
        "tenant_id": "ULID",
        "owner_id": "ULID (usr_)",
        "is_smart_list": "boolean",
        "is_shared": "boolean"
      }
    }
  ]
}
