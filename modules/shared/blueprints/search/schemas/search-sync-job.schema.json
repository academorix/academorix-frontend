{
  "id": "academorix://modules/search/schemas/search-sync-job",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "SearchSyncJob",
  "description": "Persisted operation record for reindex + backfill + flush + alias-swap runs. Same shape as `xfer_jobs` (transfer module): queue-independent, retention-aware, counters, artifact links, frozen notification channels. Enables cross-request status queries, shard-level retry, and audit trail identity for reindex operations.",
  "type": "object",
  "x-module": "search",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "search_sync_jobs",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "ssync_",
    "incrementing": false,
    "model": "Academorix\\Search\\Models\\SearchSyncJob",
    "interface": "Academorix\\Search\\Contracts\\Data\\SearchSyncJobInterface",
    "implements": ["Academorix\\Search\\Contracts\\Data\\SearchSyncJobInterface"],
    "traits": ["HasUlids", "BelongsToTenant", "HasActivityLog", "HasAudit", "SoftDeletes"],
    "casts": {
      "kind": "Academorix\\Search\\Enums\\SearchSyncJobKind",
      "status": "Academorix\\Search\\Enums\\SearchSyncJobStatus",
      "source": "Academorix\\Search\\Enums\\SearchSyncSource",
      "counters": "Academorix\\Search\\Casts\\SearchSyncCountersCast",
      "params": "array",
      "notify_channels": "Academorix\\Search\\Casts\\NotifyChannelListCast",
      "source_version": "integer",
      "target_version": "integer",
      "shards_total": "integer",
      "shards_completed": "integer",
      "progress_percent": "integer",
      "started_at": "immutable_datetime",
      "finished_at": "immutable_datetime",
      "last_progress_at": "immutable_datetime"
    },
    "hidden": [],
    "guarded": [
      "id",
      "tenant_id",
      "status",
      "counters",
      "started_at",
      "finished_at",
      "progress_percent",
      "shards_total",
      "shards_completed"
    ]
  },
  "x-database": {
    "engine": "postgres",
    "description": "Parallel table shape to `xfer_jobs`. Every long-running search sync operation persists here so status survives the queue chain lifetime, artifacts can be linked, and cancellation + retry can happen against the persisted row.",
    "columns": {
      "id": {
        "type": "string",
        "length": 64,
        "primary": true,
        "description": "Prefixed ULID: `ssync_<26 chars>`."
      },
      "tenant_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": {
          "table": "tenants",
          "column": "id",
          "onUpdate": "cascade",
          "onDelete": "cascade"
        }
      },
      "search_index_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": {
          "table": "search_indexes",
          "column": "id",
          "onUpdate": "cascade",
          "onDelete": "cascade"
        },
        "description": "The index being (re)synchronised."
      },
      "causer_type": {
        "type": "string",
        "length": 128,
        "nullable": false,
        "description": "Polymorphic initiator type. Typically User; may be System for scheduled reindexes."
      },
      "causer_id": { "type": "string", "length": 64, "nullable": false },
      "kind": {
        "type": "string",
        "length": 32,
        "nullable": false,
        "description": "Enum: reindex / backfill / flush / alias_swap / single_document."
      },
      "status": {
        "type": "string",
        "length": 32,
        "nullable": false,
        "default": "'queued'",
        "description": "Enum: queued / running / succeeded / partially_succeeded / failed / cancelling / cancelled."
      },
      "source": {
        "type": "string",
        "length": 32,
        "nullable": false,
        "default": "'live'",
        "description": "Enum: live / xfer_artifact. `xfer_artifact` reindexes from a `transfer` module export file for cross-region migrations."
      },
      "source_artifact_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": {
          "table": "xfer_artifacts",
          "column": "id",
          "onUpdate": "cascade",
          "onDelete": "set null"
        },
        "description": "Non-null only when source = xfer_artifact."
      },
      "source_version": {
        "type": "integer",
        "nullable": true,
        "description": "Source live version being replaced (e.g. 42)."
      },
      "target_version": {
        "type": "integer",
        "nullable": true,
        "description": "New version being built (e.g. 43)."
      },
      "counters": {
        "type": "jsonb",
        "nullable": false,
        "default": "'{\"total\":0,\"indexed\":0,\"updated\":0,\"skipped\":0,\"failed\":0,\"deleted\":0}'",
        "description": "Live counters. Cast to a value object."
      },
      "params": {
        "type": "jsonb",
        "nullable": true,
        "description": "Frozen snapshot of the request. For reproducibility + support."
      },
      "notify_channels": {
        "type": "jsonb",
        "nullable": false,
        "default": "'[\"database\",\"broadcast\"]'",
        "description": "Resolved-at-dispatch notification channels. Frozen \u2014 preference changes mid-run do not affect delivery."
      },
      "notify_locale": { "type": "string", "length": 8, "nullable": false, "default": "'en'" },
      "retention_tier": {
        "type": "string",
        "length": 16,
        "nullable": false,
        "default": "'medium'"
      },
      "queue_connection": { "type": "string", "length": 64, "nullable": true },
      "queue_name": { "type": "string", "length": 64, "nullable": false, "default": "'search'" },
      "laravel_queue_batch_id": {
        "type": "uuid",
        "nullable": true,
        "description": "Pointer to Laravel's `job_batches` row when we use `Bus::batch()` for shard fan-out."
      },
      "shards_total": { "type": "integer", "nullable": false, "default": "1" },
      "shards_completed": { "type": "integer", "nullable": false, "default": "0" },
      "progress_percent": { "type": "integer", "nullable": false, "default": "0" },
      "started_at": { "type": "timestamptz", "nullable": true },
      "finished_at": { "type": "timestamptz", "nullable": true },
      "last_progress_at": { "type": "timestamptz", "nullable": true },
      "last_error_message": { "type": "text", "nullable": true },
      "last_error_code": { "type": "string", "length": 64, "nullable": true },
      "cancelled_by_type": { "type": "string", "length": 128, "nullable": true },
      "cancelled_by_id": { "type": "string", "length": 64, "nullable": true },
      "cancel_reason": { "type": "string", "length": 255, "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false },
      "deleted_at": { "type": "timestamptz", "nullable": true }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "created_at"],
        "unique": false,
        "name": "search_sync_jobs_tenant_time_idx"
      },
      {
        "columns": ["search_index_id", "created_at"],
        "unique": false,
        "name": "search_sync_jobs_index_time_idx"
      },
      {
        "columns": ["causer_type", "causer_id", "created_at"],
        "unique": false,
        "name": "search_sync_jobs_causer_time_idx"
      },
      {
        "columns": ["status", "created_at"],
        "unique": false,
        "name": "search_sync_jobs_status_time_idx"
      },
      {
        "columns": ["retention_tier", "created_at"],
        "unique": false,
        "name": "search_sync_jobs_retention_scan_idx"
      },
      {
        "columns": ["last_progress_at"],
        "unique": false,
        "name": "search_sync_jobs_stalled_scan_idx",
        "predicate": "status = 'running'"
      }
    ]
  },
  "required": [
    "id",
    "search_index_id",
    "causer_type",
    "causer_id",
    "kind",
    "status",
    "source",
    "counters",
    "notify_channels",
    "notify_locale",
    "retention_tier",
    "queue_name",
    "shards_total",
    "shards_completed",
    "progress_percent",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^ssync_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": ["string", "null"], "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "search_index_id": { "type": "string", "pattern": "^sidx_[0-9A-HJKMNP-TV-Z]{26}$" },
    "causer_type": { "type": "string" },
    "causer_id": { "type": "string" },
    "kind": {
      "type": "string",
      "enum": ["reindex", "backfill", "flush", "alias_swap", "single_document"]
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "succeeded",
        "partially_succeeded",
        "failed",
        "cancelling",
        "cancelled"
      ]
    },
    "source": { "type": "string", "enum": ["live", "xfer_artifact"] },
    "source_artifact_id": {
      "type": ["string", "null"],
      "pattern": "^xart_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "source_version": { "type": ["integer", "null"], "minimum": 1 },
    "target_version": { "type": ["integer", "null"], "minimum": 1 },
    "counters": {
      "type": "object",
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "indexed": { "type": "integer", "minimum": 0 },
        "updated": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "deleted": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false,
      "required": ["total", "indexed", "updated", "skipped", "failed", "deleted"]
    },
    "params": { "type": ["object", "null"] },
    "notify_channels": {
      "type": "array",
      "items": { "type": "string", "enum": ["mail", "broadcast", "database", "push", "sms"] },
      "uniqueItems": true,
      "maxItems": 5
    },
    "notify_locale": { "type": "string", "maxLength": 8 },
    "retention_tier": { "type": "string", "enum": ["short", "medium", "long"] },
    "queue_connection": { "type": ["string", "null"], "maxLength": 64 },
    "queue_name": { "type": "string", "maxLength": 64 },
    "laravel_queue_batch_id": { "type": ["string", "null"], "format": "uuid" },
    "shards_total": { "type": "integer", "minimum": 1 },
    "shards_completed": { "type": "integer", "minimum": 0 },
    "progress_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
    "started_at": { "type": ["string", "null"], "format": "date-time" },
    "finished_at": { "type": ["string", "null"], "format": "date-time" },
    "last_progress_at": { "type": ["string", "null"], "format": "date-time" },
    "last_error_message": { "type": ["string", "null"] },
    "last_error_code": { "type": ["string", "null"], "maxLength": 64 },
    "cancelled_by_type": { "type": ["string", "null"] },
    "cancelled_by_id": { "type": ["string", "null"] },
    "cancel_reason": { "type": ["string", "null"], "maxLength": 255 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "deleted_at": { "type": ["string", "null"], "format": "date-time" }
  },
  "additionalProperties": false,
  "x-wire": {
    "envelope": "spatie-data",
    "wrap": "data",
    "mapper": "SnakeCaseMapper",
    "hidden": ["laravel_queue_batch_id"],
    "computed": [
      {
        "name": "is_terminal",
        "expression": "in_array(status, ['succeeded', 'partially_succeeded', 'failed', 'cancelled'], true)"
      },
      {
        "name": "duration_seconds",
        "expression": "started_at && finished_at ? (finished_at - started_at) : null"
      }
    ]
  }
}
