{
  "id": "geography.language-picker",
  "title": "Language picker (ISO-639 catalog)",
  "version": 1,
  "kind": "SduiWidget",
  "description": "Searchable combobox for the full ISO-639-1 catalog. Distinct from localization::language-switcher (which lists tenant-enabled locales only). Use this for reference-catalog dropdowns (author preferences, translation source language, content classification).",
  "props": {
    "name": { "type": "string", "required": true },
    "value": { "type": ["string", "null"] },
    "showRtlFirst": { "type": "boolean", "default": false },
    "placeholder": { "type": "string", "default": "Select language..." }
  },
  "dataSources": [
    {
      "name": "languages",
      "kind": "http.get",
      "url": "/api/v1/geography/languages",
      "unwrap": "data",
      "cache": { "ttlSeconds": 3600 }
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "Combobox",
      "props": { "name": "$name", "placeholder": "$placeholder" },
      "bindings": {
        "options": { "$ref": "languages" },
        "optionKey": "code",
        "optionLabel": "native",
        "value": { "$ref": "props.value" }
      },
      "children": [
        {
          "kind": "ComboboxOptionRenderer",
          "children": [
            {
              "kind": "View",
              "props": { "className": "flex items-center justify-between gap-2" },
              "children": [
                {
                  "kind": "View",
                  "props": { "className": "flex flex-col flex-1" },
                  "children": [
                    {
                      "kind": "Text",
                      "props": { "className": "font-medium" },
                      "bindings": { "children": { "$ref": "row.native" } }
                    },
                    {
                      "kind": "Text",
                      "props": { "className": "text-xs text-muted" },
                      "bindings": { "childrenExpr": "row.name + ' \u00b7 ' + row.code" }
                    }
                  ]
                },
                {
                  "kind": "Chip",
                  "props": { "size": "xs", "variant": "warning" },
                  "bindings": { "hidden": { "$expr": "!row.is_rtl" }, "children": "RTL" }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
