    },
    {
      "code": "GEOGRAPHY_GEOLOCATE_UNRESOLVABLE",
      "http": 200,
      "retryable": true,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "geography.errors.geolocate_unresolvable",
      "description": "Both MaxMind AND ip-api.com failed. Returns HTTP 200 with data:null so caller can gracefully continue \u2014 not an error state per se."
    },
    {
      "code": "GEOGRAPHY_GEOLOCATE_QUOTA_EXCEEDED",
      "http": 402,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
