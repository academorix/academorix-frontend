    {
      "code": "GEOGRAPHY_GEOLOCATE_PRIVATE_IP",
      "http": 422,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "geography.errors.geolocate_private_ip",
