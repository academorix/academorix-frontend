{
  "id": "academorix://modules/attributes/events",
  "$version": 1,
  "title": "attributes — published events",
  "namespace": "Academorix\\Attributes\\Events",
  "dispatchMode": "afterCommit",
  "description": "Every event implements `ShouldDispatchAfterCommit`. AttributeSetVersioned is the load-bearing cache-invalidation signal — every host resolver caches the active set per (entity_type, discriminator_value), and this event triggers cache purge. AttributeValuesRejected is the negative signal from HasSchemalessAttributes save — host writes refused when values fail validation against the active set.",
  "events": [
    {
      "name": "AttributeDefinitionCreated",
      "class": "Academorix\\Attributes\\Events\\AttributeDefinitionCreated",
      "trigger": "New AttributeDefinition committed via CreateAttributeDefinitionAction.",
      "queue": "attributes",
      "consumers": [
        "audit::WriteToAuditLog",
        "activity::WriteToActivityLog",
        "cache::InvalidateDefinitionCacheOnDefinitionCreated"
      ],
      "payload": {
        "definition_id": "ULID (ads_*)",
        "tenant_id": "ULID",
        "code": "string",
        "type": "'integer' | 'decimal' | 'select' | 'boolean' | 'date' | 'text' | 'slider' | 'percentage'",
        "widget": "string",
        "created_by_user_id": "ULID (usr_*)"
      }
    },
    {
      "name": "AttributeDefinitionUpdated",
      "class": "Academorix\\Attributes\\Events\\AttributeDefinitionUpdated",
      "trigger": "AttributeDefinition mutated. Labels / description / widget_config changes fire this without a version bump. Type or validation changes MUST fire AttributeSetVersioned on every set referencing this definition.",
      "queue": "attributes",
      "consumers": [
        "audit::WriteToAuditLog",
        "cache::InvalidateDefinitionCache",
        "attributes::VersionSetsReferencingDefinition"
      ],
      "payload": {
        "definition_id": "ULID",
        "tenant_id": "ULID",
        "changed_fields": "string[]",
        "is_breaking": "boolean",
        "changed_by_user_id": "ULID"
      }
    },
    {
      "name": "AttributeDefinitionDeprecated",
      "class": "Academorix\\Attributes\\Events\\AttributeDefinitionDeprecated",
      "trigger": "AttributeDefinition.is_deprecated flipped true. Preserved for historic render; blocked from new sets.",
      "queue": "attributes",
      "consumers": [
        "audit::WriteToAuditLog",
        "activity::WriteToActivityLog",
        "cache::InvalidateDefinitionCache"
      ],
      "payload": {
        "definition_id": "ULID",
        "tenant_id": "ULID",
        "deprecated_at": "ISO 8601",
        "deprecated_by_user_id": "ULID"
      }
    },
    {
      "name": "AttributeSetCreated",
      "class": "Academorix\\Attributes\\Events\\AttributeSetCreated",
      "trigger": "New AttributeSet committed (draft state — activate to publish).",
      "queue": "attributes",
      "consumers": ["audit::WriteToAuditLog", "activity::WriteToActivityLog"],
      "payload": {
        "set_id": "ULID (asg_*)",
        "tenant_id": "ULID",
        "code": "string",
        "entity_type": "string",
        "discriminator_field": "string",
        "discriminator_value": "string",
        "version_number": "integer",
        "created_by_user_id": "ULID"
      }
    },
    {
      "name": "AttributeSetVersioned",
      "class": "Academorix\\Attributes\\Events\\AttributeSetVersioned",
      "trigger": "P1 event. AttributeSet.version_number bumped due to a breaking change. Old version marked superseded but preserved for historic render. Load-bearing signal — every host resolver cache MUST invalidate on this event.",
      "queue": "attributes",
      "consumers": [
        "audit::WriteToAuditLog (retention: 7 years)",
        "activity::WriteToActivityLog",
        "cache::InvalidateHostResolverCache",
        "notifications::DispatchAttributeSetVersionedNotification (tenant admin + host module maintainers)"
      ],
      "payload": {
        "set_id": "ULID",
        "previous_set_id": "ULID | null",
        "tenant_id": "ULID",
        "entity_type": "string",
        "discriminator_value": "string",
        "previous_version_number": "integer",
        "new_version_number": "integer",
        "reason": "string",
        "changed_by_user_id": "ULID"
      }
    },
    {
      "name": "AttributeSetActivated",
      "class": "Academorix\\Attributes\\Events\\AttributeSetActivated",
      "trigger": "AttributeSet.is_active flipped false → true. Refused when it would collide with another active set at the same (entity_type, discriminator_value).",
      "queue": "attributes",
      "consumers": [
        "audit::WriteToAuditLog",
        "activity::WriteToActivityLog",
        "cache::InvalidateHostResolverCache"
      ],
      "payload": {
        "set_id": "ULID",
        "tenant_id": "ULID",
        "entity_type": "string",
        "discriminator_value": "string",
        "activated_at": "ISO 8601",
        "activated_by_user_id": "ULID"
      }
    },
    {
      "name": "AttributeSetDeactivated",
      "class": "Academorix\\Attributes\\Events\\AttributeSetDeactivated",
      "trigger": "AttributeSet.is_active flipped true → false. Fallback to next-lower version if any.",
      "queue": "attributes",
      "consumers": [
        "audit::WriteToAuditLog",
        "activity::WriteToActivityLog",
        "cache::InvalidateHostResolverCache"
      ],
      "payload": {
        "set_id": "ULID",
        "tenant_id": "ULID",
        "deactivated_at": "ISO 8601",
        "deactivated_by_user_id": "ULID"
      }
    },
    {
      "name": "AttributeGroupCreated",
      "class": "Academorix\\Attributes\\Events\\AttributeGroupCreated",
      "trigger": "New AttributeGroup committed inside an AttributeSet.",
      "queue": "attributes",
      "consumers": ["audit::WriteToAuditLog"],
      "payload": {
        "group_id": "ULID (atg_*)",
        "set_id": "ULID",
        "tenant_id": "ULID",
        "code": "string",
        "sort_order": "integer"
      }
    },
    {
      "name": "AttributeGroupReordered",
      "class": "Academorix\\Attributes\\Events\\AttributeGroupReordered",
      "trigger": "sort_order changed on one or more AttributeGroups within a set.",
      "queue": "attributes",
      "consumers": ["audit::WriteToAuditLog", "cache::InvalidateHostResolverCache"],
      "payload": {
        "set_id": "ULID",
        "tenant_id": "ULID",
        "group_orders": "array<{group_id, sort_order}>"
      }
    },
    {
      "name": "AttributeValuesValidated",
      "class": "Academorix\\Attributes\\Events\\AttributeValuesValidated",
      "trigger": "HasSchemalessAttributes trait fired the validator on host save and passed. Fires alongside the host's own persistence event.",
      "queue": "attributes",
      "consumers": ["audit::WriteToAuditLog (verbose channel)"],
      "payload": {
        "host_type": "string",
        "host_id": "ULID",
        "set_id": "ULID",
        "tenant_id": "ULID"
      }
    },
    {
      "name": "AttributeValuesRejected",
      "class": "Academorix\\Attributes\\Events\\AttributeValuesRejected",
      "trigger": "P1 event. HasSchemalessAttributes trait fired the validator on host save and FAILED. Host save refused — this is the negative signal for monitoring + alerting on schema-mismatch bugs.",
      "queue": "notifications-critical",
      "consumers": [
        "audit::WriteToAuditLog (retention: 7 years)",
        "activity::WriteToActivityLog",
        "monitoring::AlertOnValidationFailure"
      ],
      "payload": {
        "host_type": "string",
        "host_id": "ULID | null",
        "set_id": "ULID",
        "tenant_id": "ULID",
        "validation_errors": "array<{code, message, field}>",
        "attempted_by_user_id": "ULID | null"
      }
    }
  ]
}
