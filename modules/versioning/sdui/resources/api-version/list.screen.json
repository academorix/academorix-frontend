{
  "id": "versioning.resources.api-version.list",
  "title": "API versions",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/platform/versioning/api-versions",
  "host": "central-admin",
  "audience": "authenticated",
  "resource": {"module": "versioning", "entity": "api-version", "action": "list"},
  "requiresPermission": "platform.versioning.viewAny",
  "dataSources": [
    {"name": "apiVersions", "kind": "http.get", "url": "/api/v1/platform/versioning/api-versions", "unwrap": "data", "paginated": true, "queryParamsFromState": ["filter[state]", "filter[scheme]", "sort", "page", "per_page"]}
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": {"className": "flex flex-col gap-4 p-6"},
      "children": [
        {
          "id": "header",
          "kind": "View",
          "props": {"className": "flex items-center justify-between"},
          "children": [
            {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold", "children": "API versions"}},
            {"kind": "Button", "props": {"variant": "primary", "size": "sm", "leadingIcon": "plus", "children": "Draft new version"}, "bindings": {"isDisabled": {"$expr": "!identity.permissions.includes('platform.versioning.create')"}}, "actions": {"onPress": {"kind": "navigate", "to": "/platform/versioning/api-versions/new"}}}
          ]
        },
        {
          "id": "filters",
          "kind": "View",
          "props": {"className": "flex flex-wrap gap-3"},
          "children": [
            {"kind": "Select", "props": {"label": "State", "name": "filter[state]", "placeholder": "All"}, "options": [{"key": "draft", "label": "Draft"}, {"key": "released", "label": "Released"}, {"key": "deprecated", "label": "Deprecated"}, {"key": "sunset", "label": "Sunset"}], "actions": {"onChange": {"kind": "data.applyFilter", "source": "apiVersions"}}},
            {"kind": "Select", "props": {"label": "Scheme", "name": "filter[scheme]", "placeholder": "All"}, "options": [{"key": "semver", "label": "SemVer"}, {"key": "calver", "label": "CalVer"}], "actions": {"onChange": {"kind": "data.applyFilter", "source": "apiVersions"}}}
          ]
        },
        {
          "id": "table",
          "kind": "DataGrid",
          "props": {"emptyState": {"title": "No API versions yet", "description": "Release the first version to unlock the platform.", "icon": "tag"}},
          "bindings": {"items": {"$ref": "apiVersions"}, "isLoading": {"$ref": "apiVersions.isLoading"}},
          "columns": [
            {"id": "slug", "header": "Slug", "sortable": true, "sortKey": "slug", "cell": {"kind": "View", "children": [
              {"kind": "Text", "props": {"className": "font-mono font-medium"}, "bindings": {"children": {"$ref": "row.slug"}}},
              {"kind": "Text", "props": {"className": "text-xs text-muted"}, "bindings": {"children": {"$ref": "row.name"}}}
            ]}},
            {"id": "scheme", "header": "Scheme", "cell": {"kind": "Chip", "props": {"size": "xs", "variant": "neutral"}, "bindings": {"children": {"$expr": "row.scheme === 'semver' ? 'SemVer' : 'CalVer'"}}}},
            {"id": "state", "header": "State", "cell": {"kind": "Widget", "widget": "versioning.version-lifecycle-chip", "props": {"state": {"$ref": "row.state"}, "size": "sm"}}},
            {"id": "is_default", "header": "Default", "cell": {"kind": "Icon", "bindings": {"hidden": {"$expr": "!row.is_default"}, "icon": "star-solid", "className": "text-warning"}}},
            {"id": "sunset_at", "header": "Sunset", "cell": {"kind": "Text", "props": {"className": "text-sm"}, "bindings": {"hidden": {"$expr": "!row.sunset_at"}, "children": {"$expr": "row.sunset_at ? formatDate(row.sunset_at) + ' (' + (row.days_until_sunset ?? 0) + 'd)' : ''"}}}},
            {"id": "actions", "header": "", "align": "end", "cell": {"kind": "Menu", "props": {"trigger": {"kind": "Button", "props": {"variant": "ghost", "isIconOnly": true, "leadingIcon": "ellipsis-horizontal", "ariaLabel": "Actions"}}}, "items": [
              {"id": "view", "label": "View", "leadingIcon": "eye", "action": {"kind": "navigate", "toExpr": "'/platform/versioning/api-versions/' + row.slug"}},
              {"id": "edit", "label": "Edit metadata", "leadingIcon": "pencil", "bindings": {"isDisabled": {"$expr": "!identity.permissions.includes('platform.versioning.update')"}}, "action": {"kind": "navigate", "toExpr": "'/platform/versioning/api-versions/' + row.slug + '/edit'"}},
              {"id": "release", "label": "Release", "leadingIcon": "rocket-launch", "bindings": {"isDisabled": {"$expr": "row.state !== 'draft' || !identity.permissions.includes('platform.versioning.release')"}}, "action": {"kind": "http.post", "urlExpr": "'/api/v1/platform/versioning/api-versions/' + row.slug + '/release'", "confirm": {"title": "Release this version?", "description": "Publishes to public catalog + emits X-API-Version headers."}, "onSuccess": [{"kind": "toast.success", "message": "Released"}, {"kind": "data.refresh", "source": "apiVersions"}]}},
              {"id": "deprecate", "label": "Deprecate", "leadingIcon": "clock", "bindings": {"isDisabled": {"$expr": "row.state !== 'released' || !identity.permissions.includes('platform.versioning.deprecate')"}}, "action": {"kind": "navigate", "toExpr": "'/platform/versioning/api-versions/' + row.slug + '/deprecate'"}},
              {"id": "sunset", "label": "Sunset now", "leadingIcon": "x-circle", "bindings": {"isDisabled": {"$expr": "row.state !== 'deprecated' || !identity.permissions.includes('platform.versioning.sunset')"}}, "action": {"kind": "http.post", "urlExpr": "'/api/v1/platform/versioning/api-versions/' + row.slug + '/sunset'", "body": {"force": true}, "confirm": {"title": "Sunset this version now?", "description": "Bypasses the scheduled runner. Refuses requests immediately with 410 Gone. Pinned subscriptions auto-upgrade (or pause) per migration_target_slug."}, "onSuccess": [{"kind": "toast.success", "message": "Sunset"}, {"kind": "data.refresh", "source": "apiVersions"}]}}
            ]}}
          ]
        }
      ]
    }
  ]
}
