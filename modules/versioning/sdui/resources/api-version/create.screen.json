{
  "id": "versioning.resources.api-version.create",
  "title": "Draft new API version",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/platform/versioning/api-versions/new",
  "host": "central-admin",
  "audience": "authenticated",
  "resource": {"module": "versioning", "entity": "api-version", "action": "create"},
  "requiresPermission": "platform.versioning.create",
  "dataSources": [],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": {"className": "flex flex-col gap-6 p-6 max-w-2xl mx-auto"},
      "children": [
        {"kind": "Link", "props": {"leadingIcon": "arrow-left", "children": "Cancel", "className": "text-sm text-muted"}, "actions": {"onPress": {"kind": "navigate", "to": "/platform/versioning/api-versions"}}},
        {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold", "children": "Draft new API version"}},
        {
          "kind": "Alert",
          "props": {"variant": "info", "children": "New versions start in `draft` state. Release them via the version detail screen when ready."}
        },
        {
          "kind": "Form",
          "props": {"submitUrl": "/api/v1/platform/versioning/api-versions", "submitMethod": "POST", "onSuccess": [{"kind": "toast.success", "message": "Draft created"}, {"kind": "navigateExpr", "expr": "'/platform/versioning/api-versions/' + response.data.slug"}]},
          "children": [
            {"kind": "TextField", "props": {"label": "Slug", "name": "slug", "isRequired": true, "placeholder": "v2 or 2024-10-15", "description": "Lowercase, alphanumeric + dot/dash/underscore. Reserved: default, current, latest."}},
            {"kind": "TextField", "props": {"label": "Display name", "name": "name", "isRequired": true, "placeholder": "v2 (Autumn 2024 Refresh)"}},
            {"kind": "Select", "props": {"label": "Scheme", "name": "scheme", "isRequired": true, "defaultValue": "semver"}, "options": [{"key": "semver", "label": "SemVer (v1.2.3 style)"}, {"key": "calver", "label": "CalVer (2024-10-15 style)"}]},
            {"kind": "TextArea", "props": {"label": "Description (markdown)", "name": "description", "rows": 6, "description": "Rendered on the public /api/versions/{slug} page."}},
            {"kind": "Switch", "props": {"label": "Set as default", "name": "is_default", "description": "Fallback for unresolved requests. Unsets the current default automatically. Rare \u2014 usually only set at initial release."}},
            {"kind": "Button", "props": {"variant": "primary", "size": "md", "type": "submit", "children": "Create draft"}}
          ]
        }
      ]
    }
  ]
}
