{
  "id": "versioning.resources.api-version.show",
  "title": "API version detail",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/platform/versioning/api-versions/{slug}",
  "host": "central-admin",
  "audience": "authenticated",
  "resource": {"module": "versioning", "entity": "api-version", "action": "show"},
  "requiresPermission": "platform.versioning.view",
  "params": [{"name": "slug", "type": "string", "in": "path", "required": true}],
  "dataSources": [
    {"name": "apiVersion", "kind": "http.get", "urlExpr": "'/api/v1/platform/versioning/api-versions/' + params.slug + '?include=deprecationNotices,migrationTarget'", "unwrap": "data"}
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": {"className": "flex flex-col gap-6 p-6 max-w-4xl mx-auto"},
      "children": [
        {"kind": "Link", "props": {"leadingIcon": "arrow-left", "children": "Back", "className": "text-sm text-muted"}, "actions": {"onPress": {"kind": "navigate", "to": "/platform/versioning/api-versions"}}},
        {
          "kind": "View",
          "props": {"className": "flex items-start justify-between gap-4"},
          "children": [
            {
              "kind": "View",
              "props": {"className": "flex flex-col gap-1"},
              "children": [
                {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold font-mono"}, "bindings": {"children": {"$ref": "apiVersion.slug"}}},
                {"kind": "Text", "props": {"className": "text-sm text-muted"}, "bindings": {"children": {"$ref": "apiVersion.name"}}},
                {"kind": "View", "props": {"className": "flex items-center gap-2 mt-2"}, "children": [
                  {"kind": "Widget", "widget": "versioning.version-lifecycle-chip", "props": {"state": {"$ref": "apiVersion.state"}, "size": "md"}},
                  {"kind": "Chip", "props": {"size": "sm", "variant": "neutral"}, "bindings": {"children": {"$expr": "apiVersion.scheme === 'semver' ? 'SemVer' : 'CalVer'"}}},
                  {"kind": "Chip", "props": {"size": "sm", "variant": "warning"}, "bindings": {"hidden": {"$expr": "!apiVersion.is_default"}, "children": "Default"}}
                ]}
              ]
            }
          ]
        },
        {
          "kind": "Card",
          "props": {"className": "p-6"},
          "children": [
            {"kind": "Text", "props": {"as": "h2", "className": "text-sm font-semibold text-muted uppercase tracking-wide mb-3", "children": "Timeline"}},
            {"kind": "DescriptionList", "children": [
              {"kind": "DescriptionListItem", "props": {"label": "Released"}, "bindings": {"value": {"$expr": "apiVersion.released_at ? formatDate(apiVersion.released_at) : 'Not yet released'"}}},
              {"kind": "DescriptionListItem", "props": {"label": "Deprecated"}, "bindings": {"value": {"$expr": "apiVersion.deprecated_at ? formatDate(apiVersion.deprecated_at) : 'Not deprecated'"}}},
              {"kind": "DescriptionListItem", "props": {"label": "Sunset scheduled"}, "bindings": {"value": {"$expr": "apiVersion.sunset_at ? formatDate(apiVersion.sunset_at) + ' (' + (apiVersion.days_until_sunset ?? 0) + 'd remaining)' : 'No sunset scheduled'"}}},
              {"kind": "DescriptionListItem", "props": {"label": "Migration target"}, "bindings": {"value": {"$expr": "apiVersion.migration_target_slug ? apiVersion.migration_target_slug : 'None (manual migration required on sunset)'"}}},
              {"kind": "DescriptionListItem", "props": {"label": "Migration guide"}, "bindings": {"value": {"$expr": "apiVersion.sunset_notice_url ? apiVersion.sunset_notice_url : 'Not provided'"}}}
            ]}
          ]
        },
        {
          "kind": "Card",
          "props": {"className": "p-6"},
          "children": [
            {"kind": "Text", "props": {"as": "h2", "className": "text-sm font-semibold text-muted uppercase tracking-wide mb-3", "children": "Description"}},
            {"kind": "Markdown", "props": {"className": "prose prose-sm max-w-none"}, "bindings": {"content": {"$ref": "apiVersion.description"}}}
          ]
        },
        {
          "kind": "Card",
          "props": {"className": "p-6"},
          "children": [
            {"kind": "Text", "props": {"as": "h2", "className": "text-sm font-semibold text-muted uppercase tracking-wide mb-3", "children": "Deprecation notices"}},
            {"kind": "List", "props": {"emptyState": {"title": "No deprecation notices published for this version"}}, "bindings": {"items": {"$ref": "apiVersion.deprecation_notices"}}, "itemRenderer": {"kind": "View", "props": {"className": "flex items-center justify-between p-3 border-b last:border-b-0"}, "children": [
              {"kind": "View", "props": {"className": "flex flex-col"}, "children": [
                {"kind": "Text", "props": {"className": "font-medium"}, "bindings": {"children": {"$ref": "row.title"}}},
                {"kind": "Text", "props": {"className": "text-xs text-muted"}, "bindings": {"children": {"$expr": "row.notice_type + ' \u00b7 published ' + (row.published_at ? formatDate(row.published_at) : 'draft')"}}}
              ]},
              {"kind": "Chip", "props": {"size": "sm"}, "bindings": {"variant": {"$expr": "row.state === 'published' ? 'success' : (row.state === 'draft' ? 'neutral' : 'warning')"}, "children": {"$ref": "row.state"}}}
            ]}}
          ]
        }
      ]
    }
  ]
}
