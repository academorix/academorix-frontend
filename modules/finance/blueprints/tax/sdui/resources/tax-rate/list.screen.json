{
  "id": "tax.resources.tax-rate.list",
  "title": "Tax rates",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/tax/rates",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "tax", "entity": "tax-rate", "action": "list" },
  "requiresPermission": "tax.rates.viewAny",
  "requiresEntitlement": "tax_capture",
  "dataSources": [
    {
      "name": "rates",
      "kind": "http.get",
      "url": "/api/v1/tax/rates",
      "unwrap": "data",
      "queryFromFilters": true
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-7xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "kind": "View",
              "children": [
                { "kind": "Text", "props": { "as": "h1", "className": "text-2xl font-semibold", "children": "Tax rates" } },
                { "kind": "Text", "props": { "className": "text-sm text-muted", "children": "Per-jurisdiction rate rows with effective-range time bounds." } }
              ]
            },
            {
              "kind": "View",
              "props": { "className": "flex items-center gap-2" },
              "children": [
                {
                  "kind": "Button",
                  "props": { "variant": "secondary", "leadingIcon": "arrow-down-tray", "children": "Sync from provider" },
                  "requiresPermission": "tax.rates.sync",
                  "actions": {
                    "onPress": { "kind": "navigate", "to": "/tenant/tax/rates/sync" }
                  }
                },
                {
                  "kind": "Button",
                  "props": { "variant": "primary", "leadingIcon": "plus", "children": "Add rate" },
                  "requiresPermission": "tax.rates.create",
                  "actions": {
                    "onPress": { "kind": "navigate", "to": "/tenant/tax/rates/new" }
                  }
                }
              ]
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "flex items-center gap-2 py-2 flex-wrap" },
          "children": [
            {
              "kind": "Widget",
              "widget": "tax.jurisdiction-picker",
              "actions": {
                "onSelectionChange": { "kind": "filter.set", "field": "jurisdiction_id", "valueExpr": "$selectedKey" }
              }
            },
            {
              "kind": "ComboBox",
              "props": { "label": "Rate type", "menuTrigger": "focus", "className": "min-w-48" },
              "props_items_source": "tax.rate-type-catalog",
              "actions": {
                "onSelectionChange": { "kind": "filter.set", "field": "rate_type", "valueExpr": "$selectedKey" }
              }
            },
            {
              "kind": "Switch",
              "props": { "label": "Active only" },
              "actions": {
                "onChange": { "kind": "filter.set", "field": "active", "valueExpr": "$value" }
              }
            }
          ]
        },
        {
          "kind": "DataGrid",
          "bindings": {
            "items": { "$ref": "rates" },
            "isLoading": { "$ref": "rates.isLoading" }
          },
          "props": {
            "className": "w-full",
            "columns": [
              { "field": "name", "label": "Name", "sortable": true, "width": 240 },
              { "field": "rate_type", "label": "Type", "sortable": true, "width": 140 },
              { "field": "percentage", "label": "Rate", "sortable": true, "width": 100, "renderer": { "widget": "tax.rate-badge" } },
              { "field": "applies_to", "label": "Applies to", "width": 120 },
              { "field": "effective_from", "label": "Effective from", "sortable": true, "defaultSort": "desc", "width": 140, "formatter": "date" },
              { "field": "effective_to", "label": "Effective to", "width": 140, "formatter": "date" },
              { "field": "source", "label": "Source", "width": 120 }
            ],
            "onRowPress": {
              "kind": "navigate",
              "toExpr": "'/tenant/tax/rates/' + row.id"
            }
          },
          "emptyState": {
            "kind": "View",
            "props": { "className": "text-center py-12" },
            "children": [
              { "kind": "Icon", "props": { "name": "calculator", "className": "size-12 mx-auto text-muted" } },
              { "kind": "Text", "props": { "className": "mt-4 text-lg font-medium", "children": "No tax rates configured yet" } },
              { "kind": "Text", "props": { "className": "text-sm text-muted", "children": "Add rates manually or sync from your configured provider." } }
            ]
          }
        }
      ]
    }
  ]
}
