    { "code": "WALLET_POINTS_NEGATIVE", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "wallet.errors.points_negative", "description": "Points balance cannot go negative. Redemption exceeds current earning." }
