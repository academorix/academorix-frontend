{
  "id": "transaction.resources.transaction.view",
  "title": "Transaction",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/finance/transactions/:id",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "transaction", "entity": "transaction", "action": "view" },
  "requiresPermission": "transaction.view",
  "requiresEntitlement": "transaction_capture",
  "dataSources": [
    {
      "name": "transaction",
      "kind": "http.get",
      "url": "/api/v1/transactions/:id",
      "unwrap": "data"
    },
    {
      "name": "ledger_entries",
      "kind": "http.get",
      "url": "/api/v1/transactions/:id/ledger-entries",
      "unwrap": "data"
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-6 p-6 max-w-6xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "kind": "View",
              "children": [
                { "kind": "Text", "props": { "as": "h1", "className": "text-2xl font-semibold font-mono" }, "bindings": { "children": { "$ref": "transaction.transaction_number" } } },
                {
                  "kind": "View",
                  "props": { "className": "flex items-center gap-2 mt-1" },
                  "children": [
                    { "kind": "Widget", "widget": "transaction.kind-chip", "bindings": { "kind": { "$ref": "transaction.kind" } } },
                    { "kind": "Chip", "bindings": { "variant": { "$expr": "$ref('transaction.status') === 'posted' ? 'success' : 'warning'" }, "children": { "$ref": "transaction.status" } } },
                    {
                      "kind": "Chip",
                      "bindings": { "hidden": { "$expr": "!$ref('transaction.reversal_reason')" }, "children": { "$expr": "'Reversal: ' + $ref('transaction.reversal_reason')" } },
                      "props": { "variant": "warning" }
                    }
                  ]
                }
              ]
            },
            {
              "kind": "Button",
              "props": {
                "variant": "danger",
                "size": "md",
                "children": "Reverse transaction",
                "leadingIcon": "arrow-uturn-left"
              },
              "bindings": {
                "hidden": {
                  "$expr": "!$permission('transaction.reverse') || $ref('transaction.status') !== 'posted'"
                }
              },
              "actions": {
                "onPress": {
                  "kind": "navigate",
                  "toExpr": "'/tenant/finance/transactions/' + $ref('transaction.id') + '/reverse'"
                }
              }
            }
          ]
        },
        {
          "kind": "Card",
          "props": { "className": "p-6" },
          "children": [
            { "kind": "Text", "props": { "as": "h2", "className": "text-lg font-medium mb-4", "children": "Movement" } },
            {
              "kind": "View",
              "props": { "className": "grid grid-cols-3 gap-4" },
              "children": [
                { "kind": "LabeledValue", "props": { "label": "Amount", "formatter": "currency" }, "bindings": { "value": { "$ref": "transaction.amount_cents" }, "currency": { "$ref": "transaction.currency" } } },
                { "kind": "LabeledValue", "props": { "label": "Currency" }, "bindings": { "value": { "$ref": "transaction.currency" } } },
                { "kind": "LabeledValue", "props": { "label": "Effective date", "formatter": "date" }, "bindings": { "value": { "$ref": "transaction.effective_date" } } },
                { "kind": "LabeledValue", "props": { "label": "Posted at", "formatter": "datetime" }, "bindings": { "value": { "$ref": "transaction.posted_at" } } },
                {
                  "kind": "LabeledValue",
                  "props": { "label": "Reference" },
                  "bindings": {
                    "hidden": { "$expr": "!$ref('transaction.reference_type')" },
                    "value": { "$expr": "$ref('transaction.reference_type') + ' — ' + $ref('transaction.reference_id')" }
                  }
                },
                {
                  "kind": "LabeledValue",
                  "props": { "label": "Base amount (converted)", "formatter": "currency" },
                  "bindings": {
                    "hidden": { "$expr": "!$ref('transaction.base_amount_cents')" },
                    "value": { "$ref": "transaction.base_amount_cents" },
                    "currency": { "$ref": "transaction.base_currency" }
                  }
                }
              ]
            }
          ]
        },
        {
          "kind": "Card",
          "props": { "className": "p-6" },
          "children": [
            { "kind": "Text", "props": { "as": "h2", "className": "text-lg font-medium mb-4", "children": "Ledger entries" } },
            {
              "kind": "DataGrid",
              "bindings": { "items": { "$ref": "ledger_entries" } },
              "props": {
                "className": "w-full",
                "columns": [
                  { "field": "account", "label": "Account", "width": 200 },
                  { "field": "regulator_category", "label": "Category", "width": 140 },
                  { "field": "debit_cents", "label": "Debit", "width": 140, "renderer": { "kind": "Text", "formatter": "currency", "className": "text-right font-mono", "conditionalHidden": { "$expr": "row.debit_cents === 0" } } },
                  { "field": "credit_cents", "label": "Credit", "width": 140, "renderer": { "kind": "Text", "formatter": "currency", "className": "text-right font-mono", "conditionalHidden": { "$expr": "row.credit_cents === 0" } } },
                  { "field": "description", "label": "Description" }
                ]
              }
            },
            {
              "kind": "View",
              "props": { "className": "mt-4 flex items-center justify-end gap-4 text-sm text-muted font-mono" },
              "children": [
                { "kind": "Text", "bindings": { "children": { "$expr": "'Total debits: ' + $sumFormat($ref('ledger_entries'), 'debit_cents', $ref('transaction.currency'))" } } },
                { "kind": "Text", "bindings": { "children": { "$expr": "'Total credits: ' + $sumFormat($ref('ledger_entries'), 'credit_cents', $ref('transaction.currency'))" } } },
                { "kind": "Chip", "props": { "variant": "success", "children": "Balanced" } }
              ]
            }
          ]
        },
        {
          "kind": "Card",
          "bindings": {
            "hidden": { "$expr": "!$ref('transaction.source_transaction_id') && !$refExists('transaction.reversals')" }
          },
          "props": { "className": "p-6" },
          "children": [
            { "kind": "Text", "props": { "as": "h2", "className": "text-lg font-medium mb-4", "children": "Reversal chain" } },
            {
              "kind": "View",
              "bindings": { "hidden": { "$expr": "!$ref('transaction.source_transaction_id')" } },
              "children": [
                { "kind": "Text", "props": { "className": "text-sm text-muted mb-2", "children": "This transaction reverses:" } },
                {
                  "kind": "Link",
                  "bindings": {
                    "toExpr": "'/tenant/finance/transactions/' + $ref('transaction.source_transaction_id')",
                    "children": { "$expr": "'Source transaction ' + $ref('transaction.source_transaction_id')" }
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
