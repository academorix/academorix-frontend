{
  "id": "refund.resources.refund.detail",
  "title": "Refund detail",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/refunds/{refund}",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "refund", "entity": "refund", "action": "view" },
  "requiresPermission": "refunds.view",
  "requiresEntitlement": "refund_capture",
  "dataSources": [
    {
      "name": "refund",
      "kind": "http.get",
      "url": "/api/v1/refunds/{refund}",
      "unwrap": "data"
    },
    {
      "name": "refund_lines",
      "kind": "http.get",
      "url": "/api/v1/refunds/{refund}/lines",
      "unwrap": "data",
      "condition": { "$expr": "refund.refund_type !== 'full'" }
    }
  ],
  "broadcasts": [
    { "channel": "tenant.{tenantId}.refunds", "onEvent": ["*"], "filter": { "refund_id": "{refund}" }, "action": "refresh" }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-5xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "kind": "View",
              "children": [
                {
                  "kind": "Text",
                  "props": { "as": "h1", "className": "text-2xl font-semibold font-mono" },
                  "bindings": { "children": { "$ref": "refund.refund_number" } }
                },
                {
                  "kind": "Text",
                  "props": { "className": "text-sm text-muted mt-1" },
                  "bindings": {
                    "children": {
                      "$expr": "refund.reason.split('_').map(w => w[0].toUpperCase() + w.slice(1)).join(' ') + ' — ' + refund.reason_note"
                    }
                  }
                }
              ]
            },
            {
              "kind": "Widget",
              "widget": "refund.refund-status-chip",
              "props": { "size": "lg" },
              "bindings": {
                "status": { "$ref": "refund.status" },
                "requiresApproval": { "$ref": "refund.requires_approval" }
              }
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "flex items-center gap-2" },
          "children": [
            {
              "kind": "Button",
              "props": { "variant": "primary", "leadingIcon": "check", "children": "Approve" },
              "actions": { "onPress": { "kind": "navigate", "toExpr": "'/tenant/refunds/' + refund.id + '/approve'" } },
              "bindings": {
                "hidden": {
                  "$expr": "refund.status !== 'awaiting_approval' || refund.initiated_by_user_id === auth.user.id"
                }
              },
              "requiresPermission": "refunds.approve"
            },
            {
              "kind": "Button",
              "props": { "variant": "danger", "leadingIcon": "x-mark", "children": "Reject" },
              "actions": { "onPress": { "kind": "navigate", "toExpr": "'/tenant/refunds/' + refund.id + '/reject'" } },
              "bindings": {
                "hidden": {
                  "$expr": "refund.status !== 'awaiting_approval' || refund.initiated_by_user_id === auth.user.id"
                }
              },
              "requiresPermission": "refunds.approve"
            },
            {
              "kind": "Button",
              "props": { "variant": "outline", "children": "Cancel refund" },
              "actions": {
                "onPress": {
                  "kind": "http.post",
                  "url": "/api/v1/refunds/{refund}/cancel",
                  "onSuccess": { "kind": "toast", "message": "Refund cancelled." }
                }
              },
              "bindings": {
                "hidden": {
                  "$expr": "!['awaiting_approval', 'approved'].includes(refund.status)"
                }
              },
              "requiresPermission": "refunds.cancel"
            },
            {
              "kind": "Button",
              "props": { "variant": "outline", "leadingIcon": "wrench-screwdriver", "children": "Force fail" },
              "actions": { "onPress": { "kind": "navigate", "toExpr": "'/tenant/refunds/' + refund.id + '/force-fail'" } },
              "bindings": {
                "hidden": { "$expr": "refund.status !== 'provider_error'" }
              },
              "requiresPermission": "refunds.force-fail"
            }
          ]
        },
        {
          "kind": "Tabs",
          "props": { "defaultKey": "timeline" },
          "children": [
            {
              "kind": "Tab",
              "props": { "id": "timeline", "label": "Timeline" },
              "children": [
                {
                  "kind": "Timeline",
                  "bindings": {
                    "items": {
                      "$expr": "[{ at: refund.initiated_at, label: 'Initiated', by: refund.initiated_by_user_id }].concat(refund.approved_at ? [{ at: refund.approved_at, label: 'Approved', by: refund.approved_by_user_id }] : []).concat(refund.rejected_at ? [{ at: refund.rejected_at, label: 'Rejected', by: refund.rejected_by_user_id, note: refund.rejection_reason }] : []).concat(refund.processed_at ? [{ at: refund.processed_at, label: 'Processed' }] : []).concat(refund.failed_at ? [{ at: refund.failed_at, label: 'Failed', note: refund.failure_reason }] : [])"
                    }
                  }
                }
              ]
            },
            {
              "kind": "Tab",
              "props": { "id": "details", "label": "Details" },
              "children": [
                {
                  "kind": "DescriptionList",
                  "bindings": {
                    "items": {
                      "$expr": "[{ label: 'Amount', value: hasPermission('refunds.view-financials') ? formatCurrency(refund.amount_cents, refund.currency) : '••••' }, { label: 'Type', value: refund.refund_type }, { label: 'Refunded to', value: refund.refunded_to }, { label: 'Provider', value: refund.provider }, { label: 'Payment', value: refund.payment_id, link: '/tenant/payments/' + refund.payment_id }, { label: 'Invoice', value: refund.invoice_id, link: '/tenant/invoices/' + refund.invoice_id }, refund.credit_note_id ? { label: 'Credit note', value: refund.credit_note_id, link: '/tenant/credit-notes/' + refund.credit_note_id } : null, refund.transaction_id ? { label: 'Transaction', value: refund.transaction_id, link: '/tenant/transactions/' + refund.transaction_id } : null].filter(Boolean)"
                    }
                  }
                }
              ]
            },
            {
              "kind": "Tab",
              "props": { "id": "lines", "label": "Refund lines", "hidden_when": "refund.refund_type === 'full'" },
              "children": [
                {
                  "kind": "Table",
                  "bindings": {
                    "items": { "$ref": "refund_lines" },
                    "columns": [
                      { "key": "invoice_line_id", "label": "Invoice line", "renderer": "monospace-truncate" },
                      { "key": "amount_cents", "label": "Amount", "renderer": "currency", "params": { "currency": "row.currency" } },
                      { "key": "proration_config", "label": "Proration", "renderer": "expandable-json" },
                      { "key": "reason_note", "label": "Note" }
                    ]
                  }
                }
              ]
            }
          ]
        },
        {
          "kind": "Alert",
          "props": { "variant": "warning" },
          "bindings": {
            "hidden": {
              "$expr": "!(refund.status === 'succeeded' && (!refund.credit_note_id || !refund.transaction_id))"
            }
          },
          "children": [
            { "kind": "Text", "props": { "className": "font-medium", "children": "Finalization pending" } },
            { "kind": "Text", "props": { "children": "The credit note or offsetting transaction is still being created. Refresh in a minute or contact support if this persists." } }
          ]
        }
      ]
    }
  ]
}
