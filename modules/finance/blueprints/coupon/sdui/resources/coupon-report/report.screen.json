{
  "id": "coupon.resources.coupon-report.show",
  "title": "Coupon report",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/coupons/report",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "coupon", "entity": "coupon-report", "action": "show" },
  "requiresPermission": "coupons.view-report",
  "requiresEntitlement": "coupon_capture",
  "dataSources": [
    {
      "name": "report",
      "kind": "http.get",
      "url": "/api/v1/coupons/report",
      "unwrap": "data",
      "queryFromFilters": true
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-7xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            {
              "kind": "View",
              "children": [
                { "kind": "Text", "props": { "as": "h1", "className": "text-2xl font-semibold", "children": "Coupon usage report" } },
                { "kind": "Text", "props": { "className": "text-sm text-muted" }, "bindings": { "children": { "$expr": "'Reporting period: ' + formatDate(report.period_start, 'short') + ' - ' + formatDate(report.period_end, 'short')" } } }
              ]
            },
            {
              "kind": "View",
              "props": { "className": "flex items-center gap-2" },
              "children": [
                {
                  "kind": "ComboBox",
                  "props": { "label": "Range", "menuTrigger": "focus", "defaultSelectedKey": "7d" },
                  "props_items": [
                    { "id": "7d", "label": "Last 7 days" },
                    { "id": "30d", "label": "Last 30 days" },
                    { "id": "90d", "label": "Last 90 days" }
                  ],
                  "actions": {
                    "onSelectionChange": { "kind": "filter.set", "field": "range", "valueExpr": "$selectedKey" }
                  }
                },
                {
                  "kind": "Button",
                  "props": { "variant": "outline", "leadingIcon": "arrow-down-tray", "children": "Export CSV" },
                  "actions": {
                    "onPress": {
                      "kind": "http.get.download",
                      "urlExpr": "'/api/v1/coupons/report?format=csv&range=' + (filters.range || '7d')"
                    }
                  }
                }
              ]
            }
          ]
        },
        {
          "kind": "Grid",
          "props": { "className": "grid grid-cols-1 md:grid-cols-4 gap-4" },
          "children": [
            {
              "kind": "StatCard",
              "props": { "label": "Coupons issued" },
              "bindings": { "value": { "$ref": "report.coupon_count" } }
            },
            {
              "kind": "StatCard",
              "props": { "label": "Redemptions" },
              "bindings": { "value": { "$ref": "report.redemption_count" } }
            },
            {
              "kind": "StatCard",
              "props": { "label": "Total discount" },
              "requiresPermission": "coupons.view-financials",
              "bindings": { "value": { "$expr": "formatMoney(report.total_discount_cents, report.currency)" } }
            },
            {
              "kind": "StatCard",
              "props": { "label": "Clawbacks" },
              "bindings": {
                "value": { "$ref": "report.clawback_count" },
                "trend": { "$expr": "report.clawback_rate_pct + '% rate'" },
                "variant": { "$expr": "report.clawback_rate_pct > 5 ? 'warning' : 'neutral'" }
              }
            }
          ]
        },
        {
          "kind": "Card",
          "props": { "className": "p-4" },
          "children": [
            { "kind": "Text", "props": { "as": "h3", "className": "font-medium mb-3", "children": "Redemptions over time" } },
            {
              "kind": "SparklineChart",
              "props": { "className": "h-32" },
              "bindings": {
                "series": { "$ref": "report.timeseries" }
              }
            }
          ]
        },
        {
          "kind": "Grid",
          "props": { "className": "grid grid-cols-1 md:grid-cols-2 gap-4" },
          "children": [
            {
              "kind": "Card",
              "props": { "className": "p-4" },
              "children": [
                { "kind": "Text", "props": { "as": "h3", "className": "font-medium mb-3", "children": "Top coupon codes" } },
                {
                  "kind": "Table",
                  "props": { "size": "sm" },
                  "bindings": { "items": { "$ref": "report.top_codes" } },
                  "columns": [
                    { "id": "code", "label": "Code", "cell": { "kind": "Text", "props": { "className": "font-mono text-sm" }, "bindings": { "children": { "$ref": "row.code" } } } },
                    { "id": "count", "label": "Uses", "cell": { "kind": "Text", "bindings": { "children": { "$ref": "row.redemption_count" } } } },
                    {
                      "id": "discount",
                      "label": "Discount",
                      "requiresPermission": "coupons.view-financials",
                      "cell": { "kind": "Text", "bindings": { "children": { "$expr": "formatMoney(row.total_discount_cents, row.currency)" } } }
                    }
                  ]
                }
              ]
            },
            {
              "kind": "Card",
              "props": { "className": "p-4" },
              "children": [
                { "kind": "Text", "props": { "as": "h3", "className": "font-medium mb-3", "children": "By issuance source" } },
                {
                  "kind": "Table",
                  "props": { "size": "sm" },
                  "bindings": { "items": { "$ref": "report.by_issuance_source" } },
                  "columns": [
                    {
                      "id": "source",
                      "label": "Source",
                      "cell": {
                        "kind": "Chip",
                        "props": { "size": "sm", "variant": "neutral" },
                        "bindings": { "children": { "$ref": "row.issuance_source" } }
                      }
                    },
                    { "id": "coupon_count", "label": "Coupons", "cell": { "kind": "Text", "bindings": { "children": { "$ref": "row.coupon_count" } } } },
                    { "id": "redemption_count", "label": "Uses", "cell": { "kind": "Text", "bindings": { "children": { "$ref": "row.redemption_count" } } } },
                    {
                      "id": "discount",
                      "label": "Discount",
                      "requiresPermission": "coupons.view-financials",
                      "cell": { "kind": "Text", "bindings": { "children": { "$expr": "formatMoney(row.total_discount_cents, row.currency)" } } }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
