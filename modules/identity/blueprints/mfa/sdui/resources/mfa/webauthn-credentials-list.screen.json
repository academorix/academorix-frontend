{
  "id": "academorix://modules/mfa/sdui/resources/mfa/webauthn-credentials-list",
  "$version": 1,
  "kind": "screen",
  "route": "/me/mfa/webauthn/credentials",
  "title": "Registered passkeys and security keys",
  "description": "Managed list of the caller's registered WebAuthn credentials. Each row renders as a webauthn-credential-card widget with rename / disable / delete actions. Delete + disable require a recent MFA challenge.",
  "permission": "mfa.webauthn_credentials.viewAny",
  "entitlement": "mfa_webauthn",
  "data_source": {
    "kind": "resource",
    "resource": "webauthn-credential",
    "endpoint": "GET /api/v1/me/mfa/webauthn/credentials",
    "cache_ttl_seconds": 60
  },
  "layout": {
    "type": "list",
    "filters": [
      {
        "name": "include_disabled",
        "control_type": "toggle",
        "label": "Show disabled devices",
        "default": false
      }
    ],
    "empty_state": {
      "title": "No registered devices",
      "body": "Register a passkey or hardware key to enable phishing-resistant sign-in.",
      "action": {
        "label": "Register a passkey",
        "route": "/me/mfa/webauthn/register",
        "kind": "primary"
      }
    },
    "item_widget": "webauthn-credential-card",
    "item_actions": [
      {
        "label": "Rename",
        "kind": "inline-edit",
        "field": "device_name",
        "endpoint": "PATCH /api/v1/me/mfa/webauthn/credentials/{id}",
        "requires_step_up": true
      },
      {
        "label": "Disable",
        "kind": "secondary",
        "endpoint": "PATCH /api/v1/me/mfa/webauthn/credentials/{id}",
        "body": { "disabled_at": "now" },
        "requires_step_up": true,
        "condition": "item.is_active",
        "confirm": {
          "title": "Disable this device?",
          "body": "This device can't sign you in until you re-enable it. Retained for 90 days before automatic removal."
        }
      },
      {
        "label": "Delete",
        "kind": "danger",
        "endpoint": "DELETE /api/v1/me/mfa/webauthn/credentials/{id}",
        "requires_step_up": true,
        "confirm": {
          "title": "Delete this device?",
          "body": "This removes the device immediately. You'll need to register a fresh credential to use it again.",
          "confirmation_input": {
            "label": "Type the device name to confirm",
            "expected": "{{item.device_name}}"
          }
        }
      }
    ],
    "footer_action": {
      "label": "Register another device",
      "route": "/me/mfa/webauthn/register",
      "kind": "primary",
      "condition": "response.length < 10 AND caller.entitlements.includes('mfa_multiple_devices')"
    }
  }
}
