{
  "id": "academorix://modules/mfa/sdui/widgets/webauthn-credential-card",
  "$version": 1,
  "kind": "widget",
  "name": "webauthn-credential-card",
  "description": "One credential's card in the credentials-list view. Shows device_name + a device-type icon (platform vs hardware key vs synced passkey), last_used_at, action menu.",
  "props": {
    "data": {
      "type": "object",
      "description": "One WebauthnCredentialData DTO."
    },
    "compact": {
      "type": "boolean",
      "default": false,
      "description": "Compact mode = one-line summary; full = card with all metadata."
    }
  },
  "renders": {
    "kind": "card",
    "layout": "horizontal",
    "left": {
      "kind": "icon-badge",
      "icon": "{{props.data.is_platform_authenticator ? 'device-phone-mobile' : props.data.is_synced_passkey ? 'cloud' : 'key'}}",
      "colour": "{{props.data.is_active ? 'success' : 'muted'}}"
    },
    "body": {
      "kind": "text-block",
      "title": "{{props.data.device_name}}",
      "subtitle_line_1": "{{props.data.is_platform_authenticator ? 'Platform authenticator' : props.data.is_synced_passkey ? 'Synced passkey' : 'Hardware key'}} · {{props.data.attestation_format}}",
      "subtitle_line_2": "{{props.data.last_used_at ? 'Last used ' + (props.data.last_used_at | relative_time) : 'Never used'}}"
    },
    "right_status": {
      "condition": "NOT props.data.is_active",
      "widget": "chip",
      "colour": "muted",
      "label": "Disabled",
      "tooltip": "Disabled on {{props.data.disabled_at | date}}. Auto-removed after 90 days."
    },
    "actions": {
      "condition": "NOT props.compact",
      "kind": "action-menu",
      "items": [
        {
          "label": "Rename",
          "kind": "inline-edit",
          "field": "device_name",
          "endpoint": "PATCH /api/v1/me/mfa/webauthn/credentials/{id}",
          "requires_step_up": true
        },
        {
          "label": "Disable",
          "kind": "danger",
          "condition": "props.data.is_active",
          "endpoint": "PATCH /api/v1/me/mfa/webauthn/credentials/{id}",
          "body": { "disabled_at": "now" },
          "requires_step_up": true
        },
        {
          "label": "Delete permanently",
          "kind": "danger",
          "endpoint": "DELETE /api/v1/me/mfa/webauthn/credentials/{id}",
          "requires_step_up": true,
          "confirm": {
            "title": "Delete this device?",
            "body": "This removes the device immediately."
          }
        }
      ]
    }
  }
}
