{
  "id": "service-accounts.service-account-status-chip",
  "title": "Service account status chip",
  "version": 1,
  "kind": "SduiWidget",
  "description": "Colour-coded chip for the four status values (pending / active / disabled / expired) with rotation-urgency overlays. Composed on the list surface + detail card + widgets that reference an SA row. Two overlays: `is_expiring_soon` renders a secondary warning chip; `is_dormant` renders a muted-warning secondary chip. Both overlays are OFF when status is `disabled` or `expired` (the SA already stopped working; the operator doesn't need a further urgency signal).",
  "props": {
    "status": {
      "type": "string",
      "enum": ["pending", "active", "disabled", "expired"],
      "required": true
    },
    "is_expiring_soon": {
      "type": "boolean",
      "required": false,
      "default": false
    },
    "is_dormant": {
      "type": "boolean",
      "required": false,
      "default": false
    },
    "size": {
      "type": "string",
      "enum": ["xs", "sm", "md"],
      "required": false,
      "default": "sm"
    }
  },
  "renderRules": [
    {
      "when": "status == 'pending'",
      "chip": { "variant": "neutral", "children": "Pending", "leadingIcon": "clock" }
    },
    {
      "when": "status == 'active' && !is_expiring_soon && !is_dormant",
      "chip": { "variant": "success", "children": "Active", "leadingIcon": "check-circle" }
    },
    {
      "when": "status == 'active' && is_expiring_soon",
      "chips": [
        { "variant": "success", "children": "Active", "leadingIcon": "check-circle" },
        { "variant": "warning", "children": "Rotation due", "leadingIcon": "clock-alert" }
      ]
    },
    {
      "when": "status == 'active' && is_dormant && !is_expiring_soon",
      "chips": [
        { "variant": "success", "children": "Active", "leadingIcon": "check-circle" },
        { "variant": "warning-muted", "children": "Dormant", "leadingIcon": "moon" }
      ]
    },
    {
      "when": "status == 'disabled'",
      "chip": { "variant": "danger-outline", "children": "Disabled", "leadingIcon": "no-symbol" }
    },
    {
      "when": "status == 'expired'",
      "chip": { "variant": "danger", "children": "Expired", "leadingIcon": "exclamation-circle" }
    }
  ],
  "notes": [
    "Colours align with HeroUI's design tokens (neutral / success / warning / warning-muted / danger-outline / danger).",
    "Multi-chip renderings use a horizontal flex-gap-1 wrapper for the two chips.",
    "Size prop propagates to every chip in the render output."
  ]
}
