{
  "id": "newsletter.resources.newsletter-issue.show",
  "title": "Issue detail",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/workspace/newsletters/{newsletter}/issues/{id}",
  "host": "workspace",
  "audience": "authenticated",
  "resource": {"module": "newsletter", "entity": "newsletter-issue", "action": "show"},
  "requiresPermission": "newsletter-issues.view",
  "params": [{"name": "newsletter", "type": "string", "in": "path", "required": true}, {"name": "id", "type": "string", "in": "path", "required": true}],
  "dataSources": [
    {"name": "issue", "kind": "http.get", "urlExpr": "'/api/v1/newsletters/' + params.newsletter + '/issues/' + params.id", "unwrap": "data"},
    {"name": "campaigns", "kind": "http.get", "urlExpr": "'/api/v1/newsletters/' + params.newsletter + '/campaigns?filter[issue_id]=' + params.id + '&sort=-created_at&per_page=5'", "unwrap": "data"}
  ],
  "nodes": [
    {"id": "root", "kind": "View", "props": {"className": "flex flex-col gap-6 p-6 max-w-5xl mx-auto"}, "children": [
      {"kind": "Link", "props": {"leadingIcon": "arrow-left", "children": "Back to issues"}, "actions": {"onPress": {"kind": "navigate", "toExpr": "'/workspace/newsletters/' + params.newsletter + '/issues'"}}},
      {"kind": "View", "props": {"className": "flex items-start justify-between"}, "children": [
        {"kind": "View", "children": [
          {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold"}, "bindings": {"children": {"$ref": "issue.subject"}}},
          {"kind": "Text", "props": {"className": "text-sm text-muted"}, "bindings": {"children": {"$expr": "issue.preheader || ''"}}},
          {"kind": "Chip", "props": {"size": "sm", "className": "mt-2"}, "bindings": {"variant": {"$expr": "issue.state === 'sent' ? 'success' : (issue.state === 'sending' ? 'info' : (issue.state === 'cancelled' ? 'danger' : 'neutral'))"}, "children": {"$ref": "issue.state"}}}
        ]},
        {"kind": "View", "props": {"className": "flex items-center gap-2"}, "children": [
          {"kind": "Button", "props": {"variant": "outline", "size": "sm", "leadingIcon": "eye", "children": "Preview"}, "actions": {"onPress": {"kind": "http.post", "urlExpr": "'/api/v1/newsletters/' + params.newsletter + '/issues/' + params.id + '/preview'", "onSuccess": {"kind": "openDialog", "dialog": "newsletter.dialogs.preview"}}}},
          {"kind": "Button", "props": {"variant": "primary", "size": "sm", "leadingIcon": "paper-airplane", "children": "Schedule"}, "bindings": {"hidden": {"$expr": "!['draft'].includes(issue.state)"}, "isDisabled": {"$expr": "!identity.permissions.includes('newsletter-issues.publish')"}}, "actions": {"onPress": {"kind": "openDialog", "dialog": "newsletter.dialogs.schedule"}}}
        ]}
      ]},
      {"kind": "Card", "props": {"className": "p-6"}, "children": [
        {"kind": "Text", "props": {"as": "h2", "className": "text-sm font-semibold text-muted uppercase tracking-wide mb-3", "children": "Campaigns"}},
        {"kind": "List", "bindings": {"items": {"$ref": "campaigns"}}, "itemRenderer": {"kind": "View", "props": {"className": "flex flex-col gap-2 py-3 border-b last:border-b-0"}, "children": [
          {"kind": "View", "props": {"className": "flex items-center justify-between"}, "children": [
            {"kind": "Text", "props": {"className": "font-medium"}, "bindings": {"children": {"$ref": "row.name"}}},
            {"kind": "Chip", "props": {"size": "sm"}, "bindings": {"variant": {"$expr": "row.state === 'completed' ? 'success' : (row.state === 'failed' ? 'danger' : 'info')"}, "children": {"$ref": "row.state"}}}
          ]},
          {"kind": "Widget", "widget": "newsletter.campaign-progress-bar", "props": {"campaign": {"$ref": "row"}}}
        ]}}
      ]}
    ]}
  ]
}
