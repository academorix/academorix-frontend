{
  "id": "newsletter.resources.newsletter-issue.list",
  "title": "Newsletter issues",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/newsletters/{newsletter}/issues",
  "host": "tenant",
  "audience": "authenticated",
  "resource": {"module": "newsletter", "entity": "newsletter-issue", "action": "list"},
  "requiresPermission": "newsletter-issues.viewAny",
  "params": [{"name": "newsletter", "type": "string", "in": "path", "required": true}],
  "dataSources": [
    {"name": "issues", "kind": "http.get", "urlExpr": "'/api/v1/newsletters/' + params.newsletter + '/issues'", "unwrap": "data", "paginated": true, "queryParamsFromState": ["filter[state]", "sort", "page"]}
  ],
  "nodes": [
    {"id": "root", "kind": "View", "props": {"className": "flex flex-col gap-4 p-6"}, "children": [
      {"kind": "Link", "props": {"leadingIcon": "arrow-left", "children": "Back to newsletter"}, "actions": {"onPress": {"kind": "navigate", "toExpr": "'/tenant/newsletters/' + params.newsletter"}}},
      {"kind": "View", "props": {"className": "flex items-center justify-between"}, "children": [
        {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold", "children": "Issues"}},
        {"kind": "Button", "props": {"variant": "primary", "size": "sm", "leadingIcon": "plus", "children": "New issue"}, "actions": {"onPress": {"kind": "navigate", "toExpr": "'/tenant/newsletters/' + params.newsletter + '/issues/new'"}}}
      ]},
      {"kind": "DataGrid", "bindings": {"items": {"$ref": "issues"}}, "columns": [
        {"id": "subject", "header": "Subject", "cell": {"kind": "Text", "props": {"className": "font-medium"}, "bindings": {"children": {"$ref": "row.subject"}}}},
        {"id": "issue_number", "header": "#", "cell": {"kind": "Text", "props": {"className": "text-sm text-muted"}, "bindings": {"children": {"$expr": "row.issue_number || '\u2014'"}}}},
        {"id": "state", "header": "State", "cell": {"kind": "Chip", "props": {"size": "sm"}, "bindings": {"variant": {"$expr": "row.state === 'sent' ? 'success' : (row.state === 'sending' ? 'info' : (row.state === 'cancelled' ? 'danger' : 'neutral'))"}, "children": {"$ref": "row.state"}}}},
        {"id": "when", "header": "Scheduled / sent", "cell": {"kind": "Text", "props": {"className": "text-sm"}, "bindings": {"children": {"$expr": "row.sent_at ? ('Sent ' + formatRelative(row.sent_at)) : (row.scheduled_at ? ('Scheduled ' + formatRelative(row.scheduled_at)) : 'Draft')"}}}},
        {"id": "actions", "header": "", "align": "end", "cell": {"kind": "Button", "props": {"variant": "ghost", "size": "sm", "children": "Open"}, "actions": {"onPress": {"kind": "navigate", "toExpr": "'/tenant/newsletters/' + params.newsletter + '/issues/' + row.id"}}}}
      ]}
    ]}
  ]
}
