{
  "id": "newsletter.resources.newsletter-subscription.list",
  "title": "Subscribers",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/workspace/newsletters/{newsletter}/subscriptions",
  "host": "workspace",
  "audience": "authenticated",
  "resource": {"module": "newsletter", "entity": "newsletter-subscription", "action": "list"},
  "requiresPermission": "newsletter-subscriptions.viewAny",
  "params": [{"name": "newsletter", "type": "string", "in": "path", "required": true}],
  "dataSources": [
    {"name": "subscriptions", "kind": "http.get", "urlExpr": "'/api/v1/newsletters/' + params.newsletter + '/subscriptions'", "unwrap": "data", "paginated": true, "queryParamsFromState": ["filter[state]", "filter[email]", "sort", "page"]}
  ],
  "nodes": [
    {"id": "root", "kind": "View", "props": {"className": "flex flex-col gap-4 p-6"}, "children": [
      {"kind": "View", "props": {"className": "flex items-center justify-between"}, "children": [
        {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold", "children": "Subscribers"}},
        {"kind": "View", "props": {"className": "flex gap-2"}, "children": [
          {"kind": "Button", "props": {"variant": "outline", "size": "sm", "leadingIcon": "arrow-up-tray", "children": "Import"}, "bindings": {"isDisabled": {"$expr": "!identity.permissions.includes('newsletter-subscriptions.import')"}}, "actions": {"onPress": {"kind": "openDialog", "dialog": "newsletter.dialogs.import-subscribers"}}},
          {"kind": "Button", "props": {"variant": "outline", "size": "sm", "leadingIcon": "arrow-down-tray", "children": "Export"}, "bindings": {"isDisabled": {"$expr": "!identity.permissions.includes('newsletter-subscriptions.export')"}}, "actions": {"onPress": {"kind": "http.post", "urlExpr": "'/api/v1/newsletters/' + params.newsletter + '/subscriptions/export'", "onSuccess": {"kind": "toast.success", "message": "Export dispatched. You'll get an email when it's ready."}}}}
        ]}
      ]},
      {"kind": "View", "props": {"className": "flex flex-wrap gap-3"}, "children": [
        {"kind": "Select", "props": {"label": "State", "name": "filter[state]", "placeholder": "All"}, "options": [{"key": "active", "label": "Active"}, {"key": "pending_confirmation", "label": "Pending"}, {"key": "unsubscribed", "label": "Unsubscribed"}, {"key": "bounced", "label": "Bounced"}, {"key": "complained", "label": "Complained"}], "actions": {"onChange": {"kind": "data.applyFilter", "source": "subscriptions"}}},
        {"kind": "TextField", "props": {"label": "Search email", "name": "filter[email]", "placeholder": "someone@example.com"}, "actions": {"onChange": {"kind": "data.applyFilter", "source": "subscriptions"}}}
      ]},
      {"kind": "DataGrid", "bindings": {"items": {"$ref": "subscriptions"}}, "columns": [
        {"id": "email", "header": "Email", "cell": {"kind": "View", "children": [
          {"kind": "Text", "props": {"className": "font-mono text-sm"}, "bindings": {"children": {"$ref": "row.email"}}},
          {"kind": "Text", "props": {"className": "text-xs text-muted"}, "bindings": {"children": {"$expr": "(row.first_name || '') + ' ' + (row.last_name || '')"}}}
        ]}},
        {"id": "state", "header": "State", "cell": {"kind": "Chip", "props": {"size": "sm"}, "bindings": {"variant": {"$expr": "row.state === 'active' ? 'success' : (['bounced', 'complained'].includes(row.state) ? 'danger' : 'neutral')"}, "children": {"$ref": "row.state"}}}},
        {"id": "engagement", "header": "Engagement", "cell": {"kind": "Text", "props": {"className": "text-sm"}, "bindings": {"children": {"$expr": "row.engagement_score + '/100'"}}}},
        {"id": "source", "header": "Source", "cell": {"kind": "Text", "props": {"className": "text-xs text-muted"}, "bindings": {"children": {"$ref": "row.source"}}}},
        {"id": "subscribed", "header": "Subscribed", "cell": {"kind": "Text", "props": {"className": "text-sm"}, "bindings": {"children": {"$expr": "formatRelative(row.created_at)"}}}}
      ]}
    ]}
  ]
}
