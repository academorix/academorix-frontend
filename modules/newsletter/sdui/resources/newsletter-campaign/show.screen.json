{
  "id": "newsletter.resources.newsletter-campaign.show",
  "title": "Campaign detail",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/workspace/newsletters/{newsletter}/campaigns/{id}",
  "host": "workspace",
  "audience": "authenticated",
  "resource": {"module": "newsletter", "entity": "newsletter-campaign", "action": "show"},
  "requiresPermission": "newsletter-campaigns.view",
  "params": [{"name": "newsletter", "type": "string", "in": "path", "required": true}, {"name": "id", "type": "string", "in": "path", "required": true}],
  "dataSources": [
    {"name": "campaign", "kind": "http.get", "urlExpr": "'/api/v1/newsletters/' + params.newsletter + '/campaigns/' + params.id", "unwrap": "data"}
  ],
  "nodes": [
    {"id": "root", "kind": "View", "props": {"className": "flex flex-col gap-6 p-6 max-w-5xl mx-auto"}, "children": [
      {"kind": "Link", "props": {"leadingIcon": "arrow-left", "children": "Back"}, "actions": {"onPress": {"kind": "navigate", "toExpr": "'/workspace/newsletters/' + params.newsletter + '/campaigns'"}}},
      {"kind": "View", "props": {"className": "flex items-start justify-between"}, "children": [
        {"kind": "View", "children": [
          {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold"}, "bindings": {"children": {"$ref": "campaign.name"}}},
          {"kind": "Chip", "props": {"size": "sm", "className": "mt-1"}, "bindings": {"variant": {"$expr": "campaign.state === 'completed' ? 'success' : (campaign.state === 'failed' ? 'danger' : 'info')"}, "children": {"$ref": "campaign.state"}}}
        ]},
        {"kind": "Button", "props": {"variant": "danger", "size": "sm", "children": "Cancel"}, "bindings": {"hidden": {"$expr": "!['pending', 'in_progress'].includes(campaign.state)"}}, "actions": {"onPress": {"kind": "http.post", "urlExpr": "'/api/v1/newsletters/' + params.newsletter + '/campaigns/' + params.id + '/cancel'", "confirm": {"title": "Cancel this campaign?"}, "onSuccess": [{"kind": "toast.success", "message": "Cancelled"}, {"kind": "data.refresh", "source": "campaign"}]}}}
      ]},
      {"kind": "Card", "props": {"className": "p-6"}, "children": [
        {"kind": "Widget", "widget": "newsletter.campaign-progress-bar", "props": {"campaign": {"$ref": "campaign"}}}
      ]},
      {"kind": "Card", "props": {"className": "p-6"}, "children": [
        {"kind": "Text", "props": {"as": "h2", "className": "text-sm font-semibold text-muted uppercase tracking-wide mb-3", "children": "Rates"}},
        {"kind": "View", "props": {"className": "grid grid-cols-4 gap-4"}, "children": [
          {"kind": "Widget", "widget": "newsletter.newsletter-stat-card", "props": {"kind": "open_rate", "valueExpr": "campaign.open_rate"}},
          {"kind": "Widget", "widget": "newsletter.newsletter-stat-card", "props": {"kind": "click_rate", "valueExpr": "campaign.click_rate"}},
          {"kind": "Widget", "widget": "newsletter.newsletter-stat-card", "props": {"kind": "bounce_rate", "valueExpr": "campaign.bounce_rate"}},
          {"kind": "Widget", "widget": "newsletter.newsletter-stat-card", "props": {"kind": "complaint_rate", "valueExpr": "campaign.complaint_rate"}}
        ]}
      ]}
    ]}
  ]
}
