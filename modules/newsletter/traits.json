    "newsletter_issue": {"traits": ["HasFactory", "HasUlids", "BelongsToWorkspace", "HasMetadata", "HasUserstamps", "HasVersions", "HasActivityLog", "Filterable", "Searchable", "SoftDeletes"]},
    "newsletter_subscription": {"traits": ["HasFactory", "HasUlids", "BelongsToWorkspace", "HasMetadata", "HasUserstamps", "HasAuditable", "HasActivityLog", "Filterable", "Searchable", "SoftDeletes"], "notes": "HasAuditable critical for CAN-SPAM + CASL consent evidence."},
    "newsletter_campaign": {"traits": ["HasFactory", "HasUlids", "BelongsToWorkspace", "HasMetadata", "HasUserstamps", "HasActivityLog", "Filterable", "SoftDeletes"]},
    "newsletter_audience": {"traits": ["HasFactory", "HasUlids", "BelongsToWorkspace", "HasMetadata", "HasUserstamps", "HasVersions", "Filterable", "SoftDeletes"]}
