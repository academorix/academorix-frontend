{
  "id": "academorix://modules/newsletter/health",
  "$version": 1,
  "title": "newsletter \u2014 health probes",
  "probes": [
    {"name": "newsletter-scheduler-recent", "class": "Academorix\\Newsletter\\Health\\Probes\\SchedulerRecentProbe", "category": "readiness", "critical": false, "description": "newsletter:send-scheduled ran within last 5 min.", "timeoutMs": 500},
    {"name": "newsletter-audience-freshness", "class": "Academorix\\Newsletter\\Health\\Probes\\AudienceFreshnessProbe", "category": "readiness", "critical": false, "description": "No audience with cache_refreshed_at > 24h.", "timeoutMs": 500, "thresholds": {"warn_hours": 24, "fail_hours": 72}},
    {"name": "newsletter-in-progress-campaigns-stuck", "class": "Academorix\\Newsletter\\Health\\Probes\\StuckCampaignsProbe", "category": "readiness", "critical": false, "description": "No campaign stuck in state=in_progress for > 2h.", "timeoutMs": 500}
  ]
}
