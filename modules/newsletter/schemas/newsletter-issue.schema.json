    "keyType": "string",
    "keyPrefix": "nli_",
    "incrementing": false,
    "model": "Academorix\\Newsletter\\Models\\NewsletterIssue",
    "interface": "Academorix\\Newsletter\\Contracts\\Data\\NewsletterIssueInterface",
    "implements": ["Academorix\\Newsletter\\Contracts\\Data\\NewsletterIssueInterface"],
    "traits": ["HasFactory", "HasUlids", "BelongsToTenant", "HasMetadata", "HasUserstamps", "HasVersions", "HasActivityLog", "Filterable", "Searchable", "SoftDeletes"],
    "casts": {"state": "NewsletterIssueState", "content_blocks": "array", "scheduled_at": "datetime", "sent_at": "datetime", "variables": "array", "metadata": "array"},
    "appends": ["render_variables_schema"],
    "observers": ["NewsletterIssueObserver"],
    "hidden": [],
    "guarded": []
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": {"type": "string", "length": 64, "primary": true, "description": "Prefixed ULID: `nli_<26 chars>`."},
      "tenant_id": {"type": "string", "length": 64, "nullable": false, "foreign": {"table": "tenants", "column": "id", "onDelete": "cascade"}},
      "newsletter_id": {"type": "string", "length": 64, "nullable": false, "foreign": {"table": "newsletters", "column": "id", "onDelete": "cascade"}},
      "slug": {"type": "string", "length": 100, "nullable": false, "description": "URL-safe within newsletter. Used in browser-view URL."},
      "issue_number": {"type": "integer", "nullable": true, "description": "Auto-incremented per newsletter. Null for adhoc broadcasts."},
      "subject": {"type": "string", "length": 200, "nullable": false},
      "preheader": {"type": "string", "length": 200, "nullable": true, "description": "Inbox preview text."},
      "content_blocks": {"type": "jsonb", "nullable": false, "default": "'[]'::jsonb", "description": "Array of block descriptors. Rendered by the React Email template."},
      "template_ref": {"type": "string", "length": 100, "nullable": false, "default": "'newsletter.default-issue'", "description": "Reference to the notification-templates registry entry."},
      "variables": {"type": "jsonb", "nullable": true, "description": "Extra variables injected into the template at render."},
      "state": {"type": "string", "length": 24, "nullable": false, "default": "'draft'", "description": "Enum: draft / scheduled / sending / sent / cancelled / archived."},
      "scheduled_at": {"type": "timestamptz", "nullable": true, "description": "When to start sending. Null = immediate on transition scheduled\u2192sending."},
      "sent_at": {"type": "timestamptz", "nullable": true},
      "metadata": {"type": "jsonb", "nullable": true},
      "created_by": {"type": "uuid", "nullable": true},
      "updated_by": {"type": "uuid", "nullable": true},
      "deleted_by": {"type": "uuid", "nullable": true},
      "deleted_at": {"type": "timestamptz", "nullable": true},
      "created_at": {"type": "timestamptz", "nullable": false},
      "updated_at": {"type": "timestamptz", "nullable": false}
    },
    "indexes": [
      {"columns": ["newsletter_id", "slug"], "unique": true, "name": "newsletter_issues_slug_unique", "predicate": "deleted_at IS NULL"},
      {"columns": ["newsletter_id", "state", "scheduled_at"], "unique": false, "name": "newsletter_issues_send_scan_idx", "description": "Scheduler scan predicate."},
      {"columns": ["newsletter_id", "issue_number"], "unique": true, "name": "newsletter_issues_number_unique", "predicate": "issue_number IS NOT NULL"}
    ]
  },
  "required": ["id", "tenant_id", "newsletter_id", "slug", "subject", "content_blocks", "template_ref", "state", "created_at", "updated_at"],
  "properties": {
    "id": {"type": "string", "pattern": "^nli_[0-9A-HJKMNP-TV-Z]{26}$"},
    "tenant_id": {"type": "string", "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$"},
    "newsletter_id": {"type": "string", "pattern": "^nlp_[0-9A-HJKMNP-TV-Z]{26}$"},
    "slug": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,99}$"},
    "issue_number": {"type": ["integer", "null"], "minimum": 1},
    "subject": {"type": "string", "maxLength": 200},
    "preheader": {"type": ["string", "null"], "maxLength": 200},
    "content_blocks": {"type": "array"},
    "template_ref": {"type": "string", "maxLength": 100},
    "variables": {"type": ["object", "null"]},
    "state": {"type": "string", "enum": ["draft", "scheduled", "sending", "sent", "cancelled", "archived"]},
