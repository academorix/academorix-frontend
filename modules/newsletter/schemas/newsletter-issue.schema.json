{
  "id": "academorix://modules/newsletter/schemas/newsletter-issue",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "NewsletterIssue",
  "description": "An individual issue of a newsletter. Editorial content + subject + preheader + scheduled_at. State machine: draft \u2192 scheduled \u2192 sending \u2192 sent \u2192 archived (with cancelled as a side path).",
  "type": "object",
  "x-module": "newsletter",
