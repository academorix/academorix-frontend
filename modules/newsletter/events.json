{
  "id": "academorix://modules/newsletter/events",
  "$version": 1,
  "title": "newsletter \u2014 published events",
  "namespace": "Academorix\\Newsletter\\Events",
  "dispatchMode": "afterCommit",
  "events": [
    {"name": "NewsletterCreated", "class": "Academorix\\Newsletter\\Events\\NewsletterCreated", "trigger": "New Newsletter persisted.", "queue": "notifications", "consumers": ["compliance::AuditListener", "newsletter::CreateDefaultAudience"], "payload": {"newsletter_id": "ULID", "workspace_id": "ULID", "slug": "string", "cadence": "string"}},
    {"name": "NewsletterUpdated", "class": "Academorix\\Newsletter\\Events\\NewsletterUpdated", "trigger": "Newsletter attributes changed.", "queue": "notifications", "consumers": ["compliance::AuditListener"], "payload": {"newsletter_id": "ULID", "changed_fields": "string[]"}},
    {"name": "NewsletterArchived", "class": "Academorix\\Newsletter\\Events\\NewsletterArchived", "trigger": "state \u2192 archived.", "queue": "notifications", "consumers": ["newsletter::PausePendingCampaigns", "compliance::AuditListener"], "payload": {"newsletter_id": "ULID", "actor_id": "ULID | null"}},

    {"name": "NewsletterIssueDrafted", "class": "Academorix\\Newsletter\\Events\\NewsletterIssueDrafted", "trigger": "New NewsletterIssue persisted.", "queue": "notifications", "payload": {"issue_id": "ULID", "newsletter_id": "ULID"}},
    {"name": "NewsletterIssueScheduled", "class": "Academorix\\Newsletter\\Events\\NewsletterIssueScheduled", "trigger": "Issue state \u2192 scheduled. Campaign created.", "queue": "notifications", "payload": {"issue_id": "ULID", "campaign_id": "ULID", "scheduled_at": "ISO 8601"}},
    {"name": "NewsletterIssuePublished", "class": "Academorix\\Newsletter\\Events\\NewsletterIssuePublished", "trigger": "Issue state \u2192 sent. Campaign completed.", "queue": "notifications", "consumers": ["newsletter::BroadcastPublishedIssue"], "payload": {"issue_id": "ULID", "campaign_id": "ULID", "sent_at": "ISO 8601"}},
    {"name": "NewsletterIssueCancelled", "class": "Academorix\\Newsletter\\Events\\NewsletterIssueCancelled", "trigger": "Issue state \u2192 cancelled. Campaign cancelled.", "queue": "notifications", "payload": {"issue_id": "ULID", "actor_id": "ULID | null", "reason": "string"}},

    {"name": "NewsletterSubscriptionAdded", "class": "Academorix\\Newsletter\\Events\\NewsletterSubscriptionAdded", "trigger": "Subscription created (pending_confirmation or active).", "queue": "notifications", "consumers": ["newsletter::DispatchConfirmationEmail", "compliance::AuditListener"], "payload": {"subscription_id": "ULID", "newsletter_id": "ULID", "email": "string", "source": "string", "requires_confirmation": "boolean"}},
    {"name": "NewsletterSubscriptionConfirmed", "class": "Academorix\\Newsletter\\Events\\NewsletterSubscriptionConfirmed", "trigger": "state pending_confirmation \u2192 active.", "queue": "notifications", "consumers": ["newsletter::UpdateAudienceCache", "compliance::AuditListener"], "payload": {"subscription_id": "ULID", "confirmed_at": "ISO 8601"}},
    {"name": "NewsletterSubscriptionRemoved", "class": "Academorix\\Newsletter\\Events\\NewsletterSubscriptionRemoved", "trigger": "state \u2192 unsubscribed OR row soft-deleted.", "queue": "notifications", "consumers": ["newsletter::UpdateAudienceCache", "compliance::AuditListener"], "payload": {"subscription_id": "ULID", "unsubscribed_at": "ISO 8601", "reason": "'user_action' | 'bounce' | 'complaint' | 'admin_removed'"}},
    {"name": "NewsletterSubscriptionBounced", "class": "Academorix\\Newsletter\\Events\\NewsletterSubscriptionBounced", "trigger": "notifications-mail::MailBounced fired for a newsletter delivery.", "queue": "notifications", "payload": {"subscription_id": "ULID", "bounce_kind": "'hard' | 'soft'"}},

    {"name": "NewsletterCampaignScheduled", "class": "Academorix\\Newsletter\\Events\\NewsletterCampaignScheduled", "trigger": "Campaign row created with state=pending.", "queue": "notifications", "payload": {"campaign_id": "ULID", "scheduled_at": "ISO 8601"}},
    {"name": "NewsletterCampaignStarted", "class": "Academorix\\Newsletter\\Events\\NewsletterCampaignStarted", "trigger": "state \u2192 in_progress. SendNewsletterCampaignJob started.", "queue": "notifications"},
    {"name": "NewsletterCampaignCompleted", "class": "Academorix\\Newsletter\\Events\\NewsletterCampaignCompleted", "trigger": "state \u2192 completed.", "queue": "notifications", "consumers": ["notifications::DispatchNewsletterCampaignCompletedNotification", "newsletter::EvaluateReputation"], "payload": {"campaign_id": "ULID", "counters": "object"}},
    {"name": "NewsletterCampaignFailed", "class": "Academorix\\Newsletter\\Events\\NewsletterCampaignFailed", "trigger": "state \u2192 failed. Fatal issue during send.", "queue": "notifications-critical", "consumers": ["notifications::DispatchNewsletterCampaignFailedNotification"], "payload": {"campaign_id": "ULID", "reason": "string"}},

    {"name": "NewsletterAudienceCreated", "class": "Academorix\\Newsletter\\Events\\NewsletterAudienceCreated", "trigger": "New NewsletterAudience persisted.", "queue": "notifications", "payload": {"audience_id": "ULID"}},
    {"name": "NewsletterAudienceRefreshed", "class": "Academorix\\Newsletter\\Events\\NewsletterAudienceRefreshed", "trigger": "cached_subscriber_ids rewritten by BuildAudienceSegmentJob.", "queue": "notifications", "payload": {"audience_id": "ULID", "subscriber_count": "integer"}},

    {"name": "NewsletterOpenRecorded", "class": "Academorix\\Newsletter\\Events\\NewsletterOpenRecorded", "trigger": "notifications-mail::MailOpened for a newsletter delivery.", "queue": "notifications", "consumers": ["newsletter::UpdateEngagementScore"], "payload": {"subscription_id": "ULID", "campaign_id": "ULID", "opened_at": "ISO 8601"}},
    {"name": "NewsletterClickRecorded", "class": "Academorix\\Newsletter\\Events\\NewsletterClickRecorded", "trigger": "notifications-mail::MailClicked for a newsletter delivery.", "queue": "notifications", "consumers": ["newsletter::UpdateEngagementScore"], "payload": {"subscription_id": "ULID", "campaign_id": "ULID", "url": "string", "clicked_at": "ISO 8601"}}
  ]
}
