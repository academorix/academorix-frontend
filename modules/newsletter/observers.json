{
  "id": "academorix://modules/newsletter/observers",
  "$version": 1,
  "title": "newsletter \u2014 Eloquent observers",
  "observers": [
    {
      "model": "Newsletter",
      "observer": "Academorix\\Newsletter\\Observers\\NewsletterObserver",
      "handles": [
        "creating \u2192 populate ULID prefix `nlp_` + normalise slug",
        "creating \u2192 apply platform-default reputation_thresholds from config",
        "created \u2192 fire NewsletterCreated",
        "updating (state changed) \u2192 fire appropriate state event",
        "deleting \u2192 refuse when active campaigns are in_progress"
      ]
    },
    {
      "model": "NewsletterIssue",
      "observer": "Academorix\\Newsletter\\Observers\\NewsletterIssueObserver",
      "handles": [
        "creating \u2192 ULID prefix `nli_` + auto-increment issue_number for non-adhoc newsletters",
        "created \u2192 fire NewsletterIssueDrafted",
        "updating (state=scheduled) \u2192 fire NewsletterIssueScheduled",
        "updating (state=sent) \u2192 fire NewsletterIssuePublished + set sent_at",
        "updating (state=cancelled) \u2192 fire NewsletterIssueCancelled",
        "deleting \u2192 refuse when state IN (scheduled, sending, sent) unless super_admin"
      ]
    },
    {
      "model": "NewsletterSubscription",
      "observer": "Academorix\\Newsletter\\Observers\\NewsletterSubscriptionObserver",
      "handles": [
        "creating \u2192 ULID prefix `nls_` + normalise email (lowercase, trim)",
        "creating \u2192 generate confirmation_token + unsubscribe_token (signed HMAC)",
        "creating \u2192 refuse if MailSuppression exists for (email, workspace_id) \u2014 hard block per notifications-mail contract",
        "creating \u2192 refuse if NotificationPreference for marketing.newsletter is enabled=false for the resolved user (respect existing preference)",
        "creating \u2192 truncate ip_address to /24 (GDPR)",
        "created \u2192 fire NewsletterSubscriptionAdded",
        "updating (state=active from pending_confirmation) \u2192 fire NewsletterSubscriptionConfirmed + set confirmed_at + clear confirmation_token",
        "updating (state=unsubscribed/bounced/complained) \u2192 fire NewsletterSubscriptionRemoved",
        "deleted (soft) \u2192 also fire NewsletterSubscriptionRemoved if state was active"
      ]
    },
    {
      "model": "NewsletterCampaign",
      "observer": "Academorix\\Newsletter\\Observers\\NewsletterCampaignObserver",
      "handles": [
        "creating \u2192 ULID prefix `nlc_` + initialise counters",
        "created \u2192 fire NewsletterCampaignScheduled",
        "updating (state=in_progress) \u2192 fire NewsletterCampaignStarted + set started_at",
        "updating (state=completed) \u2192 fire NewsletterCampaignCompleted + set completed_at",
        "updating (state=failed) \u2192 fire NewsletterCampaignFailed + set failure_reason",
        "deleting \u2192 refuse when state=in_progress"
      ]
    },
    {
      "model": "NewsletterAudience",
      "observer": "Academorix\\Newsletter\\Observers\\NewsletterAudienceObserver",
      "handles": [
        "creating \u2192 ULID prefix `nla_` + normalise slug",
        "created \u2192 fire NewsletterAudienceCreated + dispatch BuildAudienceSegmentJob",
        "updated (expression changed) \u2192 dispatch BuildAudienceSegmentJob",
        "deleting \u2192 refuse when is_default=true"
      ]
    }
  ]
}
