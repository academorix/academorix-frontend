{
  "id": "academorix://modules/audit/schemas/audit",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "Audit",
  "description": "Extends `OwenIt\\Auditing\\Models\\Audit`. We layer ULID prefix + workspace_id FK + optional chain columns + KMS encryption on values.",
  "type": "object",
  "x-module": "audit",
  "x-eloquent": {
    "baseClass": "OwenIt\\Auditing\\Models\\Audit",
    "table": "audits",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "aud_",
    "incrementing": false,
    "model": "Academorix\\Audit\\Models\\Audit",
    "interface": "Academorix\\Audit\\Contracts\\Data\\AuditInterface",
    "implements": ["Academorix\\Audit\\Contracts\\Data\\AuditInterface"],
    "traits": ["HasUlids", "BelongsToWorkspaceOptional"],
    "casts": {"old_values": "EncryptedAuditValueCast", "new_values": "EncryptedAuditValueCast", "tags": "array"},
    "hidden": [],
    "guarded": []
  },
  "x-database": {
    "engine": "postgres",
    "description": "Extends owen-it's default audits table via ALTER migration. Our columns added: workspace_id, previous_hash, row_hash, is_encrypted, cold_key.",
    "columns": {
      "id": {"type": "string", "length": 64, "primary": true, "description": "Prefixed ULID: `aud_<26 chars>`. Overrides owen-it's bigint id."},
      "workspace_id": {"type": "string", "length": 64, "nullable": true, "foreign": {"table": "workspaces", "column": "id", "onUpdate": "cascade", "onDelete": "restrict"}, "description": "Nullable for system-level audits. RESTRICT on delete \u2014 we anonymise-not-delete workspace audits (retain evidence)."},
      "user_type": {"type": "string", "length": 128, "nullable": true, "description": "owen-it: polymorphic actor type. Typically User."},
      "user_id": {"type": "string", "length": 64, "nullable": true},
      "event": {"type": "string", "length": 32, "nullable": false, "description": "owen-it: created / updated / deleted / restored / custom."},
      "auditable_type": {"type": "string", "length": 128, "nullable": false, "description": "owen-it: polymorphic auditable type."},
      "auditable_id": {"type": "string", "length": 64, "nullable": false},
      "old_values": {"type": "jsonb", "nullable": true, "description": "owen-it: JSONB. Our EncryptedAuditValueCast KMS-encrypts entries listed in $auditEncrypted."},
      "new_values": {"type": "jsonb", "nullable": true, "description": "owen-it: JSONB. Same KMS encryption applies."},
      "url": {"type": "text", "nullable": true, "description": "owen-it: request URL."},
      "ip_address": {"type": "inet", "nullable": true, "description": "owen-it: causer IP. Truncated to /24 on write for GDPR."},
      "user_agent": {"type": "string", "length": 512, "nullable": true},
      "tags": {"type": "jsonb", "nullable": true, "description": "owen-it: custom tags."},
      "is_encrypted": {"type": "boolean", "nullable": false, "default": false, "description": "Our addition. True when at least one restricted-tier field in old_values/new_values is KMS-encrypted."},
      "previous_hash": {"type": "string", "length": 64, "nullable": true, "description": "Our addition. SHA-256 of previous audit row for this (workspace_id). Null on the first row for a workspace."},
      "row_hash": {"type": "string", "length": 64, "nullable": true, "description": "Our addition. SHA-256 of this row's canonical serialisation. Enables chain verification."},
      "cold_key": {"type": "text", "nullable": true, "description": "Our addition. S3 key when row rotated to cold storage. Non-null = row body pruned from Postgres, still queryable via cold view."},
      "created_at": {"type": "timestamptz", "nullable": false},
      "updated_at": {"type": "timestamptz", "nullable": false}
    },
    "indexes": [
      {"columns": ["workspace_id", "created_at"], "unique": false, "name": "audits_workspace_time_idx"},
      {"columns": ["auditable_type", "auditable_id", "created_at"], "unique": false, "name": "audits_auditable_time_idx", "description": "owen-it default \u2014 per-model audit trail."},
      {"columns": ["user_type", "user_id", "created_at"], "unique": false, "name": "audits_user_time_idx"},
      {"columns": ["workspace_id", "previous_hash"], "unique": false, "name": "audits_chain_verify_idx", "predicate": "row_hash IS NOT NULL", "description": "Chain-verification job scan predicate."},
      {"columns": ["created_at"], "unique": false, "name": "audits_cold_rotate_idx", "predicate": "cold_key IS NULL", "description": "RotateAuditColdStorageJob scan predicate."}
    ]
  },
  "required": ["id", "event", "auditable_type", "auditable_id", "is_encrypted", "created_at", "updated_at"],
  "properties": {
    "id": {"type": "string", "pattern": "^aud_[0-9A-HJKMNP-TV-Z]{26}$"},
    "workspace_id": {"type": ["string", "null"], "pattern": "^wsp_[0-9A-HJKMNP-TV-Z]{26}$"},
    "user_type": {"type": ["string", "null"]},
    "user_id": {"type": ["string", "null"]},
    "event": {"type": "string", "enum": ["created", "updated", "deleted", "restored", "custom"]},
    "auditable_type": {"type": "string"},
    "auditable_id": {"type": "string"},
    "old_values": {"type": ["object", "null"]},
    "new_values": {"type": ["object", "null"]},
    "url": {"type": ["string", "null"]},
    "ip_address": {"type": ["string", "null"]},
    "user_agent": {"type": ["string", "null"], "maxLength": 512},
    "tags": {"type": ["array", "null"]},
    "is_encrypted": {"type": "boolean"},
    "previous_hash": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "row_hash": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "cold_key": {"type": ["string", "null"]},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false,
  "x-wire": {"envelope": "spatie-data", "wrap": "data", "mapper": "SnakeCaseMapper", "hidden": ["cold_key"], "computed": []}
}
