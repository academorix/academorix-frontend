{
  "id": "academorix://modules/audit/caches",
  "$version": 1,
  "title": "audit \u2014 cache keys + tags",
  "driver": "redis",
  "ownedTags": ["audit"],
  "keys": [
    {"pattern": "audit:registry", "description": "AuditRegistry \u2014 compiled #[Auditable] catalogue.", "ttlSeconds": 86400, "tags": ["audit", "platform"], "invalidatedBy": ["foundation::ApplicationBooted", "foundation::ConfigReloaded"]},
    {"pattern": "audit:latest_hash:{tenant_id}", "description": "Latest row_hash for the tenant \u2014 used as previous_hash for the next row. Refreshed on every AuditRecorded.", "ttlSeconds": 3600, "tags": ["audit", "tenant"], "invalidatedBy": ["AuditRecorded event"]},
    {"pattern": "audit:kms_data_key:{key_alias}", "description": "KMS data key cached for envelope encryption bulk ops. TTL kept short to reduce blast radius.", "ttlSeconds": 300, "tags": ["audit", "kms"], "invalidatedBy": ["natural TTL"]}
  ]
}
