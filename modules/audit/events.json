{
  "id": "academorix://modules/audit/events",
  "$version": 1,
  "title": "audit \u2014 published events",
  "namespace": "Academorix\\Audit\\Events",
  "dispatchMode": "afterCommit",
  "events": [
    {"name": "AuditRecorded", "class": "Academorix\\Audit\\Events\\AuditRecorded", "trigger": "New Audit row persisted. Fires from AuditObserver::created.", "queue": "notifications", "consumers": ["observability::MetricsCollector"], "payload": {"audit_id": "ULID", "workspace_id": "ULID | null", "event": "string", "auditable_type": "string", "auditable_id": "string", "user_type": "string | null", "user_id": "string | null", "is_encrypted": "boolean"}},
    {"name": "AuditChainVerified", "class": "Academorix\\Audit\\Events\\AuditChainVerified", "trigger": "VerifyAuditChainJob completed successfully.", "queue": "notifications", "consumers": ["observability::MetricsCollector", "compliance::AuditChainVerifiedListener"], "payload": {"workspace_id": "ULID | null", "rows_verified": "integer", "duration_ms": "integer", "verified_at": "ISO 8601"}},
    {"name": "AuditChainBroken", "class": "Academorix\\Audit\\Events\\AuditChainBroken", "trigger": "VerifyAuditChainJob detected a hash chain break. CRITICAL \u2014 potential tampering.", "queue": "notifications-critical", "consumers": ["notifications::DispatchAuditChainBrokenNotification", "observability::AlertingListener", "compliance::AuditChainBrokenListener"], "payload": {"workspace_id": "ULID | null", "first_broken_audit_id": "ULID", "expected_previous_hash": "string", "actual_previous_hash": "string", "detected_at": "ISO 8601"}},
    {"name": "AuditColdRotated", "class": "Academorix\\Audit\\Events\\AuditColdRotated", "trigger": "RotateAuditColdStorageJob moved a batch of audits to S3 Glacier.", "queue": "notifications", "consumers": ["observability::MetricsCollector"], "payload": {"workspace_id": "ULID | null", "rows_rotated": "integer", "cold_storage_key": "string"}}
  ]
}
