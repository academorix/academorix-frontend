{
  "id": "academorix://modules/audit/settings",
  "$version": 1,
  "title": "audit \u2014 settings",
  "description": "Settings this module contributes to the settings registry. Canonical group/section/field taxonomy. One #[AsSetting] class \u2014 `AuditSettings` \u2014 published under group key `audit`.",
  "storedIn": "settings",
  "reference": { "contract": "academorix://modules/settings/attributes" },
  "groups": [
    {
      "key": "audit",
      "class": "Academorix\\Audit\\Settings\\AuditSettings",
      "label": "Audit trail",
      "description": "Compliance-grade audit trail configuration.",
      "icon": "shield-check",
      "scope": "workspace",
      "public": false,
      "sortOrder": 21,
      "permission": "settings.read",
      "sections": [
        {
          "label": "Tamper-evident hash chain",
          "description": "Enterprise-only. When on, each audit row gets a cryptographic hash linking to the previous row.",
          "icon": "link",
          "sortOrder": 1,
          "fields": [
            {
              "name": "chain_enabled",
              "controlType": "toggle",
              "label": "Enable hash chain",
              "defaultValue": false,
              "validation": ["boolean"],
              "sortOrder": 1,
              "helpText": "Requires audit.tamper_evident_chain entitlement (enterprise plan)."
            },
            {
              "name": "chain_verify_frequency",
              "controlType": "select",
              "label": "Chain verification frequency",
              "defaultValue": "weekly",
              "options": { "daily": "Daily", "weekly": "Weekly", "monthly": "Monthly" },
              "validation": ["required", "string", "in:daily,weekly,monthly"],
              "sortOrder": 2
            }
          ]
        },
        {
          "label": "Workspace DPO surface",
          "description": "Give your DPO read-only access to audit rows via /api/v1/audits.",
          "icon": "identification",
          "sortOrder": 2,
          "fields": [
            {
              "name": "dpo_surface_enabled",
              "controlType": "toggle",
              "label": "Enable DPO surface",
              "defaultValue": true,
              "validation": ["boolean"],
              "sortOrder": 1
            },
            {
              "name": "dpo_surface_mask_restricted",
              "controlType": "toggle",
              "label": "Mask restricted-tier fields",
              "defaultValue": true,
              "validation": ["boolean"],
              "sortOrder": 2,
              "helpText": "When on, restricted fields render as [REDACTED]. Only super-DPO with audit.view-restricted can unmask."
            }
          ]
        }
      ]
    }
  ]
}
