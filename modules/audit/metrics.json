{
  "id": "academorix://modules/audit/metrics",
  "$version": 1,
  "title": "audit \u2014 OpenTelemetry metrics",
  "instrumentation": "open-telemetry/sdk",
  "namespace": "academorix.audit",
  "labelConventions": {"always": [], "commonlyAvailable": ["workspace_id", "auditable_type", "event"], "forbiddenAsLabels": ["auditable_id", "user_id", "old_values", "new_values"]},
  "metrics": [
    {"name": "academorix.audit.rows_recorded.total", "kind": "counter", "unit": "rows", "labels": ["workspace_id", "auditable_type", "event", "is_encrypted"]},
    {"name": "academorix.audit.recording_duration_ms", "kind": "histogram", "unit": "ms", "buckets": [5, 25, 100, 500, 2000], "labels": ["auditable_type"], "description": "AuditObserver::creating end-to-end. Includes KMS encryption + chain hash compute."},
    {"name": "academorix.audit.kms_encrypt_duration_ms", "kind": "histogram", "unit": "ms", "buckets": [1, 5, 25, 100, 500, 2000], "labels": [], "description": "KMS Encrypt call latency. Should stay < 25ms P99."},
    {"name": "academorix.audit.kms_failures.total", "kind": "counter", "unit": "failures", "labels": ["operation"], "description": "operation: encrypt / decrypt / describe_key. Non-zero pages ops."},
    {"name": "academorix.audit.chain_verification.duration_ms", "kind": "histogram", "unit": "ms", "buckets": [100, 1000, 10000, 60000, 300000], "labels": ["workspace_id"]},
    {"name": "academorix.audit.chain_breaks.total", "kind": "counter", "unit": "breaks", "labels": ["workspace_id"], "description": "CRITICAL alerting metric. Any non-zero value pages compliance + ops."},
    {"name": "academorix.audit.cold_rotation.rows_rotated_total", "kind": "counter", "unit": "rows", "labels": ["workspace_id"]},
    {"name": "academorix.audit.rows_hot_gauge", "kind": "gauge", "unit": "rows", "labels": ["workspace_id"], "description": "Sampled hourly. Anomaly detection."},
    {"name": "academorix.audit.dsar_exports.total", "kind": "counter", "unit": "exports", "labels": ["format"]}
  ]
}
