{
  "id": "academorix://modules/settings/policies",
  "$version": 1,
  "title": "settings \u2014 authorization policies",
  "policies": [
    {
      "model": "SettingValue",
      "class": "Academorix\\Settings\\Policies\\SettingValuePolicy",
      "abilities": [
        {"action": "viewAny", "permission": "settings.read", "scope": "everyone with any settings.* permission"},
        {"action": "view", "permission": "AsSetting.permission per group (registry lookup)", "scope": "gated per-group via the AsSetting.permission argument"},
        {"action": "viewSensitive", "permission": "settings.view-sensitive", "scope": "unmask sensitive fields. Every use logged."},
        {"action": "update", "permission": "settings.update.{group}", "scope": "one permission per group. Owner tier by convention."},
        {"action": "updateSystem", "permission": "platform.settings.update-system", "scope": "system-scope writes. Platform admin only."},
        {"action": "unlock", "permission": "platform.settings.unlock", "scope": "clear is_locked on a SettingValue. Platform admin only."},
        {"action": "export", "permission": "settings.export"},
        {"action": "import", "permission": "settings.import"}
      ]
    }
  ]
}
