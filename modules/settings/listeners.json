{
  "id": "academorix://modules/settings/listeners",
  "$version": 1,
  "title": "settings \u2014 subscribed events",
  "listeners": [
    {"event": "foundation::ApplicationBooted", "listener": "Academorix\\Settings\\Listeners\\HydrateSettingsRegistry", "queue": null, "purpose": "Load compiled #[AsSetting] catalogue via foundation's DiscoversAttributes. First-touch cost paid at boot."},
    {"event": "foundation::ConfigReloaded", "listener": "Academorix\\Settings\\Listeners\\RehydrateSettingsRegistry", "queue": null, "purpose": "Rebuild on hot-reload."},
    {"event": "workspaces::WorkspaceErased", "listener": "Academorix\\Settings\\Listeners\\PurgeSettingsForErasedWorkspace", "queue": "notifications", "purpose": "Cascade-delete workspace-scope SettingValue rows. FK handles the delete; this listener records the compliance-side audit entry."},
    {"event": "user::UserErased", "listener": "Academorix\\Settings\\Listeners\\PurgeSettingsForErasedUser", "queue": "notifications", "purpose": "GDPR Art. 17 \u2014 delete user-scope overrides."},
    {"event": "settings::SettingsChangeEvent", "listener": "Academorix\\Settings\\Listeners\\InvalidateResolvedCache", "queue": null, "purpose": "Bust the resolved-value cache for the affected (scope, group) so next read re-resolves."}
  ]
}
