{
  "id": "academorix://modules/settings/control-types",
  "$version": 1,
  "title": "settings \u2014 ControlType enum + widget mapping",
  "description": "The `SettingField.controlType` argument accepts one of these. Each maps to a HeroUI widget in the admin renderer.",
  "enumClass": "Academorix\\Settings\\Enums\\ControlType",
  "backing": "string",
  "cases": [
    {"case": "Text", "value": "text", "widget": "TextField", "props": {"type": "text"}, "notes": "Default control."},
    {"case": "TextArea", "value": "textarea", "widget": "TextArea"},
    {"case": "Number", "value": "number", "widget": "NumberField", "props": {"type": "number"}, "notes": "min / max / step propagated from #[SettingField]."},
    {"case": "Toggle", "value": "toggle", "widget": "Switch", "notes": "Boolean values."},
    {"case": "Checkbox", "value": "checkbox", "widget": "Checkbox", "notes": "For consent-style booleans."},
    {"case": "Select", "value": "select", "widget": "Select", "notes": "Single choice; options resolved via SettingField.resolveOptions()."},
    {"case": "MultiSelect", "value": "multiselect", "widget": "MultiSelect", "notes": "Array<string> values."},
    {"case": "Radio", "value": "radio", "widget": "RadioGroup"},
    {"case": "Slider", "value": "slider", "widget": "Slider", "notes": "min / max / step required."},
    {"case": "Password", "value": "password", "widget": "TextField", "props": {"type": "password"}, "notes": "Auto-implies SettingField.sensitive=true."},
    {"case": "Email", "value": "email", "widget": "TextField", "props": {"type": "email"}, "validation": ["email"]},
    {"case": "Url", "value": "url", "widget": "TextField", "props": {"type": "url"}, "validation": ["url"]},
    {"case": "Color", "value": "color", "widget": "ColorPicker", "notes": "OKLCH or hex."},
    {"case": "Date", "value": "date", "widget": "DateField"},
    {"case": "Time", "value": "time", "widget": "TimeField", "notes": "HH:MM format."},
    {"case": "DateTime", "value": "datetime", "widget": "DatePicker", "notes": "Full timestamp."},
    {"case": "Timezone", "value": "timezone", "widget": "Select", "notes": "Options from IANA timezone list."},
    {"case": "Locale", "value": "locale", "widget": "Select", "notes": "Options from tenant.supported_locales."},
    {"case": "Country", "value": "country", "widget": "Select", "notes": "ISO 3166-1 alpha-2."},
    {"case": "Currency", "value": "currency", "widget": "Select", "notes": "ISO 4217."},
    {"case": "KeyValue", "value": "keyvalue", "widget": "KeyValueEditor", "notes": "Free-form object; validation constrains shape."},
    {"case": "Json", "value": "json", "widget": "JsonEditor", "notes": "Escape hatch for structured settings without a dedicated widget."},
    {"case": "File", "value": "file", "widget": "FilePicker", "notes": "Value is a storage-module file id."},
    {"case": "Image", "value": "image", "widget": "ImagePicker", "notes": "Same as file with image mime constraint."}
  ]
}
