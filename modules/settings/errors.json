{
  "id": "academorix://modules/settings/errors",
  "$version": 1,
  "title": "settings \u2014 error codes",
  "namespace": "settings",
  "errors": [
    {"code": "SETTINGS_GROUP_NOT_FOUND", "http": 404, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "settings.errors.group_not_found", "description": "No settings group registered under the given key."},
    {"code": "SETTINGS_FIELD_NOT_FOUND", "http": 404, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "settings.errors.field_not_found"},
    {"code": "SETTINGS_VALIDATION_FAILED", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "settings.errors.validation_failed", "description": "Laravel validation rules on the field failed. Response body carries per-field errors."},
    {"code": "SETTINGS_FIELD_LOCKED", "http": 423, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "settings.errors.field_locked", "description": "Cannot override a field locked at a higher scope."},
    {"code": "SETTINGS_SCOPE_INVALID", "http": 400, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "settings.errors.scope_invalid", "description": "Requested scope not permitted for this group (e.g. trying user-scope write on a workspace-only group)."},
    {"code": "SETTINGS_SENSITIVE_REVEAL_DENIED", "http": 403, "retryable": false, "user_facing": true, "audit_severity": "warn", "i18n_key": "settings.errors.sensitive_reveal_denied", "description": "Caller requested ?reveal=true without settings.view-sensitive permission."},
    {"code": "SETTINGS_WRITES_KILL_SWITCHED", "http": 503, "retryable": true, "user_facing": false, "audit_severity": "alert", "i18n_key": "settings.errors.writes_kill_switched", "description": "settings.writes feature flag off. Read-only mode."},
    {"code": "SETTINGS_DUAL_WRITE_FAILED", "http": 500, "retryable": false, "user_facing": false, "audit_severity": "critical", "i18n_key": "settings.errors.dual_write_failed", "description": "SettingValue persisted but activity + audit dual-write failed. CRITICAL \u2014 audit contract broken. Row flagged for manual reconciliation."},
    {"code": "SETTINGS_QUOTA_EXCEEDED", "http": 402, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "settings.errors.quota_exceeded", "description": "Would exceed settings.max_overrides_per_scope entitlement."},
    {"code": "SETTINGS_SCHEMA_DRIFT", "http": 500, "retryable": false, "user_facing": false, "audit_severity": "alert", "i18n_key": "settings.errors.schema_drift", "description": "Attempted write against a field whose type changed since last deploy without a MigrateSettingsSchemaJob."}
  ]
}
