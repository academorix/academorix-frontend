{
  "id": "academorix://modules/settings/analytics",
  "$version": 1,
  "title": "settings \u2014 product analytics",
  "sink": "segment",
  "consentTiers": ["essential", "functional", "analytics", "marketing"],
  "events": [
    {"name": "Settings Group Viewed", "kind": "track", "consent_required": "functional", "properties": ["workspace_id", "group"]},
    {"name": "Settings Group Updated", "kind": "track", "consent_required": "functional", "properties": ["workspace_id", "group", "field_count_changed"]},
    {"name": "Settings Override Cleared", "kind": "track", "consent_required": "functional", "properties": ["workspace_id", "group", "field_name"]},
    {"name": "Settings Exported", "kind": "track", "consent_required": "functional", "properties": ["workspace_id", "scope_type", "format"]}
  ]
}
