{
  "id": "academorix://modules/notifications-push/config",
  "$version": 1,
  "title": "notifications-push \u2014 developer configuration",
  "configFile": "config/notifications-push.php",
  "envPrefix": "NOTIFICATIONS_PUSH_",
  "sections": {
    "default": {"keys": [
      {"path": "notifications-push.default", "type": "string", "env": "NOTIFICATIONS_PUSH_DEFAULT", "default": "fcm", "description": "Master default provider when platform is ambiguous (rare \u2014 usually determined by subscription.platform)."}
    ]},
    "providers": {"description": "Per-provider credentials (from Doppler).", "keys": [
      {"path": "notifications-push.providers.fcm.service_account_json_secret_ref", "type": "string", "env": "FCM_SERVICE_ACCOUNT_JSON", "secret": true},
      {"path": "notifications-push.providers.fcm.project_id", "type": "string", "env": "FCM_PROJECT_ID"},
      {"path": "notifications-push.providers.apns.auth_key_secret_ref", "type": "string", "env": "APNS_AUTH_KEY", "secret": true, "description": "p8 private key."},
      {"path": "notifications-push.providers.apns.key_id", "type": "string", "env": "APNS_KEY_ID"},
      {"path": "notifications-push.providers.apns.team_id", "type": "string", "env": "APNS_TEAM_ID"},
      {"path": "notifications-push.providers.apns.bundle_id", "type": "string", "env": "APNS_BUNDLE_ID"},
      {"path": "notifications-push.providers.apns.environment", "type": "enum<production,sandbox>", "env": "APNS_ENV", "default": "production"},
      {"path": "notifications-push.providers.expo.access_token_secret_ref", "type": "string", "env": "EXPO_ACCESS_TOKEN", "secret": true},
      {"path": "notifications-push.providers.onesignal.app_id", "type": "string", "env": "ONESIGNAL_APP_ID"},
      {"path": "notifications-push.providers.onesignal.rest_api_key_secret_ref", "type": "string", "env": "ONESIGNAL_REST_API_KEY", "secret": true}
    ]},
    "webhook_signatures": {"description": "Per-provider inbound webhook signing secrets (read by webhook module's verify middleware).", "keys": [
      {"path": "notifications-push.webhook_secrets.fcm", "type": "string", "env": "NOTIFICATIONS_PUSH_FCM_WEBHOOK_SECRET", "secret": true},
      {"path": "notifications-push.webhook_secrets.apns", "type": "string", "env": "NOTIFICATIONS_PUSH_APNS_WEBHOOK_SECRET", "secret": true},
      {"path": "notifications-push.webhook_secrets.onesignal", "type": "string", "env": "NOTIFICATIONS_PUSH_ONESIGNAL_WEBHOOK_SECRET", "secret": true}
    ]},
    "token_validation": {"keys": [
      {"path": "notifications-push.token_validation.enabled", "type": "bool", "default": true, "description": "Dry-run on register. Off = accept any token (bad tokens waste send budget)."},
      {"path": "notifications-push.token_validation.cache_ttl_seconds", "type": "int", "default": 60, "description": "Recent validation results cached to prevent duplicate dry-runs."}
    ]},
    "retention": {"keys": [
      {"path": "notifications-push.retention.idle_days", "type": "int", "default": 90, "description": "Soft-delete subscriptions with last_seen_at older than this."},
      {"path": "notifications-push.retention.idle_days_minors", "type": "int", "default": 30, "description": "COPPA reduced retention for minor recipients."},
      {"path": "notifications-push.retention.soft_delete_grace_days", "type": "int", "default": 30, "description": "Grace before hard-purge of soft-deleted rows."}
    ]},
    "payload_limits": {"keys": [
      {"path": "notifications-push.payload_limits.fcm_max_bytes", "type": "int", "default": 4096},
      {"path": "notifications-push.payload_limits.apns_max_bytes", "type": "int", "default": 4096},
      {"path": "notifications-push.payload_limits.apns_voip_max_bytes", "type": "int", "default": 5120}
    ]}
  }
}
