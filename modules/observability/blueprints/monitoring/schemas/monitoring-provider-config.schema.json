{
  "id": "academorix://modules/monitoring/schemas/monitoring-provider-config",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "MonitoringProviderConfig",
  "description": "Per-tenant per-provider connection. Belongs to Tenant. Carries `tenant_id` only. NEVER carries `application_id`, `region_id`, `organization_id`, or `scope_node_id`. `config` jsonb ENCRYPTED at rest (contains DSNs, API keys, HMAC secrets).",
  "type": "object",
  "x-module": "monitoring",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "monitoring_provider_configs",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "mpr_",
    "incrementing": false,
    "model": "Academorix\\Observability\\Monitoring\\Models\\MonitoringProviderConfig",
    "interface": "Academorix\\Observability\\Monitoring\\Contracts\\Data\\MonitoringProviderConfigInterface",
    "implements": ["Academorix\\Observability\\Monitoring\\Contracts\\Data\\MonitoringProviderConfigInterface"],
    "traits": [
      "HasFactory",
      "HasUlids",
      "BelongsToTenant",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "HasActivityLog",
      "Filterable",
      "SoftDeletes"
    ],
    "casts": {
      "provider": "MonitoringProvider",
      "is_active": "boolean",
      "config": "encrypted:array",
      "enabled_severities": "array",
      "test_mode": "boolean",
      "circuit_breaker_config": "array",
      "retry_config": "array",
      "consecutive_failure_count": "integer",
      "circuit_breaker_reset_count": "integer",
      "last_success_at": "datetime",
      "last_failure_at": "datetime",
      "circuit_breaker_open_until": "datetime",
      "metadata": "array"
    },
    "observers": ["MonitoringProviderConfigObserver"],
    "appends": ["circuit_breaker_state", "config_redacted"]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 64, "primary": true },
      "tenant_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "provider": {
        "type": "string",
        "length": 32,
        "nullable": false,
        "description": "Enum matching MonitoringProvider enum: sentry / datadog / pagerduty / opsgenie / prometheus / custom_webhook."
      },
      "name": {
        "type": "string",
        "length": 128,
        "nullable": false,
        "description": "Display name (e.g. 'Primary PagerDuty', 'Secondary Opsgenie EU')."
      },
      "is_active": {
        "type": "boolean",
        "nullable": false,
        "default": true
      },
      "config": {
        "type": "jsonb",
        "nullable": false,
        "description": "ENCRYPTED AT REST. Provider-specific config validated against data/providers/<provider>-config.schema.json."
      },
      "enabled_severities": {
        "type": "jsonb",
        "nullable": false,
        "default": "'[\"p1\",\"p2\",\"p3\",\"p4\"]'::jsonb",
        "description": "jsonb array of severities this config accepts. Subset of {p1, p2, p3, p4}."
      },
      "test_mode": {
        "type": "boolean",
        "nullable": false,
        "default": false
      },
      "last_success_at": { "type": "timestamptz", "nullable": true },
      "last_failure_at": { "type": "timestamptz", "nullable": true },
      "consecutive_failure_count": {
        "type": "integer",
        "nullable": false,
        "default": 0,
        "description": "Reset to 0 on any successful notification."
      },
      "circuit_breaker_open_until": {
        "type": "timestamptz",
        "nullable": true,
        "description": "When the breaker will auto-transition to HALF_OPEN. NULL = CLOSED."
      },
      "circuit_breaker_reset_count": {
        "type": "integer",
        "nullable": false,
        "default": 0
      },
      "circuit_breaker_config": {
        "type": "jsonb",
        "nullable": false,
        "description": "Shape: { failure_threshold, open_duration_seconds, half_open_test_events }."
      },
      "retry_config": {
        "type": "jsonb",
        "nullable": false,
        "description": "Shape: { max_attempts, backoff_seconds: int[] }."
      },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_by": { "type": "string", "length": 64, "nullable": true },
      "updated_by": { "type": "string", "length": 64, "nullable": true },
      "deleted_by": { "type": "string", "length": 64, "nullable": true },
      "deleted_at": { "type": "timestamptz", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "provider", "name"],
        "unique": true,
        "name": "monitoring_provider_configs_tenant_provider_name_unique",
        "predicate": "deleted_at IS NULL"
      },
      { "columns": ["tenant_id", "is_active"], "name": "monitoring_provider_configs_active_idx" },
      { "columns": ["circuit_breaker_open_until"], "name": "monitoring_provider_configs_breaker_idx", "predicate": "circuit_breaker_open_until IS NOT NULL" }
    ]
  },
  "required": ["id", "tenant_id", "provider", "name", "is_active", "config", "enabled_severities", "test_mode", "consecutive_failure_count", "circuit_breaker_reset_count", "circuit_breaker_config", "retry_config", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string", "pattern": "^mpr_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": "string", "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "provider": {
      "type": "string",
      "enum": ["sentry", "datadog", "pagerduty", "opsgenie", "prometheus", "custom_webhook"]
    },
    "name": { "type": "string", "minLength": 1, "maxLength": 128 },
    "is_active": { "type": "boolean" },
    "config": { "type": "object", "additionalProperties": true },
    "enabled_severities": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["p1", "p2", "p3", "p4"] }
    },
    "test_mode": { "type": "boolean" },
    "last_success_at": { "type": ["string", "null"], "format": "date-time" },
    "last_failure_at": { "type": ["string", "null"], "format": "date-time" },
    "consecutive_failure_count": { "type": "integer", "minimum": 0 },
    "circuit_breaker_open_until": { "type": ["string", "null"], "format": "date-time" },
    "circuit_breaker_reset_count": { "type": "integer", "minimum": 0 },
    "circuit_breaker_config": {
      "type": "object",
      "required": ["failure_threshold", "open_duration_seconds", "half_open_test_events"],
      "properties": {
        "failure_threshold": { "type": "integer", "minimum": 1, "maximum": 100 },
        "open_duration_seconds": { "type": "integer", "minimum": 60, "maximum": 86400 },
        "half_open_test_events": { "type": "integer", "minimum": 1, "maximum": 5 }
      }
    },
    "retry_config": {
      "type": "object",
      "required": ["max_attempts", "backoff_seconds"],
      "properties": {
        "max_attempts": { "type": "integer", "minimum": 1, "maximum": 10 },
        "backoff_seconds": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1, "maximum": 86400 }
        }
      }
    },
    "metadata": { "type": ["object", "null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "x-invariants": [
    "unique (tenant_id, provider, name) WHERE deleted_at IS NULL",
    "config validates against data/providers/<provider>-config.schema.json",
    "enabled_severities is a non-empty subset of {p1, p2, p3, p4}",
    "retry_config.backoff_seconds.length == retry_config.max_attempts",
    "circuit_breaker_reset_count increments only on manual reset",
    "config field encrypted at rest",
    "soft-delete refused when circuit_breaker_open_until IS NOT NULL + still open"
  ]
}
