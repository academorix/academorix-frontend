{
  "id": "monitoring.resources.monitoring-provider.list",
  "title": "Monitoring providers",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/monitoring/providers",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "monitoring", "entity": "monitoring-provider", "action": "list" },
  "requiresPermission": "monitoring.providers.viewAny",
  "requiresEntitlement": "monitoring_capture",
  "dataSources": [
    { "name": "providers", "kind": "http.get", "url": "/api/v1/monitoring/providers", "unwrap": "data" },
    { "name": "slot", "kind": "http.get", "url": "/api/v1/entitlements/monitoring_provider_slot", "unwrap": "data" }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-7xl mx-auto" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex items-start justify-between gap-4" },
          "children": [
            { "kind": "View", "children": [
              { "kind": "Text", "props": { "as": "h1", "className": "text-2xl font-semibold", "children": "Monitoring providers" } },
              { "kind": "Text", "props": { "className": "text-sm text-muted", "children": "Notification endpoints for alerts + incidents." } }
            ] },
            { "kind": "View", "props": { "className": "flex items-center gap-3" }, "children": [
              {
                "kind": "Widget",
                "widget": "entitlements.entitlement-usage-bar",
                "props": { "size": "sm", "label": "Provider slots" },
                "bindings": { "cap": { "$ref": "slot.value_cap" }, "used": { "$ref": "slot.value_used" } }
              },
              {
                "kind": "Button",
                "props": { "variant": "primary", "leadingIcon": "plus", "children": "Add provider" },
                "requiresPermission": "monitoring.providers.create",
                "bindings": { "disabled": { "$ref": "slot.is_exceeded" } },
                "actions": { "onPress": { "kind": "navigate", "to": "/tenant/monitoring/providers/new" } }
              }
            ] }
          ]
        },
        {
          "kind": "Grid",
          "bindings": { "items": { "$ref": "providers" } },
          "props": { "className": "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" },
          "emptyState": {
            "kind": "View",
            "props": { "className": "col-span-full text-center py-12" },
            "children": [
              { "kind": "Icon", "props": { "name": "signal", "className": "size-12 mx-auto text-muted" } },
              { "kind": "Text", "props": { "className": "mt-4 text-lg font-medium", "children": "No providers configured yet" } },
              { "kind": "Text", "props": { "className": "text-sm text-muted", "children": "Add Sentry, PagerDuty, Datadog, or another provider to start receiving alert notifications." } }
            ]
          },
          "itemRenderer": {
            "kind": "Card",
            "props": { "className": "p-4 hover:shadow-md transition-shadow cursor-pointer" },
            "actions": {
              "onPress": { "kind": "navigate", "toExpr": "'/tenant/monitoring/providers/' + row.id + '/edit'" }
            },
            "children": [
              {
                "kind": "View",
                "props": { "className": "flex items-start justify-between gap-2 mb-2" },
                "children": [
                  { "kind": "Text", "props": { "className": "font-medium text-lg" }, "bindings": { "children": { "$ref": "row.provider" } } },
                  { "kind": "Widget", "widget": "monitoring.circuit-breaker-badge", "bindings": { "provider_config": { "$ref": "row" } } }
                ]
              },
              {
                "kind": "Text",
                "props": { "className": "text-xs text-muted" },
                "bindings": { "children": { "$ref": "row.name" } }
              },
              {
                "kind": "View",
                "props": { "className": "flex items-center gap-2 flex-wrap mt-3" },
                "children": [
                  { "kind": "Widget", "widget": "monitoring.provider-status-chip", "bindings": { "provider_config": { "$ref": "row" } } },
                  {
                    "kind": "Chip",
                    "props": { "size": "sm", "variant": "info" },
                    "bindings": {
                      "hidden": { "$expr": "!row.test_mode" },
                      "children": "Test mode"
                    }
                  }
                ]
              },
              {
                "kind": "Text",
                "props": { "className": "text-xs text-muted mt-2" },
                "bindings": { "children": { "$expr": "'Severities: ' + row.enabled_severities.join(', ')" } }
              }
            ]
          }
        }
      ]
    }
  ]
}
