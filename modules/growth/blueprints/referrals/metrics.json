{
  "id": "academorix://modules/referrals/metrics",
  "$version": 1,
  "title": "referrals — OpenTelemetry metrics",
  "instrumentation": "self via telemetry",
  "namespace": "academorix.referrals",
  "labelConventions": {
    "always": [],
    "commonlyAvailable": ["reward_type", "trigger_event", "vesting_rule", "cancellation_reason", "clawback_reason", "flag_type", "severity", "code_type", "click_id_provider"],
    "forbiddenAsLabels": ["tenant_id", "program_id", "code_id", "referral_id", "reward_id", "flag_id", "user_id", "recipient_id", "referrer_id", "referred_id", "reward_amount"]
  },
  "metrics": [
    {
      "name": "academorix.referrals.programs.count",
      "kind": "gauge",
      "unit": "programs",
      "labels": ["status", "side", "reward_type"],
      "description": "Count of programs per (status, side, reward_type). Sampled hourly."
    },
    {
      "name": "academorix.referrals.codes.count",
      "kind": "gauge",
      "unit": "codes",
      "labels": ["code_type", "is_active"]
    },
    {
      "name": "academorix.referrals.clicks_total",
      "kind": "counter",
      "unit": "clicks",
      "labels": ["click_id_provider", "has_utm", "has_code"]
    },
    {
      "name": "academorix.referrals.claims_total",
      "kind": "counter",
      "unit": "claims",
      "labels": ["code_type", "fraud_score_bucket"],
      "description": "fraud_score_bucket: 0-19 / 20-39 / 40-69 / 70-89 / 90-100."
    },
    {
      "name": "academorix.referrals.signups_total",
      "kind": "counter",
      "unit": "signups",
      "labels": ["click_id_provider", "utm_source_bucket"]
    },
    {
      "name": "academorix.referrals.triggers_reached_total",
      "kind": "counter",
      "unit": "triggers",
      "labels": ["trigger_event"]
    },
    {
      "name": "academorix.referrals.vestings_total",
      "kind": "counter",
      "unit": "vestings",
      "labels": ["reward_type", "side", "was_forced"]
    },
    {
      "name": "academorix.referrals.rewards.created_total",
      "kind": "counter",
      "unit": "rewards",
      "labels": ["reward_type", "recipient_role", "side"]
    },
    {
      "name": "academorix.referrals.rewards.materialized_total",
      "kind": "counter",
      "unit": "rewards",
      "labels": ["reward_type", "recipient_role"]
    },
    {
      "name": "academorix.referrals.rewards.paid_total",
      "kind": "counter",
      "unit": "rewards",
      "labels": ["reward_type", "recipient_role"]
    },
    {
      "name": "academorix.referrals.rewards.clawback_total",
      "kind": "counter",
      "unit": "rewards",
      "labels": ["clawback_reason", "was_paid", "was_materialized"]
    },
    {
      "name": "academorix.referrals.cancellations_total",
      "kind": "counter",
      "unit": "referrals",
      "labels": ["cancellation_reason"]
    },
    {
      "name": "academorix.referrals.expirations_total",
      "kind": "counter",
      "unit": "referrals",
      "labels": []
    },
    {
      "name": "academorix.referrals.claim_duration_ms",
      "kind": "histogram",
      "unit": "ms",
      "buckets": [10, 50, 200, 1000, 5000],
      "labels": [],
      "description": "GET /api/v1/referrals/claim/{code} HTTP latency including FraudDetector's synchronous score computation. P99 target < 300ms."
    },
    {
      "name": "academorix.referrals.fraud_detector.duration_ms",
      "kind": "histogram",
      "unit": "ms",
      "buckets": [1, 10, 50, 200, 500],
      "labels": ["detection_phase"],
      "description": "FraudDetector.score() duration. detection_phase: 'claim_time' / 'trigger_time'."
    },
    {
      "name": "academorix.referrals.fraud_flags_created_total",
      "kind": "counter",
      "unit": "flags",
      "labels": ["flag_type", "severity"],
      "description": "Every ReferralFraudFlag write is counted. Severity=critical is a P1 signal that must page ops."
    },
    {
      "name": "academorix.referrals.fraud_flags_reviewed_total",
      "kind": "counter",
      "unit": "flags",
      "labels": ["disposition", "days_from_created_bucket"]
    },
    {
      "name": "academorix.referrals.fraud_open_flags",
      "kind": "gauge",
      "unit": "flags",
      "labels": ["severity"],
      "description": "Currently-unreviewed fraud flags. Warns admin when > 100 across the platform."
    },
    {
      "name": "academorix.referrals.atomicity.failures_total",
      "kind": "counter",
      "unit": "failures",
      "labels": ["failure_point"],
      "description": "CRITICAL. Vested-transition + reward creation atomicity failures. Should stay at 0. failure_point: 'reward_insert' / 'referral_update' / 'db_deadlock' / 'unknown'."
    },
    {
      "name": "academorix.referrals.rewards.double_materialization_attempts_total",
      "kind": "counter",
      "unit": "attempts",
      "labels": [],
      "description": "CRITICAL. Every fire is a race condition the unique index should have prevented. P1 signal."
    },
    {
      "name": "academorix.referrals.budget.reached_total",
      "kind": "counter",
      "unit": "programs",
      "labels": []
    },
    {
      "name": "academorix.referrals.budget.spikes_total",
      "kind": "counter",
      "unit": "programs",
      "labels": []
    },
    {
      "name": "academorix.referrals.budget.drift_ratio",
      "kind": "gauge",
      "unit": "ratio",
      "labels": [],
      "description": "ReconcileProgramBudgetJob measures the drift between rewards_issued_count (denormalised counter) vs the recomputed count. Should stay 0. Any drift is a bug in the counter-increment path."
    },
    {
      "name": "academorix.referrals.invitations.sent_total",
      "kind": "counter",
      "unit": "invitations",
      "labels": ["channel", "template_slug"]
    },
    {
      "name": "academorix.referrals.invitations.suppressed_total",
      "kind": "counter",
      "unit": "invitations",
      "labels": ["suppression_reason"],
      "description": "suppression_reason: 'unsubscribed' / 'disposable_email' / 'existing_user' / 'rate_limit'."
    },
    {
      "name": "academorix.referrals.invitations.clicked_total",
      "kind": "counter",
      "unit": "clicks",
      "labels": ["channel"]
    },
    {
      "name": "academorix.referrals.materialization.duration_ms",
      "kind": "histogram",
      "unit": "ms",
      "buckets": [50, 200, 1000, 5000, 30000],
      "labels": [],
      "description": "MaterializeVestedRewardsJob per-reward duration (Finance module call latency)."
    },
    {
      "name": "academorix.referrals.entitlement.gate_refusals_total",
      "kind": "counter",
      "unit": "refusals",
      "labels": ["entitlement_key"],
      "description": "Route hits refused by the entitlement middleware. Product signal for upgrade-CTA impressions."
    },
    {
      "name": "academorix.referrals.retention.purged_total",
      "kind": "counter",
      "unit": "rows",
      "labels": ["entity"],
      "description": "PurgeArchivedReferralsJob emits. entity: 'referral_programs' / 'referral_codes' / 'referrals' / 'referral_rewards' / 'referral_fraud_flags'."
    }
  ]
}
