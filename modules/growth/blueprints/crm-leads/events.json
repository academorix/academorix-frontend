{
  "id": "academorix://modules/crm-leads/events",
  "$version": 1,
  "title": "crm-leads — published events",
  "namespace": "Academorix\\Growth\\CrmLeads\\Events",
  "dispatchMode": "afterCommit",
  "description": "Pre-enrollment sales pipeline. Leads captured from web forms, referrals, walk-ins; funneled to sports/registrations on conversion.",
  "events": [
    {
      "name": "LeadCaptured",
      "trigger": "New Lead row. Source + attribution captured.",
      "consumers": [
        "audit::WriteToAuditLog",
        "activity::WriteToActivityLog",
        "notifications::NotifyLeadOwnerAssigned"
      ],
      "payload": {
        "lead_id": "ULID (led_*)",
        "tenant_id": "ULID",
        "source": "'web_form'|'referral'|'walk_in'|'cold_outreach'|'import'",
        "email": "string",
        "phone": "string|null",
        "first_touch_utm": "object",
        "captured_at": "ISO 8601"
      }
    },
    {
      "name": "LeadContacted",
      "trigger": "Owner initiated contact. status: new → contacted.",
      "consumers": ["audit::WriteToAuditLog", "activity::WriteToActivityLog"],
      "payload": {
        "lead_id": "ULID",
        "contacted_by_user_id": "ULID",
        "contact_method": "'email'|'phone'|'sms'|'in_person'",
        "notes": "string|null"
      }
    },
    {
      "name": "LeadQualified",
      "trigger": "Lead qualified (intent + fit confirmed). status: contacted → qualified.",
      "consumers": ["audit::WriteToAuditLog"],
      "payload": { "lead_id": "ULID", "qualified_by_user_id": "ULID" }
    },
    {
      "name": "LeadConvertedToTrial",
      "trigger": "Lead booked a trial. status: qualified → trial. Handoff to sports/registrations.",
      "consumers": [
        "registrations::CreateFromLead",
        "audit::WriteToAuditLog",
        "activity::WriteToActivityLog"
      ],
      "payload": { "lead_id": "ULID", "registration_id": "ULID", "trial_booking_id": "ULID" }
    },
    {
      "name": "LeadWon",
      "trigger": "Registration converted to enrolled. status: trial → won.",
      "consumers": ["audit::WriteToAuditLog", "attribution::PropagateAttributionOnWon"],
      "payload": {
        "lead_id": "ULID",
        "registration_id": "ULID",
        "athlete_id": "ULID",
        "conversion_time_days": "int"
      }
    },
    {
      "name": "LeadLost",
      "trigger": "Lead did not convert. status: * → lost. Reason REQUIRED.",
      "consumers": ["audit::WriteToAuditLog"],
      "payload": {
        "lead_id": "ULID",
        "lost_reason": "'price'|'competitor'|'timing'|'unqualified'|'no_response'|'other'",
        "lost_at": "ISO 8601"
      }
    },
    {
      "name": "LeadFollowUpDue",
      "trigger": "Scheduled follow-up date reached.",
      "consumers": ["notifications::NotifyOwnerFollowUp"],
      "payload": { "lead_id": "ULID", "owner_user_id": "ULID", "due_at": "ISO 8601" }
    },
    {
      "name": "LeadStale",
      "trigger": "P1 event. Lead untouched 30d+. Reassign consideration.",
      "consumers": ["notifications::AlertLeadStale"],
      "payload": { "lead_id": "ULID", "last_activity_at": "ISO 8601", "days_stale": "int" }
    }
  ]
}
