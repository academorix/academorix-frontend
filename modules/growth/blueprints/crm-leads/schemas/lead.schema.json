{
  "id": "academorix://modules/crm-leads/schemas/lead",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "Lead",
  "type": "object",
  "x-module": "crm-leads",
  "x-eloquent": {
    "table": "leads",
    "keyPrefix": "lea_",
    "traits": [
      "HasFactory",
      "HasPrefixedUlid",
      "BelongsToTenant",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "HasActivityLog",
      "Filterable",
      "SoftDeletes"
    ]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 30, "primary": true },
      "tenant_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "first_name": { "type": "string", "length": 100, "nullable": false },
      "last_name": { "type": "string", "length": 100, "nullable": true },
      "email": { "type": "string", "length": 200, "nullable": true },
      "phone": { "type": "string", "length": 32, "nullable": true },
      "source": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "description": "web_form / referral / walk_in / cold_outreach / campaign_{key}."
      },
      "campaign_id": {
        "type": "string",
        "length": 30,
        "nullable": true,
        "foreign": { "table": "campaigns", "column": "id", "onDelete": "set null" }
      },
      "referral_code_id": { "type": "string", "length": 30, "nullable": true },
      "sport_interest": { "type": "string", "length": 64, "nullable": true },
      "age_of_athlete": {
        "type": "integer",
        "nullable": true,
        "description": "Age of prospective athlete (if applicable). Not directly PII on parent."
      },
      "stage": { "type": "string", "length": 16, "nullable": false, "default": "'new'" },
      "owner_user_id": {
        "type": "string",
        "length": 30,
        "nullable": true,
        "foreign": { "table": "users", "column": "id", "onDelete": "set null" }
      },
      "first_contact_at": { "type": "timestamptz", "nullable": true },
      "converted_at": { "type": "timestamptz", "nullable": true },
      "converted_athlete_id": {
        "type": "string",
        "length": 30,
        "nullable": true,
        "foreign": { "table": "athletes", "column": "id", "onDelete": "set null" }
      },
      "lost_at": { "type": "timestamptz", "nullable": true },
      "lost_reason": { "type": "string", "length": 200, "nullable": true },
      "score": { "type": "integer", "nullable": true, "description": "Lead score 0-100." },
      "notes": { "type": "text", "nullable": true },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false },
      "deleted_at": { "type": "timestamptz", "nullable": true }
    },
    "indexes": [
      { "columns": ["tenant_id", "stage"], "name": "leads_stage_idx" },
      { "columns": ["tenant_id", "owner_user_id", "stage"], "name": "leads_owner_stage_idx" },
      { "columns": ["tenant_id", "source"], "name": "leads_source_idx" }
    ]
  },
  "required": ["id", "tenant_id", "first_name", "source", "stage", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string", "pattern": "^lea_[0-9A-HJKMNP-TV-Z]{26}$" },
    "stage": {
      "type": "string",
      "enum": ["new", "contacted", "trial_scheduled", "trial_completed", "won", "lost"]
    }
  },
  "additionalProperties": false
}
