{
  "id": "academorix://modules/crm-leads/policies",
  "$version": 1,
  "title": "crm-leads — authorization policies",
  "policies": [
    {
      "model": "Lead",
      "class": "Academorix\\Growth\\CrmLeads\\Policies\\LeadPolicy",
      "abilities": [
        {
          "action": "viewAny",
          "permission": "crm-leads.viewAny",
          "scope": "own + assigned + admin"
        },
        { "action": "view", "permission": "crm-leads.view" },
        { "action": "create", "permission": "crm-leads.create" },
        { "action": "update", "permission": "crm-leads.update", "scope": "owner + admin" },
        {
          "action": "assign",
          "permission": "crm-leads.assign",
          "scope": "branch_manager + admin + owner"
        },
        {
          "action": "markWon",
          "permission": "crm-leads.mark-won",
          "scope": "owner + admin. Auto-fired on registrations::Enrolled"
        },
        { "action": "markLost", "permission": "crm-leads.mark-lost" },
        { "action": "delete", "permission": "crm-leads.delete", "scope": "admin + owner" }
      ]
    },
    {
      "model": "FollowUpTask",
      "class": "Academorix\\Growth\\CrmLeads\\Policies\\FollowUpTaskPolicy",
      "abilities": [
        { "action": "viewAny", "permission": "crm-leads.tasks.viewAny", "scope": "own + admin" },
        { "action": "view", "permission": "crm-leads.tasks.view" },
        { "action": "create", "permission": "crm-leads.tasks.create" },
        { "action": "complete", "permission": "crm-leads.tasks.complete", "scope": "assignee only" }
      ]
    }
  ]
}
