{
  "id": "academorix://modules/analytics/data/provider-capability-matrix",
  "$version": 1,
  "title": "analytics — provider capability matrix",
  "description": "Per-provider capability matrix. Read by AnalyticsProviderDriverRegistry at boot + used by the ProviderPayloadTransformer + used by SDUI to gate UI (disable session-recording toggle for non-PostHog providers, etc.).",
  "providers": {
    "posthog": {
      "supports_batching": true,
      "max_batch_size": 1000,
      "max_batch_bytes": null,
      "verbs_native": ["track", "identify", "page", "screen", "alias", "group"],
      "verbs_synthesized": [],
      "supports_session_recording": true,
      "supports_feature_flags": true,
      "supports_experiments": true,
      "supports_user_properties": true,
      "supports_group_analytics": true,
      "region_options": ["us", "eu"],
      "requires_consent_categories": ["analytics"],
      "requires_consent_categories_for_recording": ["analytics", "functional"],
      "circuit_breaker_defaults": { "threshold": 5, "failure_rate": 0.2, "window_seconds": 60 },
      "retry_defaults": { "max_attempts": 5, "backoff_ms": [1000, 5000, 30000, 300000, 3600000] }
    },
    "amplitude": {
      "supports_batching": true,
      "max_batch_size": 1000,
      "max_batch_bytes": 10485760,
      "verbs_native": ["track", "identify"],
      "verbs_synthesized": {
        "page": "track('Page Viewed', { $screen_name })",
        "screen": "track('Screen Viewed', { $screen_name })",
        "alias": "Amplitude Identity API (usermap)",
        "group": "identify with $groups"
      },
      "supports_session_recording": false,
      "supports_feature_flags": true,
      "supports_experiments": true,
      "supports_user_properties": true,
      "supports_group_analytics": true,
      "region_options": ["us", "eu"],
      "requires_consent_categories": ["analytics"],
      "circuit_breaker_defaults": { "threshold": 5, "failure_rate": 0.2, "window_seconds": 60 },
      "retry_defaults": { "max_attempts": 5, "backoff_ms": [1000, 5000, 30000, 300000, 3600000] }
    },
    "mixpanel": {
      "supports_batching": true,
      "max_batch_size": 2000,
      "max_batch_bytes": null,
      "verbs_native": ["track"],
      "verbs_synthesized": {
        "identify": "$identify special event + $set properties",
        "alias": "$create_alias special event",
        "group": "$set_group + $group_identify",
        "page": "track('Page Viewed')",
        "screen": "track('Screen Viewed')"
      },
      "supports_session_recording": false,
      "supports_feature_flags": true,
      "supports_experiments": true,
      "supports_user_properties": true,
      "supports_group_analytics": true,
      "region_options": ["us", "eu"],
      "requires_consent_categories": ["analytics"],
      "requires_entitlements": ["analytics_advanced_providers"],
      "circuit_breaker_defaults": { "threshold": 5, "failure_rate": 0.2, "window_seconds": 60 },
      "retry_defaults": { "max_attempts": 5, "backoff_ms": [2000, 10000, 60000, 600000, 3600000] }
    },
    "segment": {
      "supports_batching": true,
      "max_batch_size": 100,
      "max_batch_bytes": 500000,
      "verbs_native": ["track", "identify", "page", "screen", "alias", "group"],
      "verbs_synthesized": [],
      "supports_session_recording": false,
      "supports_feature_flags": false,
      "supports_experiments": false,
      "supports_user_properties": true,
      "supports_group_analytics": true,
      "region_options": ["us", "eu"],
      "requires_consent_categories": ["analytics"],
      "requires_entitlements": ["analytics_advanced_providers"],
      "note": "Segment fans out to N destinations configured in Segment console. Academorix sees Segment as one provider; per-destination visibility lives in Segment.",
      "circuit_breaker_defaults": { "threshold": 5, "failure_rate": 0.2, "window_seconds": 60 },
      "retry_defaults": { "max_attempts": 5, "backoff_ms": [1000, 5000, 30000, 300000, 3600000] }
    },
    "june": {
      "supports_batching": false,
      "max_batch_size": 1,
      "max_batch_bytes": null,
      "verbs_native": ["track", "identify", "group"],
      "verbs_synthesized": {
        "page": "track('Page Viewed')",
        "screen": "track('Screen Viewed')",
        "alias": "unsupported \u2014 refused with NOTIFICATIONS_ANALYTICS_INVALID_EVENT_NAME"
      },
      "supports_session_recording": false,
      "supports_feature_flags": false,
      "supports_experiments": false,
      "supports_user_properties": true,
      "supports_group_analytics": true,
      "region_options": ["us"],
      "requires_consent_categories": ["analytics"],
      "requires_entitlements": ["analytics_advanced_providers"],
      "note": "B2B-analytics oriented. No batching \u2014 one HTTP request per event.",
      "circuit_breaker_defaults": { "threshold": 3, "failure_rate": 0.3, "window_seconds": 60 },
      "retry_defaults": { "max_attempts": 3, "backoff_ms": [5000, 30000, 300000] }
    },
    "google_analytics_4": {
      "supports_batching": true,
      "max_batch_size": 25,
      "max_batch_bytes": null,
      "verbs_native": ["track"],
      "verbs_synthesized": {
        "identify": "user_id parameter on next track()",
        "page": "track('page_view')",
        "screen": "track('screen_view')",
        "alias": "unsupported",
        "group": "unsupported"
      },
      "supports_session_recording": false,
      "supports_feature_flags": false,
      "supports_experiments": true,
      "supports_user_properties": true,
      "supports_group_analytics": false,
      "region_options": ["global"],
      "requires_consent_categories": ["analytics"],
      "note": "SAME wire protocol as marketing::google_analytics_4 but distinct event catalog. Analytics uses snake_case behavioral names (screen_view, select_content); marketing uses business names (sign_up, purchase).",
      "circuit_breaker_defaults": { "threshold": 10, "failure_rate": 0.3, "window_seconds": 60 },
      "retry_defaults": { "max_attempts": 3, "backoff_ms": [5000, 30000, 300000] }
    },
    "custom_webhook": {
      "supports_batching": true,
      "max_batch_size": 100,
      "max_batch_bytes": 5242880,
      "verbs_native": ["track", "identify", "page", "screen", "alias", "group"],
      "verbs_synthesized": [],
      "supports_session_recording": false,
      "supports_feature_flags": false,
      "supports_experiments": false,
      "supports_user_properties": true,
      "supports_group_analytics": true,
      "region_options": ["tenant-configured"],
      "requires_consent_categories": ["analytics"],
      "requires_entitlements": ["analytics_advanced_providers"],
      "requires_tenant_settings": ["custom_webhook_allowed_egress_domains"],
      "note": "Generic HMAC-signed JSON dispatch to a tenant-configured HTTPS endpoint. Anti-exfiltration: endpoint URL validated against tenant.allowed_egress_domains before dispatch.",
      "circuit_breaker_defaults": { "threshold": 5, "failure_rate": 0.2, "window_seconds": 60 },
      "retry_defaults": { "max_attempts": 5, "backoff_ms": [1000, 5000, 30000, 300000, 3600000] }
    }
  }
}
