{
  "id": "geofencing.screens.branch-fence-editor",
  "title": "Edit branch geofence",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/workspace/facilities/branches/{branch}/geofence",
  "host": "workspace",
  "audience": "authenticated",
  "resource": {"module": "geofencing", "entity": "branch-geofence", "action": "edit"},
  "requiresPermission": "workspace_locales.manage",
  "requiresFeature": "feature_geofence_enforcement",
  "params": [{"name": "branch", "type": "string", "in": "path", "required": true}],
  "dataSources": [
    {"name": "branch", "kind": "http.get", "urlExpr": "'/api/v1/branches/' + params.branch", "unwrap": "data", "requires_module": "facilities"},
    {"name": "fence", "kind": "http.get", "urlExpr": "'/api/v1/branches/' + params.branch + '/geofence'", "unwrap": "data", "requires_module": "facilities"}
  ],
  "state": [
    {"name": "mode", "defaultExpr": "fence?.geofencePolygon ? 'polygon' : 'radius'"},
    {"name": "polygonWkt", "defaultExpr": "fence?.geofencePolygon ? magellanToWkt(fence.geofencePolygon) : null"},
    {"name": "radiusM", "defaultExpr": "fence?.geofenceRadiusM ?? 100"},
    {"name": "toleranceM", "defaultExpr": "fence?.geofenceAccuracyToleranceM ?? 50"},
    {"name": "enforcement", "defaultExpr": "fence?.geofenceEnforcementEnabled ?? false"}
  ],
  "notes": ["MOUNTED INSIDE the Facilities module's branch page. Ships here structurally so the geometry-editing UX stays close to the domain that owns it.", "Requires the Facilities module to be present (branch route + branch fence endpoint)."],
  "nodes": [
    {"id": "root", "kind": "View", "props": {"className": "flex flex-col gap-4 p-6 max-w-6xl mx-auto"}, "children": [
      {"kind": "Link", "props": {"leadingIcon": "arrow-left", "children": "Back to branch"}, "actions": {"onPress": {"kind": "navigate", "toExpr": "'/workspace/facilities/branches/' + params.branch"}}},
      {"kind": "View", "children": [
        {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold"}, "bindings": {"childrenExpr": "'Geofence \u2014 ' + branch.name"}},
        {"kind": "Text", "props": {"className": "text-sm text-muted", "children": "Draw a polygon around the branch OR set a radius. Set the accuracy tolerance to reject noisy GPS readings."}}
      ]},
      {"kind": "ToggleGroup", "props": {"name": "mode"}, "options": [{"key": "polygon", "label": "Polygon"}, {"key": "radius", "label": "Radius"}]},
      {"kind": "View", "props": {"className": "grid grid-cols-3 gap-4"}, "children": [
        {"kind": "View", "props": {"className": "col-span-2"}, "children": [
          {"kind": "MapEditor", "props": {"provider": "leaflet", "tileLayer": "openstreetmap-standard", "drawMode": "$mode", "style": {"height": "600px"}}, "bindings": {"center": {"$expr": "[branch.location_point?.coordinates[1] ?? 0, branch.location_point?.coordinates[0] ?? 0]"}, "zoom": 16, "polygonWkt": {"$ref": "state.polygonWkt"}, "radius": {"$ref": "state.radiusM"}}, "actions": {"onPolygonChange": {"kind": "state.set", "field": "polygonWkt", "valueExpr": "event.wkt"}, "onRadiusChange": {"kind": "state.set", "field": "radiusM", "valueExpr": "event.meters"}}}
        ]},
        {"kind": "Card", "props": {"className": "p-4 flex flex-col gap-4"}, "children": [
          {"kind": "NumberField", "props": {"name": "radiusM", "label": "Radius (m)", "min": 1, "max": 100000}, "bindings": {"value": {"$ref": "state.radiusM"}, "hidden": {"$expr": "state.mode !== 'radius'"}}},
          {"kind": "NumberField", "props": {"name": "toleranceM", "label": "Accuracy tolerance (m)", "min": 1, "max": 5000, "helpText": "Reject GPS readings noisier than this."}, "bindings": {"value": {"$ref": "state.toleranceM"}}},
          {"kind": "Toggle", "props": {"name": "enforcement", "label": "Enforce this fence"}, "bindings": {"value": {"$ref": "state.enforcement"}}, "helpText": "When off, evaluations still record but consumers ignore OUTSIDE verdicts (shadow mode)."},
          {"kind": "Button", "props": {"variant": "primary", "children": "Save fence"}, "actions": {"onPress": {"kind": "http.patch", "urlExpr": "'/api/v1/branches/' + params.branch + '/geofence'", "bodyExpr": "{ mode: state.mode, polygon_wkt: state.polygonWkt, radius_m: state.radiusM, accuracy_tolerance_m: state.toleranceM, enforcement_enabled: state.enforcement }", "onSuccess": {"kind": "toast", "variant": "success", "message": "Geofence saved."}}}}
        ]}
      ]}
    ]}
  ]
}
