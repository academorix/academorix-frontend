{
  "id": "geofencing.screens.checks-log",
  "title": "Geofence audit log",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/workspace/settings/geofencing/checks",
  "host": "workspace",
  "audience": "authenticated",
  "resource": {"module": "geofencing", "entity": "geofence-check", "action": "list"},
  "requiresPermission": "geofence.checks.viewAny",
  "dataSources": [
    {"name": "checks", "kind": "http.get", "url": "/api/v1/geofence/checks", "unwrap": "data"}
  ],
  "state": [{"name": "filters", "default": {"result": null, "mode": null, "subject_type": null, "branch_id": null}}],
  "nodes": [
    {"id": "root", "kind": "View", "props": {"className": "flex flex-col gap-4 p-6"}, "children": [
      {"kind": "View", "children": [
        {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold", "children": "Geofence audit log"}},
        {"kind": "Text", "props": {"className": "text-sm text-muted", "children": "Every evaluation this workspace has performed. Immutable \u2014 override rows appear as new entries linked to the original."}}
      ]},
      {"kind": "Toolbar", "children": [
        {"kind": "Select", "props": {"name": "result", "placeholder": "All results", "clearable": true}, "options": [{"key": "INSIDE"}, {"key": "OUTSIDE"}, {"key": "SKIPPED"}, {"key": "ERROR"}]},
        {"kind": "Select", "props": {"name": "mode", "placeholder": "All modes", "clearable": true}, "options": [{"key": "polygon"}, {"key": "radius"}]},
        {"kind": "SearchField", "props": {"placeholder": "Subject id / branch id", "name": "q"}}
      ]},
      {"kind": "Table", "columns": [
        {"key": "evaluated_at", "header": "When", "cell": {"kind": "Text", "props": {"className": "text-xs text-muted"}, "bindings": {"childrenExpr": "formatDateTime(row.evaluated_at)"}}},
        {"key": "result", "header": "Result", "cell": {"kind": "Widget", "widget": "geofencing.geofence-status-chip", "propsExpr": "{ result: row.result, mode: row.mode, size: 'xs' }"}},
        {"key": "branch_id", "header": "Branch", "cell": {"kind": "Text", "props": {"className": "font-mono text-xs truncate max-w-xs"}, "bindings": {"children": {"$ref": "row.branch_id"}}}},
        {"key": "subject", "header": "Subject", "cell": {"kind": "View", "props": {"className": "flex items-center gap-1"}, "children": [
          {"kind": "Chip", "props": {"size": "xs", "variant": "neutral"}, "bindings": {"children": {"$ref": "row.subject_type"}}},
          {"kind": "Text", "props": {"className": "font-mono text-xs truncate max-w-xs"}, "bindings": {"children": {"$ref": "row.subject_id"}}}
        ]}},
        {"key": "distance", "header": "Distance", "cell": {"kind": "Text", "props": {"className": "font-mono text-xs text-right"}, "bindings": {"childrenExpr": "row.distance_to_fence_m !== null ? row.distance_to_fence_m + ' m' : '\u2014'"}}},
        {"key": "accuracy", "header": "\u00b1", "cell": {"kind": "Text", "props": {"className": "font-mono text-xs text-right"}, "bindings": {"childrenExpr": "row.accuracy_m + ' m'"}}},
        {"key": "override", "header": "Override", "cell": {"kind": "View", "props": {"className": "flex items-center gap-1"}, "children": [
          {"kind": "Chip", "props": {"size": "xs", "variant": "warning"}, "bindings": {"hidden": {"$expr": "!row.supersedes_check_id"}, "children": "Override"}},
          {"kind": "Chip", "props": {"size": "xs", "variant": "info"}, "bindings": {"hidden": {"$expr": "row.supersedes_check_id || row.result === 'INSIDE'"}, "children": "Rejected"}}
        ]}},
        {"key": "actions", "header": "", "cell": {"kind": "Button", "props": {"variant": "ghost", "isIconOnly": true, "size": "sm", "children": {"kind": "Icon", "props": {"name": "eye"}}}, "actions": {"onPress": {"kind": "modal.open", "modal": "geofence-check-detail", "propsExpr": "{ checkId: row.id }"}}}}
      ], "bindings": {"rows": {"$ref": "checks"}}}
    ]}
  ]
}
