{
  "id": "academorix://modules/geofencing/policies",
  "$version": 1,
  "title": "geofencing \u2014 authorization policies",
  "policies": [
    {
      "model": "GeofenceCheck",
      "class": "Academorix\\Geofencing\\Policies\\GeofenceCheckPolicy",
      "abilities": [
        {"action": "preflight", "permission": "geofence.preflight", "scope": "any authenticated workspace member. Note: the ability itself is bound to a workspace, not to a specific model instance \u2014 preflight is model-less."},
        {"action": "requestOverride", "permission": "geofence.overrides.request", "scope": "any authenticated workspace member on their own subject."},
        {"action": "viewAny", "permission": "geofence.checks.viewAny", "scope": "admin + owner. Workspace members see only their own subject_id via a scope."},
        {"action": "view", "permission": "geofence.checks.view", "scope": "admin + owner OR the subject's owner."},
        {"action": "platformViewAny", "permission": "platform.geofence.checks.viewAny", "scope": "platform ops"},
        {"action": "platformView", "permission": "platform.geofence.checks.view"},
        {"action": "platformOverridesViewAny", "permission": "platform.geofence.overrides.viewAny"},
        {"action": "platformPurge", "permission": "platform.geofence.checks.purge", "scope": "super_admin only. GDPR retention path. Every use audit-logged with reason."}
      ]
    }
  ]
}
