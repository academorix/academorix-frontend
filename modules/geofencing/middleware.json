{
  "id": "academorix://modules/geofencing/middleware",
  "$version": 1,
  "title": "geofencing \u2014 HTTP middleware",
  "middleware": [
    {
      "alias": "geofence.preflight.throttle",
      "class": "Academorix\\Geofencing\\Http\\Middleware\\PreflightThrottle",
      "priority": 55,
      "description": "Rate limits the /preflight endpoint to 60 requests/minute per authenticated user. Delegates to Laravel's ThrottleRequests with a named `geofence-preflight` limiter registered by GeofencingServiceProvider. Cheaper than a generic `throttle:60,1` because the limiter reads user_id straight from the auth guard, not a request signature hash.",
      "auto_applied": false,
      "auto_applied_to": []
    }
  ],
  "consumed": [
    { "middleware": "foundation::request.id" },
    { "middleware": "foundation::cors.strict" },
    { "middleware": "foundation::auth:sanctum" },
    { "middleware": "foundation::throttle" },
    { "middleware": "foundation::response.envelope" },
    { "middleware": "workspaces::workspace.resolve" },
    { "middleware": "versioning::versioning.resolve" }
  ],
  "rate_limiter_definitions": [
    {
      "name": "geofence-preflight",
      "class": "Academorix\\Geofencing\\RateLimiters\\PreflightRateLimiter",
      "registered_by": "GeofencingServiceProvider::registerRateLimiters()",
      "default": "60 req/min per user_id",
      "env_override": "GEOFENCE_PREFLIGHT_RATE_PER_MINUTE"
    }
  ]
}
