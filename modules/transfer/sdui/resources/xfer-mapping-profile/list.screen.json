{
  "id": "transfer.resources.xfer-mapping-profile.list",
  "title": "Mapping profiles",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/transfer/mapping-profiles",
  "host": "tenant",
  "audience": "authenticated",
  "resource": {"module": "transfer", "entity": "xfer-mapping-profile", "action": "list"},
  "requiresPermission": "transfer.mapping-profiles.viewAny",
  "requiresFeature": "transfer.mapping_profiles",
  "dataSources": [
    {"name": "profiles", "kind": "http.get", "url": "/api/v1/transfer/mapping-profiles", "unwrap": "data", "paginated": true, "queryParamsFromState": ["filter[entity]", "filter[is_shared]", "sort", "page", "per_page"]},
    {"name": "entities", "kind": "http.get", "url": "/api/v1/transfer/entities", "unwrap": "data", "cache": {"ttlSeconds": 300}}
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": {"className": "flex flex-col gap-4 p-6 max-w-5xl mx-auto"},
      "children": [
        {"kind": "View", "props": {"className": "flex items-start justify-between gap-4"}, "children": [
          {"kind": "View", "children": [
            {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold", "children": "Mapping profiles"}},
            {"kind": "Text", "props": {"className": "text-sm text-muted"}, "bindings": {"children": {"$expr": "t('transfer.mapping.description')"}}}
          ]}
        ]},
        {"kind": "View", "props": {"className": "flex flex-wrap gap-3"}, "children": [
          {"kind": "Select", "props": {"label": "Entity", "name": "filter[entity]", "placeholder": "All entities"}, "optionsSource": {"$ref": "entities", "valueField": "key", "labelField": "label"}, "actions": {"onChange": {"kind": "data.applyFilter", "source": "profiles"}}},
          {"kind": "Select", "props": {"label": "Visibility", "name": "filter[is_shared]", "placeholder": "All"}, "options": [
            {"key": "true",  "label": "Shared with tenant"},
            {"key": "false", "label": "Private (mine)"}
          ], "actions": {"onChange": {"kind": "data.applyFilter", "source": "profiles"}}}
        ]},
        {"kind": "Table", "props": {"columns": [
          {"key": "name",         "label": "Name"},
          {"key": "entity",       "label": "Entity", "valueFormatter": {"$expr": "(v) => t('transfer.entity.' + v, {fallback: v})"}},
          {"key": "is_shared",    "label": "Shared", "cellRenderer": {"kind": "Chip", "bindings": {"variant": {"$expr": "row.is_shared ? 'success' : 'neutral'"}, "children": {"$expr": "row.is_shared ? t('transfer.mapping.shared') : t('transfer.mapping.private')"}, "size": "xs"}}},
          {"key": "used_count",   "label": "Uses"},
          {"key": "last_used_at", "label": "Last used", "valueFormatter": "formatRelativeOrDash"},
          {"key": "actions",      "label": "", "cellRenderer": {"kind": "Menu", "props": {"trigger": {"kind": "IconButton", "props": {"icon": "ellipsis-vertical", "aria-label": "Row actions"}}}, "children": [
            {"kind": "MenuItem", "props": {"children": {"$expr": "t('transfer.actions.edit')"}},   "actions": {"onPress": {"kind": "navigateExpr", "expr": "'/tenant/transfer/mapping-profiles/' + row.id + '/edit'"}}},
            {"kind": "MenuItem", "props": {"children": {"$expr": "t('transfer.actions.share')"}, "hidden": {"$expr": "row.is_shared || !can('transfer.mapping-profiles.share')"}}, "actions": {"onPress": {"kind": "http.patch", "url": {"$expr": "'/api/v1/transfer/mapping-profiles/' + row.id"}, "body": {"is_shared": true}, "onSuccess": {"kind": "data.refresh", "source": "profiles"}}}},
            {"kind": "MenuItem", "props": {"children": {"$expr": "t('transfer.actions.delete')"}, "className": "text-danger"}, "actions": {"onPress": {"kind": "http.delete", "url": {"$expr": "'/api/v1/transfer/mapping-profiles/' + row.id"}, "confirm": {"title": {"$expr": "t('transfer.confirm.delete_profile.title')"}, "message": {"$expr": "t('transfer.confirm.delete_profile.message')"}}, "onSuccess": {"kind": "data.refresh", "source": "profiles"}}}}
          ]}}
        ]}, "bindings": {"rows": {"$ref": "profiles"}, "isLoading": {"$ref": "profiles.isLoading"}}}
      ]
    }
  ]
}
