{
  "id": "transfer.resources.xfer-job.show",
  "title": "Transfer job",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/transfer/jobs/{jobId}",
  "host": "tenant",
  "audience": "authenticated",
  "resource": {"module": "transfer", "entity": "xfer-job", "action": "show"},
  "requiresPermission": "transfer.view",
  "requiresFeature": "transfer.enabled",
  "dataSources": [
    {"name": "job",    "kind": "http.get", "url": {"$expr": "'/api/v1/transfer/jobs/' + params.jobId"}, "unwrap": "data"},
    {"name": "shards", "kind": "http.get", "url": {"$expr": "'/api/v1/transfer/jobs/' + params.jobId + '/shards'"}, "unwrap": "data", "enabled": {"$expr": "job.shards_total > 1"}}
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": {"className": "flex flex-col gap-6 p-6 max-w-5xl mx-auto"},
      "children": [
        {"kind": "Breadcrumbs", "props": {"items": [
          {"label": {"$expr": "t('transfer.breadcrumbs.transfers')"}, "to": "/tenant/transfer/jobs"},
          {"label": {"$ref": "job.id"}}
        ]}},
        {"kind": "View", "props": {"className": "flex items-start justify-between gap-4"}, "children": [
          {"kind": "View", "props": {"className": "flex flex-col gap-1"}, "children": [
            {"kind": "View", "props": {"className": "flex items-center gap-2"}, "children": [
              {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold"}, "bindings": {"children": {"$expr": "t('transfer.kind.' + job.kind) + ' — ' + t('transfer.entity.' + job.entity, {fallback: job.entity})"}}},
              {"kind": "Widget", "widget": "transfer.xfer-job-status-chip", "props": {"size": "md"}, "bindings": {"status": {"$ref": "job.status"}}}
            ]},
            {"kind": "Text", "props": {"className": "text-sm text-muted"}, "bindings": {"children": {"$expr": "'#' + job.id + ' — ' + formatRelative(job.created_at)"}}}
          ]},
          {"kind": "View", "props": {"className": "flex items-center gap-2"}, "children": [
            {"kind": "Button", "props": {"variant": "secondary", "startIcon": "arrow-down-tray"}, "actions": {"onPress": {"kind": "http.get", "url": {"$expr": "'/api/v1/transfer/jobs/' + job.id + '/download'"}, "responseKind": "download"}}, "bindings": {"children": {"$expr": "t('transfer.actions.download')"}, "hidden": {"$expr": "!job.has_result_artifact"}}},
            {"kind": "Button", "props": {"variant": "secondary", "startIcon": "exclamation-triangle", "className": "text-danger"}, "actions": {"onPress": {"kind": "http.get", "url": {"$expr": "'/api/v1/transfer/jobs/' + job.id + '/errors'"}, "responseKind": "download"}}, "bindings": {"children": {"$expr": "t('transfer.actions.download_errors')"}, "hidden": {"$expr": "!job.has_errors_artifact"}}},
            {"kind": "Button", "props": {"variant": "danger", "startIcon": "x-mark"}, "actions": {"onPress": {"kind": "http.post", "url": {"$expr": "'/api/v1/transfer/jobs/' + job.id + '/cancel'"}, "confirm": {"title": {"$expr": "t('transfer.confirm.cancel.title')"}, "message": {"$expr": "t('transfer.confirm.cancel.message')"}}, "onSuccess": {"kind": "data.refresh", "source": "job"}}}, "bindings": {"children": {"$expr": "t('transfer.actions.cancel')"}, "hidden": {"$expr": "!['queued','running'].includes(job.status)"}}}
          ]}
        ]},
        {"kind": "Card", "children": [
          {"kind": "Card.Header", "props": {"title": {"$expr": "t('transfer.show.progress')"}}},
          {"kind": "Card.Content", "children": [
            {"kind": "Widget", "widget": "transfer.xfer-job-progress", "props": {"compact": false, "subscribeBroadcast": true}, "bindings": {"job": {"$ref": "job"}}}
          ]}
        ]},
        {"kind": "Grid", "props": {"cols": 2, "gap": 4}, "children": [
          {"kind": "Card", "children": [
            {"kind": "Card.Header", "props": {"title": {"$expr": "t('transfer.show.details')"}}},
            {"kind": "Card.Content", "children": [
              {"kind": "DescriptionList", "props": {"items": [
                {"label": {"$expr": "t('transfer.field.kind')"},        "value": {"$expr": "t('transfer.kind.' + job.kind)"}},
                {"label": {"$expr": "t('transfer.field.entity')"},      "value": {"$expr": "t('transfer.entity.' + job.entity, {fallback: job.entity})"}},
                {"label": {"$expr": "t('transfer.field.mode')"},        "value": {"$expr": "job.mode ? t('transfer.mode.' + job.mode) : '—'"}},
                {"label": {"$expr": "t('transfer.field.format')"},      "value": {"$expr": "job.format || '—'"}},
                {"label": {"$expr": "t('transfer.field.initiator')"},   "value": {"$ref": "job.causer.display_name"}},
                {"label": {"$expr": "t('transfer.field.started_at')"},  "value": {"$expr": "job.started_at ? formatDateTime(job.started_at) : '—'"}},
                {"label": {"$expr": "t('transfer.field.finished_at')"}, "value": {"$expr": "job.finished_at ? formatDateTime(job.finished_at) : '—'"}},
                {"label": {"$expr": "t('transfer.field.duration')"},    "value": {"$expr": "job.duration_seconds ? formatDuration(job.duration_seconds) : '—'"}}
              ]}}
            ]}
          ]},
          {"kind": "Card", "children": [
            {"kind": "Card.Header", "props": {"title": {"$expr": "t('transfer.show.source')"}}},
            {"kind": "Card.Content", "children": [
              {"kind": "DescriptionList", "props": {"items": [
                {"label": {"$expr": "t('transfer.field.source_filename')"}, "value": {"$expr": "job.source_filename || '—'"}},
                {"label": {"$expr": "t('transfer.field.source_size')"},     "value": {"$expr": "job.source_file_size_bytes ? formatBytes(job.source_file_size_bytes) : '—'"}},
                {"label": {"$expr": "t('transfer.field.mapping_profile')"}, "value": {"$expr": "job.mapping_profile_id || '—'"}}
              ]}}
            ]}
          ]}
        ]},
        {"kind": "Card", "bindings": {"hidden": {"$expr": "job.shards_total <= 1"}}, "children": [
          {"kind": "Card.Header", "props": {"title": {"$expr": "t('transfer.show.shards')"}}},
          {"kind": "Card.Content", "children": [
            {"kind": "Table", "props": {"columns": [
              {"key": "index",         "label": "#"},
              {"key": "sheet_name",    "label": "Sheet"},
              {"key": "status",        "label": "Status", "cellRenderer": {"kind": "Widget", "widget": "transfer.xfer-job-status-chip", "bindings": {"status": {"$ref": "row.status"}}}},
              {"key": "counters.total", "label": "Rows"},
              {"key": "counters.failed", "label": "Failed", "className": "text-danger"},
              {"key": "duration_seconds", "label": "Duration", "valueFormatter": "formatDuration"},
              {"key": "actions",       "label": "", "cellRenderer": {"kind": "Button", "props": {"variant": "ghost", "size": "sm"}, "actions": {"onPress": {"kind": "http.post", "url": {"$expr": "'/api/v1/transfer/jobs/' + job.id + '/retry-shard/' + row.id"}, "onSuccess": {"kind": "data.refresh", "source": "shards"}}}, "bindings": {"children": {"$expr": "t('transfer.actions.retry')"}, "hidden": {"$expr": "row.status !== 'failed'"}}}}
            ]}, "bindings": {"rows": {"$ref": "shards"}}}
          ]}
        ]}
      ]
    }
  ]
}
