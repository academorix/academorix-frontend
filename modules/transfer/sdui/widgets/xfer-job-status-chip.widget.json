{
  "id": "transfer.xfer-job-status-chip",
  "title": "Xfer job status chip",
  "version": 1,
  "kind": "SduiWidget",
  "description": "Colored status pill for XferJob.status. Consumed by every list / row / detail surface that shows a job.",
  "props": {
    "status": {"type": "string", "description": "One of queued / running / succeeded / partially_succeeded / failed / cancelling / cancelled."},
    "size":   {"type": "string", "default": "sm", "description": "Chip size: xs / sm / md."}
  },
  "dataSources": [],
  "nodes": [
    {
      "id": "chip",
      "kind": "Chip",
      "bindings": {
        "size": {"$ref": "props.size"},
        "variant": {
          "$expr": "({queued:'neutral',running:'info',succeeded:'success',partially_succeeded:'warning',failed:'danger',cancelling:'warning',cancelled:'neutral'})[props.status]"
        },
        "children": {"$expr": "t('transfer.status.' + props.status)"}
      }
    }
  ]
}
