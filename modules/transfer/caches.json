{
  "id": "academorix://modules/transfer/caches",
  "$version": 1,
  "title": "transfer \u2014 cache keys + tags",
  "driver": "redis",
  "ownedTags": ["transfer"],
  "keys": [
    {"pattern": "transfer:registry",                                     "description": "EntityRegistry \u2014 the compiled #[Importable] / #[Exportable] / #[SampleData] / #[TransferField] / workbook catalogue. Loaded at boot from reflection.",  "ttlSeconds": 86400, "tags": ["transfer", "platform"], "invalidatedBy": ["foundation::ApplicationBooted", "foundation::ConfigReloaded", "hourly transfer-registry-refresh schedule entry"]},
    {"pattern": "transfer:capabilities:workspace:{workspace_id}:user:{user_id}", "description": "Resolved entities-list response for GET /transfer/entities \u2014 filtered by workspace features + user permissions.",                                            "ttlSeconds": 60,    "tags": ["transfer", "workspace"], "invalidatedBy": ["feature-flag::FeatureToggled", "access::PermissionsChanged for user"]},
    {"pattern": "transfer:mapping_profiles:workspace:{workspace_id}:owner:{owner_id}:entity:{entity}", "description": "Owner's mapping profiles for one entity (private + workspace-shared).", "ttlSeconds": 300, "tags": ["transfer", "workspace"], "invalidatedBy": ["XferMappingProfile model save / delete"]},
    {"pattern": "transfer:jobs:list:workspace:{workspace_id}:user:{user_id}:page:{page}:v:{version}",   "description": "Cached xfer_jobs list page. Version bumped on XferJob save.",                                                                        "ttlSeconds": 15,    "tags": ["transfer", "workspace"], "invalidatedBy": ["XferJob save bumps transfer:jobs:list:workspace:{workspace_id}:user:{user_id}:version"]},
    {"pattern": "transfer:artifact:signed:{artifact_id}",                "description": "Cached signed URL for a recently-requested artifact. Avoids re-signing on rapid retries.",                                                             "ttlSeconds": 60,    "tags": ["transfer"],           "invalidatedBy": ["artifact purge \u2192 delete key"]},
    {"pattern": "transfer:concurrency:workspace:{workspace_id}",               "description": "In-flight (queued+running) count for the workspace. Incremented at dispatch; decremented on terminal transition.",                                       "ttlSeconds": 3600,  "tags": ["transfer", "workspace"], "invalidatedBy": ["XferJob observer on status transition"]}
  ]
}
