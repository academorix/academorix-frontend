{
  "id": "academorix://modules/geography/observers",
  "$version": 1,
  "title": "geography \u2014 Eloquent observers",
  "description": "Per-entity observers. All fire the matching domain event on created / updated / deleted. NO ULID minting (vendor uses integer PKs). NO userstamp because vendor rows are seeder-owned; platform-admin overrides carry updated_by via HasUserstamps trait applied at the migration layer (add-column extension). Deletion is refused on system rows unless a platform-admin flag is set.",
  "observers": [
    {"model": "Country", "observer": "Academorix\\Geography\\Observers\\CountryObserver", "handles": ["saving \u2192 uppercase iso2 + iso3 for consistency", "created \u2192 fire CountryCreated", "updated \u2192 fire CountryUpdated with changed_fields", "deleting \u2192 refuse when downstream FKs reference this row (states / cities / currencies / timezones)", "deleted \u2192 fire CountryDeleted"]},
    {"model": "State", "observer": "Academorix\\Geography\\Observers\\StateObserver", "handles": ["saving \u2192 uppercase country_code", "created \u2192 fire StateCreated", "updated \u2192 fire StateUpdated with changed_fields", "deleting \u2192 refuse when downstream cities reference this row", "deleted \u2192 fire StateDeleted"]},
    {"model": "City", "observer": "Academorix\\Geography\\Observers\\CityObserver", "handles": ["saving \u2192 uppercase country_code", "created \u2192 fire CityCreated", "updated \u2192 fire CityUpdated with changed_fields", "deleted \u2192 fire CityDeleted"]},
    {"model": "Currency", "observer": "Academorix\\Geography\\Observers\\CurrencyObserver", "handles": ["saving \u2192 uppercase code (ISO-4217)", "saving \u2192 refuse precision outside [0, 8]", "created \u2192 fire CurrencyCreated", "updated \u2192 fire CurrencyUpdated with changed_fields", "deleted \u2192 fire CurrencyDeleted"]},
    {"model": "Language", "observer": "Academorix\\Geography\\Observers\\LanguageObserver", "handles": ["saving \u2192 lowercase code (ISO-639-1)", "saving \u2192 auto-derive is_rtl from dir when dir set", "created \u2192 fire LanguageCreated", "updated \u2192 fire LanguageUpdated with changed_fields", "deleted \u2192 fire LanguageDeleted"]},
    {"model": "Timezone", "observer": "Academorix\\Geography\\Observers\\TimezoneObserver", "handles": ["saving \u2192 validate IANA name format via valid_iana_timezone rule", "saving \u2192 uppercase country_code", "created \u2192 fire TimezoneCreated", "updated \u2192 fire TimezoneUpdated with changed_fields", "deleted \u2192 fire TimezoneDeleted"]}
  ]
}
