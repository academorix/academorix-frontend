{
  "id": "academorix://modules/geography/schemas/country",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "Country",
  "description": "ISO-3166 country row. Vendor `nnjeim/world` owns the migration + seeder for this table. Our model subclasses the vendor's, rebound via config('world.models.country') in GeographyServiceProvider::register(). Route binding accepts both numeric id AND ISO-3166 alpha-2 (case-insensitive) so `/countries/76` and `/countries/FR` both resolve.",
  "type": "object",
  "x-module": "geography",
  "x-vendor": {"package": "nnjeim/world", "vendor_model": "Nnjeim\\World\\Models\\Country", "we_own_migration": false, "we_own_seeder": false},
  "x-eloquent": {
    "baseClass": "Nnjeim\\World\\Models\\Country",
    "table": "countries",
    "primaryKey": "id",
    "keyType": "int",
    "incrementing": true,
    "timestamps": false,
    "model": "Academorix\\Geography\\Models\\Country",
    "interface": "Academorix\\Geography\\Contracts\\Data\\CountryInterface",
    "implements": ["Academorix\\Geography\\Contracts\\Data\\CountryInterface"],
    "traits": ["HasFactory", "HasWorldLocalizedName", "Filterable"],
    "casts": {"status": "integer"},
    "appends": ["localized_name"],
    "observers": ["CountryObserver"],
    "hidden": [],
    "guarded": []
  },
  "x-database": {
    "engine": "any (vendor-supported)",
    "vendor_owned": true,
    "columns_summary": {
      "id": {"type": "integer", "primary": true},
      "iso2": {"type": "string", "length": 2, "description": "ISO-3166 alpha-2 (uppercase). E.g. FR."},
      "iso3": {"type": "string", "length": 3, "nullable": true, "description": "ISO-3166 alpha-3 (uppercase). E.g. FRA."},
      "name": {"type": "string", "description": "English display name. Vendor row \u2014 do not modify."},
      "native": {"type": "string", "nullable": true, "description": "Local-script name (e.g. \u65e5\u672c, Deutschland)."},
      "phone_code": {"type": "string", "nullable": true, "description": "E.164 country calling code (no + prefix). E.g. `33` for France."},
      "region": {"type": "string", "nullable": true, "description": "UN M49 region (Americas, Europe, Africa, ...)."},
      "subregion": {"type": "string", "nullable": true, "description": "UN M49 subregion."},
      "latitude": {"type": "string", "nullable": true},
      "longitude": {"type": "string", "nullable": true},
      "emoji": {"type": "string", "nullable": true, "description": "Flag emoji character."},
      "emojiU": {"type": "string", "nullable": true, "description": "Unicode escape sequence for the flag."},
      "status": {"type": "integer", "default": 1, "description": "1 = active, 0 = deprecated (e.g. dissolved country)."}
    },
    "note": "Vendor does not maintain `created_at` / `updated_at` on this table \u2014 the model sets $timestamps = false."
  },
  "required": ["id", "iso2", "name"],
  "properties": {
    "id": {"type": "integer"},
    "iso2": {"type": "string", "pattern": "^[A-Z]{2}$"},
    "iso3": {"type": ["string", "null"], "pattern": "^[A-Z]{3}$"},
    "name": {"type": "string", "description": "English name."},
    "localized_name": {"type": "string", "description": "Computed via HasWorldLocalizedName. Resolves against world::country.<ISO2> in the current app locale."},
    "native": {"type": ["string", "null"]},
    "phone_code": {"type": ["string", "null"]},
    "region": {"type": ["string", "null"]},
    "subregion": {"type": ["string", "null"]},
    "latitude": {"type": ["string", "null"]},
    "longitude": {"type": ["string", "null"]},
    "emoji": {"type": ["string", "null"]},
    "emojiU": {"type": ["string", "null"]},
    "status": {"type": "integer", "enum": [0, 1]}
  },
  "additionalProperties": true,
  "x-wire": {"envelope": "spatie-data", "wrap": "data", "mapper": "SnakeCaseMapper", "resource_class": "Academorix\\Geography\\Data\\Resources\\CountryResourceData", "computed": ["localized_name"]},
  "x-route-binding": {"strategy": "resolveRouteBinding", "accepts": ["numeric PK", "ISO-3166 alpha-2 (case-insensitive)"]}
}
