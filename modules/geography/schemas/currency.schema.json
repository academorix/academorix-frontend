      "country_id": {"type": "integer"},
      "name": {"type": "string", "description": "English currency name (e.g. 'Euro')."},
      "code": {"type": "string", "length": 3, "description": "ISO-4217 alpha code (e.g. EUR)."},
      "symbol": {"type": "string", "nullable": true, "description": "Currency symbol (e.g. \u20ac). May be multi-char (kr for SEK)."},
      "symbol_native": {"type": "string", "nullable": true, "description": "Native-script symbol (\u00a5 vs \uffe5)."},
      "precision": {"type": "integer", "description": "Decimal places (2 for EUR/USD, 0 for JPY, 3 for BHD)."}
