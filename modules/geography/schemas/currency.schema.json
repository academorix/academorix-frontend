    "country_id": {"type": "integer"},
    "name": {"type": "string"},
    "code": {"type": "string", "pattern": "^[A-Z]{3}$"},
    "symbol": {"type": ["string", "null"]},
    "symbol_native": {"type": ["string", "null"]},
    "precision": {"type": "integer", "minimum": 0, "maximum": 8}
  },
  "additionalProperties": true,
  "x-wire": {"envelope": "spatie-data", "wrap": "data", "mapper": "SnakeCaseMapper", "resource_class": "Academorix\\Geography\\Data\\Resources\\CurrencyResourceData"},
  "x-route-binding": {"strategy": "resolveRouteBinding", "accepts": ["numeric PK", "ISO-4217 alpha (case-insensitive)"]}
