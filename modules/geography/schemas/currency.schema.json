{
  "id": "academorix://modules/geography/schemas/currency",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "Currency",
  "description": "ISO-4217 currency row. Vendor-owned schema. Route binding accepts numeric PK OR ISO-4217 code (uppercase). Precision + minor_unit fields feed the price / money formatters across the app.",
  "type": "object",
  "x-module": "geography",
  "x-vendor": {"package": "nnjeim/world", "vendor_model": "Nnjeim\\World\\Models\\Currency", "we_own_migration": false, "we_own_seeder": false},
  "x-eloquent": {
    "baseClass": "Nnjeim\\World\\Models\\Currency",
    "table": "currencies",
    "primaryKey": "id",
    "keyType": "int",
    "incrementing": true,
    "timestamps": false,
    "model": "Academorix\\Geography\\Models\\Currency",
    "interface": "Academorix\\Geography\\Contracts\\Data\\CurrencyInterface",
    "implements": ["Academorix\\Geography\\Contracts\\Data\\CurrencyInterface"],
    "traits": ["HasFactory", "Filterable"],
    "observers": ["CurrencyObserver"]
  },
  "x-database": {
    "engine": "any (vendor-supported)",
