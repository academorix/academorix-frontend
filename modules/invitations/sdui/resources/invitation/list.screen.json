{
  "id": "invitations.resources.invitation.list",
  "title": "Invitations",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/workspace/invitations",
  "host": "workspace",
  "audience": "authenticated",
  "resource": {
    "module": "invitations",
    "entity": "invitation",
    "action": "list"
  },
  "requiresPermission": "invitations.viewAny",
  "dataSources": [
    {
      "name": "invitations",
      "kind": "http.get",
      "url": "/api/v1/workspace/invitations",
      "unwrap": "data",
      "paginated": true,
      "queryParamsFromState": ["filter[state]", "filter[target_type]", "filter[email]", "sort", "page", "per_page"],
      "cache": {"ttlSeconds": 60, "staleWhileRevalidate": true},
      "fallback": {
        "kind": "mock.static",
        "path": "modules/invitations/data/invitations.json"
      }
    },
    {
      "name": "invitationTargets",
      "kind": "http.get",
      "url": "/api/v1/workspace/invitations/target-types",
      "unwrap": "data",
      "cache": {"ttlSeconds": 3600},
      "transform": {"sort": {"by": "label", "direction": "asc"}}
    }
  ],
  "subscriptions": [
    {
      "channel": "workspace.{workspaceId}.invitations",
      "kind": "private",
      "onEvent": {
        "kind": "data.mutateItem",
        "source": "invitations",
        "keyBy": "id",
        "expr": "event.data"
      }
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": {"className": "flex flex-col gap-4 p-6"},
      "children": [
        {
          "id": "header",
          "kind": "View",
          "props": {"className": "flex items-center justify-between"},
          "children": [
            {
              "id": "title",
              "kind": "Text",
              "props": {"as": "h1", "className": "text-2xl font-semibold", "children": "Invitations"}
            },
            {
              "id": "actions",
              "kind": "View",
              "props": {"className": "flex items-center gap-2"},
              "children": [
                {
                  "id": "refresh",
                  "kind": "Button",
                  "props": {"variant": "ghost", "size": "sm", "children": "Refresh", "leadingIcon": "arrow-path"},
                  "actions": {"onPress": {"kind": "data.refresh", "source": "invitations"}}
                },
                {
                  "id": "create",
                  "kind": "Button",
                  "props": {"variant": "primary", "size": "sm", "children": "Send invitation", "leadingIcon": "paper-airplane"},
                  "bindings": {"isDisabled": {"$expr": "!identity.permissions.includes('invitations.send')"}},
                  "actions": {"onPress": {"kind": "navigate", "to": "/workspace/invitations/new"}}
                }
              ]
            }
          ]
        },
        {
          "id": "filters",
          "kind": "View",
          "props": {"className": "flex flex-wrap items-end gap-3"},
          "children": [
            {
              "id": "filter-state",
              "kind": "MultiSelect",
              "props": {
                "label": "Status",
                "name": "filter[state]",
                "placeholder": "All statuses",
                "className": "min-w-48"
              },
              "options": [
                {"key": "pending", "label": "Pending"},
                {"key": "delivered", "label": "Delivered"},
                {"key": "opened", "label": "Opened"},
                {"key": "clicked", "label": "Clicked"},
                {"key": "accepted", "label": "Accepted"},
                {"key": "declined", "label": "Declined"},
                {"key": "expired", "label": "Expired"},
                {"key": "revoked", "label": "Revoked"},
                {"key": "bounced", "label": "Bounced"}
              ],
              "actions": {"onChange": {"kind": "data.applyFilter", "source": "invitations"}}
            },
            {
              "id": "filter-target-type",
              "kind": "Select",
              "props": {"label": "Target", "name": "filter[target_type]", "placeholder": "Any target"},
              "optionsSource": {"$ref": "invitationTargets"},
              "actions": {"onChange": {"kind": "data.applyFilter", "source": "invitations"}}
            },
            {
              "id": "filter-email",
              "kind": "SearchField",
              "props": {"label": "Invitee email", "name": "filter[email]", "placeholder": "search@example.com", "debounceMs": 300, "className": "min-w-64"},
              "actions": {"onChange": {"kind": "data.applyFilter", "source": "invitations"}}
            }
          ]
        },
        {
          "id": "table",
          "kind": "DataGrid",
          "props": {
            "selection": "multi",
            "emptyState": {
              "title": "No invitations yet",
              "description": "Send your first invitation to add someone to this workspace.",
              "action": {"label": "Send invitation", "route": "/workspace/invitations/new", "variant": "primary"}
            }
          },
          "bindings": {
            "items": {"$ref": "invitations"},
            "isLoading": {"$ref": "invitations.isLoading"}
          },
          "columns": [
            {
              "id": "email",
              "header": "Invitee",
              "sortable": true,
              "sortKey": "email",
              "cell": {
                "kind": "View",
                "props": {"className": "flex flex-col"},
                "children": [
                  {"kind": "Text", "props": {"className": "font-medium"}, "bindings": {"children": {"$ref": "row.email"}}},
                  {"kind": "Text", "props": {"className": "text-muted text-xs"}, "bindings": {"children": {"$expr": "row.role_key ? ('Role: ' + row.role_key) : ''"}}}
                ]
              }
            },
            {
              "id": "target",
              "header": "Target",
              "cell": {
                "kind": "Text",
                "props": {"className": "text-sm"},
                "bindings": {"children": {"$expr": "row.target_type + (row.grants && row.grants.branch_id ? ' · ' + row.grants.branch_id : '')"}}
              }
            },
            {
              "id": "state",
              "header": "Status",
              "sortable": true,
              "sortKey": "state",
              "cell": {
                "kind": "Widget",
                "widget": "invitations.status-chip",
                "props": {"state": {"$ref": "row.state"}, "size": "sm"}
              }
            },
            {
              "id": "sent_at",
              "header": "Sent",
              "sortable": true,
              "sortKey": "created_at",
              "cell": {
                "kind": "Text",
                "props": {"className": "text-sm text-muted"},
                "bindings": {"children": {"$expr": "row.sent_at ? formatRelative(row.sent_at) : 'Not yet'"}}
              }
            },
            {
              "id": "expires_at",
              "header": "Expires",
              "sortable": true,
              "sortKey": "expires_at",
              "cell": {
                "kind": "Text",
                "props": {"className": "text-sm"},
                "bindings": {
                  "children": {"$expr": "formatRelative(row.expires_at)"},
                  "className": {"$expr": "row.state === 'pending' && diffDays(row.expires_at, now()) < 2 ? 'text-amber-600 text-sm font-medium' : 'text-sm text-muted'"}
                }
              }
            },
            {
              "id": "actions",
              "header": "",
              "align": "end",
              "cell": {
                "kind": "Menu",
                "props": {"trigger": {"kind": "Button", "props": {"variant": "ghost", "isIconOnly": true, "leadingIcon": "ellipsis-horizontal", "ariaLabel": "Row actions"}}},
                "items": [
                  {
                    "id": "view",
                    "label": "View details",
                    "leadingIcon": "eye",
                    "action": {"kind": "navigate", "toExpr": "'/workspace/invitations/' + row.id"}
                  },
                  {
                    "id": "resend",
                    "label": "Resend",
                    "leadingIcon": "arrow-path",
                    "bindings": {
                      "isDisabled": {"$expr": "row.is_terminal || row.resend_count >= 3 || !identity.permissions.includes('invitations.resend')"}
                    },
                    "action": {
                      "kind": "http.post",
                      "urlExpr": "'/api/v1/workspace/invitations/' + row.id + '/resend'",
                      "confirm": {
                        "title": "Resend invitation?",
                        "description": "A fresh email with a new link will be sent to the invitee."
                      },
                      "onSuccess": {"kind": "toast.success", "message": "Invitation resent"}
                    }
                  },
                  {
                    "id": "copy-link",
                    "label": "Copy accept link",
                    "leadingIcon": "clipboard",
                    "bindings": {"isDisabled": {"$expr": "row.is_terminal"}},
                    "action": {"kind": "clipboard.copyExpr", "expr": "row.public_accept_url", "onSuccess": {"kind": "toast.success", "message": "Link copied"}}
                  },
                  {
                    "id": "revoke",
                    "label": "Revoke",
                    "leadingIcon": "ban",
                    "variant": "danger",
                    "bindings": {
                      "isDisabled": {"$expr": "row.is_terminal || !identity.permissions.includes('invitations.revoke')"}
                    },
                    "action": {
                      "kind": "http.post",
                      "urlExpr": "'/api/v1/workspace/invitations/' + row.id + '/revoke'",
                      "confirm": {
                        "title": "Revoke invitation?",
                        "description": "The recipient will no longer be able to accept this invitation. This cannot be undone.",
                        "reasonField": {"label": "Reason (optional)", "name": "reason", "kind": "TextField"}
                      },
                      "onSuccess": {"kind": "toast.success", "message": "Invitation revoked"}
                    }
                  }
                ]
              }
            }
          ],
          "bulkActions": [
            {
              "id": "bulk-resend",
              "label": "Resend selected",
              "leadingIcon": "arrow-path",
              "bindings": {"isDisabled": {"$expr": "selectedItems.some(i => i.is_terminal || i.resend_count >= 3)"}},
              "action": {
                "kind": "http.postMany",
                "urlTemplate": "/api/v1/workspace/invitations/{id}/resend",
                "idFrom": "selectedItems",
                "confirm": {"title": "Resend {count} invitations?", "description": "Each will receive a fresh email with a new link."},
                "onSuccess": {"kind": "toast.success", "messageExpr": "'Resent ' + count + ' invitations'"}
              }
            },
            {
              "id": "bulk-revoke",
              "label": "Revoke selected",
              "leadingIcon": "ban",
              "variant": "danger",
              "bindings": {"isDisabled": {"$expr": "selectedItems.some(i => i.is_terminal)"}},
              "action": {
                "kind": "http.postMany",
                "urlTemplate": "/api/v1/workspace/invitations/{id}/revoke",
                "idFrom": "selectedItems",
                "confirm": {
                  "title": "Revoke {count} invitations?",
                  "description": "None of these invitees will be able to accept. This cannot be undone.",
                  "reasonField": {"label": "Reason (optional)", "name": "reason", "kind": "TextField"}
                },
                "onSuccess": {"kind": "toast.success", "messageExpr": "'Revoked ' + count + ' invitations'"}
              }
            }
          ],
          "pagination": {
            "kind": "cursor",
            "bindTo": "invitations"
          }
        }
      ]
    }
  ]
}
