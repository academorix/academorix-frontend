{
  "id": "invitations.resources.invitation.show",
  "title": "Invitation",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/workspace/invitations/:id",
  "host": "workspace",
  "audience": "authenticated",
  "resource": {"module": "invitations", "entity": "invitation", "action": "show"},
  "requiresPermission": "invitations.viewAny",
  "dataSources": [
    {
      "name": "invitation",
      "kind": "http.get",
      "url": "/api/v1/workspace/invitations/{id}",
      "unwrap": "data",
      "params": {"id": "$route.params.id"},
      "include": ["events", "target", "inviter", "acceptedBy", "revokedBy"]
    }
  ],
  "subscriptions": [
    {
      "channel": "workspace.{workspaceId}.invitations",
      "kind": "private",
      "filterExpr": "event.data.id === $route.params.id",
      "onEvent": {"kind": "data.refresh", "source": "invitation"}
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": {"className": "mx-auto flex max-w-4xl flex-col gap-6 p-6"},
      "children": [
        {
          "id": "breadcrumbs",
          "kind": "Breadcrumbs",
          "items": [
            {"label": "Invitations", "to": "/workspace/invitations"},
            {"label": {"$ref": "invitation.email"}, "isCurrent": true}
          ]
        },
        {
          "id": "header",
          "kind": "View",
          "props": {"className": "flex items-start justify-between gap-4"},
          "children": [
            {
              "id": "identity",
              "kind": "View",
              "props": {"className": "flex flex-col gap-1"},
              "children": [
                {"id": "email", "kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold"}, "bindings": {"children": {"$ref": "invitation.email"}}},
                {
                  "id": "meta",
                  "kind": "View",
                  "props": {"className": "text-muted flex flex-wrap items-center gap-3 text-sm"},
                  "children": [
                    {
                      "id": "status",
                      "kind": "Widget",
                      "widget": "invitations.status-chip",
                      "props": {"state": {"$ref": "invitation.state"}, "size": "md"}
                    },
                    {"id": "target", "kind": "Text", "bindings": {"children": {"$expr": "'Target: ' + invitation.target_type"}}},
                    {"id": "role", "kind": "Text", "bindings": {"children": {"$expr": "invitation.role_key ? 'Role: ' + invitation.role_key : ''"}}}
                  ]
                }
              ]
            },
            {
              "id": "actions",
              "kind": "View",
              "props": {"className": "flex items-center gap-2"},
              "children": [
                {
                  "id": "copy-link",
                  "kind": "Button",
                  "props": {"variant": "ghost", "size": "sm", "children": "Copy link", "leadingIcon": "clipboard"},
                  "bindings": {"isHidden": {"$expr": "invitation.is_terminal"}},
                  "actions": {"onPress": {"kind": "clipboard.copyExpr", "expr": "invitation.public_accept_url", "onSuccess": {"kind": "toast.success", "message": "Link copied"}}}
                },
                {
                  "id": "resend",
                  "kind": "Button",
                  "props": {"variant": "secondary", "size": "sm", "children": "Resend", "leadingIcon": "arrow-path"},
                  "bindings": {"isHidden": {"$expr": "invitation.is_terminal || invitation.resend_count >= 3"}},
                  "actions": {
                    "onPress": {
                      "kind": "http.post",
                      "urlExpr": "'/api/v1/workspace/invitations/' + invitation.id + '/resend'",
                      "confirm": {"title": "Resend invitation?", "description": "A fresh email with a new link will be sent."},
                      "onSuccess": {"kind": "sequence", "steps": [{"kind": "toast.success", "message": "Invitation resent"}, {"kind": "data.refresh", "source": "invitation"}]}
                    }
                  }
                },
                {
                  "id": "revoke",
                  "kind": "Button",
                  "props": {"variant": "danger", "size": "sm", "children": "Revoke", "leadingIcon": "ban"},
                  "bindings": {"isHidden": {"$expr": "invitation.is_terminal || !identity.permissions.includes('invitations.revoke')"}},
                  "actions": {
                    "onPress": {
                      "kind": "http.post",
                      "urlExpr": "'/api/v1/workspace/invitations/' + invitation.id + '/revoke'",
                      "confirm": {
                        "title": "Revoke invitation?",
                        "description": "The recipient will no longer be able to accept this invitation. This cannot be undone.",
                        "reasonField": {"label": "Reason (optional)", "name": "reason", "kind": "TextField"}
                      },
                      "onSuccess": {"kind": "sequence", "steps": [{"kind": "toast.success", "message": "Invitation revoked"}, {"kind": "data.refresh", "source": "invitation"}]}
                    }
                  }
                }
              ]
            }
          ]
        },
        {
          "id": "main",
          "kind": "View",
          "props": {"className": "grid gap-6 md:grid-cols-3"},
          "children": [
            {
              "id": "timeline-panel",
              "kind": "Card",
              "props": {"className": "md:col-span-2"},
              "children": [
                {
                  "id": "timeline-header",
                  "kind": "Text",
                  "props": {"as": "h2", "className": "text-lg font-medium", "children": "Timeline"}
                },
                {
                  "id": "timeline",
                  "kind": "Timeline",
                  "bindings": {"items": {"$ref": "invitation.events"}},
                  "itemTemplate": {
                    "id": "event",
                    "kind": "TimelineItem",
                    "bindings": {
                      "occurredAt": {"$ref": "item.occurred_at"},
                      "variant": {"$expr": "item.event === 'bounced' || item.event === 'revoked' ? 'danger' : (item.event === 'accepted' ? 'success' : (item.event === 'expired' ? 'warning' : 'info'))"}
                    },
                    "children": [
                      {
                        "kind": "View",
                        "props": {"className": "flex flex-col gap-1"},
                        "children": [
                          {"kind": "Text", "props": {"className": "font-medium"}, "bindings": {"children": {"$expr": "item.event.charAt(0).toUpperCase() + item.event.slice(1)"}}},
                          {"kind": "Text", "props": {"className": "text-muted text-sm"}, "bindings": {"children": {"$expr": "formatDateTime(item.occurred_at) + ' · ' + (item.actor_type || 'system') + (item.city ? ' · ' + item.city + ', ' + item.country_code : '')"}}},
                          {"kind": "Text", "props": {"className": "text-muted text-xs"}, "bindings": {"hidden": {"$expr": "!item.error_message"}, "children": {"$ref": "item.error_message"}}}
                        ]
                      }
                    ]
                  }
                }
              ]
            },
            {
              "id": "details-panel",
              "kind": "Card",
              "props": {"className": "flex flex-col gap-4"},
              "children": [
                {
                  "id": "details-header",
                  "kind": "Text",
                  "props": {"as": "h2", "className": "text-lg font-medium", "children": "Details"}
                },
                {
                  "id": "details-list",
                  "kind": "DescriptionList",
                  "items": [
                    {"label": "Invited by", "valueExpr": "invitation.inviter?.name || invitation.inviter?.email || invitation.inviter_type"},
                    {"label": "Target", "valueExpr": "invitation.target?.name || invitation.target_type + ' · ' + invitation.target_id"},
                    {"label": "Channel", "valueExpr": "invitation.channel"},
                    {"label": "Role on accept", "valueExpr": "invitation.role_key || '—'"},
                    {"label": "Created", "valueExpr": "formatDateTime(invitation.created_at)"},
                    {"label": "Sent", "valueExpr": "invitation.sent_at ? formatDateTime(invitation.sent_at) : '—'"},
                    {"label": "Expires", "valueExpr": "formatDateTime(invitation.expires_at)"},
                    {"label": "Resend count", "valueExpr": "invitation.resend_count + ' of ' + 3"},
                    {"label": "Accepted by", "valueExpr": "invitation.acceptedBy?.name || '—'", "hiddenExpr": "!invitation.accepted_at"},
                    {"label": "Revoked by", "valueExpr": "invitation.revokedBy?.name || '—'", "hiddenExpr": "!invitation.revoked_at"},
                    {"label": "Revoke reason", "valueExpr": "invitation.revoked_reason || '—'", "hiddenExpr": "!invitation.revoked_at"},
                    {"label": "Bounce reason", "valueExpr": "invitation.bounce_reason || '—'", "hiddenExpr": "invitation.state !== 'bounced'"}
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
