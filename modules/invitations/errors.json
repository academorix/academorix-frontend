{
  "id": "academorix://modules/invitations/errors",
  "$version": 1,
  "title": "invitations — error catalogue",
  "description": "Error codes this module can emit. `user_facing` controls whether the message renders to end users (translated via i18n). `retryable` signals client-side retry. `audit_severity` routes to the correct log channel — `alert` pages on-call.",
  "namespace": "invitations",
  "errors": [
    {"code": "INVITATIONS_TOKEN_NOT_FOUND", "http": 404, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "invitations.errors.token_not_found"},
    {"code": "INVITATIONS_TOKEN_EXPIRED", "http": 410, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "invitations.errors.token_expired"},
    {"code": "INVITATIONS_TOKEN_ALREADY_USED", "http": 409, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "invitations.errors.token_already_used", "description": "Idempotency guard — the token was already accepted / declined."},
    {"code": "INVITATIONS_INVITATION_REVOKED", "http": 410, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "invitations.errors.invitation_revoked"},
    {"code": "INVITATIONS_INVITATION_BOUNCED_TERMINAL", "http": 410, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "invitations.errors.invitation_bounced_terminal", "description": "Hard-bounced or complaint — invitee cannot receive further messages via this channel."},
    {"code": "INVITATIONS_EMAIL_ALREADY_INVITED", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "invitations.errors.email_already_invited", "description": "unique_pending_invitation validation rule tripped."},
    {"code": "INVITATIONS_EMAIL_ALREADY_MEMBER", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "invitations.errors.email_already_member", "description": "Preflight validator on the target refused: the invitee is already a member."},
    {"code": "INVITATIONS_TARGET_NOT_REGISTERED", "http": 422, "retryable": false, "user_facing": false, "audit_severity": "warn", "i18n_key": "invitations.errors.target_not_registered", "description": "target_type has no matching registration in InvitationTargetRegistry. Indicates a consumer module boot ordering bug."},
    {"code": "INVITATIONS_TARGET_NOT_FOUND", "http": 404, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "invitations.errors.target_not_found", "description": "target_id does not resolve to a row of target_type."},
    {"code": "INVITATIONS_ROLE_NOT_ASSIGNABLE", "http": 403, "retryable": false, "user_facing": true, "audit_severity": "warn", "i18n_key": "invitations.errors.role_not_assignable", "description": "role_key does not exist on the target's guard OR the inviter lacks the ability to assign it."},
    {"code": "INVITATIONS_CHANNEL_NOT_ENABLED", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "invitations.errors.channel_not_enabled", "description": "The requested channel (sms/slack) is not in the workspace's entitlement grant."},
    {"code": "INVITATIONS_INVALID_EMAIL", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "invitations.errors.invalid_email"},
    {"code": "INVITATIONS_INVALID_TARGET_TYPE", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "invitations.errors.invalid_target_type"},
    {"code": "INVITATIONS_RATE_LIMIT_EXCEEDED", "http": 429, "retryable": true, "user_facing": true, "audit_severity": "info", "i18n_key": "invitations.errors.rate_limit_exceeded", "description": "One of the throttle.invitations counters tripped. Response includes X-RateLimit-Trigger + Retry-After."},
    {"code": "INVITATIONS_ENTITLEMENT_EXCEEDED", "http": 402, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "invitations.errors.entitlement_exceeded", "description": "invitations.max_per_month pool is exhausted. Distinct from 429 — this one requires an upgrade, not a wait."},
    {"code": "INVITATIONS_STATE_TRANSITION_FORBIDDEN", "http": 409, "retryable": false, "user_facing": false, "audit_severity": "warn", "i18n_key": "invitations.errors.state_transition_forbidden", "description": "Attempt to move an invitation to a state that is not allowed from its current state (e.g. revoke after accept)."},
    {"code": "INVITATIONS_RESEND_CAP_REACHED", "http": 409, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "invitations.errors.resend_cap_reached", "description": "settings.max_resends cap hit."},
    {"code": "INVITATIONS_TOKEN_UNAVAILABLE", "http": 500, "retryable": false, "user_facing": false, "audit_severity": "alert", "i18n_key": "invitations.errors.token_unavailable", "description": "SendInvitationJob re-hydrated a payload without the raw token — indicates a queue corruption or a leftover job from a rollback. Marks the invitation `send_failed` and pages on-call."},
    {"code": "INVITATIONS_WEBHOOK_SIGNATURE_INVALID", "http": 401, "retryable": false, "user_facing": false, "audit_severity": "alert", "i18n_key": "invitations.errors.webhook_signature_invalid", "description": "Inbound mail-transport webhook failed signature verification. High volume of these = active attack; alerts fire above threshold."},
    {"code": "INVITATIONS_WEBHOOK_TRANSPORT_UNKNOWN", "http": 400, "retryable": false, "user_facing": false, "audit_severity": "warn", "i18n_key": "invitations.errors.webhook_transport_unknown", "description": "Unknown transport param in the URL. Usually a misconfigured provider or a probe."},
    {"code": "INVITATIONS_WEBHOOK_REPLAY_DETECTED", "http": 200, "retryable": false, "user_facing": false, "audit_severity": "info", "i18n_key": "invitations.errors.webhook_replay_detected", "description": "Idempotency guard tripped: (signal_id, transport) already seen. Returns 200 to prevent transport retry storms."},
    {"code": "INVITATIONS_MAIL_TRANSPORT_UNAVAILABLE", "http": 503, "retryable": true, "user_facing": false, "audit_severity": "warn", "i18n_key": "invitations.errors.mail_transport_unavailable", "description": "SendInvitationJob failed to reach the mail transport. Handled by job retry with backoff."},
    {"code": "INVITATIONS_ACCEPT_PREFLIGHT_FAILED", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "invitations.errors.accept_preflight_failed", "description": "Target-registered accept-handler refused. Message from the handler is surfaced (must be already localised)."},
    {"code": "INVITATIONS_MINOR_CONSENT_REQUIRED", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "invitations.errors.minor_consent_required", "description": "Invitee stated age < 16 / 13 (per jurisdiction); safeguarding module's VPC flow must be completed first."},
    {"code": "INVITATIONS_INVITEE_BLOCKED", "http": 403, "retryable": false, "user_facing": true, "audit_severity": "warn", "i18n_key": "invitations.errors.invitee_blocked", "description": "Invitee email is on the platform's block-list (abuse-response). Refused before send."}
  ]
}
