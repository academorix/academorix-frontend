{
  "id": "academorix://modules/medical/schemas/medical-record",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "MedicalRecord",
  "description": "Root health record per athlete — container aggregating Injury, Treatment, Clearance, Allergy, Medication. Restricted to medical role + admin.",
  "type": "object",
  "x-module": "medical",
  "x-eloquent": {
    "table": "medical_records",
    "keyPrefix": "mrc_",
    "traits": [
      "HasFactory",
      "HasPrefixedUlid",
      "BelongsToTenant",
      "BelongsToAthlete",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "HasActivityLog",
      "EncryptsSensitiveFields",
      "Filterable",
      "SoftDeletes"
    ]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 30, "primary": true },
      "tenant_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "athlete_id": {
        "type": "string",
        "length": 30,
        "nullable": false,
        "foreign": { "table": "athletes", "column": "id", "onDelete": "cascade" }
      },
      "blood_group": { "type": "string", "length": 8, "nullable": true },
      "primary_physician_encrypted": { "type": "text", "nullable": true },
      "emergency_medical_notes_encrypted": { "type": "text", "nullable": true },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false },
      "deleted_at": { "type": "timestamptz", "nullable": true }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "athlete_id"],
        "unique": true,
        "name": "medical_records_athlete_unique",
        "predicate": "deleted_at IS NULL"
      }
    ]
  },
  "required": ["id", "tenant_id", "athlete_id", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string", "pattern": "^mrc_[0-9A-HJKMNP-TV-Z]{26}$" }
  },
  "additionalProperties": false
}
