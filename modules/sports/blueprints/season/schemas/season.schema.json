{
  "id": "academorix://modules/season/schemas/season",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "Season",
  "description": "Time-bounded competition/training cycle. Answers 'which competitive year are we in?'. Carries `tenant_id` + `organization_id` (nullable) + `branch_id` (nullable) — scoping tuple lets a season be tenant-wide, org-scoped, or branch-scoped. NEVER carries `application_id` (cascades through tenant), NEVER `region_id`, NEVER `scope_node_id`. Exactly one `is_current=true` per (tenant_id, organization_id, branch_id, sport_key) tuple.",
  "type": "object",
  "x-module": "season",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "seasons",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "sea_",
    "incrementing": false,
    "model": "Academorix\\Sports\\Season\\Models\\Season",
    "interface": "Academorix\\Sports\\Season\\Contracts\\Data\\SeasonInterface",
    "implements": ["Academorix\\Sports\\Season\\Contracts\\Data\\SeasonInterface"],
    "traits": [
      "HasFactory",
      "HasUlids",
      "BelongsToTenant",
      "HasSlug",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "HasActivityLog",
      "Filterable",
      "Searchable",
      "SoftDeletes"
    ],
    "casts": {
      "season_type": "SeasonType",
      "status": "SeasonStatus",
      "is_current": "boolean",
      "has_playoffs": "boolean",
      "allows_late_registration": "boolean",
      "start_date": "date",
      "end_date": "date",
      "registration_opens_at": "datetime",
      "registration_closes_at": "datetime",
      "late_registration_ends_at": "datetime",
      "competition_starts_at": "datetime",
      "playoff_starts_at": "datetime",
      "playoff_ends_at": "datetime",
      "capacity_target": "integer",
      "max_enrollments_per_athlete": "integer",
      "late_registration_fee_cents": "integer",
      "sort_order": "integer",
      "metadata": "array"
    },
    "appends": ["is_registration_open", "current_phase", "days_until_start", "days_until_end"],
    "observers": ["SeasonObserver"]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": {
        "type": "string",
        "length": 64,
        "primary": true,
        "description": "Prefixed ULID: `sea_<26>`."
      },
      "tenant_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": { "table": "tenants", "column": "id", "onDelete": "cascade" }
      },
      "organization_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": { "table": "organizations", "column": "id", "onDelete": "restrict" },
        "description": "Nullable = tenant-wide season. Immutable post-create."
      },
      "branch_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": { "table": "branches", "column": "id", "onDelete": "restrict" },
        "description": "Nullable = tenant-wide OR org-wide season. Immutable post-create. When set, organization_id MUST equal branch.organization_id."
      },
      "name": { "type": "string", "length": 128, "nullable": false },
      "slug": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "description": "Unique per (tenant_id, organization_id, branch_id, slug) partial WHERE deleted_at IS NULL."
      },
      "sport_key": {
        "type": "string",
        "length": 32,
        "nullable": true,
        "description": "Wave 3c sports registry key. Nullable = applies to every sport in the scoping tuple. Free-text pre-Wave-3c."
      },
      "description": { "type": "text", "nullable": true },
      "season_type": {
        "type": "string",
        "length": 24,
        "nullable": false,
        "default": "'annual'",
        "description": "Enum: annual / academic_year / summer_camp / winter_camp / half_year / quarter / trimester / custom."
      },
      "start_date": { "type": "date", "nullable": false },
      "end_date": { "type": "date", "nullable": false, "description": "Must be > start_date." },
      "registration_opens_at": { "type": "timestamptz", "nullable": true },
      "registration_closes_at": { "type": "timestamptz", "nullable": true },
      "late_registration_ends_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "Grace window past registration_closes_at; requires allows_late_registration=true."
      },
      "competition_starts_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "When actual competition/session series begins; may differ from start_date for training-first seasons."
      },
      "has_playoffs": { "type": "boolean", "nullable": false, "default": false },
      "playoff_starts_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "Required when has_playoffs=true. Within [start_date, end_date]."
      },
      "playoff_ends_at": { "type": "timestamptz", "nullable": true },
      "status": {
        "type": "string",
        "length": 24,
        "nullable": false,
        "default": "'planned'",
        "description": "Enum: planned / registration_open / in_progress / playoffs / completed / archived. Transitions auto-flipped by RollSeasonPhaseJob."
      },
      "is_current": {
        "type": "boolean",
        "nullable": false,
        "default": false,
        "description": "Exactly one is_current=true per (tenant, organization, branch, sport_key) tuple."
      },
      "sort_order": { "type": "integer", "nullable": false, "default": 100 },
      "primary_color": { "type": "string", "length": 7, "nullable": true },
      "capacity_target": {
        "type": "integer",
        "nullable": true,
        "description": "Expected enrollment count for capacity planning. Informational only — not enforced."
      },
      "max_enrollments_per_athlete": {
        "type": "integer",
        "nullable": false,
        "default": 1,
        "description": "How many enrollments a single athlete can have this season (multi-sport athletes)."
      },
      "allows_late_registration": { "type": "boolean", "nullable": false, "default": false },
      "late_registration_fee_cents": { "type": "integer", "nullable": false, "default": 0 },
      "form_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "foreign": { "table": "forms", "column": "id", "onDelete": "set null" },
        "description": "Optional binding to a `platform/forms::Form` (kind = season_registration). When set, the form auto-publishes on Season transition to `registration_open` (via PublishFormOnSeasonRegistrationOpen hook) and auto-archives on transition to `registration_closed`. Null = season uses inline / hand-rolled registration flow. See ADR 0024."
      },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_by": { "type": "string", "length": 64, "nullable": true },
      "updated_by": { "type": "string", "length": 64, "nullable": true },
      "deleted_by": { "type": "string", "length": 64, "nullable": true },
      "deleted_at": { "type": "timestamptz", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "organization_id", "branch_id", "slug"],
        "unique": true,
        "name": "seasons_scope_slug_unique",
        "predicate": "deleted_at IS NULL",
        "description": "One live slug per scoping tuple."
      },
      {
        "columns": ["tenant_id", "organization_id", "branch_id", "sport_key"],
        "unique": true,
        "name": "seasons_scope_current_unique",
        "predicate": "is_current = true AND deleted_at IS NULL",
        "description": "Exactly one current per scoping tuple + sport_key."
      },
      { "columns": ["tenant_id", "status"], "name": "seasons_status_idx" },
      { "columns": ["tenant_id", "start_date"], "name": "seasons_start_date_idx" },
      { "columns": ["tenant_id", "end_date"], "name": "seasons_end_date_idx" },
      { "columns": ["tenant_id", "is_current"], "name": "seasons_current_idx" },
      {
        "columns": ["tenant_id", "sport_key"],
        "name": "seasons_sport_idx",
        "predicate": "sport_key IS NOT NULL"
      }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "name",
    "slug",
    "season_type",
    "start_date",
    "end_date",
    "has_playoffs",
    "status",
    "is_current",
    "sort_order",
    "max_enrollments_per_athlete",
    "allows_late_registration",
    "late_registration_fee_cents",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^sea_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": "string", "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "organization_id": { "type": ["string", "null"], "pattern": "^org_[0-9A-HJKMNP-TV-Z]{26}$" },
    "branch_id": { "type": ["string", "null"], "pattern": "^brn_[0-9A-HJKMNP-TV-Z]{26}$" },
    "name": { "type": "string", "minLength": 2, "maxLength": 128 },
    "slug": {
      "type": "string",
      "minLength": 2,
      "maxLength": 64,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "sport_key": { "type": ["string", "null"], "maxLength": 32 },
    "description": { "type": ["string", "null"] },
    "season_type": {
      "type": "string",
      "enum": [
        "annual",
        "academic_year",
        "summer_camp",
        "winter_camp",
        "half_year",
        "quarter",
        "trimester",
        "custom"
      ]
    },
    "start_date": { "type": "string", "format": "date" },
    "end_date": { "type": "string", "format": "date" },
    "registration_opens_at": { "type": ["string", "null"], "format": "date-time" },
    "registration_closes_at": { "type": ["string", "null"], "format": "date-time" },
    "late_registration_ends_at": { "type": ["string", "null"], "format": "date-time" },
    "competition_starts_at": { "type": ["string", "null"], "format": "date-time" },
    "has_playoffs": { "type": "boolean" },
    "playoff_starts_at": { "type": ["string", "null"], "format": "date-time" },
    "playoff_ends_at": { "type": ["string", "null"], "format": "date-time" },
    "status": {
      "type": "string",
      "enum": ["planned", "registration_open", "in_progress", "playoffs", "completed", "archived"]
    },
    "is_current": { "type": "boolean" },
    "sort_order": { "type": "integer", "minimum": 0, "maximum": 9999 },
    "primary_color": { "type": ["string", "null"], "pattern": "^#[0-9A-Fa-f]{6}$" },
    "capacity_target": { "type": ["integer", "null"], "minimum": 0 },
    "max_enrollments_per_athlete": { "type": "integer", "minimum": 1, "maximum": 20 },
    "allows_late_registration": { "type": "boolean" },
    "late_registration_fee_cents": { "type": "integer", "minimum": 0 },
    "metadata": { "type": ["object", "null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false,
  "x-wire": {
    "envelope": "spatie-data",
    "wrap": "data",
    "mapper": "SnakeCaseMapper",
    "computed": ["is_registration_open", "current_phase", "days_until_start", "days_until_end"]
  },
  "x-route-binding": {
    "strategy": "resolveRouteBinding",
    "accepts": [
      "ULID (`sea_<26>`)",
      "slug (case-insensitive, resolved within active scoping tuple)"
    ]
  },
  "invariants": [
    "end_date > start_date",
    "registration_opens_at IS NULL OR registration_opens_at < start_date + 30 days",
    "registration_closes_at IS NULL OR registration_closes_at > registration_opens_at",
    "has_playoffs=true implies playoff_starts_at IS NOT NULL AND playoff_starts_at IN [start_date, end_date]",
    "playoff_ends_at, when set, > playoff_starts_at",
    "COUNT(*) FILTER (WHERE is_current=true) <= 1 per (tenant_id, organization_id, branch_id, sport_key) tuple — enforced by unique partial index",
    "organization_id IS NULL WHEN branch_id IS NULL OR branch.organization_id = organization_id",
    "organization_id + branch_id + tenant_id IMMUTABLE post-create",
    "allows_late_registration=false implies late_registration_ends_at IS NULL AND late_registration_fee_cents = 0"
  ]
}
