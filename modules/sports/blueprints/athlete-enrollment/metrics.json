{
  "id": "academorix://modules/athlete-enrollment/metrics",
  "$version": 1,
  "title": "athlete-enrollment — OpenTelemetry metrics",
  "instrumentation": "self via telemetry",
  "namespace": "academorix.athlete_enrollment",
  "labelConventions": {
    "always": [],
    "commonlyAvailable": ["status", "enrollment_type", "enrollment_source", "withdrawal_reason"],
    "forbiddenAsLabels": ["tenant_id", "enrollment_id", "athlete_id", "team_id", "user_id", "price_amount_cents"]
  },
  "metrics": [
    { "name": "academorix.athlete_enrollment.count", "kind": "gauge", "unit": "enrollments", "labels": ["status", "enrollment_type"] },
    { "name": "academorix.athlete_enrollment.submitted_total", "kind": "counter", "unit": "enrollments", "labels": ["enrollment_source", "enrollment_type"] },
    { "name": "academorix.athlete_enrollment.confirmed_total", "kind": "counter", "unit": "enrollments", "labels": [] },
    { "name": "academorix.athlete_enrollment.activated_total", "kind": "counter", "unit": "enrollments", "labels": [] },
    { "name": "academorix.athlete_enrollment.completed_total", "kind": "counter", "unit": "enrollments", "labels": [] },
    { "name": "academorix.athlete_enrollment.withdrawn_total", "kind": "counter", "unit": "enrollments", "labels": ["withdrawal_reason"] },
    { "name": "academorix.athlete_enrollment.expelled_total", "kind": "counter", "unit": "enrollments", "labels": [] },
    { "name": "academorix.athlete_enrollment.expired_total", "kind": "counter", "unit": "enrollments", "labels": ["prior_status"] },
    { "name": "academorix.athlete_enrollment.waitlisted_total", "kind": "counter", "unit": "enrollments", "labels": [] },
    { "name": "academorix.athlete_enrollment.promoted_from_waitlist_total", "kind": "counter", "unit": "enrollments", "labels": [] },
    {
      "name": "academorix.athlete_enrollment.atomicity.failures_total",
      "kind": "counter",
      "unit": "failures",
      "labels": [],
      "description": "CRITICAL. Every increment is P1. Should stay at 0. Atomic conversion to TeamMember failed."
    },
    { "name": "academorix.athlete_enrollment.atomicity.retries_total", "kind": "counter", "unit": "retries", "labels": [], "description": "Non-fatal retries by ActivateConfirmedEnrollmentsJob before giving up + firing P1." },
    { "name": "academorix.athlete_enrollment.invariant.broken", "kind": "counter", "unit": "findings", "labels": [], "description": "CRITICAL. ReconcileEnrollmentTeamMemberInvariantJob findings. Should stay at 0." },
    { "name": "academorix.athlete_enrollment.age_group_snapshot_mismatch_total", "kind": "counter", "unit": "mismatches", "labels": ["mismatch_kind"] },
    { "name": "academorix.athlete_enrollment.activation.duration_ms", "kind": "histogram", "unit": "ms", "buckets": [50, 200, 1000, 5000], "labels": [], "description": "P99 target < 1000ms. Slower indicates DB contention on team_members SELECT ... FOR UPDATE." },
    { "name": "academorix.athlete_enrollment.retention.hard_purges_total", "kind": "counter", "unit": "purges", "labels": [] },
    { "name": "academorix.athlete_enrollment.entitlement.gate_refusals_total", "kind": "counter", "unit": "refusals", "labels": ["entitlement_key"] }
  ]
}
