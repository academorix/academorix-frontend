{
  "id": "academorix://modules/athlete-enrollment/listeners",
  "$version": 1,
  "title": "athlete-enrollment — subscribed events",
  "listeners": [
    { "event": "athlete::AthleteArchived (pre-write)", "listener": "Academorix\\Sports\\AthleteEnrollment\\Listeners\\PreventEnrollmentOrphansOnAthleteArchived", "queue": "athlete-enrollment", "priority": 30, "purpose": "Refuses athlete archive when active enrollments exist." },
    { "event": "athlete::AthleteWithdrawn", "listener": "Academorix\\Sports\\AthleteEnrollment\\Listeners\\CancelEnrollmentsOnAthleteWithdrawn", "queue": "athlete-enrollment", "purpose": "Cascade — transitions active enrollments to withdrawn. Fires only when cascade=true on the athlete withdraw route." },
    { "event": "athlete::AthleteGraduated", "listener": "Academorix\\Sports\\AthleteEnrollment\\Listeners\\CompleteEnrollmentsOnAthleteGraduated", "queue": "athlete-enrollment", "purpose": "Cascade — transitions active enrollments to completed. Fires only when cascade=true on the athlete graduate route." },
    { "event": "teams::TeamArchived (pre-write)", "listener": "Academorix\\Sports\\AthleteEnrollment\\Listeners\\PreventEnrollmentOrphansOnTeamArchived", "queue": "athlete-enrollment", "priority": 30, "purpose": "Refuses team archive when active enrollments exist." },
    { "event": "season::SeasonArchived (pre-write)", "listener": "Academorix\\Sports\\AthleteEnrollment\\Listeners\\PreventEnrollmentOrphansOnSeasonArchived", "queue": "athlete-enrollment", "priority": 30, "purpose": "Refuses season archive when active enrollments exist." },
    { "event": "season::SeasonCompleted", "listener": "Academorix\\Sports\\AthleteEnrollment\\Listeners\\CompleteEnrollmentsOnSeasonCompleted", "queue": "athlete-enrollment", "purpose": "Cascade — every active enrollment in the completed season transitions to completed." },
    { "event": "season::SeasonStarted", "listener": "Academorix\\Sports\\AthleteEnrollment\\Listeners\\ActivateConfirmedEnrollmentsOnSeasonStarted", "queue": "athlete-enrollment", "purpose": "Cascade — every confirmed enrollment for the started season transitions to active (via atomic conversion)." },
    { "event": "athlete-enrollment::EnrollmentActivated", "listener": "Academorix\\Sports\\AthleteEnrollment\\Listeners\\ConvertEnrollmentToTeamMemberAtomically", "queue": "athlete-enrollment", "priority": 10, "purpose": "The atomic-conversion hook. Runs BEFORE all other listeners on this event." },
    { "event": "athlete-enrollment::EnrollmentSubmitted", "listener": "Academorix\\Sports\\AthleteEnrollment\\Listeners\\SnapshotAgeGroupOnEnrollmentSubmitted", "queue": "athlete-enrollment", "priority": 15, "purpose": "In-band age-group snapshot resolution." },
    { "event": "tenancy::TenantErased", "listener": "Academorix\\Sports\\AthleteEnrollment\\Listeners\\PurgeAthleteEnrollmentDataForErasedTenant", "queue": "athlete-enrollment", "purpose": "Cascade delete via FK." }
  ]
}
