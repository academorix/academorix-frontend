{
  "id": "attendance.resources.attendance-policy.activate",
  "title": "Activate attendance policy",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/attendance-policies/{policy}/activate",
  "host": "tenant",
  "audience": "authenticated",
  "resource": { "module": "attendance", "entity": "attendance-policy", "action": "activate" },
  "requiresPermission": "attendance-policies.activate",
  "dataSources": [
    { "name": "policy", "kind": "http.get", "urlTemplate": "/api/v1/attendance-policies/{policy}", "unwrap": "data" },
    { "name": "collisions", "kind": "http.get", "urlTemplate": "/api/v1/attendance-policies?filter[branch_id]={policy.branch_id}&filter[membership_plan_id]={policy.membership_plan_id}&filter[is_active]=true", "unwrap": "data" }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": { "className": "flex flex-col gap-4 p-6 max-w-3xl mx-auto" },
      "children": [
        { "kind": "Text", "props": { "as": "h1", "className": "text-2xl font-semibold", "children": "Activate policy" } },
        {
          "kind": "Alert",
          "props": { "variant": "warning" },
          "bindings": { "hidden": { "$expr": "collisions.length === 0" } },
          "children": [
            { "kind": "Text", "props": { "className": "font-semibold", "children": "Collision detected" } },
            { "kind": "Text", "propsExpr": "{ children: 'An active policy already exists at this (branch, plan) specificity. Activating will supersede it: ' + collisions[0].name }" }
          ]
        },
        {
          "kind": "Card",
          "children": [
            {
              "kind": "Card.Header",
              "children": [
                { "kind": "Text", "propsExpr": "{ children: 'Activate policy: ' + policy.name }" }
              ]
            },
            {
              "kind": "Card.Content",
              "props": { "className": "flex flex-col gap-2" },
              "children": [
                { "kind": "Text", "propsExpr": "{ children: 'Grace period: ' + policy.grace_period_minutes + ' minutes' }" },
                { "kind": "Text", "propsExpr": "{ children: 'Max unexcused absences: ' + policy.max_unexcused_absences_per_period + ' in ' + policy.absence_freeze_period_days + '-day window' }" },
                { "kind": "Text", "propsExpr": "{ children: 'Late penalty: ' + policy.late_arrival_penalty_type }" }
              ]
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "flex justify-end gap-2" },
          "children": [
            {
              "kind": "Button",
              "props": { "variant": "secondary", "children": "Cancel" },
              "actions": { "onPress": { "kind": "navigate.back" } }
            },
            {
              "kind": "Button",
              "props": { "variant": "primary", "children": "Activate" },
              "actions": {
                "onPress": {
                  "kind": "http.post",
                  "urlTemplate": "/api/v1/attendance-policies/{policy}/activate",
                  "onSuccess": { "kind": "navigate", "to": "/tenant/attendance-policies" }
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
