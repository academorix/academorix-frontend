{
  "id": "academorix://modules/coaching/schemas/coach-certification",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "CoachCertification",
  "description": "Held certification credential for a CoachingProfile. Captures issuing_body + certification_name + level + issued_at + optional expires_at. Drives the 90/30/7-day expiration cadence via NotifyCertificationExpiringJob + NotifyCertificationExpiredJob. Two-step lifecycle: added → verified (admin). document_url references a signed S3 file (Wave 4+). Carries tenant_id (CASCADE) + coaching_profile_id (CASCADE — certs have no meaning without their profile, but survive profile deactivation for compliance audit). NEVER carries application_id, organization_id, region_id, branch_id, or scope_node_id.",
  "type": "object",
  "x-module": "coaching",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "coach_certifications",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "ccf_",
    "incrementing": false,
    "model": "Academorix\\Sports\\Coaching\\Models\\CoachCertification",
    "interface": "Academorix\\Sports\\Coaching\\Contracts\\Data\\CoachCertificationInterface",
    "implements": ["Academorix\\Sports\\Coaching\\Contracts\\Data\\CoachCertificationInterface"],
    "traits": [
      "HasFactory",
      "HasPrefixedUlid",
      "BelongsToTenant",
      "BelongsToCoachingProfile",
      "HasMetadata",
      "HasUserstamps",
      "Auditable",
      "HasActivityLog",
      "Filterable",
      "SoftDeletes"
    ],
    "casts": {
      "level": "CoachCertificationLevel",
      "issued_at": "date",
      "expires_at": "date",
      "verified_at": "datetime",
      "metadata": "array"
    },
    "observers": ["CoachCertificationObserver"],
    "appends": [
      "coach_display_name",
      "is_verified",
      "is_expired",
      "days_until_expiry"
    ]
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": { "type": "string", "length": 30, "primary": true, "description": "Prefixed ULID: `ccf_<26>`." },
      "tenant_id": { "type": "string", "length": 30, "nullable": false, "foreign": { "table": "tenants", "column": "id", "onUpdate": "cascade", "onDelete": "cascade" } },
      "coaching_profile_id": { "type": "string", "length": 30, "nullable": false, "foreign": { "table": "coaching_profiles", "column": "id", "onUpdate": "cascade", "onDelete": "cascade" }, "description": "The coach's profile. CASCADE — certs go with the profile on hard-delete." },
      "issuing_body": { "type": "string", "length": 256, "nullable": false, "description": "Certification body slug or free-text. Autocompletes against the certification-body-catalog." },
      "certification_name": { "type": "string", "length": 256, "nullable": false, "description": "Certification name (e.g. 'USSF C License', 'CPR + AED Certification', 'CSCS')." },
      "level": { "type": "string", "length": 32, "nullable": true, "description": "Enum: entry / intermediate / advanced / expert / master." },
      "issued_at": { "type": "date", "nullable": false },
      "expires_at": { "type": "date", "nullable": true, "description": "NULL = does not expire." },
      "verification_url": { "type": "string", "length": 512, "nullable": true, "description": "External verification URL (issuing body's public verify portal)." },
      "document_url": { "type": "string", "length": 512, "nullable": true, "description": "Signed HTTPS S3 URL to scanned cert. Requires coaching_advanced_certifications entitlement." },
      "verified_by_admin_user_id": { "type": "string", "length": 30, "nullable": true, "foreign": { "table": "users", "column": "id", "onUpdate": "cascade", "onDelete": "set null" } },
      "verified_at": { "type": "timestamptz", "nullable": true },
      "verification_notes": { "type": "text", "nullable": true, "description": "Admin-visible notes on the verification. HR-visible only." },
      "metadata": { "type": "jsonb", "nullable": true, "description": "Reserved keys: expiration_notices (map cadence_days -> ISO), expired_at (ISO)." },
      "created_by": { "type": "string", "length": 30, "nullable": true },
      "updated_by": { "type": "string", "length": 30, "nullable": true },
      "deleted_by": { "type": "string", "length": 30, "nullable": true },
      "deleted_at": { "type": "timestamptz", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["tenant_id", "coaching_profile_id", "issuing_body", "certification_name", "issued_at"],
        "unique": true,
        "name": "coach_certifications_body_name_unique",
        "predicate": "deleted_at IS NULL",
        "description": "One live row per (coach, issuing_body, certification_name, issued_at). Prevents duplicate captures."
      },
      { "columns": ["tenant_id", "expires_at"], "name": "coach_certifications_expires_idx", "description": "Feeds NotifyCertificationExpiringJob's per-tenant sweep." },
      { "columns": ["tenant_id", "coaching_profile_id", "verified_at"], "name": "coach_certifications_profile_verified_idx" },
      { "columns": ["tenant_id", "coaching_profile_id", "issuing_body"], "name": "coach_certifications_body_idx" }
    ]
  },
  "required": [
    "id",
    "tenant_id",
    "coaching_profile_id",
    "issuing_body",
    "certification_name",
    "issued_at",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^ccf_[0-9A-HJKMNP-TV-Z]{26}$" },
    "tenant_id": { "type": "string", "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$" },
    "coaching_profile_id": { "type": "string", "pattern": "^cop_[0-9A-HJKMNP-TV-Z]{26}$" },
    "issuing_body": { "type": "string", "maxLength": 256 },
    "certification_name": { "type": "string", "maxLength": 256 },
    "level": { "type": ["string", "null"], "enum": ["entry", "intermediate", "advanced", "expert", "master", null] },
    "issued_at": { "type": "string", "format": "date" },
    "expires_at": { "type": ["string", "null"], "format": "date" },
    "verification_url": { "type": ["string", "null"], "maxLength": 512, "format": "uri" },
    "document_url": { "type": ["string", "null"], "maxLength": 512, "format": "uri" },
    "verified_by_admin_user_id": { "type": ["string", "null"], "pattern": "^usr_[0-9A-HJKMNP-TV-Z]{26}$" },
    "verified_at": { "type": ["string", "null"], "format": "date-time" },
    "verification_notes": { "type": ["string", "null"], "maxLength": 2048 },
    "metadata": { "type": ["object", "null"] },
    "coach_display_name": { "type": "string" },
    "is_verified": { "type": "boolean" },
    "is_expired": { "type": "boolean" },
    "days_until_expiry": { "type": ["integer", "null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false,
  "x-invariants": [
    "One live row per (tenant_id, coaching_profile_id, issuing_body, certification_name, issued_at) — enforced by partial unique index",
    "expires_at > issued_at when both set — enforced by observer",
    "document_url matches HTTPS S3 pattern when set — enforced by observer",
    "document_url requires coaching_advanced_certifications entitlement — enforced by observer",
    "Verification requires coaching_advanced_certifications entitlement (Medium+) — enforced by observer",
    "Verified certs are terminal for the verification workflow — cannot un-verify (must delete + re-capture)"
  ]
}
