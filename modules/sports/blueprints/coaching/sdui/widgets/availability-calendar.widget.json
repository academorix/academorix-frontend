      "props": { "className": "mt-3" },
      "bindings": { "hidden": { "$expr": "!$params.editable" } },
      "children": [
        {
          "kind": "Button",
          "props": { "size": "sm", "variant": "flat", "leadingIcon": "plus", "children": "Add time range" }
        }
      ]
    }
  ]
