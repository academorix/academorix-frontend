              "props": { "className": "text-xs text-muted", "children": "—" },
              "bindings": { "hidden": { "$expr": "($params.availability.tuesday || []).length > 0" } }
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "flex flex-col gap-1" },
          "children": [
