{
  "id": "coaching.widgets.availability-calendar",
  "title": "Availability calendar",
  "version": 1,
  "kind": "SduiWidget",
  "widget": "coaching.availability-calendar",
  "description": "Day-of-week grid showing the coach's availability_json ranges. Renders a 7-column grid (Mon-Sun) with time-range chips. When editable=true (used on coach's /me/profile), each day supports adding/removing time ranges. When editable=false (read-only preview), renders as compact chips.",
  "params": {
    "availability": { "type": ["object", "null"], "required": false, "description": "Day-of-week map: { monday: [{start_hhmm, end_hhmm}], ... }." },
    "editable": { "type": "boolean", "required": false, "default": false },
    "name": { "type": "string", "required": false, "description": "Form field name when editable=true." }
  },
  "nodes": [
    {
      "kind": "View",
      "props": { "className": "grid grid-cols-7 gap-2" },
      "children": [
        {
          "kind": "View",
          "props": { "className": "flex flex-col gap-1" },
          "children": [
            { "kind": "Text", "props": { "className": "text-xs font-medium text-muted uppercase", "children": "Mon" } },
            {
              "kind": "View",
              "props": { "className": "flex flex-col gap-1" },
              "bindings": { "items": { "$ref": "$params.availability.monday" } },
              "itemRenderer": {
                "kind": "Chip",
                "props": { "size": "xs" },
                "bindings": { "children": { "$expr": "$item.start_hhmm + '-' + $item.end_hhmm" } }
              }
            },
            {
              "kind": "Text",
              "props": { "className": "text-xs text-muted", "children": "—" },
              "bindings": { "hidden": { "$expr": "($params.availability.monday || []).length > 0" } }
            }
          ]
        },
        {
          "kind": "View",
          "props": { "className": "flex flex-col gap-1" },
          "children": [
            { "kind": "Text", "props": { "className": "text-xs font-medium text-muted uppercase", "children": "Tue" } },
            {
              "kind": "View",
              "props": { "className": "flex flex-col gap-1" },
              "bindings": { "items": { "$ref": "$params.availability.tuesday" } },
              "itemRenderer": {
                "kind": "Chip",
                "props": { "size": "xs" },
