{
  "id": "notifications-sms.resources.sms-opt-out.show",
  "title": "SMS opt-out detail",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/workspace/sms-opt-outs/{id}",
  "host": "workspace",
  "audience": "authenticated",
  "resource": {"module": "notifications-sms", "entity": "sms-opt-out", "action": "show"},
  "requiresPermission": "notifications.sms.opt-outs.view",
  "params": [{"name": "id", "type": "string", "in": "path", "required": true}],
  "dataSources": [
    {"name": "optOut", "kind": "http.get", "urlExpr": "'/api/v1/workspace/sms-opt-outs/' + params.id", "unwrap": "data"}
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": {"className": "flex flex-col gap-6 p-6 max-w-3xl mx-auto"},
      "children": [
        {"kind": "Link", "props": {"leadingIcon": "arrow-left", "children": "Back to opt-outs", "className": "text-sm text-muted"}, "actions": {"onPress": {"kind": "navigate", "to": "/workspace/sms-opt-outs"}}},
        {"kind": "View", "props": {"className": "flex items-start justify-between"}, "children": [
          {"kind": "View", "props": {"className": "flex flex-col gap-1"}, "children": [
            {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold font-mono"}, "bindings": {"children": {"$ref": "optOut.phone"}}},
            {"kind": "Chip", "props": {"size": "md"}, "bindings": {"variant": {"$expr": "['stop_keyword', 'complaint', 'spam_trap', 'do_not_call_registry'].includes(optOut.reason) ? 'danger' : (optOut.reason === 'invalid_number' ? 'warning' : 'info')"}, "children": {"$ref": "optOut.reason"}}}
          ]},
          {"kind": "Button", "props": {"variant": "outline", "size": "sm", "leadingIcon": "arrow-uturn-left", "children": "Revoke"}, "bindings": {"isDisabled": {"$expr": "optOut.is_system || (optOut.reason === 'stop_keyword' && !identity.roles.includes('super_admin'))"}}, "actions": {"onPress": {"kind": "http.delete", "urlExpr": "'/api/v1/workspace/sms-opt-outs/' + params.id", "confirm": {"title": "Revoke this opt-out?"}, "onSuccess": [{"kind": "toast.success", "message": "Revoked"}, {"kind": "navigate", "to": "/workspace/sms-opt-outs"}]}}}
        ]},
        {"kind": "Card", "props": {"className": "p-6"}, "children": [
          {"kind": "Text", "props": {"as": "h2", "className": "text-sm font-semibold text-muted uppercase tracking-wide mb-3", "children": "Details"}},
          {"kind": "DescriptionList", "children": [
            {"kind": "DescriptionListItem", "props": {"label": "Phone"}, "bindings": {"value": {"$ref": "optOut.phone"}}},
            {"kind": "DescriptionListItem", "props": {"label": "Country code"}, "bindings": {"value": {"$expr": "'+' + optOut.phone_country_code"}}},
            {"kind": "DescriptionListItem", "props": {"label": "Reason"}, "bindings": {"value": {"$ref": "optOut.reason"}}},
            {"kind": "DescriptionListItem", "props": {"label": "Provider"}, "bindings": {"value": {"$expr": "optOut.provider || 'Manual'"}}},
            {"kind": "DescriptionListItem", "props": {"label": "Opted out at"}, "bindings": {"value": {"$expr": "formatDate(optOut.opted_out_at)"}}},
            {"kind": "DescriptionListItem", "props": {"label": "Expires"}, "bindings": {"value": {"$expr": "optOut.expires_at ? formatDate(optOut.expires_at) : 'Never (permanent)'"}}}
          ]}
        ]},
        {"kind": "Card", "props": {"className": "p-6"}, "children": [
          {"kind": "Text", "props": {"as": "h2", "className": "text-sm font-semibold text-muted uppercase tracking-wide mb-3", "children": "Inbound message"}},
          {"kind": "Alert", "props": {"variant": "info", "children": "No inbound message body \u2014 this opt-out was added manually or via DNC list."}, "bindings": {"hidden": {"$expr": "!!optOut.inbound_message_body"}}},
          {"kind": "View", "props": {"className": "font-mono text-sm bg-content2 p-3 rounded"}, "bindings": {"hidden": {"$expr": "!optOut.inbound_message_body"}, "children": {"$ref": "optOut.inbound_message_body"}}}
        ]}
      ]
    }
  ]
}
