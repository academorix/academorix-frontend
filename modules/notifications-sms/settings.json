{
  "id": "academorix://modules/notifications-sms/settings",
  "$version": 1,
  "title": "notifications-sms \u2014 settings",
  "description": "SMS channel settings. Canonical group/section/field taxonomy. One #[AsSetting] class \u2014 `SmsSettings` \u2014 group key `sms`.",
  "storedIn": "settings",
  "reference": { "contract": "academorix://modules/settings/attributes" },
  "groups": [
    {
      "key": "sms",
      "class": "Academorix\\Notifications\\Sms\\Settings\\SmsSettings",
      "label": "SMS",
      "description": "SMS provider + sender identity + geographic scope + STOP/START/HELP auto-replies.",
      "icon": "chat-bubble-bottom-center-text",
      "scope": "workspace",
      "public": false,
      "sortOrder": 15,
      "permission": "settings.read",
      "sections": [
        {
          "label": "Provider preference",
          "icon": "arrows-right-left",
          "sortOrder": 1,
          "fields": [
            {
              "name": "default_provider",
              "controlType": "select",
              "label": "Default provider",
              "defaultValue": null,
              "options": {
                "twilio": "Twilio",
                "messagebird": "MessageBird",
                "vonage": "Vonage",
                "plivo": "Plivo",
                "aws-sns": "AWS SNS"
              },
              "validation": ["nullable", "string", "in:twilio,messagebird,vonage,plivo,aws-sns"],
              "sortOrder": 1,
              "helpText": "Null = platform default from config."
            }
          ]
        },
        {
          "label": "Sender identity",
          "description": "Sender number or alphanumeric ID displayed to recipients.",
          "icon": "identification",
          "sortOrder": 2,
          "fields": [
            {
              "name": "sender_from_number",
              "controlType": "text",
              "label": "From number (E.164)",
              "defaultValue": null,
              "validation": ["nullable", "string", "regex:/^\\+[1-9][0-9]{1,14}$/"],
              "sortOrder": 1,
              "placeholder": "+15551234567"
            },
            {
              "name": "sender_messaging_service_sid",
              "controlType": "text",
              "label": "Twilio Messaging Service SID",
              "defaultValue": null,
              "validation": ["nullable", "string", "starts_with:MG"],
              "sortOrder": 2,
              "helpText": "Preferred over from_number \u2014 Twilio picks from a pool automatically."
            },
            {
              "name": "sender_alphanumeric_id",
              "controlType": "text",
              "label": "Alphanumeric sender ID",
              "defaultValue": null,
              "validation": ["nullable", "string", "regex:/^[a-zA-Z0-9]{3,11}$/"],
              "sortOrder": 3,
              "helpText": "3-11 alphanumeric chars. NOT supported in US/Canada. Requires notifications.sms.alphanumeric_sender_id feature."
            }
          ]
        },
        {
          "label": "Geographic scope",
          "description": "Restricts destination countries. Prevents accidental international spend.",
          "icon": "globe-alt",
          "sortOrder": 3,
          "fields": [
            {
              "name": "allowed_country_codes",
              "controlType": "multiselect",
              "label": "Allowed country codes",
              "defaultValue": ["1"],
              "validation": ["array", "min:1"],
              "sortOrder": 1,
              "helpText": "E.164 dial codes. Default: US/Canada only (+1). Add codes to enable international sends."
            }
          ]
        },
        {
          "label": "Auto-reply customisation",
          "description": "Overrides platform defaults for STOP/START/HELP auto-replies.",
          "icon": "chat-bubble-left-right",
          "sortOrder": 4,
          "fields": [
            {
              "name": "auto_reply_opt_out_confirmation",
              "controlType": "textarea",
              "label": "Opt-out confirmation",
              "defaultValue": null,
              "validation": ["nullable", "string", "max:160"],
              "sortOrder": 1,
              "helpText": "160-char cap. Null = platform default."
            },
            {
              "name": "auto_reply_subscribe_confirmation",
              "controlType": "textarea",
              "label": "Subscribe confirmation",
              "defaultValue": null,
              "validation": ["nullable", "string", "max:160"],
              "sortOrder": 2
            },
            {
              "name": "auto_reply_help",
              "controlType": "textarea",
              "label": "HELP reply",
              "defaultValue": null,
              "validation": ["nullable", "string", "max:160"],
              "sortOrder": 3
            }
          ]
        }
      ]
    }
  ]
}
