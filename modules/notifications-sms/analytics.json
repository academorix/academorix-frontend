{
  "id": "academorix://modules/notifications-sms/analytics",
  "$version": 1,
  "title": "notifications-sms \u2014 product analytics",
  "sink": "segment",
  "consentTiers": ["essential", "functional", "analytics", "marketing"],
  "events": [
    {"name": "Sms Sent", "kind": "track", "consent_required": "analytics", "properties": ["workspace_id", "provider", "destination_country_code", "cost_micro_units", "segments"]},
    {"name": "Sms Delivered", "kind": "track", "consent_required": "analytics", "properties": ["workspace_id", "provider", "destination_country_code"]},
    {"name": "Sms Failed", "kind": "track", "consent_required": "functional", "properties": ["workspace_id", "provider", "error_code"]},
    {"name": "Sms Undeliverable", "kind": "track", "consent_required": "functional", "properties": ["workspace_id", "provider", "error_code"]},
    {"name": "Sms Opted Out", "kind": "track", "consent_required": "functional", "properties": ["workspace_id", "reason", "source"]},
    {"name": "Sms Subscribed In", "kind": "track", "consent_required": "functional", "properties": ["workspace_id"]},
    {"name": "Sms Cost Cap Approached", "kind": "track", "consent_required": "functional", "properties": ["workspace_id", "percent_consumed"], "description": "Fires at 80% + 95% of monthly cap."}
  ]
}
