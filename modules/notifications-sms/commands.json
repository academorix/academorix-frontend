{
  "id": "academorix://modules/notifications-sms/commands",
  "$version": 1,
  "title": "notifications-sms \u2014 Artisan commands",
  "commands": [
    {"signature": "notifications:sms:test {phone} {--provider=}", "class": "Academorix\\Notifications\\Sms\\Console\\Commands\\TestCommand", "purpose": "Send a synthetic SMS. Rate-limited 10/day per operator + refused in production without --allow-production."},
    {"signature": "notifications:sms:opt-out-add {phone} {--workspace=} {--reason=manual}", "class": "Academorix\\Notifications\\Sms\\Console\\Commands\\OptOutAddCommand"},
    {"signature": "notifications:sms:opt-out-remove {phone} {--workspace=} {--force}", "class": "Academorix\\Notifications\\Sms\\Console\\Commands\\OptOutRemoveCommand", "purpose": "Refuses stop_keyword opt-outs unless --force + super_admin."},
    {"signature": "notifications:sms:opt-out-cleanup-expired", "class": "Academorix\\Notifications\\Sms\\Console\\Commands\\OptOutCleanupExpiredCommand"},
    {"signature": "notifications:sms:cost-report {--workspace=} {--month=previous}", "class": "Academorix\\Notifications\\Sms\\Console\\Commands\\CostReportCommand", "purpose": "Print or email SMS cost report for the given workspace + month."}
  ]
}
