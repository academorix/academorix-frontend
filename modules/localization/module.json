{
  "$version": 1,
  "name": "localization",
  "alias": "localization",
  "namespace": "Academorix\\Localization",
  "description": "Multilingual substrate on top of Laravel's built-in localization. Owns four entities \u2014 Language (platform catalogue with ISO 639 code + native name + direction + script), WorkspaceLocale (per-workspace enabled languages with default + fallback), Translation (persistent cache of resolved key\u2192value bindings per workspace + locale, indexed for fast lookup), TranslationJob (async bulk-translation audit). Resolves the caller's active locale from user preference \u2192 workspace setting \u2192 Accept-Language header \u2192 subdomain \u2192 app default. Publishes override helpers (`t()`, `__()`, `trans()`, `trans_choice()`) that pass through to Laravel's translator but consult our DB cache first + optionally auto-translate via configured driver (OpenAI, Google Cloud Translation, DeepL, AWS Translate, Azure Translator). Ships #[Translatable] attribute for Eloquent property translation. RTL-aware.",
  "keywords": ["localization", "i18n", "translation", "locale", "language", "iso639", "rtl", "openai", "google-translate", "deepl", "aws-translate", "azure-translator"],
  "priority": 14,
  "providers": ["Academorix\\Localization\\Providers\\LocalizationServiceProvider"],
  "files": [],
  "dependencies": ["foundation", "workspaces", "activity", "entitlements"],
  "extendedBy": [],
  "contributes": {
    "traits": ["HasTranslations", "IsLocaleAware"],
    "attributes": ["Translatable", "AsTranslation"],
    "blueprints": [],
    "middleware": ["locale.resolve", "locale.persist"],
    "events": [
      "LocaleResolved",
      "LocaleChanged",
      "TranslationCacheHit",
      "TranslationCacheMiss",
      "MachineTranslationRequested",
      "MachineTranslationCompleted",
      "MachineTranslationFailed",
      "TranslationOverridden",
      "TranslationJobStarted",
      "TranslationJobCompleted",
      "LanguageEnabledForWorkspace",
      "LanguageDisabledForWorkspace"
    ],
    "policies": ["LanguagePolicy", "WorkspaceLocalePolicy", "TranslationPolicy", "TranslationJobPolicy"],
    "hooks": [],
    "commands": [
      "localization:list-locales",
      "localization:describe",
      "localization:translate",
      "localization:warm-cache",
      "localization:bulk-translate",
      "localization:seed-languages",
      "localization:reconcile-cache"
    ],
    "jobs": [
      "TranslateJob",
      "BulkTranslateNamespaceJob",
      "WarmTranslationCacheJob",
      "PruneStaleTranslationsJob",
      "ReconcileTranslationCacheJob"
    ],
    "notifications": [
      "TranslationJobCompletedNotification",
      "TranslationJobFailedNotification",
      "MachineTranslationQuotaApproachingNotification"
    ],
    "broadcasts": ["workspace.{id}.translations"],
    "observers": ["LanguageObserver", "WorkspaceLocaleObserver", "TranslationObserver", "TranslationJobObserver"],
    "rules": ["valid_iso639_code", "valid_bcp47_tag"],
    "casts": ["LocaleCode", "TextDirection", "TranslationSource"],
    "views": [],
    "lang": ["localization"],
    "config": ["localization"],
    "macros": ["str_localize"],
    "bindings": ["LocaleResolver", "TranslationRepository", "TranslatorDriverManager", "OpenAITranslatorDriver", "GoogleTranslatorDriver", "DeepLTranslatorDriver", "AwsTranslateDriver", "AzureTranslatorDriver", "NullTranslatorDriver", "PluralizationEngine", "InterpolationEngine"],
    "resources": ["language", "workspace-locale", "translation", "translation-job"]
  },
  "wraps": {
    "package": "illuminate/translation",
    "rationale": "We do not replace Laravel's Translator \u2014 we decorate it. Our Translator extends `Illuminate\\Translation\\Translator` and overrides `get()` + `choice()` to consult the DB cache first. All Laravel behaviours (JSON files, PHP arrays, `:placeholder`, `{0} zero|{1} one|[2,*] other`) work unchanged."
  },
  "hosts": {
    "workspace": {
      "description": "Workspace-facing locale + translation management.",
      "routes": [
        "GET /api/v1/languages",
        "GET /api/v1/workspace-locales",
        "POST /api/v1/workspace-locales/{language}",
        "DELETE /api/v1/workspace-locales/{language}",
        "PATCH /api/v1/workspace-locales/{language}",
        "GET /api/v1/translations",
        "POST /api/v1/translations",
        "PATCH /api/v1/translations/{translation}",
        "DELETE /api/v1/translations/{translation}",
        "GET /api/v1/translation-jobs",
        "POST /api/v1/translation-jobs"
      ]
    },
    "platform-admin": {
      "description": "Platform-admin language catalogue + cross-workspace observability.",
      "routes": [
        "GET/POST/PATCH/DELETE /api/v1/platform/languages[/{language}]",
        "GET /api/v1/platform/translations",
        "GET /api/v1/platform/translation-drivers/status"
      ]
    }
  }
}
