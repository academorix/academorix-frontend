{
  "id": "academorix://modules/localization/schemas/language",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "Language",
  "description": "Platform-owned language catalogue. Seeded from ISO 639 + BCP 47 subset. Rows are system + globally-scoped; workspaces enable + configure via WorkspaceLocale.",
  "type": "object",
  "x-module": "localization",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "languages",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "lng_",
    "incrementing": false,
    "model": "Academorix\\Localization\\Models\\Language",
    "interface": "Academorix\\Localization\\Contracts\\Data\\LanguageInterface",
    "implements": ["Academorix\\Localization\\Contracts\\Data\\LanguageInterface"],
    "traits": ["HasFactory", "HasUlids", "HasSystemFlag", "HasMetadata", "HasUserstamps", "Filterable", "Searchable", "SoftDeletes"],
    "casts": {
      "direction": "TextDirection",
      "is_system": "boolean",
      "is_active_on_platform": "boolean",
      "is_beta": "boolean",
      "metadata": "array"
    },
    "appends": ["display_label", "flag_emoji"],
    "observers": ["LanguageObserver"],
    "hidden": [],
    "guarded": []
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": {"type": "string", "length": 64, "primary": true, "description": "Prefixed ULID: `lng_<26 chars>`."},
      "code": {"type": "string", "length": 12, "nullable": false, "description": "BCP 47 tag. E.g. `en`, `en-GB`, `fr`, `fr-CA`, `ar`, `zh-Hans`, `zh-Hant`. Lowercase language + optional uppercase region + optional script."},
      "iso_639_1": {"type": "string", "length": 2, "nullable": true, "description": "Two-letter code when applicable (en, fr, ar)."},
      "iso_639_3": {"type": "string", "length": 3, "nullable": true, "description": "Three-letter code (eng, fra, arb) \u2014 used for languages without ISO 639-1 assignment."},
      "name": {"type": "string", "length": 100, "nullable": false, "description": "English name (`English`, `Arabic`, `Spanish`)."},
      "native_name": {"type": "string", "length": 100, "nullable": false, "description": "Endonym in native script (`English`, `\u0627\u0644\u0639\u0631\u0628\u064a\u0629`, `Espa\u00f1ol`, `\u4e2d\u6587`)."},
      "direction": {"type": "string", "length": 3, "nullable": false, "default": "'ltr'", "description": "Enum: ltr / rtl."},
      "script_code": {"type": "string", "length": 4, "nullable": true, "description": "ISO 15924 four-letter code. E.g. Latn, Arab, Cyrl, Hans, Hant, Deva."},
      "country_code": {"type": "string", "length": 2, "nullable": true, "description": "Optional ISO 3166 alpha-2. For regional variants: fr-CA \u2192 CA, en-GB \u2192 GB."},
      "flag_emoji": {"type": "string", "length": 8, "nullable": true, "description": "\ud83c\uddec\ud83c\udde7 style. Convenience for UI. May be a country flag (regional variant) or a scripted-language marker."},
      "is_system": {"type": "boolean", "nullable": false, "default": true, "description": "System-seeded languages cannot be deleted by admins."},
      "is_active_on_platform": {"type": "boolean", "nullable": false, "default": true, "description": "Platform-level toggle. False hides from workspace pickers even if enabled somewhere."},
      "is_beta": {"type": "boolean", "nullable": false, "default": false, "description": "Beta languages surface a warning banner \u2014 translation completeness < 90%."},
      "sort_order": {"type": "integer", "nullable": false, "default": 100, "description": "Ascending sort in picker UIs. Common languages get low values (English=1, Arabic=5, French=10)."},
      "notes": {"type": "text", "nullable": true},
      "metadata": {"type": "jsonb", "nullable": true},
      "created_by": {"type": "uuid", "nullable": true},
      "updated_by": {"type": "uuid", "nullable": true},
      "deleted_by": {"type": "uuid", "nullable": true},
      "deleted_at": {"type": "timestamptz", "nullable": true},
      "created_at": {"type": "timestamptz", "nullable": false},
      "updated_at": {"type": "timestamptz", "nullable": false}
    },
    "indexes": [
      {"columns": ["code"], "unique": true, "name": "languages_code_unique", "predicate": "deleted_at IS NULL"},
      {"columns": ["iso_639_1"], "unique": false, "name": "languages_iso639_1_idx"},
      {"columns": ["is_active_on_platform", "sort_order"], "unique": false, "name": "languages_picker_idx"}
    ]
  },
  "required": ["id", "code", "name", "native_name", "direction", "is_system", "is_active_on_platform", "is_beta", "sort_order", "created_at", "updated_at"],
  "properties": {
    "id": {"type": "string", "pattern": "^lng_[0-9A-HJKMNP-TV-Z]{26}$"},
    "code": {"type": "string", "pattern": "^[a-z]{2,3}(-[A-Z][a-z]{3})?(-[A-Z]{2})?$", "maxLength": 12},
    "iso_639_1": {"type": ["string", "null"], "pattern": "^[a-z]{2}$"},
    "iso_639_3": {"type": ["string", "null"], "pattern": "^[a-z]{3}$"},
    "name": {"type": "string", "maxLength": 100},
    "native_name": {"type": "string", "maxLength": 100},
    "direction": {"type": "string", "enum": ["ltr", "rtl"]},
    "script_code": {"type": ["string", "null"], "pattern": "^[A-Z][a-z]{3}$"},
    "country_code": {"type": ["string", "null"], "pattern": "^[A-Z]{2}$"},
    "flag_emoji": {"type": ["string", "null"], "maxLength": 8},
    "is_system": {"type": "boolean"},
    "is_active_on_platform": {"type": "boolean"},
    "is_beta": {"type": "boolean"},
    "sort_order": {"type": "integer"},
    "notes": {"type": ["string", "null"]},
    "display_label": {"type": "string", "description": "Computed. E.g. `English (US)` or `\u0627\u0644\u0639\u0631\u0628\u064a\u0629`."},
    "metadata": {"type": ["object", "null"]},
    "created_by": {"type": ["string", "null"], "format": "uuid"},
    "updated_by": {"type": ["string", "null"], "format": "uuid"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false,
  "x-wire": {"envelope": "spatie-data", "wrap": "data", "mapper": "SnakeCaseMapper", "computed": ["display_label", "flag_emoji"]}
}
