{
  "id": "academorix://modules/webhook/policies",
  "$version": 1,
  "title": "webhook \u2014 authorization policies",
  "description": "Two policies. Workspace admins manage their own subscriptions + deliveries. Platform admins have cross-workspace visibility + emergency-pause powers. Signing secrets never exposed in any policy \u2014 rotation surfaces + one-time reveal only.",
  "policies": [
    {
      "model": "WebhookSubscription",
      "class": "Academorix\\Webhook\\Policies\\WebhookSubscriptionPolicy",
      "abilities": [
        {"action": "viewAny", "permission": "webhook.subscriptions.viewAny", "scope": "workspace admin or platform admin. Workspace scope enforced by BelongsToWorkspace global scope."},
        {"action": "view", "permission": "webhook.subscriptions.view", "scope": "workspace admin sees own; platform admin sees any"},
        {"action": "create", "permission": "webhook.subscriptions.create", "scope": "workspace admin; entitlement webhook.subscriptions.count.remaining > 0"},
        {"action": "update", "permission": "webhook.subscriptions.update", "scope": "workspace admin. Refused for is_system=true rows unless super_admin."},
        {"action": "delete", "permission": "webhook.subscriptions.delete", "scope": "workspace admin. Refused for is_system=true rows unless super_admin."},
        {"action": "manage", "permission": "webhook.subscriptions.manage", "scope": "pause/resume. Same guards as update."},
        {"action": "test", "permission": "webhook.subscriptions.test"},
        {"action": "rotate-secret", "permission": "webhook.subscriptions.rotate-secret"},
        {"action": "platformManage", "permission": "platform.webhook.subscriptions.manage", "scope": "platform admin. Cross-workspace emergency pause/resume."}
      ]
    },
    {
      "model": "WebhookDelivery",
      "class": "Academorix\\Webhook\\Policies\\WebhookDeliveryPolicy",
      "abilities": [
        {"action": "viewAny", "permission": "webhook.deliveries.viewAny", "scope": "workspace admin sees own via BelongsToWorkspace scope"},
        {"action": "view", "permission": "webhook.deliveries.view"},
        {"action": "retry", "permission": "webhook.deliveries.retry", "scope": "workspace admin. Only allowed on state=failedPermanent \u2014 retryable state is scheduled automatically."},
        {"action": "platformViewAny", "permission": "platform.webhook.deliveries.viewAny", "scope": "platform admin cross-workspace search"},
        {"action": "platformView", "permission": "platform.webhook.deliveries.view"},
        {"action": "platformRetry", "permission": "platform.webhook.deliveries.retry", "scope": "platform admin. Cross-workspace retry for support."}
      ]
    }
  ]
}
