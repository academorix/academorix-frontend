{
  "id": "academorix://modules/webhook/schemas/webhook-delivery",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "WebhookDelivery",
  "description": "Per-attempt audit row for outbound webhook dispatches. Append-only. Captures the full request + response with configurable body-size caps (default 64KB each). Retention 30d hot / pruned via daily `webhook:prune`. State machine: pending \u2192 inFlight \u2192 delivered / failedRetryable / failedPermanent / cancelled.",
  "type": "object",
  "x-module": "webhook",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "webhook_deliveries",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "wdlv_",
    "incrementing": false,
    "model": "Academorix\\Webhook\\Models\\WebhookDelivery",
    "interface": "Academorix\\Webhook\\Contracts\\Data\\WebhookDeliveryInterface",
    "implements": ["Academorix\\Webhook\\Contracts\\Data\\WebhookDeliveryInterface"],
    "traits": ["HasFactory", "HasUlids", "HasStates", "BelongsToWorkspace", "HasMetadata", "HasUserstamps", "HasAuditable", "Filterable"],
    "casts": {
      "state": "WebhookDeliveryState",
      "payload": "WebhookPayloadCast",
      "request_headers": "array",
      "response_headers": "array",
      "retryable": "boolean",
      "attempted_at": "datetime",
      "delivered_at": "datetime",
      "next_attempt_at": "datetime",
      "signed_at": "datetime",
      "metadata": "array"
    },
    "appends": ["is_terminal", "is_retryable_state", "response_snippet"],
    "observers": ["WebhookDeliveryObserver"],
    "hidden": ["payload", "request_headers", "response_body", "response_headers", "signature", "signature_previous", "metadata"],
    "guarded": []
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": {"type": "string", "length": 64, "primary": true, "description": "Prefixed ULID: `wdlv_<26 chars>`."},
      "subscription_id": {"type": "string", "length": 64, "nullable": false, "foreign": {"table": "webhook_subscriptions", "column": "id", "onUpdate": "cascade", "onDelete": "cascade"}},
      "workspace_id": {"type": "string", "length": 64, "nullable": false, "foreign": {"table": "workspaces", "column": "id", "onUpdate": "cascade", "onDelete": "cascade"}, "description": "Denormalised from parent subscription for query filter efficiency."},
      "event_name": {"type": "string", "length": 128, "nullable": false, "description": "The event this delivery is for (e.g. 'invitation.sent')."},
      "event_version": {"type": "string", "length": 32, "nullable": false, "description": "Resolved payload version at dispatch time (via subscription.api_version + versioning module's transformer chain)."},
      "payload": {"type": "jsonb", "nullable": false, "description": "Final serialised payload after transformer chain. Confidential tier \u2014 may contain PII."},
      "payload_bytes": {"type": "unsignedInteger", "nullable": false, "description": "Raw payload size before compression."},
      "state": {"type": "string", "length": 24, "nullable": false, "default": "pending", "description": "spatie state: pending, inFlight, delivered, failedRetryable, failedPermanent, cancelled."},
      "attempt_number": {"type": "unsignedSmallInteger", "nullable": false, "default": 1, "description": "1-indexed. Emitted in the X-Webhook-Attempt header."},
      "max_attempts": {"type": "unsignedSmallInteger", "nullable": false, "description": "Denormalised from subscription at dispatch. Kept for retry-limit enforcement + analytics."},
      "http_verb": {"type": "string", "length": 8, "nullable": false, "description": "Denormalised from subscription."},
      "request_url": {"type": "string", "length": 2000, "nullable": false, "description": "Destination URL at dispatch time. Denormalised so subscription URL edits don't break the audit trail."},
      "request_headers": {"type": "jsonb", "nullable": false, "description": "Full outbound header set including signature headers. Retained for provenance."},
      "request_body_bytes": {"type": "unsignedInteger", "nullable": false, "description": "Actual bytes sent (post-compression)."},
      "response_status": {"type": "unsignedSmallInteger", "nullable": true, "description": "HTTP status. Null until state = inFlight completes."},
      "response_headers": {"type": "jsonb", "nullable": true},
      "response_body": {"type": "text", "nullable": true, "description": "Truncated to webhook.audit.max_response_body_bytes (default 64KB)."},
      "response_body_bytes": {"type": "unsignedInteger", "nullable": true, "description": "Actual response size (may exceed captured body if truncated)."},
      "duration_ms": {"type": "unsignedInteger", "nullable": true, "description": "End-to-end HTTP round-trip time."},
      "error_class": {"type": "string", "length": 200, "nullable": true, "description": "Fully-qualified exception class name when the send threw."},
      "error_message": {"type": "text", "nullable": true, "description": "Sanitised exception message. Truncated."},
      "attempted_at": {"type": "timestamptz", "nullable": true},
      "delivered_at": {"type": "timestamptz", "nullable": true},
      "next_attempt_at": {"type": "timestamptz", "nullable": true, "description": "Scheduled retry time when state = failedRetryable."},
      "retry_after_hint": {"type": "unsignedInteger", "nullable": true, "description": "Seconds from Retry-After response header when receiver returned one. Consumed by RetryAfterAwareBackoffStrategy."},
      "retryable": {"type": "boolean", "nullable": false, "default": false, "description": "Denormalised outcome of the status-code policy check. Convenience column for retry scans."},
      "signed_at": {"type": "timestamptz", "nullable": false},
      "signature_algorithm": {"type": "string", "length": 16, "nullable": false, "default": "sha256"},
      "signature": {"type": "text", "nullable": false, "description": "The signature sent in X-Webhook-Signature. Retained for provenance."},
      "signature_previous": {"type": "text", "nullable": true, "description": "When rotation grace active: signature computed with previous secret."},
      "batch_id": {"type": "string", "length": 64, "nullable": true, "description": "Bus::batch id when the delivery is part of a fan-out batch."},
      "metadata": {"type": "jsonb", "nullable": true},
      "created_by": {"type": "uuid", "nullable": true},
      "updated_by": {"type": "uuid", "nullable": true},
      "created_at": {"type": "timestamptz", "nullable": false},
      "updated_at": {"type": "timestamptz", "nullable": false}
    },
    "indexes": [
      {"columns": ["subscription_id", "created_at"], "unique": false, "name": "webhook_deliveries_subscription_index", "description": "Per-subscription audit query."},
      {"columns": ["workspace_id", "state", "created_at"], "unique": false, "name": "webhook_deliveries_workspace_state_index", "description": "Admin dashboard filtering."},
      {"columns": ["state", "next_attempt_at"], "unique": false, "name": "webhook_deliveries_retry_scan_index", "predicate": "state = 'failedRetryable' AND next_attempt_at IS NOT NULL", "description": "Retry scan."},
      {"columns": ["event_name", "created_at"], "unique": false, "name": "webhook_deliveries_event_index"},
      {"columns": ["batch_id"], "unique": false, "name": "webhook_deliveries_batch_index", "predicate": "batch_id IS NOT NULL"},
      {"columns": ["created_at"], "unique": false, "name": "webhook_deliveries_created_at_index", "type": "BRIN", "description": "BRIN for the retention prune scan (large-table sequential-ish scan)."}
    ]
  },
  "required": ["id", "subscription_id", "workspace_id", "event_name", "event_version", "payload", "payload_bytes", "state", "attempt_number", "max_attempts", "http_verb", "request_url", "request_headers", "request_body_bytes", "retryable", "signed_at", "signature_algorithm", "signature", "created_at", "updated_at"],
  "properties": {
    "id": {"type": "string", "pattern": "^wdlv_[0-9A-HJKMNP-TV-Z]{26}$"},
    "subscription_id": {"type": "string", "pattern": "^wsub_[0-9A-HJKMNP-TV-Z]{26}$"},
    "workspace_id": {"type": "string", "pattern": "^wsp_[0-9A-HJKMNP-TV-Z]{26}$"},
    "event_name": {"type": "string", "maxLength": 128},
    "event_version": {"type": "string", "maxLength": 32},
    "payload": {"type": "object", "additionalProperties": true},
    "payload_bytes": {"type": "integer", "minimum": 0},
    "state": {"type": "string", "enum": ["pending", "inFlight", "delivered", "failedRetryable", "failedPermanent", "cancelled"]},
    "attempt_number": {"type": "integer", "minimum": 1},
    "max_attempts": {"type": "integer", "minimum": 1},
    "http_verb": {"type": "string", "enum": ["POST", "PUT", "PATCH"]},
    "request_url": {"type": "string", "maxLength": 2000},
    "request_headers": {"type": "object", "additionalProperties": true},
    "request_body_bytes": {"type": "integer", "minimum": 0},
    "response_status": {"type": ["integer", "null"], "minimum": 100, "maximum": 599},
    "response_headers": {"type": ["object", "null"], "additionalProperties": true},
    "response_body": {"type": ["string", "null"]},
    "response_body_bytes": {"type": ["integer", "null"], "minimum": 0},
    "duration_ms": {"type": ["integer", "null"], "minimum": 0},
    "error_class": {"type": ["string", "null"], "maxLength": 200},
    "error_message": {"type": ["string", "null"]},
    "attempted_at": {"type": ["string", "null"], "format": "date-time"},
    "delivered_at": {"type": ["string", "null"], "format": "date-time"},
    "next_attempt_at": {"type": ["string", "null"], "format": "date-time"},
    "retry_after_hint": {"type": ["integer", "null"], "minimum": 0},
    "retryable": {"type": "boolean"},
    "signed_at": {"type": "string", "format": "date-time"},
    "signature_algorithm": {"type": "string", "maxLength": 16},
    "signature": {"type": "string"},
    "signature_previous": {"type": ["string", "null"]},
    "batch_id": {"type": ["string", "null"], "maxLength": 64},
    "is_terminal": {"type": "boolean", "description": "Computed. state IN delivered / failedPermanent / cancelled."},
    "is_retryable_state": {"type": "boolean", "description": "Computed. state === 'failedRetryable'."},
    "response_snippet": {"type": ["string", "null"], "description": "Computed. First 200 chars of response_body for admin listings (avoids loading full 64KB blob)."},
    "metadata": {"type": ["object", "null"], "additionalProperties": true},
    "created_by": {"type": ["string", "null"], "format": "uuid"},
    "updated_by": {"type": ["string", "null"], "format": "uuid"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false,
  "x-wire": {
    "envelope": "spatie-data",
    "wrap": "data",
    "mapper": "SnakeCaseMapper",
    "hidden": ["payload", "request_headers", "response_body", "response_headers", "signature", "signature_previous", "metadata", "created_by", "updated_by"],
    "computed": ["is_terminal", "is_retryable_state", "response_snippet"]
  }
}
