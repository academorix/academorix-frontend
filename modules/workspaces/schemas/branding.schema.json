{
  "id": "academorix://modules/workspaces/schemas/branding",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "Branding",
  "description": "Theme + logo profile per workspace. Multiple profiles per workspace supported (e.g. per-domain branding for a federation with regional sub-brands, or day / night variants). Exactly one profile per workspace is marked `is_default=true`; that profile's fields are denormalised into `workspaces.branding` (JSONB) by WorkspaceObserver on save so the workspace picker does not need to join.",
  "type": "object",
  "x-module": "workspaces",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "brandings",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "brd_",
    "incrementing": false,
    "model": "Academorix\\Workspaces\\Models\\Branding",
    "interface": "Academorix\\Workspaces\\Contracts\\Data\\BrandingInterface",
    "implements": ["Academorix\\Workspaces\\Contracts\\Data\\BrandingInterface"],
    "traits": [
      "HasFactory",
      "HasUlids",
      "BelongsToWorkspace",
      "HasMetadata",
      "HasUserstamps",
      "HasAuditable",
      "HasTranslations",
      "SoftDeletes"
    ],
    "casts": {
      "css_variables": "array",
      "is_default": "boolean",
      "metadata": "array",
      "translations": "array"
    },
    "appends": [],
    "observers": ["BrandingObserver"],
    "hidden": ["metadata"],
    "guarded": []
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": {
        "type": "string",
        "length": 64,
        "primary": true,
        "description": "Prefixed ULID: `brd_<26 chars>`."
      },
      "workspace_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": {
          "table": "workspaces",
          "column": "id",
          "onUpdate": "cascade",
          "onDelete": "cascade"
        }
      },
      "domain_id": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "description": "Optional FK to a specific Domain. When set, this profile is served only for requests resolving to that domain (per-domain branding). Null = workspace-wide profile.",
        "foreign": {
          "table": "domains",
          "column": "id",
          "onUpdate": "cascade",
          "onDelete": "set null"
        }
      },
      "name": {
        "type": "string",
        "length": 100,
        "nullable": false,
        "description": "Display name for the profile (e.g. 'Default', 'Dark Mode', 'Championship 2026'). Translated via `HasTranslations`."
      },
      "is_default": {
        "type": "boolean",
        "nullable": false,
        "default": false,
        "description": "Exactly one row per workspace with is_default=true (partial unique index). Denormalised into workspaces.branding by WorkspaceObserver."
      },
      "theme": {
        "type": "string",
        "length": 16,
        "nullable": false,
        "default": "auto",
        "description": "Enum: `light`, `dark`, `auto`. Controls the base HeroUI theme applied under this profile."
      },
      "logo_url": {
        "type": "string",
        "length": 2048,
        "nullable": true
      },
      "logo_dark_url": {
        "type": "string",
        "length": 2048,
        "nullable": true,
        "description": "Alternate logo used when the OS-level colour scheme is dark and theme=`auto`."
      },
      "favicon_url": {
        "type": "string",
        "length": 2048,
        "nullable": true
      },
      "primary_color": {
        "type": "string",
        "length": 7,
        "nullable": true
      },
      "secondary_color": {
        "type": "string",
        "length": 7,
        "nullable": true
      },
      "accent_color": {
        "type": "string",
        "length": 7,
        "nullable": true
      },
      "background_color": {
        "type": "string",
        "length": 7,
        "nullable": true
      },
      "surface_color": {
        "type": "string",
        "length": 7,
        "nullable": true
      },
      "text_color": {
        "type": "string",
        "length": 7,
        "nullable": true
      },
      "font_stack": {
        "type": "string",
        "length": 500,
        "nullable": true
      },
      "custom_font_url": {
        "type": "string",
        "length": 2048,
        "nullable": true,
        "description": "Optional web-font URL. Must be HTTPS and served with correct CORS."
      },
      "css_variables": {
        "type": "jsonb",
        "nullable": true,
        "description": "Free-form CSS custom-property overrides (e.g. `{'--radius-md': '8px'}`). Applied at :root under this profile."
      },
      "metadata": {
        "type": "jsonb",
        "nullable": true,
        "description": "Free-form platform notes on this branding profile — designer refs, Figma links, migration source. From HasMetadata."
      },
      "translations": {
        "type": "jsonb",
        "nullable": false,
        "default": "'{}'::jsonb",
        "description": "Per-locale content-translation blob. Shape: `{ locale_code: { field: value } }`. Managed by the `HasTranslations` trait (wraps `spatie/laravel-translatable`). Column added via `foundation::Blueprint::translations()`."
      },
      "created_by": {
        "type": "uuid",
        "nullable": true
      },
      "updated_by": {
        "type": "uuid",
        "nullable": true
      },
      "deleted_by": {
        "type": "uuid",
        "nullable": true
      },
      "deleted_at": {
        "type": "timestamptz",
        "nullable": true
      },
      "created_at": {
        "type": "timestamptz",
        "nullable": false
      },
      "updated_at": {
        "type": "timestamptz",
        "nullable": false
      }
    },
    "indexes": [
      {
        "columns": ["workspace_id", "is_default"],
        "unique": true,
        "name": "brandings_workspace_default_unique",
        "predicate": "is_default = TRUE AND deleted_at IS NULL"
      },
      {
        "columns": ["workspace_id", "domain_id"],
        "unique": true,
        "name": "brandings_workspace_domain_unique",
        "predicate": "domain_id IS NOT NULL AND deleted_at IS NULL"
      },
      {
        "columns": ["workspace_id", "created_at"],
        "unique": false,
        "name": "brandings_workspace_created_at_index"
      }
    ]
  },
  "required": ["id", "workspace_id", "name", "theme", "translations", "created_at", "updated_at"],
  "x-translatable": {
    "trait": "Academorix\\Localization\\Concerns\\HasTranslations",
    "column": "translations",
    "fields": ["name"],
    "underlying_package": "spatie/laravel-translatable ^6.0",
    "migration_macro": "foundation::Blueprint::translations()",
    "wire_convention": "Active-locale projection onto the field name by default. Full JSONB blob under `data.translations` when the request carries `?include=translations`.",
    "auto_translate": "opt-in via WorkspaceLocale.auto_translate=true per target locale"
  },
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^brd_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "workspace_id": {
      "type": "string",
      "pattern": "^wsp_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "domain_id": {
      "type": ["string", "null"],
      "pattern": "^dom_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "x-translatable": true,
      "description": "Active-locale projection. Full blob available via `?include=translations`."
    },
    "translations": {
      "type": "object",
      "description": "Per-locale content translations. Wire-included only when `?include=translations`. Shape: `{ locale_code: { field: value } }`.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": ["string", "null"]
        }
      }
    },
    "is_default": {
      "type": "boolean",
      "default": false
    },
    "theme": {
      "type": "string",
      "enum": ["light", "dark", "auto"]
    },
    "logo_url": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "logo_dark_url": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "favicon_url": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "primary_color": {
      "type": ["string", "null"],
      "pattern": "^#[0-9a-fA-F]{6}$"
    },
    "secondary_color": {
      "type": ["string", "null"],
      "pattern": "^#[0-9a-fA-F]{6}$"
    },
    "accent_color": {
