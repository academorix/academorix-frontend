{
  "id": "academorix://modules/workspaces/relations",
  "$version": 1,
  "title": "workspaces — cross-module relations",
  "description": "All Eloquent relations rooted at models owned by this module. Cross-module edges declare `target.module` as a lowercase folder name; CI resolves it to the target's `schemas/*.schema.json` and validates the FK columns match. Reverse relations reconcile: if X has HasMany Y here, Y's schema must declare the corresponding BelongsTo FK. Cross-workspace FKs are FORBIDDEN — every FK is either same-workspace, application-scoped, or crosses no workspaces boundary at all.",
  "anchors": [
    {
      "model": {
        "name": "Application",
        "class": "Academorix\\Workspaces\\Models\\Application",
        "schemaRef": "academorix://modules/workspaces/schemas/application"
      },
      "relations": [
        {
          "name": "workspaces",
          "type": "HasMany",
          "target": {
            "module": "workspaces",
            "model": "Workspace",
            "class": "Academorix\\Workspaces\\Models\\Workspace"
          },
          "foreignKey": "application_id",
          "description": "Every workspace belongs to exactly one Application."
        },
        {
          "name": "identities",
          "type": "HasMany",
          "target": {
            "module": "workspaces",
            "model": "Identity",
            "class": "Academorix\\Workspaces\\Models\\Identity"
          },
          "foreignKey": "application_id",
          "description": "Cross-workspace person records live at the Application layer."
        },
        {
          "name": "domains",
          "type": "HasMany",
          "target": {
            "module": "workspaces",
            "model": "Domain",
            "class": "Academorix\\Workspaces\\Models\\Domain"
          },
          "foreignKey": "application_id",
          "description": "Domains carry application_id so central-host lookup can resolve them before a workspace is known."
        }
      ]
    },
    {
      "model": {
        "name": "Workspace",
        "class": "Academorix\\Workspaces\\Models\\Workspace",
        "schemaRef": "academorix://modules/workspaces/schemas/workspace"
      },
      "relations": [
        {
          "name": "application",
          "type": "BelongsTo",
          "target": {
            "module": "workspaces",
            "model": "Application",
            "class": "Academorix\\Workspaces\\Models\\Application"
          },
          "foreignKey": "application_id",
          "ownerKey": "id",
          "description": "Owned via BelongsToApplication trait."
        },
        {
          "name": "primaryBranding",
          "type": "BelongsTo",
          "target": {
            "module": "workspaces",
            "model": "Branding",
            "class": "Academorix\\Workspaces\\Models\\Branding"
          },
          "foreignKey": "primary_branding_id",
          "ownerKey": "id",
          "description": "Nullable. Materialises the active Branding row and drives the denormalised `branding` JSONB."
        },
        {
          "name": "brandings",
          "type": "HasMany",
          "target": {
            "module": "workspaces",
            "model": "Branding",
            "class": "Academorix\\Workspaces\\Models\\Branding"
          },
          "foreignKey": "workspace_id"
        },
        {
          "name": "domains",
          "type": "HasMany",
          "target": {
            "module": "workspaces",
            "model": "Domain",
            "class": "Academorix\\Workspaces\\Models\\Domain"
          },
          "foreignKey": "workspace_id",
          "cascade": {
            "onDelete": "cascade",
            "description": "Archiving a Workspace archives its Domains via the cascade FK on the domains table."
          }
        },
        {
          "name": "contacts",
          "type": "HasMany",
          "target": {
            "module": "workspaces",
            "model": "WorkspaceContact",
            "class": "Academorix\\Workspaces\\Models\\WorkspaceContact"
          },
          "foreignKey": "workspace_id"
        },
        {
          "name": "integrations",
          "type": "HasMany",
          "target": {
            "module": "workspaces",
            "model": "WorkspaceIntegration",
            "class": "Academorix\\Workspaces\\Models\\WorkspaceIntegration"
          },
          "foreignKey": "workspace_id"
        },
        {
          "name": "organizations",
          "type": "HasMany",
          "target": {
            "module": "organization",
            "model": "Organization",
            "class": "Academorix\\Organization\\Models\\Organization"
          },
          "foreignKey": "workspace_id",
          "cascade": {
            "onDelete": "cascade",
            "description": "Archiving a Workspace archives every Organization under it (soft-delete cascade)."
          },
          "description": "Every workspace carries at least one Organization (auto-provisioned with is_default=true). Multi-brand workspaces add more."
        },
        {
          "name": "regions",
          "type": "HasMany",
          "target": {
            "module": "region",
            "model": "Region",
            "class": "Academorix\\Region\\Models\\Region"
          },
          "foreignKey": "workspace_id",
          "description": "Every workspace provisions one default Region on create."
        },
        {
          "name": "branches",
          "type": "HasMany",
          "target": {
            "module": "branch",
            "model": "Branch",
            "class": "Academorix\\Branch\\Models\\Branch"
          },
          "foreignKey": "workspace_id",
          "description": "Direct shortcut; also reachable via organizations.branches and regions.branches."
        },
        {
          "name": "users",
          "type": "HasMany",
          "target": {
            "module": "user",
            "model": "User",
            "class": "Academorix\\User\\Models\\User"
          },
          "foreignKey": "workspace_id",
          "description": "Every user belongs to exactly one workspace. A person invited to two workspaces has one User row per workspace, all pointing at the same application-scoped Identity."
        },
        {
          "name": "roles",
          "type": "HasMany",
          "target": {
            "module": "access",
            "model": "Role",
            "class": "Academorix\\Access\\Models\\Role"
          },
          "foreignKey": "workspace_id",
          "description": "Workspace-scoped roles on the sanctum guard. Platform roles (platform_admin guard) have workspace_id = null and are NOT part of this relation."
        },
        {
          "name": "subscription",
          "type": "HasOne",
          "target": {
            "module": "subscription",
            "model": "WorkspaceSubscription",
            "class": "Academorix\\Subscription\\Models\\WorkspaceSubscription"
          },
          "foreignKey": "workspace_id",
          "description": "Exactly one subscription per (application_id, workspace_id) tuple."
        },
        {
          "name": "entitlementLicenses",
          "type": "HasMany",
          "target": {
            "module": "entitlements",
            "model": "EntitlementLicense",
            "class": "Academorix\\Entitlements\\Models\\EntitlementLicense"
          },
          "foreignKey": "workspace_id",
          "description": "Full entitlement matrix for this workspace. quota_summary on /api/auth/me returns the top 3-5; the whole set is behind GET /api/v1/entitlements."
        },
        {
          "name": "audits",
          "type": "HasMany",
          "target": {
            "module": "audit",
            "model": "Audit",
            "class": "Academorix\\Audit\\Models\\Audit"
          },
          "foreignKey": "workspace_id",
          "description": "Every mutation on any workspace-scoped model writes here. Depends on the Audit-adds-workspace_id migration (gap register)."
        }
      ],
      "morphs": [
        {
          "name": "scopeNode",
          "type": "MorphOne",
          "target": {
            "module": "scope",
            "model": "ScopeNode",
            "class": "Academorix\\Scope\\Models\\ScopeNode"
          },
          "morphType": "entity_type",
          "morphId": "entity_id",
          "description": "Every Workspace projects into the scope substrate as a root node."
        }
      ]
    },
    {
      "model": {
        "name": "Domain",
        "class": "Academorix\\Workspaces\\Models\\Domain",
        "schemaRef": "academorix://modules/workspaces/schemas/domain"
      },
      "relations": [
        {
          "name": "application",
          "type": "BelongsTo",
          "target": {"module": "workspaces", "model": "Application", "class": "Academorix\\Workspaces\\Models\\Application"},
          "foreignKey": "application_id",
          "ownerKey": "id"
        },
        {
          "name": "workspace",
          "type": "BelongsTo",
          "target": {"module": "workspaces", "model": "Workspace", "class": "Academorix\\Workspaces\\Models\\Workspace"},
          "foreignKey": "workspace_id",
          "ownerKey": "id"
        },
        {
          "name": "records",
          "type": "HasMany",
          "target": {"module": "workspaces", "model": "DomainRecord", "class": "Academorix\\Workspaces\\Models\\DomainRecord"},
          "foreignKey": "domain_id"
        },
        {
          "name": "brandings",
          "type": "HasMany",
          "target": {"module": "workspaces", "model": "Branding", "class": "Academorix\\Workspaces\\Models\\Branding"},
          "foreignKey": "domain_id",
          "description": "Per-domain branding profiles."
        }
      ]
    },
    {
      "model": {
        "name": "DomainRecord",
        "class": "Academorix\\Workspaces\\Models\\DomainRecord",
        "schemaRef": "academorix://modules/workspaces/schemas/domain-record"
      },
      "relations": [
        {
          "name": "workspace",
          "type": "BelongsTo",
          "target": {"module": "workspaces", "model": "Workspace", "class": "Academorix\\Workspaces\\Models\\Workspace"},
          "foreignKey": "workspace_id"
        },
        {
          "name": "domain",
          "type": "BelongsTo",
          "target": {"module": "workspaces", "model": "Domain", "class": "Academorix\\Workspaces\\Models\\Domain"},
          "foreignKey": "domain_id"
        }
      ]
    },
    {
      "model": {
        "name": "Branding",
        "class": "Academorix\\Workspaces\\Models\\Branding",
        "schemaRef": "academorix://modules/workspaces/schemas/branding"
      },
      "relations": [
        {
          "name": "workspace",
          "type": "BelongsTo",
          "target": {"module": "workspaces", "model": "Workspace", "class": "Academorix\\Workspaces\\Models\\Workspace"},
          "foreignKey": "workspace_id"
        },
        {
          "name": "domain",
          "type": "BelongsTo",
          "target": {"module": "workspaces", "model": "Domain", "class": "Academorix\\Workspaces\\Models\\Domain"},
          "foreignKey": "domain_id",
          "description": "Nullable — null means workspace-wide profile."
        }
      ]
    },
    {
      "model": {
        "name": "Identity",
        "class": "Academorix\\Workspaces\\Models\\Identity",
        "schemaRef": "academorix://modules/workspaces/schemas/identity"
      },
      "relations": [
        {
          "name": "application",
          "type": "BelongsTo",
          "target": {"module": "workspaces", "model": "Application", "class": "Academorix\\Workspaces\\Models\\Application"},
          "foreignKey": "application_id"
        },
        {
          "name": "users",
          "type": "HasMany",
          "target": {"module": "user", "model": "User", "class": "Academorix\\User\\Models\\User"},
          "foreignKey": "identity_id",
          "description": "One Identity → many Users across workspaces under the same Application. The User model in the `user` module must declare the identity_id FK column."
        }
      ]
    },
    {
      "model": {
        "name": "WorkspaceContact",
        "class": "Academorix\\Workspaces\\Models\\WorkspaceContact",
        "schemaRef": "academorix://modules/workspaces/schemas/workspace-contact"
      },
      "relations": [
        {
          "name": "workspace",
          "type": "BelongsTo",
          "target": {"module": "workspaces", "model": "Workspace", "class": "Academorix\\Workspaces\\Models\\Workspace"},
          "foreignKey": "workspace_id"
        }
      ]
    },
    {
      "model": {
        "name": "WorkspaceIntegration",
        "class": "Academorix\\Workspaces\\Models\\WorkspaceIntegration",
        "schemaRef": "academorix://modules/workspaces/schemas/workspace-integration"
      },
      "relations": [
        {
          "name": "workspace",
          "type": "BelongsTo",
          "target": {"module": "workspaces", "model": "Workspace", "class": "Academorix\\Workspaces\\Models\\Workspace"},
          "foreignKey": "workspace_id"
        }
      ]
    }
  ],
  "notes": [
    "Cross-workspace FKs are FORBIDDEN. Every FK on every relation above is same-workspace (BelongsToWorkspace), application-scoped (BelongsToApplication), or crosses no workspaces boundary at all (scopeNode morph).",
    "BusinessType is a config catalogue, not an Eloquent model — no relations declared here. Referenced by Workspace.business_type as a string enum.",
    "Cascade semantics: archiving a Workspace soft-deletes its Domain / Branding / Contact / Integration rows via the cascade FKs on those tables. Downstream domain modules (Organization, Branch, etc.) wire their own on-delete behaviour."
  ]
}
