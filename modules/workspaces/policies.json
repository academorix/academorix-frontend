{
  "id": "academorix://modules/workspaces/policies",
  "$version": 1,
  "title": "workspaces — authorization policies",
  "description": "Policy classes and the abilities they gate. Most policies target the `platform_admin` guard (the workspace catalogue is a platform-plane concern). Workspace-scoped self-service abilities (a workspace admin editing their own workspace) target the `sanctum` guard and are marked `guard: sanctum`. Policies registered by `WorkspacesServiceProvider::registerPolicies()`.",
  "policies": [
    {
      "class": "Academorix\\Workspaces\\Policies\\ApplicationPolicy",
      "target": "Academorix\\Workspaces\\Models\\Application",
      "guard": "platform_admin",
      "abilities": [
        {"name": "viewAny", "requires": ["view_applications OR manage_applications"]},
        {"name": "view", "requires": ["view_applications OR manage_applications"]},
        {"name": "create", "requires": ["manage_applications"]},
        {"name": "update", "requires": ["manage_applications"], "refusedOnSystemRow": true},
        {"name": "delete", "requires": ["manage_applications"], "refusedOnSystemRow": true}
      ]
    },
    {
      "class": "Academorix\\Workspaces\\Policies\\WorkspacePolicy",
      "target": "Academorix\\Workspaces\\Models\\Workspace",
      "guard": "platform_admin",
      "abilities": [
        {"name": "viewAny", "requires": ["view_workspaces OR manage_workspaces"]},
        {"name": "view", "requires": ["view_workspaces OR manage_workspaces"]},
        {"name": "create", "requires": ["manage_workspaces"], "description": "Distinct from self-serve `POST /api/v1/workspaces/register` (public route, no policy)."},
        {"name": "update", "requires": ["manage_workspaces"], "refusedOnSystemRow": true},
        {"name": "delete", "requires": ["manage_workspaces"], "refusedOnSystemRow": true, "description": "Archive (soft-delete). Hard-delete happens via HardDeleteArchivedWorkspaceJob after retention."},
        {"name": "suspend", "requires": ["manage_workspaces"], "refusedOnSystemRow": true},
        {"name": "resume", "requires": ["manage_workspaces"]},
        {"name": "archive", "requires": ["manage_workspaces"], "refusedOnSystemRow": true}
      ]
    },
    {
      "class": "Academorix\\Workspaces\\Policies\\WorkspaceSelfPolicy",
      "target": "Academorix\\Workspaces\\Models\\Workspace",
      "guard": "sanctum",
      "abilities": [
        {"name": "updateOwn", "requires": ["workspaces.manage_own_settings"], "description": "Workspace admin editing their own workspace via PATCH /api/current-workspace. Refuses if `auth()->user()->workspace_id !== workspace->id`."}
      ]
    },
    {
      "class": "Academorix\\Workspaces\\Policies\\BusinessTypePolicy",
      "target": "Academorix\\Workspaces\\Models\\BusinessType",
      "guard": "platform_admin",
      "abilities": [
        {"name": "create", "requires": ["manage_business_types"]},
        {"name": "update", "requires": ["manage_business_types"]},
        {"name": "delete", "requires": ["manage_business_types"], "description": "Refused if any Workspace currently uses this business_type key."}
      ]
    },
    {
      "class": "Academorix\\Workspaces\\Policies\\DomainPolicy",
      "target": "Academorix\\Workspaces\\Models\\Domain",
      "guard": ["platform_admin", "sanctum"],
      "abilities": [
        {"name": "viewAny", "requires": ["manage_workspaces (platform) OR workspaces.manage_domains (sanctum)"]},
        {"name": "view", "requires": ["manage_workspaces OR workspaces.manage_domains"]},
        {"name": "create", "requires": ["workspaces.manage_domains (sanctum only — customers add their own domains)"]},
        {"name": "update", "requires": ["workspaces.manage_domains"]},
        {"name": "delete", "requires": ["workspaces.manage_domains"]},
        {"name": "verify", "requires": ["workspaces.manage_domains"], "description": "Manual re-verify from the SPA."}
      ]
    },
    {
      "class": "Academorix\\Workspaces\\Policies\\DomainRecordPolicy",
      "target": "Academorix\\Workspaces\\Models\\DomainRecord",
      "guard": ["platform_admin", "sanctum"],
      "abilities": [
        {"name": "viewAny", "requires": ["workspaces.manage_domains OR manage_workspaces"]},
        {"name": "view", "requires": ["workspaces.manage_domains OR manage_workspaces"]}
      ],
      "note": "Read-only. DomainRecord rows are populated by DomainObserver; there is no direct create/update path."
    },
    {
      "class": "Academorix\\Workspaces\\Policies\\BrandingPolicy",
      "target": "Academorix\\Workspaces\\Models\\Branding",
      "guard": ["platform_admin", "sanctum"],
      "abilities": [
        {"name": "viewAny", "requires": ["manage_workspaces OR workspaces.manage_branding"]},
        {"name": "view", "requires": ["manage_workspaces OR workspaces.manage_branding"]},
        {"name": "create", "requires": ["workspaces.manage_branding"]},
        {"name": "update", "requires": ["workspaces.manage_branding"]},
        {"name": "promote", "requires": ["workspaces.manage_branding"], "description": "Sets this Branding as the workspace's primary_branding_id."},
        {"name": "delete", "requires": ["workspaces.manage_branding"], "description": "Refused when trying to delete the primary — must promote another first."}
      ]
    },
    {
      "class": "Academorix\\Workspaces\\Policies\\IdentityPolicy",
      "target": "Academorix\\Workspaces\\Models\\Identity",
      "guard": "platform_admin",
      "abilities": [
        {"name": "viewAny", "requires": ["manage_identities OR manage_workspaces"]},
        {"name": "view", "requires": ["manage_identities OR manage_workspaces"]},
        {"name": "erase", "requires": ["manage_identities"], "description": "GDPR Art. 17 right-to-erasure. Anonymises the row + cascades through User references. Recorded in the audit trail."}
      ],
      "note": "No create/update — Identity rows are created by the auth flow, not by admin CRUD."
    },
    {
      "class": "Academorix\\Workspaces\\Policies\\WorkspaceContactPolicy",
      "target": "Academorix\\Workspaces\\Models\\WorkspaceContact",
      "guard": ["platform_admin", "sanctum"],
      "abilities": [
        {"name": "viewAny", "requires": ["manage_workspaces OR workspaces.manage_contacts"]},
        {"name": "view", "requires": ["manage_workspaces OR workspaces.manage_contacts"]},
        {"name": "create", "requires": ["manage_workspaces OR workspaces.manage_contacts"]},
        {"name": "update", "requires": ["manage_workspaces OR workspaces.manage_contacts"]},
        {"name": "delete", "requires": ["manage_workspaces OR workspaces.manage_contacts"], "description": "Refused when trying to delete the last remaining `kind=dpo` contact if the workspace is GDPR-subject."}
      ]
    },
    {
      "class": "Academorix\\Workspaces\\Policies\\WorkspaceIntegrationPolicy",
      "target": "Academorix\\Workspaces\\Models\\WorkspaceIntegration",
      "guard": ["platform_admin", "sanctum"],
      "abilities": [
        {"name": "viewAny", "requires": ["manage_workspaces OR workspaces.manage_integrations"]},
        {"name": "view", "requires": ["manage_workspaces OR workspaces.manage_integrations"]},
        {"name": "create", "requires": ["workspaces.manage_integrations"]},
        {"name": "update", "requires": ["workspaces.manage_integrations"]},
        {"name": "delete", "requires": ["workspaces.manage_integrations"]}
      ],
      "note": "v2 — routes exist as stubs in v1 that return 501 unless the caller carries the permission."
    }
  ]
}
