{
  "id": "workspaces.forms.workspace-branding",
  "title": "Workspace branding form",
  "version": 1,
  "kind": "SduiForm",
  "description": "Reusable branding form. Embedded in workspace self-edit + platform-admin branding edit. Live preview + WCAG contrast validation.",
  "props": {
    "brandingId": {"type": "string", "description": "Branding row id. Null when embedded in workspace create (draft mode)."},
    "submitUrlExpr": {"type": "string", "description": "Full URL expression. E.g. `'/api/v1/workspace/brandings/' + params.id`."},
    "submitMethod": {"type": "string", "default": "PATCH", "enum": ["POST", "PATCH", "PUT"]},
    "onSuccess": {"type": "array", "description": "Actions on save success."}
  },
  "dataSources": [
    {"name": "branding", "kind": "http.get", "urlExpr": "'/api/v1/workspace/brandings/' + props.brandingId", "unwrap": "data", "condition": "!!props.brandingId"}
  ],
  "nodes": [
    {
      "id": "form",
      "kind": "Form",
      "props": {
        "submitUrlExpr": "props.submitUrlExpr",
        "submitMethod": "props.submitMethod",
        "onSuccess": "props.onSuccess"
      },
      "bindings": {"initialValues": {"$ref": "branding"}},
      "children": [
        {"kind": "View", "props": {"className": "grid grid-cols-1 lg:grid-cols-2 gap-6"}, "children": [
          {"kind": "View", "props": {"className": "flex flex-col gap-4"}, "children": [
            {"kind": "TextField", "props": {"label": "Profile name", "name": "name", "isRequired": true}, "bindings": {"defaultValue": {"$ref": "branding.name"}}},
            {"kind": "TextArea", "props": {"label": "Description", "name": "description", "rows": 2}, "bindings": {"defaultValue": {"$ref": "branding.description"}}},
            {"kind": "TextField", "props": {"label": "Logo URL", "name": "logo_url", "type": "url", "placeholder": "https://cdn.example.com/logo.svg"}, "bindings": {"defaultValue": {"$ref": "branding.logo_url"}}},
            {"kind": "TextField", "props": {"label": "Favicon URL", "name": "favicon_url", "type": "url"}, "bindings": {"defaultValue": {"$ref": "branding.favicon_url"}}},
            {"kind": "View", "props": {"className": "grid grid-cols-2 gap-3"}, "children": [
              {"kind": "ColorPicker", "props": {"label": "Primary colour", "name": "primary_color", "isRequired": true}, "bindings": {"defaultValue": {"$ref": "branding.primary_color"}}},
              {"kind": "ColorPicker", "props": {"label": "Accent colour", "name": "accent_color"}, "bindings": {"defaultValue": {"$ref": "branding.accent_color"}}},
              {"kind": "ColorPicker", "props": {"label": "Foreground colour", "name": "foreground_color"}, "bindings": {"defaultValue": {"$ref": "branding.foreground_color"}}},
              {"kind": "ColorPicker", "props": {"label": "Background colour", "name": "background_color"}, "bindings": {"defaultValue": {"$ref": "branding.background_color"}}}
            ]},
            {"kind": "Switch", "props": {"label": "Set as primary branding", "name": "is_primary", "description": "The Workspace record's branding preview column follows the primary profile."}, "bindings": {"defaultValue": {"$ref": "branding.is_primary"}}}
          ]},
          {"kind": "View", "props": {"className": "flex flex-col gap-3"}, "children": [
            {"kind": "Text", "props": {"as": "h3", "className": "text-sm font-semibold text-muted uppercase tracking-wide", "children": "Preview"}},
            {"kind": "Card", "props": {"className": "p-6"}, "bindings": {"style": {"$expr": "{ backgroundColor: values.background_color || '#ffffff', color: values.foreground_color || '#000000' }"}}, "children": [
              {"kind": "View", "props": {"className": "flex items-center gap-3 mb-4"}, "children": [
                {"kind": "Image", "props": {"className": "size-10 rounded"}, "bindings": {"src": {"$ref": "values.logo_url"}, "alt": "Preview logo"}},
                {"kind": "Text", "props": {"as": "h4", "className": "text-lg font-semibold"}, "bindings": {"children": {"$expr": "values.name || 'Your workspace'"}}}
              ]},
              {"kind": "Button", "props": {"size": "md", "className": "w-full mb-2"}, "bindings": {"style": {"$expr": "{ backgroundColor: values.primary_color, color: values.foreground_color }"}}, "children": {"kind": "Text", "props": {"children": "Primary button"}}},
              {"kind": "Link", "props": {"className": "text-sm"}, "bindings": {"style": {"$expr": "{ color: values.accent_color }"}}, "children": {"kind": "Text", "props": {"children": "Accent link"}}}
            ]},
            {"kind": "Alert", "props": {"variant": "warning"}, "bindings": {"hidden": {"$expr": "wcagContrastRatio(values.foreground_color, values.background_color) >= 4.5"}, "children": {"$expr": "'Contrast ratio ' + wcagContrastRatio(values.foreground_color, values.background_color).toFixed(2) + ':1 fails WCAG 2.2 AA (SC 1.4.3 requires >= 4.5:1).'"}}}
          ]}
        ]},
        {"kind": "View", "props": {"className": "flex items-center justify-end gap-2 mt-4"}, "children": [
          {"kind": "Button", "props": {"variant": "primary", "size": "md", "type": "submit", "children": "Save branding"}}
        ]}
      ]
    }
  ]
}
