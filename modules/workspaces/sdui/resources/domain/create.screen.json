{
  "id": "workspaces.resources.domain.create",
  "title": "Add custom domain",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/workspace/domains/new",
  "host": "workspace",
  "audience": "authenticated",
  "resource": {"module": "workspaces", "entity": "domain", "action": "create"},
  "requiresPermission": "workspaces.manage_domains",
  "dataSources": [],
  "nodes": [
    {"id": "root", "kind": "View", "props": {"className": "flex flex-col gap-6 p-6 max-w-2xl mx-auto"}, "children": [
      {"kind": "Link", "props": {"leadingIcon": "arrow-left", "children": "Cancel"}, "actions": {"onPress": {"kind": "navigate", "to": "/workspace/domains"}}},
      {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold", "children": "Add custom domain"}},
      {"kind": "Alert", "props": {"variant": "info", "children": "After you add the domain, we'll generate DNS records to point at Academorix. Verification runs automatically once the records are live."}},
      {"kind": "Form", "props": {"submitUrl": "/api/v1/workspace/domains", "submitMethod": "POST", "onSuccess": [{"kind": "toast.success", "message": "Domain added. Verify DNS records on the detail screen."}, {"kind": "navigateExpr", "expr": "'/workspace/domains/' + response.data.id"}]}, "children": [
        {"kind": "TextField", "props": {"label": "Host", "name": "host", "isRequired": true, "type": "url", "placeholder": "academy.example.com", "description": "Full hostname. Do not include http://."}},
        {"kind": "Select", "props": {"label": "Kind", "name": "kind", "isRequired": true, "defaultValue": "custom"}, "options": [{"key": "custom", "label": "Custom domain (primary)"}, {"key": "alias", "label": "Alias (redirects to primary)"}]},
        {"kind": "Button", "props": {"variant": "primary", "size": "md", "type": "submit", "children": "Add domain"}}
      ]}
    ]}
  ]
}
