{
  "id": "workspaces.resources.application.list",
  "title": "Applications",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/platform/applications",
  "host": "central_admin",
  "audience": "authenticated",
  "resource": {"module": "workspaces", "entity": "application", "action": "list"},
  "requiresPermission": "platform.applications.viewAny",
  "dataSources": [
    {"name": "applications", "kind": "http.get", "url": "/api/v1/applications", "unwrap": "data", "paginated": true, "queryParamsFromState": ["filter[status]", "sort", "page", "per_page"]}
  ],
  "nodes": [
    {"id": "root", "kind": "View", "props": {"className": "flex flex-col gap-4 p-6"}, "children": [
      {"kind": "View", "props": {"className": "flex items-center justify-between"}, "children": [
        {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold", "children": "Applications"}},
        {"kind": "Button", "props": {"variant": "primary", "size": "sm", "leadingIcon": "plus", "children": "New application"}, "actions": {"onPress": {"kind": "navigate", "to": "/platform/applications/new"}}}
      ]},
      {"kind": "DataGrid", "props": {"emptyState": {"title": "No applications registered", "description": "An Application is the top-level product container. Every workspace belongs to one.", "icon": "cube"}}, "bindings": {"items": {"$ref": "applications"}, "isLoading": {"$ref": "applications.isLoading"}}, "columns": [
        {"id": "name", "header": "Name", "cell": {"kind": "View", "children": [
          {"kind": "Text", "props": {"className": "font-medium"}, "bindings": {"children": {"$ref": "row.name"}}},
          {"kind": "Text", "props": {"className": "text-xs text-muted font-mono"}, "bindings": {"children": {"$ref": "row.slug"}}}
        ]}},
        {"id": "region", "header": "Region", "cell": {"kind": "Chip", "props": {"size": "xs", "variant": "neutral"}, "bindings": {"children": {"$ref": "row.data_residency_region"}}}},
        {"id": "payment_provider", "header": "Payment", "cell": {"kind": "Chip", "props": {"size": "xs"}, "bindings": {"children": {"$ref": "row.payment_provider"}}}},
        {"id": "workspaces_count", "header": "Workspaces", "cell": {"kind": "Text", "props": {"className": "text-sm"}, "bindings": {"children": {"$ref": "row.workspaces_count"}}}},
        {"id": "status", "header": "Status", "cell": {"kind": "Chip", "props": {"size": "sm"}, "bindings": {"variant": {"$expr": "row.status === 'active' ? 'success' : 'warning'"}, "children": {"$ref": "row.status"}}}},
        {"id": "actions", "header": "", "align": "end", "cell": {"kind": "Button", "props": {"variant": "ghost", "size": "sm", "children": "Open"}, "actions": {"onPress": {"kind": "navigate", "toExpr": "'/platform/applications/' + row.id"}}}}
      ]}
    ]}
  ]
}
