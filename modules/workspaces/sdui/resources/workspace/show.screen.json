{
  "id": "workspaces.resources.workspace.show",
  "title": "Workspace detail",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/platform/workspaces/{id}",
  "host": "central_admin",
  "audience": "authenticated",
  "resource": {"module": "workspaces", "entity": "workspace", "action": "show"},
  "requiresPermission": "platform.workspaces.view",
  "params": [{"name": "id", "type": "string", "in": "path", "required": true}],
  "dataSources": [
    {"name": "workspace", "kind": "http.get", "urlExpr": "'/api/v1/workspaces/' + params.id + '?include=application,branding,domains,contacts'", "unwrap": "data"}
  ],
  "broadcasts": [
    {"channel": "workspace.{id}.lifecycle", "on": ["WorkspaceSuspended", "WorkspaceResumed", "WorkspaceArchived", "WorkspaceErased"], "action": {"kind": "data.refresh", "source": "workspace"}}
  ],
  "nodes": [
    {"id": "root", "kind": "View", "props": {"className": "flex flex-col gap-6 p-6 max-w-5xl mx-auto"}, "children": [
      {"kind": "Link", "props": {"leadingIcon": "arrow-left", "children": "Back to workspaces"}, "actions": {"onPress": {"kind": "navigate", "to": "/platform/workspaces"}}},
      {"kind": "View", "props": {"className": "flex items-start justify-between gap-4"}, "children": [
        {"kind": "View", "props": {"className": "flex items-center gap-4"}, "children": [
          {"kind": "Avatar", "props": {"size": "lg"}, "bindings": {"src": {"$expr": "workspace.branding?.logo_url"}, "fallback": {"$expr": "(workspace.name || 'T')[0]"}}},
          {"kind": "View", "children": [
            {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold"}, "bindings": {"children": {"$ref": "workspace.name"}}},
            {"kind": "Text", "props": {"className": "text-sm text-muted font-mono"}, "bindings": {"children": {"$expr": "workspace.slug + '.academorix.app'"}}},
            {"kind": "View", "props": {"className": "flex items-center gap-2 mt-2"}, "children": [
              {"kind": "Chip", "props": {"size": "sm"}, "bindings": {"variant": {"$expr": "workspace.status === 'active' ? 'success' : (workspace.status === 'suspended' ? 'warning' : 'danger')"}, "children": {"$ref": "workspace.status"}}},
              {"kind": "Chip", "props": {"size": "xs", "variant": "neutral"}, "bindings": {"children": {"$ref": "workspace.business_type"}}},
              {"kind": "Chip", "props": {"size": "xs", "variant": "info"}, "bindings": {"children": {"$expr": "'plan: ' + (workspace.plan || 'free')"}}}
            ]}
          ]}
        ]},
        {"kind": "View", "props": {"className": "flex items-center gap-2"}, "children": [
          {"kind": "Button", "props": {"variant": "outline", "size": "sm", "leadingIcon": "pencil", "children": "Edit"}, "actions": {"onPress": {"kind": "navigate", "toExpr": "'/platform/workspaces/' + params.id + '/edit'"}}},
          {"kind": "Menu", "props": {"trigger": {"kind": "Button", "props": {"variant": "outline", "size": "sm", "isIconOnly": true, "leadingIcon": "ellipsis-horizontal"}}}, "items": [
            {"id": "suspend", "label": "Suspend", "leadingIcon": "pause", "bindings": {"isDisabled": {"$expr": "workspace.status !== 'active'"}}, "action": {"kind": "http.post", "urlExpr": "'/api/v1/workspaces/' + params.id + '/suspend'", "confirm": {"title": "Suspend this workspace?", "confirmationInputMatches": "workspace.slug"}, "onSuccess": [{"kind": "toast.success", "message": "Suspended"}, {"kind": "data.refresh", "source": "workspace"}]}},
            {"id": "resume", "label": "Resume", "leadingIcon": "play", "bindings": {"isDisabled": {"$expr": "workspace.status !== 'suspended'"}}, "action": {"kind": "http.post", "urlExpr": "'/api/v1/workspaces/' + params.id + '/resume'", "onSuccess": {"kind": "data.refresh", "source": "workspace"}}},
            {"id": "archive", "label": "Archive", "leadingIcon": "archive-box", "bindings": {"isDisabled": {"$expr": "workspace.status === 'archived'"}}, "action": {"kind": "http.post", "urlExpr": "'/api/v1/workspaces/' + params.id + '/archive'", "confirm": {"title": "Archive this workspace?", "description": "Marks archived. 30-day grace before hard delete.", "confirmationInputMatches": "workspace.slug"}, "onSuccess": {"kind": "data.refresh", "source": "workspace"}}}
          ]}
        ]}
      ]},
      {"kind": "Card", "props": {"className": "p-6"}, "children": [
        {"kind": "Text", "props": {"as": "h2", "className": "text-sm font-semibold text-muted uppercase tracking-wide mb-3", "children": "Details"}},
        {"kind": "DescriptionList", "children": [
          {"kind": "DescriptionListItem", "props": {"label": "Application"}, "bindings": {"value": {"$expr": "workspace.application?.name"}}},
          {"kind": "DescriptionListItem", "props": {"label": "Owner"}, "bindings": {"value": {"$expr": "workspace.owner?.display_name || workspace.owner?.email"}}},
          {"kind": "DescriptionListItem", "props": {"label": "Users"}, "bindings": {"value": {"$ref": "workspace.users_count"}}},
          {"kind": "DescriptionListItem", "props": {"label": "Data residency"}, "bindings": {"value": {"$ref": "workspace.data_residency_region"}}},
          {"kind": "DescriptionListItem", "props": {"label": "Provisioned"}, "bindings": {"value": {"$expr": "formatDate(workspace.created_at)"}}},
          {"kind": "DescriptionListItem", "props": {"label": "Suspended"}, "bindings": {"hidden": {"$expr": "!workspace.suspended_at"}, "value": {"$expr": "formatDate(workspace.suspended_at)"}}}
        ]}
      ]}
    ]}
  ]
}
