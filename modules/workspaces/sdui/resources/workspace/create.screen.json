{
  "id": "workspaces.resources.workspace.create",
  "title": "New workspace",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/platform/workspaces/new",
  "host": "central_admin",
  "audience": "authenticated",
  "resource": {"module": "workspaces", "entity": "workspace", "action": "create"},
  "requiresPermission": "platform.workspaces.create",
  "dataSources": [
    {"name": "applications", "kind": "http.get", "url": "/api/v1/applications?per_page=50", "unwrap": "data"}
  ],
  "nodes": [
    {"id": "root", "kind": "View", "props": {"className": "flex flex-col gap-6 p-6 max-w-3xl mx-auto"}, "children": [
      {"kind": "Link", "props": {"leadingIcon": "arrow-left", "children": "Cancel"}, "actions": {"onPress": {"kind": "navigate", "to": "/platform/workspaces"}}},
      {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold", "children": "New workspace"}},
      {"kind": "Alert", "props": {"variant": "info", "children": "The workspace will be provisioned with defaults for its business type: sample organisation + branch + region + owner user seeded from BusinessType.default_config."}},
      {"kind": "Form", "props": {"submitUrl": "/api/v1/workspaces", "submitMethod": "POST", "onSuccess": [{"kind": "toast.success", "message": "Workspace created \u2014 provisioning in progress"}, {"kind": "navigateExpr", "expr": "'/platform/workspaces/' + response.data.id"}]}, "children": [
        {"kind": "Select", "props": {"label": "Application", "name": "application_id", "isRequired": true}, "optionsSource": {"$ref": "applications", "valueField": "id", "labelField": "name"}},
        {"kind": "TextField", "props": {"label": "Workspace name", "name": "name", "isRequired": true, "placeholder": "Acme Academy"}},
        {"kind": "TextField", "props": {"label": "Slug", "name": "slug", "isRequired": true, "placeholder": "acme", "description": "Becomes the primary subdomain (acme.academorix.app)."}},
        {"kind": "Widget", "widget": "workspaces.widgets.business-type-select", "props": {"name": "business_type", "label": "Business type", "isRequired": true}},
        {"kind": "TextField", "props": {"label": "Owner email", "name": "owner_email", "isRequired": true, "type": "email", "description": "Invitation sent to this address to complete provisioning."}},
        {"kind": "TextField", "props": {"label": "Owner display name", "name": "owner_display_name", "isRequired": true}},
        {"kind": "Select", "props": {"label": "Initial plan", "name": "plan", "isRequired": true, "defaultValue": "free"}, "options": [{"key": "free", "label": "Free"}, {"key": "team", "label": "Team (14-day trial)"}, {"key": "enterprise", "label": "Enterprise (contract)"}]},
        {"kind": "Button", "props": {"variant": "primary", "size": "md", "type": "submit", "children": "Provision workspace"}}
      ]}
    ]}
  ]
}
