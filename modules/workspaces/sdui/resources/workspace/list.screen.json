{
  "id": "workspaces.resources.workspace.list",
  "title": "Workspaces",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/platform/workspaces",
  "host": "central_admin",
  "audience": "authenticated",
  "resource": {"module": "workspaces", "entity": "workspace", "action": "list"},
  "requiresPermission": "platform.workspaces.viewAny",
  "dataSources": [
    {"name": "workspaces", "kind": "http.get", "url": "/api/v1/workspaces", "unwrap": "data", "paginated": true, "queryParamsFromState": ["filter[status]", "filter[application_id]", "filter[business_type]", "sort", "page", "per_page"]},
    {"name": "applications", "kind": "http.get", "url": "/api/v1/applications?per_page=50", "unwrap": "data", "cache": {"ttlSeconds": 600}},
    {"name": "businessTypes", "kind": "http.get", "url": "/api/v1/business-types", "unwrap": "data", "cache": {"ttlSeconds": 3600}}
  ],
  "nodes": [
    {"id": "root", "kind": "View", "props": {"className": "flex flex-col gap-4 p-6"}, "children": [
      {"kind": "View", "props": {"className": "flex items-center justify-between"}, "children": [
        {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold", "children": "Workspaces"}},
        {"kind": "Button", "props": {"variant": "primary", "size": "sm", "leadingIcon": "plus", "children": "New workspace"}, "actions": {"onPress": {"kind": "navigate", "to": "/platform/workspaces/new"}}}
      ]},
      {"kind": "View", "props": {"className": "flex flex-wrap gap-3"}, "children": [
        {"kind": "Select", "props": {"label": "Application", "name": "filter[application_id]", "placeholder": "All"}, "optionsSource": {"$ref": "applications", "valueField": "id", "labelField": "name"}, "actions": {"onChange": {"kind": "data.applyFilter", "source": "workspaces"}}},
        {"kind": "Select", "props": {"label": "Status", "name": "filter[status]", "placeholder": "All"}, "options": [{"key": "provisioning", "label": "Provisioning"}, {"key": "active", "label": "Active"}, {"key": "suspended", "label": "Suspended"}, {"key": "archived", "label": "Archived"}], "actions": {"onChange": {"kind": "data.applyFilter", "source": "workspaces"}}},
        {"kind": "Select", "props": {"label": "Business type", "name": "filter[business_type]", "placeholder": "All"}, "optionsSource": {"$ref": "businessTypes", "valueField": "key", "labelField": "display_name"}, "actions": {"onChange": {"kind": "data.applyFilter", "source": "workspaces"}}}
      ]},
      {"kind": "DataGrid", "props": {"emptyState": {"title": "No workspaces match", "description": "Adjust your filters or create a workspace."}}, "bindings": {"items": {"$ref": "workspaces"}, "isLoading": {"$ref": "workspaces.isLoading"}}, "columns": [
        {"id": "identity", "header": "Workspace", "cell": {"kind": "View", "props": {"className": "flex items-center gap-3"}, "children": [
          {"kind": "Avatar", "props": {"size": "sm"}, "bindings": {"src": {"$expr": "row.branding?.logo_url"}, "fallback": {"$expr": "(row.name || 'T')[0]"}}},
          {"kind": "View", "children": [
            {"kind": "Text", "props": {"className": "font-medium"}, "bindings": {"children": {"$ref": "row.name"}}},
            {"kind": "Text", "props": {"className": "text-xs text-muted font-mono"}, "bindings": {"children": {"$expr": "row.slug + '.academorix.app'"}}}
          ]}
        ]}},
        {"id": "business_type", "header": "Type", "cell": {"kind": "Chip", "props": {"size": "xs", "variant": "neutral"}, "bindings": {"children": {"$ref": "row.business_type"}}}},
        {"id": "users_count", "header": "Users", "cell": {"kind": "Text", "props": {"className": "text-sm"}, "bindings": {"children": {"$ref": "row.users_count"}}}},
        {"id": "plan", "header": "Plan", "cell": {"kind": "Chip", "props": {"size": "xs"}, "bindings": {"variant": {"$expr": "row.plan === 'enterprise' ? 'info' : (row.plan === 'team' ? 'success' : 'neutral')"}, "children": {"$expr": "row.plan || 'free'"}}}},
        {"id": "status", "header": "Status", "cell": {"kind": "Chip", "props": {"size": "sm"}, "bindings": {"variant": {"$expr": "row.status === 'active' ? 'success' : (row.status === 'suspended' ? 'warning' : (row.status === 'archived' ? 'danger' : 'info'))"}, "children": {"$ref": "row.status"}}}},
        {"id": "actions", "header": "", "align": "end", "cell": {"kind": "Menu", "props": {"trigger": {"kind": "Button", "props": {"variant": "ghost", "isIconOnly": true, "leadingIcon": "ellipsis-horizontal", "ariaLabel": "Actions"}}}, "items": [
          {"id": "view", "label": "View", "leadingIcon": "eye", "action": {"kind": "navigate", "toExpr": "'/platform/workspaces/' + row.id"}},
          {"id": "edit", "label": "Edit", "leadingIcon": "pencil", "action": {"kind": "navigate", "toExpr": "'/platform/workspaces/' + row.id + '/edit'"}},
          {"id": "suspend", "label": "Suspend", "leadingIcon": "pause", "bindings": {"isDisabled": {"$expr": "row.status !== 'active'"}}, "action": {"kind": "http.post", "urlExpr": "'/api/v1/workspaces/' + row.id + '/suspend'", "confirm": {"title": "Suspend this workspace?"}, "onSuccess": [{"kind": "toast.success", "message": "Suspended"}, {"kind": "data.refresh", "source": "workspaces"}]}},
          {"id": "resume", "label": "Resume", "leadingIcon": "play", "bindings": {"isDisabled": {"$expr": "row.status !== 'suspended'"}}, "action": {"kind": "http.post", "urlExpr": "'/api/v1/workspaces/' + row.id + '/resume'", "onSuccess": [{"kind": "toast.success", "message": "Resumed"}, {"kind": "data.refresh", "source": "workspaces"}]}}
        ]}}
      ]}
    ]}
  ]
}
