{
  "id": "academorix://modules/workspaces/metrics",
  "$version": 1,
  "title": "workspaces — OpenTelemetry metrics",
  "description": "OpenTelemetry / Prometheus metrics this module emits. Every metric follows the RED pattern where relevant (Rate / Errors / Duration). Labels are aggressive — filter cardinality is capped at ~5k per metric.",
  "instrumentation": "open-telemetry/sdk",
  "namespace": "academorix.workspaces",
  "metrics": [
    {"name": "academorix.workspaces.provisioned.total", "kind": "counter", "unit": "workspaces", "labels": ["application_id", "business_type"], "description": "WorkspaceProvisioned dispatches."},
    {"name": "academorix.workspaces.suspended.total", "kind": "counter", "unit": "workspaces", "labels": ["application_id", "business_type", "reason"]},
    {"name": "academorix.workspaces.resumed.total", "kind": "counter", "unit": "workspaces", "labels": ["application_id", "business_type"]},
    {"name": "academorix.workspaces.archived.total", "kind": "counter", "unit": "workspaces", "labels": ["application_id", "business_type"]},
    {"name": "academorix.workspaces.active", "kind": "gauge", "unit": "workspaces", "labels": ["application_id", "business_type"], "description": "Point-in-time count of `status=active` workspaces. Sampled every 60s."},
    {"name": "academorix.workspaces.trialing", "kind": "gauge", "unit": "workspaces", "labels": ["application_id"]},
    {"name": "academorix.workspaces.grace", "kind": "gauge", "unit": "workspaces", "labels": ["application_id"]},
    {"name": "academorix.applications.count", "kind": "gauge", "unit": "applications"},
    {"name": "academorix.workspaces.orphaned.count", "kind": "gauge", "unit": "workspaces", "description": "Emitted by workspaces-not-orphaned health probe. Expected 0."},
    {"name": "academorix.domains.added.total", "kind": "counter", "unit": "domains", "labels": ["application_id", "kind"]},
    {"name": "academorix.domains.verified.total", "kind": "counter", "unit": "domains", "labels": ["application_id"]},
    {"name": "academorix.domains.verification_failed.total", "kind": "counter", "unit": "domains", "labels": ["application_id", "failure_reason"]},
    {"name": "academorix.domains.verify.duration_ms", "kind": "histogram", "unit": "ms", "buckets": [50, 100, 250, 500, 1000, 2500, 5000, 10000, 30000], "labels": ["kind"]},
    {"name": "academorix.workspace.provisioning.duration_ms", "kind": "histogram", "unit": "ms", "buckets": [50, 100, 250, 500, 1000, 2500, 5000, 10000], "labels": ["business_type"]},
    {"name": "academorix.workspace.branding.cache_hit_ratio", "kind": "gauge", "unit": "ratio", "labels": ["application_id"]},
    {"name": "academorix.workspace.features.cache_hit_ratio", "kind": "gauge", "unit": "ratio", "labels": ["application_id"]},
    {"name": "academorix.workspace_contacts.added.total", "kind": "counter", "unit": "contacts", "labels": ["kind"]},
    {"name": "academorix.workspace_integrations.configured.total", "kind": "counter", "unit": "integrations", "labels": ["kind", "provider"]},
    {"name": "academorix.workspace_integrations.sync.duration_ms", "kind": "histogram", "unit": "ms", "buckets": [500, 1000, 5000, 15000, 60000, 300000], "labels": ["kind", "provider", "outcome"]},
    {"name": "academorix.workspace_integrations.sync.failures.total", "kind": "counter", "unit": "syncs", "labels": ["kind", "provider", "error_class"]}
  ]
}
