{
  "id": "academorix://modules/workspaces/errors",
  "$version": 1,
  "title": "workspaces — error catalogue",
  "description": "Error codes this module can emit, with their HTTP status, i18n key, and support-runbook classification. `user_facing=true` means the message renders to end users (i18n key must exist in every supported locale). `retryable=true` signals the client should retry with backoff. `audit_severity` routes the error to the correct log channel — `alert` events page on-call.",
  "namespace": "workspaces",
  "errors": [
    {
      "code": "WORKSPACES_WORKSPACE_NOT_FOUND",
      "http": 404,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "workspaces.errors.workspace_not_found",
      "thrown_by": "ResolveWorkspace middleware",
      "description": "Host header did not resolve to a Workspace on the current Application."
    },
    {
      "code": "WORKSPACES_APPLICATION_NOT_FOUND",
      "http": 404,
      "retryable": false,
      "user_facing": false,
      "audit_severity": "warn",
      "i18n_key": "workspaces.errors.application_not_found",
      "thrown_by": "ResolveWorkspace middleware",
      "description": "Host header did not match any Application. Usually a misconfigured DNS record or a request to an unmapped host."
    },
    {
      "code": "WORKSPACES_WORKSPACE_SUSPENDED",
      "http": 403,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "workspaces.errors.workspace_suspended",
      "thrown_by": "WorkspaceSuspendedException, checked in EnsureUserBelongsToWorkspace"
    },
    {
      "code": "WORKSPACES_WORKSPACE_ARCHIVED",
      "http": 410,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "workspaces.errors.workspace_archived"
    },
    {
      "code": "WORKSPACES_CROSS_WORKSPACE_ACCESS",
      "http": 400,
      "retryable": false,
      "user_facing": false,
      "audit_severity": "alert",
      "i18n_key": "workspaces.errors.cross_workspace_access",
      "thrown_by": "WorkspaceException::crossWorkspaceAccess() — BelongsToWorkspace saving hook, workspace.user middleware",
      "description": "Attempt to read or write across workspace boundaries. Always a bug OR an attack — pages on-call."
    },
    {
      "code": "WORKSPACES_SLUG_TAKEN",
      "http": 422,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "workspaces.errors.slug_taken",
      "description": "Attempt to register a workspace with a slug already in use in the target Application."
    },
    {
      "code": "WORKSPACES_SLUG_RESERVED",
      "http": 422,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "workspaces.errors.slug_reserved",
      "description": "Reserved word (www, api, admin, mail, blog, platform, app). Enforced by the reserved_slug validation rule."
    },
    {
      "code": "WORKSPACES_INVALID_BUSINESS_TYPE",
      "http": 422,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "workspaces.errors.invalid_business_type",
      "description": "business_type not present in the BusinessType catalogue."
    },
    {
      "code": "WORKSPACES_DOMAIN_NOT_VERIFIED",
      "http": 400,
      "retryable": true,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "workspaces.errors.domain_not_verified",
      "description": "Attempt to promote a Domain to primary before it is verified."
    },
    {
      "code": "WORKSPACES_DOMAIN_VERIFICATION_EXHAUSTED",
      "http": 400,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "warn",
      "i18n_key": "workspaces.errors.domain_verification_exhausted",
      "description": "verification_attempts hit the 100 cap. Requires manual replay."
    },
    {
      "code": "WORKSPACES_DOMAIN_HOST_INVALID",
      "http": 422,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "workspaces.errors.domain_host_invalid",
      "description": "Enforced by the valid_domain_host validation rule. Rejects IP addresses, sub-of-sub without a suffix, and RFC-1035-non-compliant labels."
    },
    {
      "code": "WORKSPACES_BRANDING_LAST_PRIMARY",
      "http": 409,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "workspaces.errors.branding_last_primary",
      "description": "Attempt to delete the workspace's primary Branding without promoting another first."
    },
    {
      "code": "WORKSPACES_CONTACT_VERIFICATION_REQUIRED",
      "http": 422,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "workspaces.errors.contact_verification_required",
      "description": "kind=dpo or kind=legal contact promoted to primary before verified_at is set."
    },
    {
      "code": "WORKSPACES_CONTACT_LAST_DPO",
      "http": 409,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "warn",
      "i18n_key": "workspaces.errors.contact_last_dpo",
      "description": "Attempt to delete the last remaining DPO contact for a GDPR-subject workspace."
    },
    {
      "code": "WORKSPACES_INTEGRATION_NOT_IMPLEMENTED",
      "http": 501,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "info",
      "i18n_key": "workspaces.errors.integration_not_implemented",
      "description": "v1 stub. Returned by the integration controllers until v2 wires the provider adapters."
    },
    {
      "code": "WORKSPACES_SYSTEM_ROW_REFUSED",
      "http": 403,
      "retryable": false,
      "user_facing": true,
      "audit_severity": "warn",
      "i18n_key": "workspaces.errors.system_row_refused",
      "description": "Attempt to update or delete a row with is_system=true."
    }
  ]
}
