{
  "id": "subscription.resources.subscription.show",
  "title": "Subscription",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/platform/subscriptions/{subscription}",
  "host": "central_admin",
  "audience": "platform_admin",
  "resource": {"module": "subscription", "entity": "subscription", "action": "show"},
  "requiresPermission": "platform.subscriptions.view",
  "params": [{"name": "subscription", "type": "string", "in": "path", "required": true}],
  "dataSources": [
    {"name": "sub", "kind": "http.get", "urlExpr": "'/api/v1/platform/subscriptions/' + params.subscription", "unwrap": "data"},
    {"name": "events", "kind": "http.get", "urlExpr": "'/api/v1/platform/subscriptions/' + params.subscription + '/events'", "unwrap": "data"}
  ],
  "nodes": [
    {"id": "root", "kind": "View", "props": {"className": "flex flex-col gap-6 p-6 max-w-5xl mx-auto"}, "children": [
      {"kind": "Link", "props": {"leadingIcon": "arrow-left", "children": "Back to subscriptions"}, "actions": {"onPress": {"kind": "navigate", "to": "/platform/subscriptions"}}},
      {"kind": "View", "props": {"className": "flex items-start justify-between gap-4"}, "children": [
        {"kind": "View", "children": [
          {"kind": "Link", "props": {"variant": "unstyled", "size": "sm"}, "actions": {"onPress": {"kind": "navigate", "toExpr": "'/platform/workspaces/' + sub.workspace_id"}}, "bindings": {"childrenExpr": "sub.workspace?.name || sub.workspace_id"}},
          {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold mt-1"}, "bindings": {"childrenExpr": "sub.plan?.name"}},
          {"kind": "View", "props": {"className": "flex items-center gap-2 mt-2"}, "children": [
            {"kind": "Widget", "widget": "subscription.subscription-state-chip", "props": {"state": {"$ref": "sub.state"}}},
            {"kind": "Chip", "props": {"size": "xs", "variant": "neutral"}, "bindings": {"children": {"$ref": "sub.provider"}}}
          ]}
        ]},
        {"kind": "View", "props": {"className": "flex items-center gap-2"}, "children": [
          {"kind": "Button", "props": {"variant": "outline", "className": "text-warning", "children": "Force state"}, "actions": {"onPress": {"kind": "modal.open", "modal": "force-state"}}, "requiresPermission": "platform.subscriptions.force-state"}
        ]}
      ]},
      {"kind": "Card", "props": {"className": "p-6"}, "children": [
        {"kind": "View", "props": {"className": "grid grid-cols-2 md:grid-cols-4 gap-4"}, "children": [
          {"kind": "View", "children": [{"kind": "Text", "props": {"className": "text-xs uppercase text-muted", "children": "Cycle"}}, {"kind": "Text", "props": {"className": "mt-1 font-medium"}, "bindings": {"children": {"$ref": "sub.billing_cycle"}}}]},
          {"kind": "View", "children": [{"kind": "Text", "props": {"className": "text-xs uppercase text-muted", "children": "Period end"}}, {"kind": "Text", "props": {"className": "mt-1 font-medium"}, "bindings": {"childrenExpr": "sub.current_period_end ? formatDate(sub.current_period_end) : '\u2014'"}}]},
          {"kind": "View", "children": [{"kind": "Text", "props": {"className": "text-xs uppercase text-muted", "children": "Grace ends"}}, {"kind": "Text", "props": {"className": "mt-1 font-medium"}, "bindings": {"childrenExpr": "sub.grace_ends_at ? formatDate(sub.grace_ends_at) : '\u2014'"}}]},
          {"kind": "View", "children": [{"kind": "Text", "props": {"className": "text-xs uppercase text-muted", "children": "Consecutive fails"}}, {"kind": "Text", "props": {"className": "mt-1 font-mono font-medium"}, "bindings": {"children": {"$ref": "sub.consecutive_failures"}}}]}
        ]}
      ]},
      {"kind": "Card", "props": {"className": "p-6"}, "children": [
        {"kind": "Text", "props": {"as": "h3", "className": "text-sm font-semibold uppercase text-muted mb-4", "children": "Lifecycle events"}},
        {"kind": "Timeline", "bindings": {"items": {"$ref": "events"}}, "itemRenderer": {"kind": "TimelineItem", "propsExpr": "{ time: row.occurred_at, kind: row.kind }", "children": [
          {"kind": "Text", "props": {"className": "font-medium"}, "bindings": {"children": {"$ref": "row.kind"}}},
          {"kind": "Text", "props": {"className": "text-sm text-muted"}, "bindings": {"hidden": {"$expr": "!row.from_state && !row.to_state"}, "childrenExpr": "row.from_state + ' \u2192 ' + row.to_state"}},
          {"kind": "Text", "props": {"className": "text-sm text-muted"}, "bindings": {"hidden": {"$expr": "!row.reason"}, "children": {"$ref": "row.reason"}}},
          {"kind": "Text", "props": {"className": "text-xs text-muted"}, "bindings": {"childrenExpr": "row.actor_type + (row.actor_id ? ' (' + row.actor_id + ')' : '')"}}
        ]}}
      ]}
    ]}
  ]
}
