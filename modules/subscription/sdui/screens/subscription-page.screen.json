{
  "id": "subscription.subscription-page",
  "title": "Subscription",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/workspace/subscription",
  "host": "workspace",
  "audience": "authenticated",
  "requiresPermission": "subscription.view",
  "dataSources": [
    {"name": "subscription", "kind": "http.get", "url": "/api/v1/subscription", "unwrap": "data"},
    {"name": "upcoming", "kind": "http.get", "url": "/api/v1/subscription/upcoming-invoice", "unwrap": "data", "skipOnState": ["cancelled", "expired"]}
  ],
  "nodes": [
    {"id": "root", "kind": "View", "props": {"className": "flex flex-col gap-6 p-6 max-w-4xl mx-auto"}, "children": [
      {"kind": "View", "children": [
        {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold", "children": "Subscription"}},
        {"kind": "Text", "props": {"className": "text-sm text-muted", "children": "Your workspace's current plan and billing state."}}
      ]},
      {"kind": "Card", "props": {"className": "p-6"}, "children": [
        {"kind": "View", "props": {"className": "flex items-start justify-between gap-4 flex-wrap"}, "children": [
          {"kind": "View", "children": [
            {"kind": "Text", "props": {"className": "text-sm text-muted uppercase tracking-wide", "children": "Current plan"}},
            {"kind": "Text", "props": {"as": "h2", "className": "text-xl font-semibold mt-1"}, "bindings": {"children": {"$expr": "subscription.plan.name"}}},
            {"kind": "View", "props": {"className": "mt-2"}, "children": [
              {"kind": "Widget", "widget": "subscription.subscription-state-chip", "props": {"state": {"$ref": "subscription.state"}}}
            ]}
          ]},
          {"kind": "View", "props": {"className": "flex items-center gap-2"}, "children": [
            {"kind": "Button", "props": {"variant": "outline", "children": "Change plan"}, "actions": {"onPress": {"kind": "navigate", "to": "/workspace/subscription/checkout"}}},
            {"kind": "Button", "props": {"variant": "outline", "children": "Billing portal"}, "actions": {"onPress": {"kind": "http.post", "url": "/api/v1/subscription/portal", "onSuccess": {"kind": "redirectExternal", "urlExpr": "response.data.url"}}}, "bindings": {"hidden": {"$expr": "subscription.provider === 'invoice'"}}}
          ]}
        ]},
        {"kind": "Separator", "props": {"className": "my-4"}},
        {"kind": "View", "props": {"className": "grid grid-cols-2 md:grid-cols-4 gap-4 text-sm"}, "children": [
          {"kind": "View", "children": [
            {"kind": "Text", "props": {"className": "text-muted uppercase text-xs", "children": "Billing cycle"}},
            {"kind": "Text", "props": {"className": "mt-1 font-medium"}, "bindings": {"children": {"$ref": "subscription.billing_cycle"}}}
          ]},
          {"kind": "View", "children": [
            {"kind": "Text", "props": {"className": "text-muted uppercase text-xs", "children": "Next renewal"}},
            {"kind": "Text", "props": {"className": "mt-1 font-medium"}, "bindings": {"hidden": {"$expr": "!subscription.current_period_end"}, "children": {"$expr": "formatDate(subscription.current_period_end)"}}}
          ]},
          {"kind": "View", "children": [
            {"kind": "Text", "props": {"className": "text-muted uppercase text-xs", "children": "Payment"}},
            {"kind": "Text", "props": {"className": "mt-1 font-medium capitalize"}, "bindings": {"children": {"$ref": "subscription.provider"}}}
          ]},
          {"kind": "View", "children": [
            {"kind": "Text", "props": {"className": "text-muted uppercase text-xs", "children": "Since"}},
            {"kind": "Text", "props": {"className": "mt-1 font-medium"}, "bindings": {"children": {"$expr": "formatDate(subscription.created_at)"}}}
          ]}
        ]}
      ]},
      {"kind": "Alert", "props": {"variant": "warning"}, "bindings": {"hidden": {"$expr": "!['at_risk','grace'].includes(subscription.state)"}, "children": {"$expr": "'Payment failed. Grace ends ' + formatRelative(subscription.grace_ends_at) + '. Update payment method to avoid suspension.'"}}, "children": [
        {"kind": "Button", "props": {"variant": "primary", "size": "sm", "children": "Update payment"}, "actions": {"onPress": {"kind": "http.post", "url": "/api/v1/subscription/portal", "onSuccess": {"kind": "redirectExternal", "urlExpr": "response.data.url"}}}}
      ]},
      {"kind": "Alert", "props": {"variant": "danger"}, "bindings": {"hidden": {"$expr": "subscription.state !== 'suspended'"}, "children": "Workspace suspended. Most features refused until payment is resolved. Contact billing@ or update your payment method."}},
      {"kind": "Card", "props": {"className": "p-6"}, "bindings": {"hidden": {"$expr": "['cancelled','expired'].includes(subscription.state)"}}, "children": [
        {"kind": "Text", "props": {"as": "h3", "className": "text-sm font-semibold uppercase text-muted tracking-wide", "children": "Next invoice"}},
        {"kind": "View", "props": {"className": "mt-3 flex items-baseline justify-between"}, "children": [
          {"kind": "Text", "props": {"className": "text-2xl font-semibold"}, "bindings": {"children": {"$expr": "upcoming ? (upcoming.amount_formatted) : '\u2014'"}}},
          {"kind": "Text", "props": {"className": "text-sm text-muted"}, "bindings": {"children": {"$expr": "upcoming ? ('Due ' + formatDate(upcoming.due_date)) : ''"}}}
        ]}
      ]},
      {"kind": "View", "props": {"className": "flex items-center justify-end"}, "children": [
        {"kind": "Button", "props": {"variant": "ghost", "className": "text-danger", "children": "Cancel subscription"}, "bindings": {"hidden": {"$expr": "['cancelled','expired'].includes(subscription.state)"}}, "actions": {"onPress": {"kind": "modal.open", "modal": "subscription-cancel-confirm"}}}
      ]}
    ]}
  ]
}
