{
  "id": "academorix://modules/subscription/routes",
  "$version": 1,
  "title": "subscription \u2014 HTTP routes",
  "description": "Workspace owner self-serve + platform admin plan catalogue + Cashier webhook receivers.",
  "groups": [
    {
      "name": "workspace-subscription",
      "prefix": "/api/v1/subscription",
      "middleware": ["request.id", "cors.strict", "versioning.resolve", "auth:sanctum", "workspace.resolve", "throttle:foundation-base", "response.envelope"],
      "hosts": ["workspace"],
      "description": "Workspace's own subscription. Owner-only.",
      "routes": [
        {"method": "GET", "path": "/", "controller": "Academorix\\Subscription\\Http\\Controllers\\Workspace\\SubscriptionController@show", "permission": "subscription.view"},
        {"method": "GET", "path": "/invoices", "controller": "Academorix\\Subscription\\Http\\Controllers\\Workspace\\SubscriptionController@invoices", "permission": "subscription.view.invoices"},
        {"method": "GET", "path": "/upcoming-invoice", "controller": "Academorix\\Subscription\\Http\\Controllers\\Workspace\\SubscriptionController@upcomingInvoice", "permission": "subscription.view.invoices"},
        {"method": "POST", "path": "/checkout", "controller": "Academorix\\Subscription\\Http\\Controllers\\Workspace\\SubscriptionController@checkout", "permission": "subscription.manage", "description": "Body: { plan_id }. Returns Cashier checkout session URL (Stripe) or Paddle checkout link. Client redirects."},
        {"method": "POST", "path": "/swap", "controller": "Academorix\\Subscription\\Http\\Controllers\\Workspace\\SubscriptionController@swap", "permission": "subscription.manage", "description": "Body: { plan_id, prorate }. Instant plan swap for existing subscription. Fires SubscriptionUpgraded/Downgraded."},
        {"method": "POST", "path": "/cancel", "controller": "Academorix\\Subscription\\Http\\Controllers\\Workspace\\SubscriptionController@cancel", "permission": "subscription.manage", "description": "Body: { at_period_end: bool, reason?: string }. Sets cancel_at_period_end=true or cancels immediately."},
        {"method": "POST", "path": "/resume", "controller": "Academorix\\Subscription\\Http\\Controllers\\Workspace\\SubscriptionController@resume", "permission": "subscription.manage", "description": "Reinstate a pending cancellation (cancel_at_period_end=true but not yet effective)."},
        {"method": "GET", "path": "/portal", "controller": "Academorix\\Subscription\\Http\\Controllers\\Workspace\\SubscriptionController@portal", "permission": "subscription.manage", "description": "Redirect to Cashier's customer portal (Stripe Customer Portal / Paddle Portal)."}
      ]
    },
    {
      "name": "workspace-plans",
      "prefix": "/api/v1/plans",
      "middleware": ["request.id", "cors.strict", "versioning.resolve", "auth:sanctum", "workspace.resolve", "throttle:foundation-base", "response.envelope"],
      "hosts": ["workspace"],
      "description": "Public plan catalogue (workspace's Application only). Used by pricing page + upgrade UI.",
      "routes": [
        {"method": "GET", "path": "/", "controller": "Academorix\\Subscription\\Http\\Controllers\\Workspace\\PlanController@index", "permission": "plans.viewAny", "description": "Lists is_public=true plans for the workspace's Application."},
        {"method": "GET", "path": "/{plan}", "controller": "Academorix\\Subscription\\Http\\Controllers\\Workspace\\PlanController@show", "permission": "plans.view"}
      ]
    },
    {
      "name": "platform-plans",
      "prefix": "/api/v1/platform/plans",
      "middleware": ["request.id", "cors.strict", "versioning.resolve", "auth:platform_admin", "throttle:foundation-platform", "response.envelope"],
      "hosts": ["central_admin"],
      "description": "Plan catalogue CRUD. Platform ops team.",
      "routes": [
        {"method": "GET", "path": "/", "controller": "Academorix\\Subscription\\Http\\Controllers\\Platform\\PlanController@index", "permission": "platform.plans.viewAny"},
        {"method": "POST", "path": "/", "controller": "Academorix\\Subscription\\Http\\Controllers\\Platform\\PlanController@store", "permission": "platform.plans.create"},
        {"method": "GET", "path": "/{plan}", "controller": "Academorix\\Subscription\\Http\\Controllers\\Platform\\PlanController@show", "permission": "platform.plans.view"},
        {"method": "PATCH", "path": "/{plan}", "controller": "Academorix\\Subscription\\Http\\Controllers\\Platform\\PlanController@update", "permission": "platform.plans.update"},
        {"method": "DELETE", "path": "/{plan}", "controller": "Academorix\\Subscription\\Http\\Controllers\\Platform\\PlanController@archive", "permission": "platform.plans.archive", "description": "Soft delete. Refused when active subscriptions exist."}
      ]
    },
    {
      "name": "platform-subscriptions",
      "prefix": "/api/v1/platform/subscriptions",
      "middleware": ["request.id", "cors.strict", "versioning.resolve", "auth:platform_admin", "throttle:foundation-platform", "response.envelope"],
      "hosts": ["central_admin"],
      "description": "Cross-workspace subscription inspection + enterprise-contract offline billing.",
      "routes": [
        {"method": "GET", "path": "/", "controller": "Academorix\\Subscription\\Http\\Controllers\\Platform\\SubscriptionController@index", "permission": "platform.subscriptions.viewAny"},
        {"method": "GET", "path": "/{subscription}", "controller": "Academorix\\Subscription\\Http\\Controllers\\Platform\\SubscriptionController@show", "permission": "platform.subscriptions.view"},
        {"method": "POST", "path": "/{workspace}/enterprise-invoice", "controller": "Academorix\\Subscription\\Http\\Controllers\\Platform\\SubscriptionController@enterpriseInvoice", "permission": "platform.subscriptions.enterprise", "description": "Body: { plan_id, invoice_number, due_date, notes }. Creates a billing_mode=invoice Subscription without Cashier."},
        {"method": "POST", "path": "/{workspace}/force-state", "controller": "Academorix\\Subscription\\Http\\Controllers\\Platform\\SubscriptionController@forceState", "permission": "platform.subscriptions.force-state", "description": "Emergency state override. Every use audit-logged with reason."}
      ]
    },
    {
      "name": "cashier-webhooks",
      "prefix": "/webhooks/inbound/subscription",
      "middleware": ["request.id", "cors.strict", "throttle:webhook-inbound", "response.envelope"],
      "hosts": ["central", "central_admin", "workspace"],
      "description": "Provider webhook receivers. Delegated to the webhook module which verifies signatures then fires webhook::InboundWebhookReceived. Our IngestCashierWebhookListener dispatches SyncFromCashierWebhookJob.",
      "routes": [
        {"method": "POST", "path": "/stripe", "controller": "Academorix\\Subscription\\Http\\Controllers\\Webhook\\StripeWebhookController@handle", "description": "Stripe events. Signature verified via webhook module."},
        {"method": "POST", "path": "/paddle", "controller": "Academorix\\Subscription\\Http\\Controllers\\Webhook\\PaddleWebhookController@handle", "description": "Paddle events."}
      ]
    }
  ]
}
