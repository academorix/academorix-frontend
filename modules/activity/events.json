{
  "id": "academorix://modules/activity/events",
  "$version": 1,
  "title": "activity \u2014 published events",
  "namespace": "Academorix\\Activity\\Events",
  "dispatchMode": "afterCommit",
  "events": [
    {"name": "ActivityRecorded", "class": "Academorix\\Activity\\Events\\ActivityRecorded", "trigger": "New Activity row persisted. Fires from Activity's `created` model event.", "queue": "notifications", "consumers": ["notifications-in-app::MaybeFanoutToInAppFeed", "any downstream analytics or dashboard aggregation"], "payload": {"activity_id": "ULID", "workspace_id": "ULID | null", "log_name": "string", "event": "string", "subject_type": "string | null", "subject_id": "string | null", "causer_type": "string | null", "causer_id": "string | null", "description": "string", "batch_uuid": "string | null"}},
    {"name": "ActivityPruned", "class": "Academorix\\Activity\\Events\\ActivityPruned", "trigger": "PruneActivityLogJob hard-deleted rows past retention tier.", "queue": "notifications", "consumers": ["observability::MetricsCollector"], "payload": {"workspace_id": "ULID | null", "retention_tier": "'short' | 'medium' | 'long'", "rows_pruned": "integer", "cutoff": "ISO 8601"}}
  ]
}
