{
  "id": "academorix://modules/activity/caches",
  "$version": 1,
  "title": "activity \u2014 cache keys + tags",
  "driver": "redis",
  "ownedTags": ["activity"],
  "keys": [
    {"pattern": "activity:registry", "description": "ActivityRegistry \u2014 the compiled #[LoggableActivity] catalogue. Loaded at boot.", "ttlSeconds": 86400, "tags": ["activity", "platform"], "invalidatedBy": ["foundation::ApplicationBooted", "foundation::ConfigReloaded"]},
    {"pattern": "activity:feed:tenant:{tenant_id}:page:{page}", "description": "Cached first N pages of the tenant feed. Invalidated on ActivityRecorded via a versioned key.", "ttlSeconds": 30, "tags": ["activity", "tenant"], "invalidatedBy": ["ActivityRecorded event bumps activity:feed:tenant:{tenant_id}:version"]},
    {"pattern": "activity:tier_days:{plan}", "description": "Resolved retention tier days per plan.", "ttlSeconds": 3600, "tags": ["activity", "platform"], "invalidatedBy": ["subscription::PlanUpdated"]}
  ]
}
