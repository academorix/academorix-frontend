{
  "id": "academorix://modules/search/schemas/search-synonym",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "SearchSynonym",
  "description": "One synonym entry. Per-workspace + per-language, mutable at runtime. `WarmSynonymCacheJob` picks up mutations and pushes to every affected engine's synonym map. Class-level `#[SearchSynonym]` declarations seed platform defaults (rows with `is_system = true`); workspace admins can add / override / disable.",
  "type": "object",
  "x-module": "search",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "search_synonyms",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "syn_",
    "incrementing": false,
    "model": "Academorix\\Search\\Models\\SearchSynonym",
    "interface": "Academorix\\Search\\Contracts\\Data\\SearchSynonymInterface",
    "implements": ["Academorix\\Search\\Contracts\\Data\\SearchSynonymInterface"],
    "traits": ["HasUlids", "BelongsToWorkspace", "HasSystemFlag", "HasMetadata", "HasActivityLog", "SoftDeletes"],
    "casts": {
      "kind": "Academorix\\Search\\Enums\\SynonymKind",
      "terms": "array",
      "one_way_targets": "array",
      "source": "Academorix\\Search\\Enums\\SynonymSource",
      "is_active": "boolean",
      "is_system": "boolean",
      "metadata": "array"
    },
    "hidden": [],
    "guarded": ["id", "workspace_id", "is_system"]
  },
  "x-database": {
    "engine": "postgres",
    "description": "Synonym entries scoped to (workspace_id, language) with optional narrowing to a single search_index. Three kinds: equivalent (bidirectional group), one_way (source \u2192 targets), expansion (source expands into more terms at query time). Matches Meilisearch's synonym contract; postgres-fts uses these too via ts_synonym dictionary swap.",
    "columns": {
      "id": {"type": "string", "length": 64, "primary": true, "description": "Prefixed ULID: `syn_<26 chars>`."},
      "workspace_id": {"type": "string", "length": 64, "nullable": true, "foreign": {"table": "workspaces", "column": "id", "onUpdate": "cascade", "onDelete": "cascade"}, "description": "Workspace scope. Null for platform-seeded system synonyms available to every workspace."},
      "search_index_id": {"type": "string", "length": 64, "nullable": true, "foreign": {"table": "search_indexes", "column": "id", "onUpdate": "cascade", "onDelete": "cascade"}, "description": "Optional narrowing to a specific index. Null = applies to every index for this workspace + language."},
      "language": {"type": "string", "length": 16, "nullable": false, "default": "'en'", "description": "BCP-47 language tag. `en`, `ar`, `fr`, etc. Synonyms are lexical \u2014 same word means different things in different languages."},
      "kind": {"type": "string", "length": 16, "nullable": false, "default": "'equivalent'", "description": "Enum: equivalent / one_way / expansion."},
      "terms": {"type": "jsonb", "nullable": false, "description": "Array of terms in the equivalence group. For kind=equivalent: bidirectional. For kind=expansion: the base terms that expand. Example: `[\"flu\", \"influenza\", \"grippe\"]`."},
      "one_way_source": {"type": "string", "length": 128, "nullable": true, "description": "Non-null only when kind = one_way. The term that maps forward without reverse mapping."},
      "one_way_targets": {"type": "jsonb", "nullable": true, "description": "Array of targets for one_way synonyms. Example: source=`cheap`, targets=`[\"affordable\", \"low-cost\", \"budget\"]`."},
      "description": {"type": "text", "nullable": true, "description": "Optional human-readable rationale for the entry. Shown in admin UI."},
      "is_active": {"type": "boolean", "nullable": false, "default": "true", "description": "Disable an entry without deleting \u2014 useful for A/B testing."},
      "is_system": {"type": "boolean", "nullable": false, "default": "false", "description": "Platform-seeded (from `#[SearchSynonym]` on model classes). System entries can't be deleted by workspaces; only disabled."},
      "source": {"type": "string", "length": 32, "nullable": false, "default": "'workspace_admin'", "description": "Enum: attribute / workspace_admin / platform_admin / imported."},
      "metadata": {"type": "jsonb", "nullable": true},
      "created_by_type": {"type": "string", "length": 128, "nullable": true, "description": "Polymorphic creator type."},
      "created_by_id": {"type": "string", "length": 64, "nullable": true},
      "created_at": {"type": "timestamptz", "nullable": false},
      "updated_at": {"type": "timestamptz", "nullable": false},
      "deleted_at": {"type": "timestamptz", "nullable": true}
    },
    "indexes": [
      {"columns": ["workspace_id", "language", "is_active"], "unique": false, "name": "search_synonyms_workspace_lang_idx", "predicate": "deleted_at IS NULL", "description": "Fast scan for cache warm-up on synonym mutations."},
      {"columns": ["search_index_id"], "unique": false, "name": "search_synonyms_index_idx"},
      {"columns": ["is_system", "language"], "unique": false, "name": "search_synonyms_system_scan_idx", "predicate": "is_system = true"},
      {"columns": ["workspace_id", "created_at"], "unique": false, "name": "search_synonyms_workspace_time_idx"}
    ]
  },
  "required": ["id", "language", "kind", "terms", "is_active", "is_system", "source", "created_at", "updated_at"],
  "properties": {
    "id": {"type": "string", "pattern": "^syn_[0-9A-HJKMNP-TV-Z]{26}$"},
    "workspace_id": {"type": ["string", "null"], "pattern": "^wsp_[0-9A-HJKMNP-TV-Z]{26}$"},
    "search_index_id": {"type": ["string", "null"], "pattern": "^sidx_[0-9A-HJKMNP-TV-Z]{26}$"},
    "language": {"type": "string", "maxLength": 16},
    "kind": {"type": "string", "enum": ["equivalent", "one_way", "expansion"]},
    "terms": {"type": "array", "items": {"type": "string", "maxLength": 128}, "minItems": 1, "maxItems": 32},
    "one_way_source": {"type": ["string", "null"], "maxLength": 128},
    "one_way_targets": {"type": ["array", "null"], "items": {"type": "string", "maxLength": 128}},
    "description": {"type": ["string", "null"]},
    "is_active": {"type": "boolean"},
    "is_system": {"type": "boolean"},
    "source": {"type": "string", "enum": ["attribute", "workspace_admin", "platform_admin", "imported"]},
    "metadata": {"type": ["object", "null"]},
    "created_by_type": {"type": ["string", "null"]},
    "created_by_id": {"type": ["string", "null"]},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "deleted_at": {"type": ["string", "null"], "format": "date-time"}
  },
  "additionalProperties": false,
  "x-wire": {
    "envelope": "spatie-data",
    "wrap": "data",
    "mapper": "SnakeCaseMapper",
    "hidden": [],
    "computed": [
      {"name": "effective_terms", "expression": "kind === 'one_way' ? [one_way_source, ...one_way_targets] : terms"}
    ]
  }
}
