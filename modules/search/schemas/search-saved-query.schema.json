{
  "id": "academorix://modules/search/schemas/search-saved-query",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "SearchSavedQuery",
  "description": "User-saved query. Drives the \u2318K palette 'Recent searches', smart-list filters (e.g. 'Athletes in Branch A, active in last 30 days'), and workspace admin dashboards. Per-user by default; a workspace admin may share to the workspace.",
  "type": "object",
  "x-module": "search",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "search_saved_queries",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "sq_",
    "incrementing": false,
    "model": "Academorix\\Search\\Models\\SearchSavedQuery",
    "interface": "Academorix\\Search\\Contracts\\Data\\SearchSavedQueryInterface",
    "implements": ["Academorix\\Search\\Contracts\\Data\\SearchSavedQueryInterface"],
    "traits": ["HasUlids", "BelongsToWorkspace", "HasMetadata", "HasActivityLog", "SoftDeletes"],
    "casts": {
      "across": "array",
      "filters": "array",
      "facets": "array",
      "boosts": "array",
      "is_shared": "boolean",
      "is_smart_list": "boolean",
      "use_count": "integer",
      "last_result_count": "integer",
      "metadata": "array",
      "last_run_at": "immutable_datetime"
    },
    "hidden": [],
    "guarded": ["id", "workspace_id", "owner_id", "use_count", "last_run_at", "last_result_count"]
  },
  "x-database": {
    "engine": "postgres",
    "description": "Owner-scoped or workspace-shared query presets. Composite uniqueness on (workspace_id, owner_id, name) prevents duplicate names per owner.",
    "columns": {
      "id": {"type": "string", "length": 64, "primary": true, "description": "Prefixed ULID: `sq_<26 chars>`."},
      "workspace_id": {"type": "string", "length": 64, "nullable": false, "foreign": {"table": "workspaces", "column": "id", "onUpdate": "cascade", "onDelete": "cascade"}},
      "owner_id": {"type": "string", "length": 64, "nullable": false, "foreign": {"table": "users", "column": "id", "onUpdate": "cascade", "onDelete": "cascade"}, "description": "User who created + owns the saved query."},
      "name": {"type": "string", "length": 128, "nullable": false, "description": "User-provided name (e.g. 'Active athletes in Branch A')."},
      "description": {"type": "text", "nullable": true},
      "query": {"type": "text", "nullable": true, "description": "The base search term. Null when the saved query is a pure filter preset (smart list)."},
      "across": {"type": "jsonb", "nullable": false, "default": "'[]'", "description": "Array of Eloquent model class names to search across."},
      "filters": {"type": "jsonb", "nullable": true, "description": "Filter dictionary (spatie/laravel-query-builder grammar). Same shape the list endpoint accepts."},
      "facets": {"type": "jsonb", "nullable": true, "description": "Array of facet keys to return alongside results."},
      "boosts": {"type": "jsonb", "nullable": true, "description": "Optional per-invocation boosts overriding the entity default."},
      "is_shared": {"type": "boolean", "nullable": false, "default": "false", "description": "Visible workspace-wide when true. Requires `search.saved-queries.share` permission."},
      "is_smart_list": {"type": "boolean", "nullable": false, "default": "false", "description": "Auto-refreshing preset (like Gmail's Smart Labels). SPA re-runs periodically. Drives dashboard tiles."},
      "use_count": {"type": "integer", "nullable": false, "default": "0"},
      "last_result_count": {"type": "integer", "nullable": true, "description": "Cached from the last invocation \u2014 shown in the sidebar count badge."},
      "last_run_at": {"type": "timestamptz", "nullable": true},
      "metadata": {"type": "jsonb", "nullable": true},
      "created_at": {"type": "timestamptz", "nullable": false},
      "updated_at": {"type": "timestamptz", "nullable": false},
      "deleted_at": {"type": "timestamptz", "nullable": true}
    },
    "indexes": [
      {"columns": ["workspace_id", "owner_id", "name"], "unique": true, "name": "search_saved_queries_uniq_idx", "predicate": "deleted_at IS NULL"},
      {"columns": ["workspace_id", "is_shared"], "unique": false, "name": "search_saved_queries_shared_scan_idx", "predicate": "is_shared = true AND deleted_at IS NULL"},
      {"columns": ["owner_id", "is_smart_list"], "unique": false, "name": "search_saved_queries_smart_list_idx", "predicate": "is_smart_list = true AND deleted_at IS NULL"},
      {"columns": ["last_run_at"], "unique": false, "name": "search_saved_queries_recency_idx"}
    ]
  },
  "required": ["id", "workspace_id", "owner_id", "name", "across", "is_shared", "is_smart_list", "use_count", "created_at", "updated_at"],
  "properties": {
    "id": {"type": "string", "pattern": "^sq_[0-9A-HJKMNP-TV-Z]{26}$"},
    "workspace_id": {"type": "string", "pattern": "^wsp_[0-9A-HJKMNP-TV-Z]{26}$"},
    "owner_id": {"type": "string", "pattern": "^usr_[0-9A-HJKMNP-TV-Z]{26}$"},
    "name": {"type": "string", "maxLength": 128},
    "description": {"type": ["string", "null"]},
    "query": {"type": ["string", "null"]},
    "across": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "filters": {"type": ["object", "null"]},
    "facets": {"type": ["array", "null"], "items": {"type": "string"}},
    "boosts": {"type": ["object", "null"]},
    "is_shared": {"type": "boolean"},
    "is_smart_list": {"type": "boolean"},
    "use_count": {"type": "integer", "minimum": 0},
    "last_result_count": {"type": ["integer", "null"], "minimum": 0},
    "last_run_at": {"type": ["string", "null"], "format": "date-time"},
    "metadata": {"type": ["object", "null"]},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "deleted_at": {"type": ["string", "null"], "format": "date-time"}
  },
  "additionalProperties": false,
  "x-wire": {
    "envelope": "spatie-data",
    "wrap": "data",
    "mapper": "SnakeCaseMapper",
    "hidden": [],
    "computed": []
  }
}
