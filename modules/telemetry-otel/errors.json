  "title": "telemetry-otel \u2014 error codes",
  "namespace": "telemetry-otel",
  "errors": [
    {"code": "OTEL_SDK_NOT_INITIALIZED", "http": 500, "retryable": false, "user_facing": false, "audit_severity": "critical", "i18n_key": "telemetry-otel.errors.sdk_not_initialized"},
    {"code": "OTEL_EXPORTER_UNREACHABLE", "http": 200, "retryable": false, "user_facing": false, "audit_severity": "warn", "i18n_key": "telemetry-otel.errors.exporter_unreachable", "description": "Downgraded to warn \u2014 backpressure drops spans, doesn't fail requests."},
    {"code": "OTEL_QUEUE_FULL", "http": 200, "retryable": false, "user_facing": false, "audit_severity": "warn", "i18n_key": "telemetry-otel.errors.queue_full", "description": "BatchSpanProcessor internal buffer full \u2014 dropping spans."},
    {"code": "OTEL_KILL_SWITCHED", "http": 200, "retryable": false, "user_facing": false, "audit_severity": "info", "i18n_key": "telemetry-otel.errors.kill_switched"},
