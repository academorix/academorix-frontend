    {"code": "OTEL_EXPORT_AUTH_FAILED", "http": 500, "retryable": true, "user_facing": false, "audit_severity": "critical", "i18n_key": "telemetry-otel.errors.export_auth_failed", "description": "OTLP endpoint returned 401. Rotate OTEL_EXPORTER_OTLP_HEADERS secret."}
