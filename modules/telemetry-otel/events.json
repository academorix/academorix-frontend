{
  "id": "academorix://modules/telemetry-otel/events",
  "$version": 1,
  "title": "telemetry-otel \u2014 published events",
  "namespace": "Academorix\\TelemetryOtel\\Events",
  "dispatchMode": "sync",
  "note": "These events exist for internal debugging + testing. They are NOT the OTel spans themselves \u2014 those go out via OTLP.",
  "events": [
    {"name": "TracerInitialized", "class": "Academorix\\TelemetryOtel\\Events\\TracerInitialized", "trigger": "On app boot, once the SDK + provider are wired up.", "queue": null, "payload": {"service_name": "string", "resource_attributes": "object", "exporter": "string"}},
    {"name": "SpanStarted", "class": "Academorix\\TelemetryOtel\\Events\\SpanStarted", "trigger": "Fired only when config('telemetry-otel.emit_span_events')=true (debug builds).", "queue": null, "payload": {"trace_id": "string", "span_id": "string", "name": "string", "attributes": "object"}},
    {"name": "SpanEnded", "class": "Academorix\\TelemetryOtel\\Events\\SpanEnded", "trigger": "Same. Debug-only.", "queue": null, "payload": {"trace_id": "string", "span_id": "string", "name": "string", "duration_ms": "number"}},
    {"name": "SpanErrored", "class": "Academorix\\TelemetryOtel\\Events\\SpanErrored", "trigger": "A span was recorded with status=ERROR.", "queue": null, "payload": {"trace_id": "string", "span_id": "string", "name": "string", "exception_class": "string", "exception_message": "string"}}
  ]
}
