{
  "id": "academorix://modules/telemetry-otel/config",
  "$version": 1,
  "title": "telemetry-otel \u2014 developer configuration",
  "configFile": "config/telemetry-otel.php",
  "envPrefix": "OTEL_",
  "underlying_package_config": "config/opentelemetry.php (keepsuit) \u2014 we do NOT override its keys directly; instead, publish our own config that keepsuit reads at boot.",
  "sections": {
    "resource": {"keys": [
      {"path": "telemetry-otel.resource.service_name", "type": "string", "env": "OTEL_SERVICE_NAME", "default": "academorix"},
      {"path": "telemetry-otel.resource.service_namespace", "type": "string", "env": "OTEL_SERVICE_NAMESPACE", "default": "academorix"},
      {"path": "telemetry-otel.resource.service_version", "type": "string", "env": "APP_VERSION", "description": "Set by build pipeline to git-sha short + build tag."},
      {"path": "telemetry-otel.resource.deployment_environment", "type": "string", "env": "APP_ENV", "default": "local"}
    ]},
    "exporter": {"keys": [
      {"path": "telemetry-otel.exporter.protocol", "type": "string", "env": "OTEL_EXPORTER_OTLP_PROTOCOL", "default": "http/protobuf", "enum": ["http/protobuf", "grpc"]},
      {"path": "telemetry-otel.exporter.endpoint", "type": "string", "env": "OTEL_EXPORTER_OTLP_ENDPOINT", "default": "http://localhost:4318", "description": "OTLP collector endpoint. Grafana Alloy default 4318 (http) / 4317 (grpc)."},
      {"path": "telemetry-otel.exporter.headers", "type": "string", "env": "OTEL_EXPORTER_OTLP_HEADERS", "description": "Comma-separated key=value pairs. Common: `api-key=xxx` for DataDog / Honeycomb."},
      {"path": "telemetry-otel.exporter.timeout_ms", "type": "int", "env": "OTEL_EXPORTER_OTLP_TIMEOUT", "default": 10000},
      {"path": "telemetry-otel.exporter.compression", "type": "string", "default": "gzip", "enum": ["gzip", "none"]}
    ]},
    "sampling": {"keys": [
      {"path": "telemetry-otel.sampling.strategy", "type": "string", "env": "OTEL_TRACES_SAMPLER", "default": "parentbased_traceidratio"},
      {"path": "telemetry-otel.sampling.ratio", "type": "float", "env": "OTEL_TRACES_SAMPLER_ARG", "default": 0.1, "description": "Fraction of new traces sampled. 0.1 = 10%. In dev bump to 1.0."}
    ]},
    "batch_processor": {"keys": [
      {"path": "telemetry-otel.batch_processor.max_queue_size", "type": "int", "default": 2048},
      {"path": "telemetry-otel.batch_processor.schedule_delay_ms", "type": "int", "default": 5000, "description": "Flush interval. Every 5s regardless of buffer fill."},
      {"path": "telemetry-otel.batch_processor.max_export_batch_size", "type": "int", "default": 512}
    ]},
    "auto_instrumentation": {"keys": [
      {"path": "telemetry-otel.auto.http_server", "type": "bool", "default": true},
      {"path": "telemetry-otel.auto.http_client", "type": "bool", "default": true},
      {"path": "telemetry-otel.auto.db", "type": "bool", "default": true},
      {"path": "telemetry-otel.auto.queue", "type": "bool", "default": true},
      {"path": "telemetry-otel.auto.cache", "type": "bool", "default": false},
      {"path": "telemetry-otel.auto.view", "type": "bool", "default": false}
    ]},
    "redact": {"keys": [
      {"path": "telemetry-otel.redact.keys", "type": "array", "default": ["password", "secret", "token", "api_key", "credit_card", "cvv", "authorization", "cookie"], "description": "Substring match against attribute keys. Case-insensitive."},
      {"path": "telemetry-otel.redact.patterns", "type": "array", "default": [], "description": "Regex patterns applied to attribute VALUES. E.g. credit-card numbers, SSN patterns."},
      {"path": "telemetry-otel.redact.ip", "type": "bool", "env": "OTEL_REDACT_IP", "default": true, "description": "Redact http.client_ip in production. Keep false in dev."}
    ]},
    "propagators": {"keys": [
      {"path": "telemetry-otel.propagators", "type": "array", "default": ["tracecontext", "baggage", "b3"], "description": "Enabled context propagators. Order matters \u2014 first-match wins on extract."}
    ]}
  }
}
