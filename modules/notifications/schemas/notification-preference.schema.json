{
  "id": "academorix://modules/notifications/schemas/notification-preference",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "NotificationPreference",
  "description": "Per-user opt-in per (category, channel) triple. Also carries per-user quiet hours + digest mode. Never soft-deleted \u2014 GDPR Art. 17 mandates hard-delete on user erasure (cascade via FK). Absence of a row means the resolver falls back to tenant default (settings.json) then platform default (NotificationCategory).",
  "type": "object",
  "x-module": "notifications",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "notification_preferences",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "pref_",
    "incrementing": false,
    "model": "Academorix\\Notifications\\Models\\NotificationPreference",
    "interface": "Academorix\\Notifications\\Contracts\\Data\\NotificationPreferenceInterface",
    "implements": ["Academorix\\Notifications\\Contracts\\Data\\NotificationPreferenceInterface"],
    "traits": [
      "HasFactory",
      "HasUlids",
      "BelongsToTenant",
      "HasMetadata",
      "HasUserstamps",
      "HasAuditable",
      "Filterable",
      "Importable",
      "Exportable"
    ],
    "casts": {
      "enabled": "boolean",
      "digest_mode": "DigestMode",
      "quiet_hours_start": "string",
      "quiet_hours_end": "string",
      "metadata": "array"
    },
    "appends": [],
    "observers": ["NotificationPreferenceObserver"],
    "hidden": ["metadata"],
    "guarded": []
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": {"type": "string", "length": 64, "primary": true, "description": "Prefixed ULID: `pref_<26 chars>`."},
      "tenant_id": {"type": "string", "length": 64, "nullable": false, "foreign": {"table": "tenants", "column": "id", "onUpdate": "cascade", "onDelete": "cascade"}},
      "user_id": {"type": "string", "length": 64, "nullable": false, "foreign": {"table": "users", "column": "id", "onUpdate": "cascade", "onDelete": "cascade"}, "description": "Hard cascade on user delete (GDPR Art. 17)."},
      "category_slug": {"type": "string", "length": 128, "nullable": false, "foreign": {"table": "notification_categories", "column": "slug", "onUpdate": "cascade", "onDelete": "cascade"}},
      "channel": {"type": "string", "length": 16, "nullable": false, "description": "Enum: `mail`, `sms`, `push`, `in_app`."},
      "enabled": {"type": "boolean", "nullable": false, "default": true, "description": "False = opted out. Refused for categories with opt_out_allowed=false."},
      "digest_mode": {"type": "string", "length": 16, "nullable": false, "default": "immediate", "description": "Enum: `immediate`, `daily`, `weekly`, `off`. Applies to non-critical priorities only \u2014 critical bypasses digest."},
      "quiet_hours_start": {"type": "string", "length": 5, "nullable": true, "description": "HH:MM local time (per user's timezone). Null = no quiet-hours start (i.e. always allowed)."},
      "quiet_hours_end": {"type": "string", "length": 5, "nullable": true, "description": "HH:MM local time. Null = no quiet-hours end."},
      "quiet_hours_timezone": {"type": "string", "length": 64, "nullable": true, "description": "IANA timezone string. Falls back to user.timezone when null."},
      "metadata": {"type": "jsonb", "nullable": true},
      "created_by": {"type": "uuid", "nullable": true},
      "updated_by": {"type": "uuid", "nullable": true},
      "created_at": {"type": "timestamptz", "nullable": false},
      "updated_at": {"type": "timestamptz", "nullable": false}
    },
    "indexes": [
      {"columns": ["user_id", "category_slug", "channel"], "unique": true, "name": "notification_preferences_user_cat_chan_unique", "description": "One row per (user, category, channel). Primary read path for PreferenceResolver."},
      {"columns": ["tenant_id", "user_id"], "unique": false, "name": "notification_preferences_tenant_user_index", "description": "DPO Art. 30 records-of-processing scan."},
      {"columns": ["category_slug"], "unique": false, "name": "notification_preferences_category_index", "description": "Category-wide opt-out counting for analytics."},
      {"columns": ["updated_at"], "unique": false, "name": "notification_preferences_updated_at_index"}
    ]
  },
  "required": ["id", "tenant_id", "user_id", "category_slug", "channel", "enabled", "digest_mode", "created_at", "updated_at"],
  "properties": {
    "id": {"type": "string", "pattern": "^pref_[0-9A-HJKMNP-TV-Z]{26}$"},
    "tenant_id": {"type": "string", "pattern": "^ten_[0-9A-HJKMNP-TV-Z]{26}$"},
    "user_id": {"type": "string", "pattern": "^usr_[0-9A-HJKMNP-TV-Z]{26}$"},
    "category_slug": {"type": "string", "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$", "maxLength": 128},
    "channel": {"type": "string", "enum": ["mail", "sms", "push", "in_app"]},
    "enabled": {"type": "boolean"},
    "digest_mode": {"type": "string", "enum": ["immediate", "daily", "weekly", "off"]},
    "quiet_hours_start": {"type": ["string", "null"], "pattern": "^([01]?[0-9]|2[0-3]):[0-5][0-9]$"},
    "quiet_hours_end": {"type": ["string", "null"], "pattern": "^([01]?[0-9]|2[0-3]):[0-5][0-9]$"},
    "quiet_hours_timezone": {"type": ["string", "null"], "maxLength": 64},
    "metadata": {"type": ["object", "null"], "additionalProperties": true},
    "created_by": {"type": ["string", "null"], "format": "uuid"},
    "updated_by": {"type": ["string", "null"], "format": "uuid"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false,
  "x-wire": {
    "envelope": "spatie-data",
    "wrap": "data",
    "mapper": "SnakeCaseMapper",
    "hidden": ["metadata", "created_by", "updated_by"],
    "computed": []
  }
}
