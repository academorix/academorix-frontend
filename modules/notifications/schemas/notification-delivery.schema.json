{
  "id": "academorix://modules/notifications/schemas/notification-delivery",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "NotificationDelivery",
  "description": "Per-channel send attempt for a Notification. One Notification fans out to N deliveries (one per resolved channel). Each delivery carries provider metadata (message_id, provider name), retry state, cost tracking (SMS), and open/click tracking. Channel modules write to this table via their SendJobs + IngestProviderWebhookJobs. Terminal states: delivered / failed / permanently_failed.",
  "type": "object",
  "x-module": "notifications",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "notification_deliveries",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "delv_",
    "incrementing": false,
    "model": "Academorix\\Notifications\\Models\\NotificationDelivery",
    "interface": "Academorix\\Notifications\\Contracts\\Data\\NotificationDeliveryInterface",
    "implements": ["Academorix\\Notifications\\Contracts\\Data\\NotificationDeliveryInterface"],
    "traits": [
      "HasFactory",
      "HasUlids",
      "HasStates",
      "BelongsToWorkspace",
      "HasMetadata",
      "HasUserstamps",
      "HasAuditable",
      "Filterable",
      "SoftDeletes"
    ],
    "casts": {
      "state": "NotificationDeliveryState",
      "attempted_at": "datetime",
      "delivered_at": "datetime",
      "opened_at": "datetime",
      "last_click_at": "datetime",
      "failed_at": "datetime",
      "next_retry_at": "datetime",
      "metadata": "array"
    },
    "appends": ["is_terminal", "is_retryable"],
    "observers": ["NotificationDeliveryObserver"],
    "hidden": ["error_message", "opened_ip", "opened_user_agent", "metadata"],
    "guarded": []
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": {
        "type": "string",
        "length": 64,
        "primary": true,
        "description": "Prefixed ULID: `delv_<26 chars>`."
      },
      "notification_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": {
          "table": "notifications",
          "column": "id",
          "onUpdate": "cascade",
          "onDelete": "cascade"
        }
      },
      "workspace_id": {
        "type": "string",
        "length": 64,
        "nullable": false,
        "foreign": {
          "table": "workspaces",
          "column": "id",
          "onUpdate": "cascade",
          "onDelete": "cascade"
        },
        "description": "Denormalised from parent Notification for query filter efficiency."
      },
      "channel": {
        "type": "string",
        "length": 16,
        "nullable": false,
        "description": "Enum: `mail`, `sms`, `push`, `in_app`."
      },
      "provider": {
        "type": "string",
        "length": 32,
        "nullable": true,
        "description": "Provider slug (`mailgun`, `sendgrid`, `aws-ses`, `twilio`, `messagebird`, `fcm`, `apns`, `reverb`). Null until provider selected."
      },
      "provider_message_id": {
        "type": "string",
        "length": 255,
        "nullable": true,
        "description": "Provider-assigned message id. Captured on send-accept. Used to correlate inbound provider webhooks."
      },
      "state": {
        "type": "string",
        "length": 24,
        "nullable": false,
        "default": "queued",
        "description": "Enum: `queued`, `sending`, `sent`, `delivered`, `opened`, `clicked`, `failed`, `permanently_failed`."
      },
      "attempted_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "First send attempt. Null until state\u2260queued."
      },
      "delivered_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "Provider webhook confirmed delivery."
      },
      "opened_at": { "type": "timestamptz", "nullable": true, "description": "First open event." },
      "last_click_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "Latest click event. Individual clicks tracked in a separate audit table."
      },
      "failed_at": { "type": "timestamptz", "nullable": true },
      "next_retry_at": {
        "type": "timestamptz",
        "nullable": true,
        "description": "When RetryDeliveryJob is next scheduled. Set by channel module; cleared on state=delivered."
      },
      "retry_count": {
        "type": "integer",
        "nullable": false,
        "default": 0,
        "description": "Retry attempts made. Max 6 per notifications/config.retry.max_attempts."
      },
      "error_code": {
        "type": "string",
        "length": 64,
        "nullable": true,
        "description": "Module-namespaced error code (e.g. NOTIFICATIONS_MAIL_HARD_BOUNCE). Set on state=failed/permanently_failed."
      },
      "error_message": {
        "type": "text",
        "nullable": true,
        "description": "Provider-reported error message. Sanitised (PII stripped) before persistence. Confidential tier because may contain recipient email fragments."
      },
      "opened_ip": {
        "type": "inet",
        "nullable": true,
        "description": "IP address from tracking pixel. Last octet zeroed at rest per audit_log convention."
      },
      "opened_user_agent": {
        "type": "text",
        "nullable": true,
        "description": "User-agent from tracking pixel."
      },
      "cost_micro_units": {
        "type": "bigint",
        "nullable": true,
        "description": "Provider-reported cost in micro-units (1 unit = 1 currency micro-cent). SMS + international mail carry cost; in-app + push are free-of-charge."
      },
      "metadata": { "type": "jsonb", "nullable": true },
      "created_by": { "type": "uuid", "nullable": true },
      "updated_by": { "type": "uuid", "nullable": true },
      "deleted_by": { "type": "uuid", "nullable": true },
      "deleted_at": { "type": "timestamptz", "nullable": true },
      "created_at": { "type": "timestamptz", "nullable": false },
      "updated_at": { "type": "timestamptz", "nullable": false }
    },
    "indexes": [
      {
        "columns": ["notification_id", "channel"],
        "unique": true,
        "name": "notification_deliveries_notif_channel_unique",
        "description": "Prevents duplicate delivery rows for the same (Notification, channel) tuple. Enforced by the SendNotificationJob orchestrator."
      },
      {
        "columns": ["provider", "provider_message_id"],
        "unique": true,
        "name": "notification_deliveries_provider_message_id_unique",
        "predicate": "provider_message_id IS NOT NULL",
        "description": "Provider webhook lookup path: `WHERE provider=? AND provider_message_id=?`."
      },
      {
        "columns": ["workspace_id", "channel", "state", "created_at"],
        "unique": false,
        "name": "notification_deliveries_workspace_channel_state_index",
        "description": "Admin dashboard: per-workspace delivery health by channel over time."
      },
      {
        "columns": ["state", "next_retry_at"],
        "unique": false,
        "name": "notification_deliveries_retry_scan_index",
        "predicate": "state IN ('failed') AND next_retry_at IS NOT NULL",
        "description": "RetryDeliveryJob scan."
      },
      {
        "columns": ["state", "attempted_at"],
        "unique": false,
        "name": "notification_deliveries_oldest_pending_index",
        "predicate": "state IN ('queued', 'sending')",
        "description": "OldestPendingDeliveryProbe query."
      },
      {
        "columns": ["created_at"],
        "unique": false,
        "name": "notification_deliveries_created_at_index"
      }
    ]
  },
  "required": [
    "id",
    "notification_id",
    "workspace_id",
    "channel",
    "state",
    "retry_count",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^delv_[0-9A-HJKMNP-TV-Z]{26}$" },
    "notification_id": { "type": "string", "pattern": "^not_[0-9A-HJKMNP-TV-Z]{26}$" },
    "workspace_id": { "type": "string", "pattern": "^wsp_[0-9A-HJKMNP-TV-Z]{26}$" },
    "channel": { "type": "string", "enum": ["mail", "sms", "push", "in_app"] },
    "provider": { "type": ["string", "null"], "maxLength": 32 },
    "provider_message_id": { "type": ["string", "null"], "maxLength": 255 },
    "state": {
      "type": "string",
      "enum": [
        "queued",
        "sending",
        "sent",
        "delivered",
        "opened",
        "clicked",
        "failed",
        "permanently_failed"
      ]
    },
    "attempted_at": { "type": ["string", "null"], "format": "date-time" },
    "delivered_at": { "type": ["string", "null"], "format": "date-time" },
    "opened_at": { "type": ["string", "null"], "format": "date-time" },
    "last_click_at": { "type": ["string", "null"], "format": "date-time" },
    "failed_at": { "type": ["string", "null"], "format": "date-time" },
    "next_retry_at": { "type": ["string", "null"], "format": "date-time" },
    "retry_count": { "type": "integer", "minimum": 0, "maximum": 6 },
    "error_code": { "type": ["string", "null"], "maxLength": 64 },
    "error_message": { "type": ["string", "null"] },
    "opened_ip": { "type": ["string", "null"], "format": "ipv4" },
    "opened_user_agent": { "type": ["string", "null"] },
    "cost_micro_units": { "type": ["integer", "null"], "minimum": 0 },
    "is_terminal": {
      "type": "boolean",
      "description": "Computed. state IN delivered/permanently_failed."
    },
    "is_retryable": {
      "type": "boolean",
      "description": "Computed. state=failed AND retry_count < max_attempts."
    },
    "metadata": { "type": ["object", "null"], "additionalProperties": true },
    "created_by": { "type": ["string", "null"], "format": "uuid" },
    "updated_by": { "type": ["string", "null"], "format": "uuid" },
    "deleted_by": { "type": ["string", "null"], "format": "uuid" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "deleted_at": { "type": ["string", "null"], "format": "date-time" }
  },
  "additionalProperties": false,
  "x-wire": {
    "envelope": "spatie-data",
    "wrap": "data",
    "mapper": "SnakeCaseMapper",
    "hidden": [
      "error_message",
      "opened_ip",
      "opened_user_agent",
      "metadata",
      "created_by",
      "updated_by",
      "deleted_by"
    ],
    "computed": ["is_terminal", "is_retryable"]
  }
}
