{
  "id": "academorix://modules/notifications-push/events",
  "$version": 1,
  "title": "notifications-push \u2014 published events",
  "namespace": "Academorix\\Notifications\\Push\\Events",
  "dispatchMode": "afterCommit",
  "events": [
    {
      "name": "PushSent",
      "class": "Academorix\\Notifications\\Push\\Events\\PushSent",
      "trigger": "SendPushJob completed \u2014 provider accepted the payload + returned message id.",
      "queue": "notifications",
      "consumers": ["notifications::UpdateDeliverySentListener"],
      "payload": {
        "notification_id": "ULID",
        "delivery_id": "ULID",
        "subscription_id": "ULID",
        "provider": "'fcm' | 'apns' | 'expo' | 'onesignal'",
        "provider_message_id": "string",
        "platform": "string",
        "sent_at": "ISO 8601"
      }
    },
    {
      "name": "PushDelivered",
      "class": "Academorix\\Notifications\\Push\\Events\\PushDelivered",
      "trigger": "Provider webhook confirms endpoint delivery (FCM success or APNs feedback of successful delivery).",
      "queue": "notifications",
      "consumers": ["notifications::UpdateDeliveryDeliveredListener"],
      "payload": {
        "notification_id": "ULID",
        "delivery_id": "ULID",
        "provider": "string",
        "delivered_at": "ISO 8601"
      }
    },
    {
      "name": "PushOpened",
      "class": "Academorix\\Notifications\\Push\\Events\\PushOpened",
      "trigger": "Client SDK reports user tapped the notification. Signalled via a POST from the app.",
      "queue": "notifications",
      "consumers": [
        "notifications::UpdateDeliveryOpenedListener",
        "analytics::TrackPushOpenListener"
      ],
      "payload": {
        "notification_id": "ULID",
        "delivery_id": "ULID",
        "opened_at": "ISO 8601",
        "action_id": "string | null"
      }
    },
    {
      "name": "PushFailed",
      "class": "Academorix\\Notifications\\Push\\Events\\PushFailed",
      "trigger": "SendPushJob provider call failed with non-invalid-token error (transient network, provider 5xx, quota exceeded).",
      "queue": "notifications",
      "consumers": ["notifications::UpdateDeliveryFailedListener"],
      "payload": {
        "notification_id": "ULID",
        "delivery_id": "ULID",
        "subscription_id": "ULID",
        "provider": "string",
        "error_code": "string",
        "error_message": "string",
        "failed_at": "ISO 8601"
      }
    },
    {
      "name": "PushInvalidToken",
      "class": "Academorix\\Notifications\\Push\\Events\\PushInvalidToken",
      "trigger": "Provider reports the device token is no longer valid (uninstalled app, revoked notification permission, token rotated). Fires from either SendPushJob (immediate at send) or IngestPushProviderWebhookJob (via APNs Feedback Service).",
      "queue": "notifications",
      "consumers": ["notifications-push::ExpireSubscriptionListener"],
      "payload": {
        "subscription_id": "ULID",
        "provider": "string",
        "reason": "'invalid_token' | 'unregistered' | 'permission_revoked'",
        "reported_at": "ISO 8601"
      }
    },
    {
      "name": "PushSubscriptionRegistered",
      "class": "Academorix\\Notifications\\Push\\Events\\PushSubscriptionRegistered",
      "trigger": "New PushSubscription persisted (device token validated + stored).",
      "queue": "notifications",
      "consumers": ["compliance::AuditListener", "notifications-push::WarmSubscriptionCache"],
      "payload": {
        "subscription_id": "ULID",
        "user_id": "ULID",
        "tenant_id": "ULID",
        "application_id": "ULID",
        "provider": "string",
        "platform": "string",
        "device_name": "string | null"
      }
    },
    {
      "name": "PushSubscriptionExpired",
      "class": "Academorix\\Notifications\\Push\\Events\\PushSubscriptionExpired",
      "trigger": "PushSubscription marked expired via PushInvalidToken OR PruneExpiredSubscriptionsJob for 90d idle.",
      "queue": "notifications",
      "consumers": ["notifications-push::InvalidateSubscriptionCache", "compliance::AuditListener"],
      "payload": {
        "subscription_id": "ULID",
        "user_id": "ULID",
        "reason": "'invalid_token' | 'idle_prune' | 'permission_revoked' | 'user_revoke'"
      }
    },
    {
      "name": "PushSubscriptionRevoked",
      "class": "Academorix\\Notifications\\Push\\Events\\PushSubscriptionRevoked",
      "trigger": "User or admin explicitly deleted the subscription (soft delete).",
      "queue": "notifications",
      "consumers": ["notifications-push::InvalidateSubscriptionCache"],
      "payload": { "subscription_id": "ULID", "user_id": "ULID", "revoked_by_user_id": "ULID" }
    }
  ]
}
