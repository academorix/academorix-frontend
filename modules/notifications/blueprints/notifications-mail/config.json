{
  "id": "academorix://modules/notifications-mail/config",
  "$version": 1,
  "title": "notifications-mail \u2014 developer configuration",
  "description": "Deploy-static configuration. Mirrors `config/notifications-mail.php`. Delegates transport to Laravel Mail's own `config/mail.php` \u2014 the driver + mailer definitions live there. This config governs per-category routing + provider observability + suppression cache TTLs.",
  "configFile": "config/notifications-mail.php",
  "envPrefix": "NOTIFICATIONS_MAIL_",
  "sections": {
    "default": {
      "description": "Which Laravel mailer to use by default.",
      "keys": [
        {
          "path": "notifications-mail.default",
          "type": "string",
          "default": "log",
          "env": "NOTIFICATIONS_MAIL_DEFAULT",
          "description": "One of Laravel's configured mailers. Same values as config('mail.default') accepts."
        }
      ]
    },
    "categories": {
      "description": "Per-category mailer routing. Falls back to default when category not mapped.",
      "example": {
        "notifications-mail.categories.invitations.invitation_sent.mailer": "ses",
        "notifications-mail.categories.marketing.digest.mailer": "sendgrid"
      },
      "keys": [
        {
          "path": "notifications-mail.categories.{category_slug}.mailer",
          "type": "string",
          "description": "Laravel mailer name for this category. Enables routing transactional through SES + marketing through SendGrid."
        },
        {
          "path": "notifications-mail.categories.{category_slug}.from_address",
          "type": "email",
          "description": "Override sender for this category. Falls back to tenant sender_identity."
        }
      ]
    },
    "webhook_signatures": {
      "description": "Provider webhook signing secrets. Read from Doppler.",
      "keys": [
        {
          "path": "notifications-mail.webhook_secrets.mailgun",
          "type": "string",
          "env": "MAILGUN_WEBHOOK_SIGNING_KEY",
          "secret": true
        },
        {
          "path": "notifications-mail.webhook_secrets.sendgrid",
          "type": "string",
          "env": "SENDGRID_WEBHOOK_PUBLIC_KEY",
          "secret": true,
          "description": "Ed25519 public key for verification."
        },
        {
          "path": "notifications-mail.webhook_secrets.aws-ses",
          "type": "string",
          "env": "AWS_SES_SNS_TOPIC_ARN",
          "description": "SNS topic ARN \u2014 verification uses the SNS message signature + certificate."
        },
        {
          "path": "notifications-mail.webhook_secrets.postmark",
          "type": "string",
          "env": "POSTMARK_WEBHOOK_BASIC_AUTH",
          "secret": true,
          "description": "Basic auth header value."
        },
        {
          "path": "notifications-mail.webhook_secrets.resend",
          "type": "string",
          "env": "RESEND_WEBHOOK_SIGNING_SECRET",
          "secret": true
        }
      ]
    },
    "suppression": {
      "description": "Suppression list behaviour.",
      "keys": [
        {
          "path": "notifications-mail.suppression.cache_ttl_seconds",
          "type": "int",
          "default": 300,
          "description": "Redis TTL for the per-tenant suppression bloom filter."
        },
        {
          "path": "notifications-mail.suppression.soft_bounce_expiry_days",
          "type": "int",
          "default": 7,
          "description": "Soft-bounce entries auto-expire after this many days if not re-triggered."
        },
        {
          "path": "notifications-mail.suppression.hard_bounce_max_retries",
          "type": "int",
          "default": 0,
          "description": "Zero \u2014 hard bounces do not retry. Kept as a config for override in test env."
        }
      ]
    },
    "footer": {
      "description": "CAN-SPAM footer + List-Unsubscribe injection.",
      "keys": [
        {
          "path": "notifications-mail.footer.inject_postal_address",
          "type": "bool",
          "default": true
        },
        {
          "path": "notifications-mail.footer.inject_list_unsubscribe",
          "type": "bool",
          "default": true,
          "description": "RFC 8058 header + link."
        },
        {
          "path": "notifications-mail.footer.one_click_unsubscribe_url_template",
          "type": "string",
          "default": "{app_url}/api/notifications/unsubscribe/{token}"
        }
      ]
    },
    "test_mode": {
      "description": "Local dev + test env defaults.",
      "keys": [
        {
          "path": "notifications-mail.test.local_from_address",
          "type": "email",
          "default": "no-reply@localhost",
          "description": "Overrides sender in local + test env. Prevents accidental live sends."
        },
        {
          "path": "notifications-mail.test.allowed_recipient_domains",
          "type": "array<string>",
          "default": ["example.com", "example.net", "test"],
          "description": "In test env, sends refused unless recipient domain is in this list."
        }
      ]
    }
  }
}
