{
  "id": "notifications.screens.admin-sends",
  "title": "Notifications dashboard",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/workspace/notifications-admin",
  "host": "workspace",
  "audience": "authenticated",
  "requiresPermission": "notifications.admin.view",
  "requiresFeature": "notifications.admin_sends_dashboard",
  "dataSources": [
    {"name": "workspaceSendStats", "kind": "http.get", "url": "/api/v1/workspace/notifications/stats?window=7d", "unwrap": "data", "cache": {"ttlSeconds": 60}},
    {"name": "recentFailures", "kind": "http.get", "url": "/api/v1/workspace/notifications?filter[state]=failed&sort=-created_at&per_page=20", "unwrap": "data"}
  ],
  "subscriptions": [
    {
      "channel": "workspace.{workspaceId}.notifications",
      "kind": "private",
      "onEvent": [{"kind": "data.refresh", "source": "workspaceSendStats"}, {"kind": "data.refresh", "source": "recentFailures"}]
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": {"className": "flex flex-col gap-6 p-6"},
      "children": [
        {
          "kind": "View",
          "props": {"className": "flex items-center justify-between"},
          "children": [
            {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold", "children": "Notifications dashboard"}},
            {"kind": "Text", "props": {"className": "text-sm text-muted", "children": "Last 7 days"}}
          ]
        },
        {
          "id": "kpi-grid",
          "kind": "View",
          "props": {"className": "grid grid-cols-1 md:grid-cols-4 gap-4"},
          "children": [
            {"kind": "Card", "props": {"className": "p-4"}, "children": [
              {"kind": "Text", "props": {"className": "text-xs uppercase tracking-wide text-muted", "children": "Dispatched"}},
              {"kind": "Text", "props": {"className": "text-3xl font-semibold mt-1"}, "bindings": {"children": {"$ref": "workspaceSendStats.dispatched_total"}}}
            ]},
            {"kind": "Card", "props": {"className": "p-4"}, "children": [
              {"kind": "Text", "props": {"className": "text-xs uppercase tracking-wide text-muted", "children": "Delivered"}},
              {"kind": "Text", "props": {"className": "text-3xl font-semibold mt-1"}, "bindings": {"children": {"$ref": "workspaceSendStats.delivered_total"}}},
              {"kind": "Text", "props": {"className": "text-xs text-muted mt-1"}, "bindings": {"children": {"$expr": "(workspaceSendStats.delivery_rate * 100).toFixed(1) + '% delivery rate'"}}}
            ]},
            {"kind": "Card", "props": {"className": "p-4"}, "children": [
              {"kind": "Text", "props": {"className": "text-xs uppercase tracking-wide text-muted", "children": "Failed"}},
              {"kind": "Text", "props": {"className": "text-3xl font-semibold mt-1 text-danger"}, "bindings": {"children": {"$ref": "workspaceSendStats.failed_total"}}}
            ]},
            {"kind": "Card", "props": {"className": "p-4"}, "children": [
              {"kind": "Text", "props": {"className": "text-xs uppercase tracking-wide text-muted", "children": "Unsubscribes"}},
              {"kind": "Text", "props": {"className": "text-3xl font-semibold mt-1"}, "bindings": {"children": {"$ref": "workspaceSendStats.unsubscribes_total"}}}
            ]}
          ]
        },
        {
          "id": "channel-breakdown",
          "kind": "Card",
          "props": {"className": "p-6"},
          "children": [
            {"kind": "Text", "props": {"as": "h2", "className": "text-lg font-semibold mb-3", "children": "By channel"}},
            {"kind": "BarChart", "props": {"height": 200}, "bindings": {"data": {"$ref": "workspaceSendStats.by_channel"}, "xKey": "channel", "yKeys": ["delivered", "failed"]}}
          ]
        },
        {
          "id": "recent-failures",
          "kind": "Card",
          "props": {"className": "p-6"},
          "children": [
            {"kind": "Text", "props": {"as": "h2", "className": "text-lg font-semibold mb-3", "children": "Recent failures"}},
            {
              "kind": "List",
              "props": {"emptyState": {"title": "No failures in the last window", "icon": "check-circle"}},
              "bindings": {"items": {"$ref": "recentFailures"}},
              "itemRenderer": {"kind": "Widget", "widget": "notifications.notification-card", "props": {"notification": {"$ref": "row"}, "onPressUrl": {"$expr": "'/workspace/notifications/' + row.id"}}}
            }
          ]
        }
      ]
    }
  ]
}
