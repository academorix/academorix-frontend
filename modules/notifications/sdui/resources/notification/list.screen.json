{
  "id": "notifications.resources.notification.list",
  "title": "Inbox",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/workspace/notifications",
  "host": "workspace",
  "audience": "authenticated",
  "resource": {"module": "notifications", "entity": "notification", "action": "list"},
  "requiresPermission": "notifications.viewAny",
  "dataSources": [
    {
      "name": "notifications",
      "kind": "http.get",
      "url": "/api/v1/workspace/notifications",
      "unwrap": "data",
      "paginated": true,
      "queryParamsFromState": ["filter[category_slug]", "filter[channel]", "filter[state]", "filter[seen]", "sort", "page", "per_page"],
      "cache": {"ttlSeconds": 30, "staleWhileRevalidate": true}
    },
    {
      "name": "notificationCategories",
      "kind": "http.get",
      "url": "/api/v1/workspace/notification-categories",
      "unwrap": "data",
      "cache": {"ttlSeconds": 3600}
    }
  ],
  "subscriptions": [
    {
      "channel": "user.{userId}.notifications",
      "kind": "private",
      "onEvent": {"kind": "data.mutateItem", "source": "notifications", "keyBy": "id", "expr": "event.data"}
    }
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": {"className": "flex flex-col gap-4 p-6"},
      "children": [
        {
          "id": "header",
          "kind": "View",
          "props": {"className": "flex items-center justify-between"},
          "children": [
            {"id": "title", "kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold", "children": "Inbox"}},
            {
              "id": "actions",
              "kind": "View",
              "props": {"className": "flex items-center gap-2"},
              "children": [
                {
                  "id": "mark-all-seen",
                  "kind": "Button",
                  "props": {"variant": "ghost", "size": "sm", "children": "Mark all seen", "leadingIcon": "check-circle"},
                  "bindings": {"isDisabled": {"$expr": "notifications.data.every(n => n.is_seen)"}},
                  "actions": {
                    "onPress": {
                      "kind": "http.post",
                      "url": "/api/v1/workspace/notifications/mark-all-seen",
                      "onSuccess": [
                        {"kind": "data.refresh", "source": "notifications"},
                        {"kind": "toast.success", "message": "Inbox marked as seen"}
                      ]
                    }
                  }
                },
                {
                  "id": "preferences",
                  "kind": "Button",
                  "props": {"variant": "outline", "size": "sm", "children": "Preferences", "leadingIcon": "cog-6-tooth"},
                  "actions": {"onPress": {"kind": "navigate", "to": "/workspace/notification-preferences"}}
                }
              ]
            }
          ]
        },
        {
          "id": "filters",
          "kind": "View",
          "props": {"className": "flex flex-wrap items-end gap-3"},
          "children": [
            {
              "id": "filter-seen",
              "kind": "SegmentedControl",
              "props": {"label": "Show", "name": "filter[seen]", "defaultValue": "all"},
              "options": [{"key": "all", "label": "All"}, {"key": "unseen", "label": "Unseen"}, {"key": "seen", "label": "Seen"}, {"key": "archived", "label": "Archived"}],
              "actions": {"onChange": {"kind": "data.applyFilter", "source": "notifications"}}
            },
            {
              "id": "filter-category",
              "kind": "MultiSelect",
              "props": {"label": "Category", "name": "filter[category_slug]", "placeholder": "All categories", "className": "min-w-56"},
              "optionsSource": {"$ref": "notificationCategories", "valueField": "slug", "labelField": "display_name"},
              "actions": {"onChange": {"kind": "data.applyFilter", "source": "notifications"}}
            },
            {
              "id": "filter-channel",
              "kind": "MultiSelect",
              "props": {"label": "Channel", "name": "filter[channel]", "placeholder": "All channels"},
              "options": [{"key": "in_app", "label": "In-app"}, {"key": "mail", "label": "Email"}, {"key": "push", "label": "Push"}, {"key": "sms", "label": "SMS"}],
              "actions": {"onChange": {"kind": "data.applyFilter", "source": "notifications"}}
            }
          ]
        },
        {
          "id": "list",
          "kind": "List",
          "props": {
            "emptyState": {
              "title": "You're all caught up",
              "description": "New notifications will appear here.",
              "icon": "envelope-open"
            }
          },
          "bindings": {"items": {"$ref": "notifications"}, "isLoading": {"$ref": "notifications.isLoading"}},
          "itemRenderer": {
            "kind": "Widget",
            "widget": "notifications.notification-card",
            "props": {
              "notification": {"$ref": "row"},
              "onPressUrl": {"$expr": "'/workspace/notifications/' + row.id"},
              "onMarkSeenAction": {"kind": "http.post", "urlExpr": "'/api/v1/workspace/notifications/' + row.id + '/seen'"},
              "onArchiveAction": {"kind": "http.post", "urlExpr": "'/api/v1/workspace/notifications/' + row.id + '/archive'"}
            }
          },
          "pagination": {"kind": "cursor", "bindTo": "notifications"}
        }
      ]
    }
  ]
}
