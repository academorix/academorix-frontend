{
  "id": "notifications.resources.template.create",
  "title": "New template",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/tenant/notification-templates/new",
  "host": "tenant",
  "audience": "authenticated",
  "resource": {"module": "notifications", "entity": "template", "action": "create"},
  "requiresPermission": "notifications.templates.create",
  "dataSources": [
    {"name": "notificationCategories", "kind": "http.get", "url": "/api/v1/tenant/notification-categories", "unwrap": "data", "cache": {"ttlSeconds": 3600}}
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": {"className": "flex flex-col gap-6 p-6 max-w-3xl mx-auto"},
      "children": [
        {"kind": "Link", "props": {"leadingIcon": "arrow-left", "children": "Cancel", "className": "text-sm text-muted"}, "actions": {"onPress": {"kind": "navigate", "to": "/tenant/notification-templates"}}},
        {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold", "children": "Create template"}},
        {
          "id": "form",
          "kind": "Form",
          "props": {"submitUrl": "/api/v1/tenant/notification-templates", "submitMethod": "POST", "onSuccess": [{"kind": "toast.success", "message": "Template created as draft"}, {"kind": "navigateExpr", "expr": "'/tenant/notification-templates/' + response.data.id"}]},
          "children": [
            {"kind": "Select", "props": {"label": "Category", "name": "category_slug", "isRequired": true, "placeholder": "Pick a category"}, "optionsSource": {"$ref": "notificationCategories", "valueField": "slug", "labelField": "display_name"}},
            {"kind": "Select", "props": {"label": "Channel", "name": "channel", "isRequired": true, "placeholder": "Pick a channel"}, "options": [{"key": "mail", "label": "Email"}, {"key": "sms", "label": "SMS"}, {"key": "push", "label": "Push"}, {"key": "in_app", "label": "In-app"}]},
            {"kind": "Select", "props": {"label": "Locale", "name": "locale", "isRequired": true, "defaultValue": "en"}, "options": [{"key": "en", "label": "English"}, {"key": "ar", "label": "Arabic"}, {"key": "fr", "label": "French"}, {"key": "es", "label": "Spanish"}]},
            {"kind": "TextField", "props": {"label": "Key", "name": "key", "isRequired": true, "placeholder": "e.g. billing.invoice_paid", "description": "Module-namespaced. Must match a category slug OR follow the `module.slug` pattern."}},
            {"kind": "TextField", "props": {"label": "Subject template", "name": "subject_template", "placeholder": "e.g. Invoice {{ $invoice_number }} paid", "description": "Blade template. Applies to email + in-app only."}},
            {"kind": "TextArea", "props": {"label": "Body (React Email .tsx path)", "name": "body_tsx_ref", "placeholder": "modules/billing/emails/invoice-paid.tsx", "rows": 3, "description": "Path to the React Email .tsx source. Rendered at CI build time via packages/notifications-emails-renderer."}},
            {"kind": "Button", "props": {"variant": "primary", "size": "md", "children": "Create draft", "type": "submit"}}
          ]
        }
      ]
    }
  ]
}
