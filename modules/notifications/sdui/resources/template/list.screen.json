{
  "id": "notifications.resources.template.list",
  "title": "Notification templates",
  "version": 1,
  "kind": "SduiScreen",
  "route": "/workspace/notification-templates",
  "host": "workspace",
  "audience": "authenticated",
  "resource": {"module": "notifications", "entity": "template", "action": "list"},
  "requiresPermission": "notifications.templates.viewAny",
  "dataSources": [
    {
      "name": "templates",
      "kind": "http.get",
      "url": "/api/v1/workspace/notification-templates",
      "unwrap": "data",
      "paginated": true,
      "queryParamsFromState": ["filter[category_slug]", "filter[channel]", "filter[locale]", "filter[state]", "sort", "page", "per_page"]
    },
    {"name": "notificationCategories", "kind": "http.get", "url": "/api/v1/workspace/notification-categories", "unwrap": "data", "cache": {"ttlSeconds": 3600}}
  ],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": {"className": "flex flex-col gap-4 p-6"},
      "children": [
        {
          "id": "header",
          "kind": "View",
          "props": {"className": "flex items-center justify-between"},
          "children": [
            {"kind": "Text", "props": {"as": "h1", "className": "text-2xl font-semibold", "children": "Templates"}},
            {
              "kind": "Button",
              "props": {"variant": "primary", "size": "sm", "children": "New template", "leadingIcon": "plus"},
              "bindings": {"isDisabled": {"$expr": "!identity.permissions.includes('notifications.templates.create')"}},
              "actions": {"onPress": {"kind": "navigate", "to": "/workspace/notification-templates/new"}}
            }
          ]
        },
        {
          "id": "filters",
          "kind": "View",
          "props": {"className": "flex flex-wrap gap-3"},
          "children": [
            {"id": "filter-category", "kind": "Select", "props": {"label": "Category", "name": "filter[category_slug]", "placeholder": "All"}, "optionsSource": {"$ref": "notificationCategories", "valueField": "slug", "labelField": "display_name"}, "actions": {"onChange": {"kind": "data.applyFilter", "source": "templates"}}},
            {"id": "filter-channel", "kind": "Select", "props": {"label": "Channel", "name": "filter[channel]", "placeholder": "All"}, "options": [{"key": "mail", "label": "Email"}, {"key": "sms", "label": "SMS"}, {"key": "push", "label": "Push"}, {"key": "in_app", "label": "In-app"}], "actions": {"onChange": {"kind": "data.applyFilter", "source": "templates"}}},
            {"id": "filter-state", "kind": "Select", "props": {"label": "State", "name": "filter[state]", "placeholder": "All"}, "options": [{"key": "draft", "label": "Draft"}, {"key": "published", "label": "Published"}, {"key": "archived", "label": "Archived"}], "actions": {"onChange": {"kind": "data.applyFilter", "source": "templates"}}}
          ]
        },
        {
          "id": "table",
          "kind": "DataGrid",
          "props": {"emptyState": {"title": "No templates yet", "description": "Templates are seeded from platform defaults. Create a workspace override to customise wording or branding."}},
          "bindings": {"items": {"$ref": "templates"}, "isLoading": {"$ref": "templates.isLoading"}},
          "columns": [
            {"id": "key", "header": "Key", "sortable": true, "sortKey": "key", "cell": {"kind": "View", "children": [
              {"kind": "Text", "props": {"className": "font-medium"}, "bindings": {"children": {"$ref": "row.key"}}},
              {"kind": "Text", "props": {"className": "text-xs text-muted"}, "bindings": {"children": {"$expr": "row.is_system ? 'Platform default' : 'Workspace override'"}}}
            ]}},
            {"id": "channel", "header": "Channel", "cell": {"kind": "Widget", "widget": "notifications.channel-icon", "props": {"channel": {"$ref": "row.channel"}, "showLabel": true, "size": "sm"}}},
            {"id": "locale", "header": "Locale", "cell": {"kind": "Chip", "props": {"size": "xs", "variant": "neutral"}, "bindings": {"children": {"$ref": "row.locale"}}}},
            {"id": "version", "header": "Version", "cell": {"kind": "Text", "bindings": {"children": {"$expr": "'v' + row.version"}}}},
            {"id": "state", "header": "State", "cell": {"kind": "Chip", "bindings": {"variant": {"$expr": "row.state === 'published' ? 'success' : (row.state === 'draft' ? 'info' : 'neutral')"}, "children": {"$ref": "row.state"}}}},
            {"id": "actions", "header": "", "align": "end", "cell": {"kind": "Menu", "props": {"trigger": {"kind": "Button", "props": {"variant": "ghost", "isIconOnly": true, "leadingIcon": "ellipsis-horizontal", "ariaLabel": "Actions"}}}, "items": [
              {"id": "view", "label": "View", "leadingIcon": "eye", "action": {"kind": "navigate", "toExpr": "'/workspace/notification-templates/' + row.id"}},
              {"id": "edit", "label": "Edit", "leadingIcon": "pencil", "bindings": {"isDisabled": {"$expr": "row.is_system && !identity.roles.includes('super_admin')"}}, "action": {"kind": "navigate", "toExpr": "'/workspace/notification-templates/' + row.id + '/edit'"}},
              {"id": "publish", "label": "Publish draft", "leadingIcon": "arrow-up-tray", "bindings": {"isDisabled": {"$expr": "row.state !== 'draft' || !identity.permissions.includes('notifications.templates.publish')"}}, "action": {"kind": "http.post", "urlExpr": "'/api/v1/workspace/notification-templates/' + row.id + '/publish'", "confirm": {"title": "Publish this template?", "description": "Future sends will use this version."}, "onSuccess": {"kind": "toast.success", "message": "Published"}}}
            ]}}
          ]
        }
      ]
    }
  ]
}
