{
  "id": "notifications.channel-icon",
  "title": "Channel icon",
  "version": 1,
  "kind": "SduiWidget",
  "description": "Small icon representing a notification channel. Optionally paired with the channel label. Used in preference grid headers, inbox cards, template list, admin dashboard breakdown. Icons: in_app=inbox, mail=envelope, push=device-phone-mobile, sms=chat-bubble-left-ellipsis.",
  "props": {
    "channel": {"type": "string", "description": "One of: `in_app`, `mail`, `push`, `sms`."},
    "size": {"type": "string", "default": "sm", "enum": ["xs", "sm", "md", "lg"]},
    "showLabel": {"type": "boolean", "default": false}
  },
  "dataSources": [],
  "nodes": [
    {
      "id": "root",
      "kind": "View",
      "props": {"className": "inline-flex items-center gap-1"},
      "children": [
        {
          "kind": "Icon",
          "bindings": {
            "icon": {"$expr": "props.channel === 'in_app' ? 'inbox' : (props.channel === 'mail' ? 'envelope' : (props.channel === 'push' ? 'device-phone-mobile' : (props.channel === 'sms' ? 'chat-bubble-left-ellipsis' : 'question-mark-circle')))"},
            "className": {"$expr": "props.size === 'xs' ? 'size-3' : (props.size === 'sm' ? 'size-4' : (props.size === 'lg' ? 'size-6' : 'size-5'))"}
          }
        },
        {
          "kind": "Text",
          "props": {"as": "span", "className": "text-sm"},
          "bindings": {
            "hidden": {"$expr": "!props.showLabel"},
            "children": {"$expr": "props.channel === 'in_app' ? 'In-app' : (props.channel === 'mail' ? 'Email' : (props.channel === 'push' ? 'Push' : (props.channel === 'sms' ? 'SMS' : props.channel)))"}
          }
        }
      ]
    }
  ]
}
