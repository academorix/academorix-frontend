{
  "id": "academorix://modules/entitlements/errors",
  "$version": 1,
  "title": "entitlements \u2014 error codes",
  "namespace": "entitlements",
  "errors": [
    {"code": "ENTITLEMENTS_QUOTA_EXCEEDED", "http": 402, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "entitlements.errors.quota_exceeded", "description": "Enforcer refused because value_used + delta > value_cap. Response body carries upgrade path + current cap + used."},
    {"code": "ENTITLEMENTS_KEY_NOT_FOUND", "http": 404, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "entitlements.errors.key_not_found", "description": "No Entitlement row for (workspace, key). Usually a bug \u2014 seed on workspace provisioning missed this key."},
    {"code": "ENTITLEMENTS_KEY_NOT_REGISTERED", "http": 500, "retryable": false, "user_facing": false, "audit_severity": "alert", "i18n_key": "entitlements.errors.key_not_registered", "description": "consume() called with a key not in the registry. Registration missing in the module's entitlements.json."},
    {"code": "ENTITLEMENTS_KIND_MISMATCH", "http": 422, "retryable": false, "user_facing": false, "audit_severity": "warn", "i18n_key": "entitlements.errors.kind_mismatch", "description": "Called has() on a pool key or consume() on a boolean key. API misuse."},
    {"code": "ENTITLEMENTS_KILL_SWITCHED", "http": 503, "retryable": true, "user_facing": false, "audit_severity": "alert", "i18n_key": "entitlements.errors.kill_switched", "description": "entitlements.enforcement flag off. Emergency mode."},
    {"code": "ENTITLEMENTS_REDIS_UNREACHABLE", "http": 200, "retryable": false, "user_facing": false, "audit_severity": "warn", "i18n_key": "entitlements.errors.redis_unreachable", "description": "Redis down. Enforcer falls back to Postgres \u2014 slower but works. Not surfaced as error to callers."},
    {"code": "ENTITLEMENTS_PLAN_SYNC_FAILED", "http": 500, "retryable": true, "user_facing": false, "audit_severity": "critical", "i18n_key": "entitlements.errors.plan_sync_failed", "description": "SyncEntitlementsFromPlanJob exhausted retries. Manual reconciliation required."},
    {"code": "ENTITLEMENTS_METERED_BILLING_EXPORT_FAILED", "http": 500, "retryable": true, "user_facing": false, "audit_severity": "critical", "i18n_key": "entitlements.errors.metered_billing_export_failed", "description": "ExportUsageForBillingJob failed against Stripe/Paddle. Financial-material \u2014 requires ops attention."},
    {"code": "ENTITLEMENTS_OVERRIDE_INVALID", "http": 422, "retryable": false, "user_facing": true, "audit_severity": "info", "i18n_key": "entitlements.errors.override_invalid", "description": "Platform admin submitted an invalid override (negative cap, wrong kind, etc)."}
  ]
}
