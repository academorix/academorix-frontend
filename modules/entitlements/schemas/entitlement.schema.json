{
  "id": "academorix://modules/entitlements/schemas/entitlement",
  "draft": "https://json-schema.org/draft/2020-12/schema",
  "$version": 1,
  "title": "Entitlement",
  "description": "Resolved cap for a (workspace, key) tuple. Value inherits from Plan.default_entitlements + optional workspace-level override. `value_used` is the SoT for slot/pool kinds \u2014 hot path via Redis, reconciled to Postgres hourly.",
  "type": "object",
  "x-module": "entitlements",
  "x-eloquent": {
    "baseClass": "Illuminate\\Database\\Eloquent\\Model",
    "table": "entitlements",
    "primaryKey": "id",
    "keyType": "string",
    "keyPrefix": "ent_",
    "incrementing": false,
    "model": "Academorix\\Entitlements\\Models\\Entitlement",
    "interface": "Academorix\\Entitlements\\Contracts\\Data\\EntitlementInterface",
    "implements": ["Academorix\\Entitlements\\Contracts\\Data\\EntitlementInterface"],
    "traits": ["HasFactory", "HasUlids", "BelongsToWorkspace", "HasMetadata", "HasUserstamps", "HasActivityLog", "HasAudit", "Filterable", "SoftDeletes"],
    "casts": {
      "kind": "EntitlementKind",
      "period": "EntitlementPeriod",
      "value_cap": "integer",
      "value_used": "integer",
      "is_unlimited": "boolean",
      "is_metered_billing": "boolean",
      "is_platform_overridden": "boolean",
      "resets_at": "datetime",
      "metadata": "array"
    },
    "appends": ["remaining", "usage_ratio", "is_exceeded", "is_approaching_cap"],
    "observers": ["EntitlementObserver"],
    "hidden": [],
    "guarded": []
  },
  "x-database": {
    "engine": "postgres",
    "columns": {
      "id": {"type": "string", "length": 64, "primary": true, "description": "Prefixed ULID: `ent_<26 chars>`."},
      "workspace_id": {"type": "string", "length": 64, "nullable": false, "foreign": {"table": "workspaces", "column": "id", "onDelete": "cascade"}},
      "key": {"type": "string", "length": 128, "nullable": false, "description": "Dotted entitlement key. E.g. `webhook.deliveries.month`. Registered by declaring module's entitlements.json blueprint."},
      "kind": {"type": "string", "length": 16, "nullable": false, "description": "Enum: slot / pool / boolean / unlimited."},
      "period": {"type": "string", "length": 16, "nullable": true, "description": "Enum: month / year / anniversary / lifetime. Null for slot + boolean + unlimited kinds."},
      "value_cap": {"type": "bigint", "nullable": true, "description": "The cap. Null when is_unlimited=true. For boolean: 1 = on, 0 = off."},
      "value_used": {"type": "bigint", "nullable": false, "default": 0, "description": "Current usage. Reconciled from Redis hourly."},
      "is_unlimited": {"type": "boolean", "nullable": false, "default": false, "description": "Shortcut for enterprise plans. Enforcer short-circuits without incrementing."},
      "is_metered_billing": {"type": "boolean", "nullable": false, "default": false, "description": "When true, usage exported to Stripe/Paddle at period end via ExportUsageForBillingJob."},
      "is_platform_overridden": {"type": "boolean", "nullable": false, "default": false, "description": "True when a platform admin manually set value_cap outside the source plan. Preserved across plan syncs."},
      "source_plan_id": {"type": "string", "length": 64, "nullable": true, "foreign": {"table": "plans", "column": "id", "onUpdate": "cascade", "onDelete": "set null"}, "description": "Plan whose default_entitlements resolved this cap. Null when manually overridden."},
      "resets_at": {"type": "timestamptz", "nullable": true, "description": "Next reset boundary. Null for slot / boolean / unlimited. Set on create for pool kinds."},
      "notes": {"type": "text", "nullable": true, "description": "Platform admin note on override reason (contract negotiation, support credit, etc)."},
      "metadata": {"type": "jsonb", "nullable": true},
      "created_by": {"type": "uuid", "nullable": true},
      "updated_by": {"type": "uuid", "nullable": true},
      "deleted_by": {"type": "uuid", "nullable": true},
      "deleted_at": {"type": "timestamptz", "nullable": true},
      "created_at": {"type": "timestamptz", "nullable": false},
      "updated_at": {"type": "timestamptz", "nullable": false}
    },
    "indexes": [
      {"columns": ["workspace_id", "key"], "unique": true, "name": "entitlements_workspace_key_unique", "predicate": "deleted_at IS NULL"},
      {"columns": ["key", "kind"], "unique": false, "name": "entitlements_key_kind_idx"},
      {"columns": ["resets_at"], "unique": false, "name": "entitlements_reset_scan_idx", "predicate": "kind = 'pool' AND deleted_at IS NULL"}
    ]
  },
  "required": ["id", "workspace_id", "key", "kind", "value_used", "is_unlimited", "is_metered_billing", "is_platform_overridden", "created_at", "updated_at"],
  "properties": {
    "id": {"type": "string", "pattern": "^ent_[0-9A-HJKMNP-TV-Z]{26}$"},
    "workspace_id": {"type": "string", "pattern": "^wsp_[0-9A-HJKMNP-TV-Z]{26}$"},
    "key": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{0,127}$", "maxLength": 128},
    "kind": {"type": "string", "enum": ["slot", "pool", "boolean", "unlimited"]},
    "period": {"type": ["string", "null"], "enum": ["month", "year", "anniversary", "lifetime", null]},
    "value_cap": {"type": ["integer", "null"], "minimum": 0},
    "value_used": {"type": "integer", "minimum": 0},
    "is_unlimited": {"type": "boolean"},
    "is_metered_billing": {"type": "boolean"},
    "is_platform_overridden": {"type": "boolean"},
    "source_plan_id": {"type": ["string", "null"], "pattern": "^pln_[0-9A-HJKMNP-TV-Z]{26}$"},
    "resets_at": {"type": ["string", "null"], "format": "date-time"},
    "notes": {"type": ["string", "null"]},
    "remaining": {"type": ["integer", "null"], "description": "Computed. value_cap - value_used. Null for boolean / unlimited."},
    "usage_ratio": {"type": ["number", "null"], "description": "Computed. value_used / value_cap. Null when value_cap = 0 or is_unlimited."},
    "is_exceeded": {"type": "boolean", "description": "Computed. value_used >= value_cap for slot/pool."},
    "is_approaching_cap": {"type": "boolean", "description": "Computed. usage_ratio >= config('entitlements.warn_threshold') (default 0.8)."},
    "metadata": {"type": ["object", "null"]},
    "created_by": {"type": ["string", "null"], "format": "uuid"},
    "updated_by": {"type": ["string", "null"], "format": "uuid"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false,
  "x-wire": {"envelope": "spatie-data", "wrap": "data", "mapper": "SnakeCaseMapper", "computed": ["remaining", "usage_ratio", "is_exceeded", "is_approaching_cap"]}
}
