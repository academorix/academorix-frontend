{
  "id": "academorix://modules/entitlements/permissions",
  "$version": 1,
  "title": "entitlements \u2014 permissions",
  "seeder": "Academorix\\Entitlements\\Database\\Seeders\\EntitlementsPermissionSeeder",
  "isSystem": true,
  "permissions": [
    {"name": "entitlements.viewAny", "guard": "sanctum", "seededOn": ["member", "admin", "owner"]},
    {"name": "entitlements.view", "guard": "sanctum", "seededOn": ["member", "admin", "owner"]},
    {"name": "entitlements.usage.viewAny", "guard": "sanctum", "seededOn": ["admin", "owner"]},
    {"name": "entitlements.usage.view", "guard": "sanctum", "seededOn": ["admin", "owner"]},
    {"name": "platform.entitlements.viewAny", "guard": "platform_admin", "seededOn": ["super_admin", "support", "ops", "billing"]},
    {"name": "platform.entitlements.view", "guard": "platform_admin", "seededOn": ["super_admin", "support", "ops", "billing"]},
    {"name": "platform.entitlements.override", "guard": "platform_admin", "description": "Enterprise contract overrides. Every use produces a compliance audit row.", "seededOn": ["super_admin", "ops"]},
    {"name": "platform.entitlements.reset", "guard": "platform_admin", "description": "Support-credit resets. Every use produces a compliance audit row.", "seededOn": ["super_admin", "support", "ops"]},
    {"name": "platform.entitlements.sync", "guard": "platform_admin", "seededOn": ["super_admin", "ops"]},
    {"name": "platform.entitlements.usage.viewAny", "guard": "platform_admin", "seededOn": ["super_admin", "billing", "ops"]}
  ]
}
